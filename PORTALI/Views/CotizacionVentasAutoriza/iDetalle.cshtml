        function CalcularDescuentos(tipo) {
            const precioBase = parseFloat(document.getElementById("selected-price").value) || 0;
            let dsctoPorcentaje = parseFloat(document.getElementById("txtPdecuento").value) || 0;
            let dsctoCantidad = parseFloat(document.getElementById("txtQdescuento").value) || 0;

            let granTotal = 0;
            if (precioBase <= 0) {
                alert("El precio base no es válido.");
                return;
            }

            if (tipo === "P") {
                dsctoCantidad = (precioBase * dsctoPorcentaje) / 100;
                granTotal = precioBase - dsctoCantidad;
                document.getElementById("txtQdescuento").value = dsctoCantidad.toFixed(2);
            } else if (tipo === "Q") {
                if (dsctoCantidad > precioBase) {
                    alert("El descuento no puede ser mayor al precio base.");
                    return;
                }
                dsctoPorcentaje = (dsctoCantidad / precioBase) * 100;
                granTotal = precioBase - dsctoCantidad;
                document.getElementById("txtPdecuento").value = dsctoPorcentaje.toFixed(2);
            }

            document.getElementById("txtTotalDescuento").value = granTotal.toFixed(2);
            const tabla = document.querySelector("#discountTableBody");

            if (!tabla) {
                console.error("No se encontró el tbody.");
                return;
            }

            let idListaSeleccionado = null; // Variable para almacenar el IdListaP seleccionado
            tabla.querySelectorAll("tr").forEach((fila, index) => {
                const celdas = fila.querySelectorAll("td"); // Obtener todas las celdas de la fila

                if (celdas.length < 4) {
                    console.warn(`Fila ${index + 1} no tiene suficientes celdas. Total de celdas: ${celdas.length}`);
                    return; // Saltar esta fila si no tiene suficientes columnas
                }

                const IdListaP = parseFloat(celdas[0].innerText.trim()) || 0;
                const precioInicial = parseFloat(celdas[2].innerText.replace("Q", "").replace(",", "").trim()) || 0;
                const precioFinal = parseFloat(celdas[3].innerText.replace("Q", "").replace(",", "").trim()) || 0;

                if (granTotal >= precioInicial && granTotal <= precioFinal && idListaSeleccionado === null) {
                    fila.style.backgroundColor = "orange";
                    fila.style.color = "white";
                    idListaSeleccionado = IdListaP; // Guardar solo el primer IdListaP que cumple la condición
                } else {
                    fila.style.backgroundColor = "";
                    fila.style.color = "";
                }
            });
            txtLP.innerHTML = idListaSeleccionado;
        }

        function CrearCotizacion() {
            Swal.fire({
                title: `¿Está seguro de crear la cotización?`,
                text: "Esta acción no se puede deshacer.",
                icon: "warning",
                showCancelButton: true,
                confirmButtonColor: "#28a745",
                cancelButtonColor: "#6c757d",
                confirmButtonText: `Sí, estoy seguro`,
                cancelButtonText: "Cancelar"
            }).then((result) => {
                if (result.isConfirmed) {
                    $("#globalLoading").show();
                    const docEntry = document.getElementById("txtDocEntry").textContent;
                    const docNum = document.getElementById("txtDocNum").textContent;

                    $.ajax({
                        url: '/CotizacionVentasAutoriza/EnviarAutorizacionSAP/',
                        type: 'POST',
                        data: {
                            DocEntry: docEntry,
                            DocNum: docNum,
                            Estado: 117,
                            Notas: "Generacion de"
                        },
                        success: function (response) {
                            $("#globalLoading").hide();
                            Swal.fire({
                                title: "Éxito",
                                text: `La cotización fue generada correctamente.`,
                                icon: "success",
                                confirmButtonText: "Aceptar"
                            }).then(() => {
                                window.location.assign("/CotizacionVentasAutoriza/Autorizacion");
                            });
                        },
                        error: function (xhr, status, error) {
                            $("#globalLoading").hide();
                            Swal.fire("Error", "Ocurrió un error: " + error, "error");
                        }
                    });

                } else {
                    $("#globalLoading").hide();
                    Swal.fire("Cancelado", "La operación fue cancelada.", "info");
                }
            });
        }

        function guardarAutorizacion() {
            const estado = document.getElementById("status").value;
            const observaciones = document.getElementById("observaciones").value;
            const docEntry = document.getElementById("txtDocEntry").textContent;
            const docNum = document.getElementById("txtDocNum").textContent;

            let accion = "";
            switch (estado) {
                case "0":
                    accion = "rechazar";
                    break;
                case "1":
                    accion = "autorizar";
                    break;
                case "2":
                    accion = "revision sugerida";
                    break;
                default:
                    accion = "desconocida";
                    break;
            }

            Swal.fire({
                title: `¿Está seguro de ${accion} la cotización?`,
                text: "Esta acción no se puede deshacer.",
                icon: "warning",
                showCancelButton: true,
                confirmButtonColor: estado === "R" ? "#d33" : "#28a745",
                cancelButtonColor: "#6c757d",
                confirmButtonText: `Sí, ${accion}`,
                cancelButtonText: "Cancelar"
            }).then((result) => {
                if (result.isConfirmed) {
                    $("#globalLoading").show();
                    $.ajax({
                        url: '/CotizacionVentasAutoriza/EnviarAutorizacionSAP/',
                        type: 'POST',
                        data: {
                            DocEntry: docEntry,
                            DocNum: docNum,
                            Estado: estado,
                            Notas: observaciones
                        },
                        success: function (response) {
                            $("#globalLoading").hide();
                            Swal.fire({
                                text: `La cotización fue ${accion}`,
                                icon: "success",
                                confirmButtonText: "Aceptar"
                            }).then(() => {
                                window.location.assign("/CotizacionVentasAutoriza/Autorizacion");
                            });
                        },
                        error: function (xhr, status, error) {
                            $("#globalLoading").hide();
                            Swal.fire("Error", "Ocurrió un error: " + error, "error");
                        }
                    });
                } else {
                    $("#globalLoading").hide();
                    Swal.fire("Cancelado", "La operación fue cancelada.", "info");
                }
            });
        }
    </script>
