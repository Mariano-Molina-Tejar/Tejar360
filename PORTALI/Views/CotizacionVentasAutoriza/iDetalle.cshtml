@model Entity.CarritoComprasPDFEntity

@{
    // Calcula los valores necesarios
    double subtotal = Model.Detalle.Sum(d => d.PrecioReal * d.Quantity);
    double descuento = Model.Detalle.Sum(d => d.DescuentoQtz * d.Quantity);
    double baseGrav = subtotal - descuento;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Detalle de Cotización</title>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <style>
        .btn-guardar {
            background-color: #28a745; /* verde bonito */
            color: white;
            border: none;
            padding: 10px 20px;
            font-size: 16px;
            border-radius: 8px;
            transition: background-color 0.3s ease, transform 0.2s ease;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        }

            .btn-guardar:hover {
                background-color: #218838; /* verde más oscuro al pasar el mouse */
                transform: scale(1.03);
                cursor: pointer;
            }

            .btn-guardar i {
                margin-right: 8px;
            }

        .btn-crear {
            background: linear-gradient(135deg, #1abc9c, #16a085); /* verde turquesa degradado */
            color: #fff;
            border: none;
            border-radius: 6px;
            padding: 8px 16px;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 6px;
            box-shadow: 0 2px 6px rgba(0,0,0,0.2);
            transition: all 0.3s ease;
        }

            .btn-crear:hover {
                background: linear-gradient(135deg, #16a085, #1abc9c); /* invertir degradado al pasar el mouse */
                box-shadow: 0 4px 10px rgba(0,0,0,0.3);
            }

        .combo-estilizado {
            background-color: #fff;
            border: 2px solid #28a745;
            border-radius: 6px;
            padding: 8px 12px;
            font-size: 16px;
            color: #333;
            transition: all 0.3s ease;
        }

            .combo-estilizado:hover {
                border-color: #218838;
                background-color: #f1fdf5;
            }

            .combo-estilizado:focus {
                outline: none;
                border-color: #1e7e34;
                box-shadow: 0 0 0 0.2rem rgba(40, 167, 69, 0.25);
            }
    </style>
</head>
<body>
    <div class="alert alert-primary d-flex align-items-center shadow-sm rounded-3 p-3" role="alert">
        <i class="fas fa-key me-2"></i>
        <div style="margin-left:5px">
            <strong>Nivel de autorización:</strong>
            <span style="font-weight:bold; color:#0d1b2a;">
                @Model.Encabezado.Texto
            </span>
        </div>
    </div>


    <div class="container mt-4">
        <!-- Encabezado de la cotización -->
        <div class="card mt-3">
            <div class="card-header">
                📌 Información General

                @if (Model.Encabezado.Estado == "Autorizado")
                {
                    <div style="
                display: inline-flex;
                align-items: center;
                gap: 6px;
                padding: 4px 10px;
                background-color: #2ecc71;  /* verde */
                color: #fff;
                font-weight: 600;
                border-radius: 12px;
                font-size: 14px;
            ">
                        <i class="fas fa-check-circle"></i> Ya está autorizada
                    </div>
                }
                else if (Model.Encabezado.Estado == "Revision")
                {
                    <div style="
                display: inline-flex;
                align-items: center;
                gap: 6px;
                padding: 4px 10px;
                background-color: #f1c40f;  /* amarillo */
                color: #fff;
                font-weight: 600;
                border-radius: 12px;
                font-size: 14px;
            ">
                        <i class="fas fa-hourglass-half"></i> Se necesita revisión
                    </div>
                }
            </div>
            <div class="card-body">
                <div class="row">
                    <!-- Columna izquierda -->
                    <div class="col-md-6">
                        <div><strong>No. Documento:</strong> <span id="docNum">@Model.Encabezado.DocEntry</span></div>
                        <div><strong>Fecha:</strong> <span id="fecha">@Model.Encabezado.DocDate.ToString("dd/MM/yyyy")</span></div>
                        <div><strong>NIT:</strong> <span id="nit">@Model.Encabezado.NitDocto</span></div>
                        <div><strong>Cliente:</strong> <span id="cliente">@Model.Encabezado.CardName</span></div>
                    </div>

                    <!-- Línea vertical de separación -->
                    <div class="col-md-1 d-none d-md-block">
                        <div style="border-left: 2px solid #ccc; height: 100%;"></div>
                    </div>

                    <!-- Columna derecha -->
                    <div class="col-md-5">
                        <div><strong>Asesor:</strong> <span id="asesor">@Model.Encabezado.SlpName</span></div>
                        <div><strong>Contacto:</strong> <span id="contacto">@Model.Encabezado.Contacto</span></div>
                        <div><strong>Teléfono:</strong> <span id="telefono">@Model.Encabezado.TelefonoDocto</span></div>
                        <div><strong>Correo:</strong> <span id="correo">@Model.Encabezado.CorreoDocto</span></div>
                    </div>
                </div>

                <!-- Comentarios -->
                <div class="row mt-3">
                    <div class="col-12">
                        <label for="comentarios" class="form-label"><strong>Comentarios:</strong></label>
                        <textarea id="comentarios" class="form-control" rows="2" readonly style="background-color:white">@Model.Encabezado.Comments</textarea>
                    </div>
                </div>


            </div>
        </div>
        <a id="txtDocEntry" style="display:none">@Model.Encabezado.DocEntry</a>
        <a id="txtDocNum" style="display:none">@Model.Encabezado.DocNum</a>
        <!-- Detalle de productos -->
        <div class="card mt-3">
            <div class="card-header">
                📦 Detalle de Productos
                <span class="badge bg-success text-white px-3" style="font-size:12px;">
                    Lista de precios: @Model.Encabezado.ListName
                </span>
            </div>

            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-bordered table-hover" style="font-size:11px; padding:40px">
                        <thead style="text-align:center">
                            <tr>
                                <th style="text-align: center;">Código</th>
                                <th style="text-align: center;">Producto</th>
                                <th style="text-align: center;">Cantidad</th>
                                <th style="text-align: center;">Precio</th>
                                <th style="text-align: center; width: 110px">Descuento %</th>
                                <th style="text-align: center; width: 110px">Descuento Q</th>
                                <th style="text-align: center; width: 140px">Precio con Dscto</th>
                                <th style="text-align: center; width: 110px">Total</th>
                            </tr>
                        </thead>
                        <tbody id="detalle-body" style="font-size:11px">
                            @foreach (var item in Model.Detalle)
                            {
                                <tr data-llaves="@item.LineNum">
                                    <td>@item.ItemCode</td>
                                    <td>
                                        <a href="#"
                                           data-bs-toggle="modal"
                                           data-bs-target="#discountModal"
                                           data-linenum="@item.LineNum"
                                           data-itemcode="@item.ItemCode"
                                           data-precioreal="@item.PrecioReal"
                                           data-descuentopor="@item.DescuentoPor"
                                           data-dscription="@item.Dscription"
                                           data-listname="@Model.Encabezado.ListName"
                                           data-listnum="@Model.Encabezado.ListNum"
                                           data-descuentoqtz="@item.DescuentoQtz"
                                           data-descuentolpr="@item.DescuentoLpr"
                                           onclick="cargarDescuentos(this)">
                                            @item.Dscription @if (item.CodigoPromo > 0)
                                            {
                                                <i class="fas fa-tag text-success ms-2" title="Promoción"></i>
                                            }
                                        </a>
                                    </td>
                                    <td style="text-align: center;" class="quantity">@item.Quantity</td>
                                    <td style="text-align: center;" class="precio">Q @item.PrecioReal.ToString("N2")</td>
                                    <td style="text-align: center;" class="descuentoPor">@item.DescuentoPor.ToString("N2")%</td>
                                    <td style="text-align: center;" class="descuentoQtz">Q @item.DescuentoQtz.ToString("N2")</td>
                                    <td style="text-align: center;" class="precioDscto">Q @item.Price.ToString("N2")</td>
                                    <td style="text-align: end;" class="total">Q @item.LineTotal.ToString("N2")</td>

                                    <td class="text-end descuentoLpr" style="display:none">@item.DescuentoLpr</td>
                                    <td class="text-end ilinenum" style="display:none">@item.LineNum</td>
                                </tr>
                            }
                            <!-- Fila de totales -->
                            <tr class="table-secondary fw-bold" style="padding: 0; font-size: 11px;">
                                <td colspan="7" class="text-end" style="text-align: right;">Subtotal</td>
                                <td colspan="1" class="text-end isubtotal" style="text-align: right;">Q @subtotal.ToString("N2")</td>
                            </tr>
                            <tr class="table-secondary fw-bold" style="padding: 0; font-size: 11px;">
                                <td colspan="7" class="text-end" style="text-align: right;">Descuento</td>
                                <td colspan="2" class="text-end tdescuento" style="text-align: right;">Q @descuento.ToString("N2")</td>
                            </tr>
                            <tr class="table-primary fw-bold" style="padding: 0; font-size: 11px;">
                                <td colspan="7" class="text-end" style="text-align: right;">Gran Total</td>
                                <td colspan="2" class="text-end igrantotal" style="text-align: right;">Q @baseGrav.ToString("N2")</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        @if (Model.Encabezado.Estado == "Autorizado" || Model.Encabezado.Estado == "Revision")
        {
            <div class="mb-3">
                <label for="Notas" class="form-label">Notas del autorizador:</label>
                <textarea id="Notas" class="form-control" rows="2" readonly style="background-color:white">
                    @foreach (var nota in Model.Encabezado.HistorialNotas)
                    {
                        @($"📝 {nota.Notas}\n")
                    }
                </textarea>
            </div>
        }

        @if (Model.EsAsesor == "N" && Model.Encabezado.Estado != "Autorizado")
        {
            <div class="card mt-4">
                <div class="card-header">✅ Autorizar Cotización</div>
                <div class="card-body">
                    <div class="mb-3">
                        <label for="status" class="form-label">Estado de Autorización:</label>
                        <select id="status" class="form-select combo-estilizado">
                            <option value="-1" disabled selected hidden>🔽 Seleccionar</option>
                            <option value="1">✔️ Autorizado</option>
                            <option value="0">❌ Rechazado</option>
                            <option value="2">💡 Revisión sugerida</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label for="observaciones" class="form-label">Observaciones:</label>
                        <textarea id="observaciones" class="form-control" rows="3" placeholder="Ingrese observaciones si es necesario..."></textarea>
                    </div>
                </div>
            </div>

            <div class="row mt-3">
                <div class="col-12 d-flex justify-content-center">
                    <button class="btn-guardar" onclick="guardarAutorizacion()">
                        <i class="fas fa-save"></i> Guardar
                    </button>
                </div>
            </div>
        }
        else if (Model.EsAsesor == "Y" && Model.Encabezado.Estado == "Autorizado")
        {
            <div class="row mt-3">
                <div class="col-12 d-flex justify-content-center">
                    <button class="btn-crear" onclick="CrearCotizacion()">
                        <i class="fas fa-plus"></i> Generar cotización
                    </button>
                </div>
            </div>
        }

        @if (Model.Encabezado.Estado == "Revision" && Model.EsAsesor == "Y")
        {
            <div class="row mt-3">
                <div class="col-12 d-flex justify-content-center">
                    <button class="btn-crear" onclick="UpdateCambiosPrecios()">
                        <i class="fas fa-sync-alt"></i> Aplicar cambios
                    </button>
                </div>
            </div>
        }
    </div>

    <div class="modal fade" id="discountModal" tabindex="-1" aria-labelledby="discountModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="discountModalLabel">Calculadora de descuentos</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="selected-price" class="form-label fw-bold text-primary">Nombre del producto</label>
                        <div class="input-group">
                            <input type="text" id="txtNombreProducto" class="form-control" readonly value="" aria-describedby="basic-addon1" style="background-color:white; font-size: 1.2rem; color: black; text-align: left;">
                        </div>
                        <a id="txtLlave" style="display:none"></a>
                    </div>

                    <div class="mb-3">
                        <label for="selected-price" class="form-label fw-bold text-primary">Forma de pago</label>
                        <div class="input-group">
                            <input type="text" id="txtFormaPago" class="form-control" readonly value="" aria-describedby="basic-addon1" style="background-color:white; font-size: 1.2rem; color: black; text-align: left;">
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="selected-price" class="form-label fw-bold text-primary">Precio seleccionado</label>
                        <div class="input-group">
                            <span class="input-group-text" id="basic-addon1" style="background-color: #f1f1f1; color: #333;">Q</span>
                            <input type="text" id="selected-price" class="form-control" readonly value="0.00" aria-describedby="basic-addon1" style="font-size: 1.2rem; font-weight: bold; color: #0056b3; text-align: right;">
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="selected-price" class="form-label fw-bold text-primary">Aplicar descuento</label>
                        <div class="input-group">
                            <span class="input-group-text" id="basic-addon1" style="background-color: #f1f1f1; color: #333;">%</span>
                            <input type="number" min="0" id="txtPdecuento" class="form-control" placeholder="0.00"
                                   aria-describedby="basic-addon1" style="font-size: 1.2rem; font-weight: bold; color: red; text-align: right;"
                                   oninput="CalcularDescuentos('P')" />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="selected-price" class="form-label fw-bold text-primary">Descuento unitario</label>
                        <div class="input-group">
                            <span class="input-group-text" id="basic-addon1" style="background-color: #f1f1f1; color: #333;">Q</span>
                            <input type="number" min="0" id="txtQdescuento" class="form-control" placeholder="0.00"
                                   aria-describedby="basic-addon1" style="font-size: 1.2rem; font-weight: bold; color: red; text-align: right;"
                                   oninput="CalcularDescuentos('Q')">
                        </div>
                    </div>
                    <!-- Tabla -->
                    <table class="table table-striped table-hover table-bordered tblPrecios">
                        <thead class="table-dark">
                            <tr>
                                <th scope="col" style="display: none;">Id</th>
                                <th scope="col">Nombre</th>
                                <th scope="col" class="text-center">Precio inicial</th>
                                <th scope="col" class="text-center">Precio final</th>
                            </tr>
                        </thead>
                        <tbody id="discountTableBody">
                        </tbody>
                    </table>
                    <a id="txtLP" style="display:none"></a>
                    <div class="mb-3">
                        <label for="selected-price" class="form-label fw-bold text-primary">Precio unitario con descuento</label>
                        <div class="input-group">
                            <span class="input-group-text" id="basic-addon1" style="background-color: #f1f1f1; color: #333;">Q</span>
                            <input type="number" min="0" id="txtTotalDescuento" class="form-control" value="" readonly placeholder="0.00" aria-describedby="basic-addon1" style="font-size: 1.2rem; font-weight: bold; color: red; text-align: right;">
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal" onclick="cerrarModal()">Cancelar</button>
                    <script>
                        function cerrarModal() {
                            $('#discountModal').modal('hide');
                        }
                    </script>

                    <button type="button" class="btn btn-primary" onclick="aplicarDescuento()">Aplicar</button>
                </div>
            </div>
        </div>
    </div>

    <script>
        function obtenerDetalleTabla() {
            let detalle = [];
            $("#detalle-body tr[data-llaves]").each(function () {
                let row = $(this);

                // Buscar el link dentro de la fila
                let link = row.find("a[data-bs-toggle='modal']");

                let item = {
                    DocEntry: '@Model.Encabezado.DocEntry',
                    LineNum: row.find(".ilinenum").text(), // atributo en <tr>
                    ItemCode: link.data("itemcode"),
                    DescuentoP: parseFloat(row.find(".descuentoPor").text().replace("%", "").trim()) || 0,
                    DescuentoQ: parseFloat(row.find(".descuentoQtz").text().replace("Q", "").trim()) || 0,
                    DescuentoNwp: parseFloat(row.find(".precioDscto").text().replace("Q", "").trim()) || 0,
                    Quantity: parseFloat(row.find(".quantity").text()),
                    DescuentoLpr: row.find(".descuentoLpr").text()
                };

                detalle.push(item);
            });
            return detalle;
        }

        function UpdateCambiosPrecios() {
            let encontroAlMenosUno = false;

            $("#detalle-body tr[data-llaves]").each(function () {
                let row = $(this);
                let descuento = row.find(".descuentoLpr").text().trim();

                if (descuento !== "" && descuento !== null) {
                    encontroAlMenosUno = true;
                    return false; // 🚨 Rompe el ciclo, ya no sigue recorriendo
                }
            });

            // 🚨 Si no encontró ninguno válido
            if (!encontroAlMenosUno) {
                Swal.fire({
                    icon: "warning",
                    title: "Atención",
                    text: "Esta cotización no lleva proceso de autorización"
                });
                return; // detener todo
            }

            Swal.fire({
                title: '¿Actualizar precios?',
                text: "Este cambio solicitará nuevamente autorización.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Sí, actualizar',
                cancelButtonText: 'No, cancelar',
                reverseButtons: true,
                footer: '<small style="color:#888">⚠️ Una vez aplicado, regresa a estado pendiente.</small>'
            }).then((result) => {
                if (result.isConfirmed) {
                    let data = obtenerDetalleTabla();
                    $.ajax({
                        url: "/CotizacionVentasAutoriza/ActualizarCambiosDraft",
                        type: "POST",
                        contentType: "application/json",
                        data: JSON.stringify(data),
                        success: function (response) {
                            Swal.fire({
                                title: 'Actualizado',
                                text: 'Los cambios han sido enviados para autorización.',
                                icon: 'success',
                                timer: 2500,
                                showConfirmButton: false,
                                allowOutsideClick: false, // 🚫 no se puede cerrar haciendo clic afuera
                                allowEscapeKey: false     // 🚫 no se puede cerrar con la tecla ESC
                            }).then(() => {
                                location.reload(); // 🔄 recarga la página después del Swal
                            });
                        },
                        error: function (xhr, status, error) {
                            console.error("Error al enviar", error);
                        }
                    });
                } else if (result.dismiss === Swal.DismissReason.cancel) {
                    Swal.fire({
                        title: 'Cancelado',
                        text: 'No se aplicaron los cambios.',
                        icon: 'info',
                        timer: 2000,
                        showConfirmButton: false
                    });
                }
            });
        }

        function aplicarDescuento() {
            const _llave = document.getElementById('txtLlave').textContent.trim();
            const _dsctoPor = parseFloat(document.getElementById('txtPdecuento').value) || 0;
            const _dsctoQtz = parseFloat(document.getElementById('txtQdescuento').value) || 0;
            const _nuevoPrecio = parseFloat(document.getElementById('txtTotalDescuento').value) || 0;
            const _descuentoLpr = txtLP.textContent.trim();

            const fila = document.querySelector(`#detalle-body tr[data-llaves='${_llave}']`);
            if (!fila) return;

            // 🔹 Actualizo la fila
            fila.querySelector(".descuentoPor").textContent = _dsctoPor.toFixed(2) + "%";
            fila.querySelector(".descuentoQtz").textContent = "Q " + _dsctoQtz.toFixed(2);
            fila.querySelector(".precioDscto").textContent = "Q " + _nuevoPrecio.toFixed(2);
            fila.querySelector(".descuentoLpr").textContent = _descuentoLpr;

            const cantidad = parseFloat(fila.children[2].textContent) || 0;
            fila.querySelector(".total").textContent = "Q " + (cantidad * _nuevoPrecio).toFixed(2);

            // 🔑 Actualizo también los data-* del enlace dentro de la fila
            const link = fila.querySelector("a[data-itemcode]");
            if (link) {
                link.setAttribute("data-descuentopor", _dsctoPor);
                link.setAttribute("data-descuentoqtz", _dsctoQtz);
                link.setAttribute("data-descuentolpr", _descuentoLpr);
            }

            // 🔹 Recalcular totales de toda la tabla
            let subtotal = 0;
            let descuento = 0;
            let granTotal = 0;

            document.querySelectorAll("#detalle-body tr[data-llaves]").forEach(tr => {
                const cantidad = parseFloat(tr.children[2].textContent) || 0;
                const precioReal = parseFloat(tr.querySelector(".precio").textContent.replace("Q", "").trim()) || 0;
                const precioDscto = parseFloat(tr.querySelector(".precioDscto").textContent.replace("Q", "").trim()) || 0;

                subtotal += cantidad * precioReal;
                granTotal += cantidad * precioDscto;

                const dsctoQtz = parseFloat(tr.querySelector(".descuentoQtz").textContent.replace("Q", "").trim()) || 0;
                descuento += dsctoQtz;
            });

            // 🔹 Actualizar en la tabla
            document.querySelector(".isubtotal").textContent = "Q " + subtotal.toFixed(2);
            document.querySelector(".tdescuento").textContent = "Q " + descuento.toFixed(2);
            document.querySelector(".igrantotal").textContent = "Q " + granTotal.toFixed(2);

            $('#discountModal').modal('hide');
        }

        function cargarDescuentos(element) {
            const itemCode = element.getAttribute("data-itemcode");
            const lineNum = element.getAttribute("data-linenum");
            const precioReal = element.getAttribute("data-precioreal");
            const descuentoPor = element.getAttribute("data-descuentopor");
            const dscription = element.getAttribute("data-dscription");
            const listName = element.getAttribute("data-listname");
            const listNum = element.getAttribute("data-listNum");
            const descuentoQtz = element.getAttribute("data-descuentoQtz");

            const tipoLp = listNum;
            document.getElementById('txtLlave').textContent = lineNum;
            document.getElementById('txtNombreProducto').value = dscription;
            document.getElementById('selected-price').value = Number(precioReal).toFixed(2);
            document.getElementById('txtFormaPago').value = tipoLp === "1" ? "PRECIO BENEFICIO" : "PRECIO NORMAL";
            document.getElementById('txtNombreProducto').value = dscription;
            document.getElementById('txtPdecuento').value = Number(descuentoPor).toFixed(2);
            document.getElementById('txtQdescuento').value = Number(descuentoQtz).toFixed(2);

            $.ajax({
                url: '/MiCarrito/TablaDescuentos', // Ajusta el nombre del controlador
                type: 'GET',
                data: { ItemCode: itemCode,  },
                success: function (data) {
                    let tbody = $('#discountTableBody');
                    tbody.empty();

                    if (data.length > 0) {
                        data.forEach(function (item) {
                            let row = `<tr>
