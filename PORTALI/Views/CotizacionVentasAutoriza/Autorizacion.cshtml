@{
    var sessions = (Entity.SessionLoginEntity)Session["PropertiesEntity"];
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Cotizaciones Pendientes de Autorizar</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            background: #f5f7fa;
            margin: 0;
        }


        .table-container {
            background: #fff;
            border-radius: 12px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.1);
            padding: 20px;
            overflow-x: auto;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 14px;
        }

        thead {
            background: #2d6cdf;
            color: #fff;
        }

        th, td {
            padding: 12px 15px;
            text-align: left;
        }

        tbody tr {
            border-bottom: 1px solid #e6e6e6;
        }

            tbody tr:nth-child(even) {
                background: #f9fbff;
            }

            tbody tr:hover {
                background: #eef3ff;
            }

        .btn {
            display: inline-flex;
            align-items: center;
            background: #2d6cdf;
            color: white;
            padding: 6px 12px;
            border-radius: 8px;
            text-decoration: none;
            font-size: 13px;
            transition: 0.2s;
            border: none;
            cursor: pointer;
        }

            .btn:hover {
                background: #1d4bb8;
            }

            .btn i {
                margin-right: 6px;
            }

        /* Clase personalizada para ancho amplio en desktop */
        .modal-full-width {
            max-width: 60% !important; /* Ancho máximo del 90% */
            width: 60% !important;
            margin: auto;
        }

        /* Scroll y padding para modal-body */
        #detalleModal .modal-body {
            max-height: 90vh;
            overflow-y: auto;
            padding: 1rem;
        }
    </style>
    <script src="https://kit.fontawesome.com/64d58efce2.js" crossorigin="anonymous"></script>
</head>
<body>

    <h2 style="
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            font-size: 26px;
            font-weight: 600;
            color: #34495e;
            background-color: #ecf0f1;
            padding: 12px 18px;
            border-left: 5px solid #27ae60;
            border-radius: 6px;
            letter-spacing: 0.5px;
        ">
        📌 Cotizaciones en Espera de Autorización
    </h2>

    <div class="table-container">
        <table id="tablaCotizaciones">
            <thead>
                <tr>
                    <th>Número</th>
                    <th>Tienda</th>
                    <th>Asesor</th>
                    <th>Fecha</th>
                    <th>NIT</th>
                    <th>Cliente</th>
                    <th>Contacto</th>
                    <th>Monto</th>
                    <th>Estado</th>
                    <th>Acción</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td colspan="8" style="text-align:center; padding:20px; color:#777; font-style:italic;">
                        No hay datos para mostrar aún
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</body>
</html>

<div class="modal fade" id="detalleModal" tabindex="-1" aria-labelledby="detalleModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-scrollable modal-fullscreen-sm-down modal-full-width">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="detalleModalLabel">Detalle de Cotización</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body" id="detalleModalBody">
            </div>
        </div>
    </div>
</div>

<script>
        function formatSAPDate(sapDate) {
            const timestamp = parseInt(sapDate.replace(/\/Date\((\d+)\)\//, "$1"));
            const date = new Date(timestamp);

            const day = String(date.getDate()).padStart(2, "0");
            const month = String(date.getMonth() + 1).padStart(2, "0");
            const year = date.getFullYear();

            return `${day}/${month}/${year}`;
        }

        $(document).ready(function () {
            $.getJSON('/CotizacionVentasAutoriza/CargarAutorizaciones', function (data) {
                let rows = '';

                if (data && data.length > 0) {
                    data.forEach(c => {
                        rows += `
                        <tr>
                            <td>${c.DocEntry}</td>
                            <td>${c.WhsName}</td>
                            <td>${c.SlpName}</td>
                            <td>${formatSAPDate(c.DocDate)}</td>
                            <td>${c.Nit}</td>
                            <td>${c.CardName}</td>
                            <td>${c.FacNombre}</td>
                            <td>Q${c.DocTotal.toLocaleString('es-GT', { minimumFractionDigits: 2 })}</td>
                            <td>${c.Estado}</td>
                            <td><button class="btn" onclick="viewDocument(${c.DocEntry})"><i class="fas fa-eye"></i> Ver</button></td>
                        </tr>`;
                            });
                    } else {
                        rows = `
                <tr>
                    <td colspan="9" style="text-align:center; padding:20px; color:#777; font-style:italic;">
                        No hay datos para mostrar aún
                    </td>
                </tr>`;
                }

                $('#tablaCotizaciones tbody').html(rows);
            });
        });

        // Función fuera del ready
        function viewDocument(DocEntry) {
            const slpCode = '@sessions.SlpCode'
            window.location.href = `/CotizacionVentasAutoriza/Detalle?DocEntry=${DocEntry}&SlpCode=${slpCode}`;
        }

    function viewDocument(docEntry) {
        const slpCode = '@sessions.SlpCode'
            $("#detalleModalBody").html('<div class="text-center p-4">Cargando detalles...</div>');
            var myModal = new bootstrap.Modal(document.getElementById('detalleModal'));
            myModal.show();

            $.ajax({
                url: '/CotizacionVentasAutoriza/Detalle',
                type: 'GET',
                data: { docEntry: docEntry, SlpCode: slpCode },
                success: function (data) {
                    $("#detalleModalBody").html(data);
                },
                error: function () {
                    $("#detalleModalBody").html('<div class="text-danger p-3">Error al cargar los detalles.</div>');
                }
            });
    }
</script>
