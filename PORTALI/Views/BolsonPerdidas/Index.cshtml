<script>
    let sortDirection = {};

    function sortTable(colIndex) {
        const table = document.querySelector(".tablaBolson");
        const tbody = table.tBodies[0];

        // OCULTAMOS TODAS LAS FILAS EXPANDIDAS para que no queden visibles
        document.querySelectorAll('.fila-expandida').forEach(expandedRow => {
            expandedRow.style.display = 'none';
        });

        // RECOLECTAMOS filas principales y sus filas expandidas
        const rows = [];
        const allRows = Array.from(tbody.querySelectorAll("tr"));

        for (let i = 0; i < allRows.length; i++) {
            const row = allRows[i];
            if (!row.classList.contains('fila-expandida')) {
                rows.push({
                    mainRow: row,
                    expandedRows: []
                });
                let j = i + 1;
                while (j < allRows.length && allRows[j].classList.contains('fila-expandida')) {
                    rows[rows.length - 1].expandedRows.push(allRows[j]);
                    j++;
                }
            }
        }

        // ORDENAMOS filas principales
        const dir = sortDirection[colIndex] === "asc" ? "desc" : "asc";
        sortDirection[colIndex] = dir;

        rows.sort((a, b) => {
            let aText = a.mainRow.cells[colIndex]?.innerText.trim() || '';
            let bText = b.mainRow.cells[colIndex]?.innerText.trim() || '';

            const parseMonto = val => parseFloat(val.replace(/[Q,]/g, '').trim()) || 0;
            const parseFecha = val => {
                const parts = val.split('/');
                return parts.length === 3 ? new Date(parts[2], parts[1] - 1, parts[0]) : new Date(val);
            };

            const isMonto = aText.startsWith('Q') && bText.startsWith('Q');
            const isFecha = aText.includes('/') && bText.includes('/');

            if (isMonto) {
                let aVal = parseMonto(aText);
                let bVal = parseMonto(bText);
                return dir === "asc" ? aVal - bVal : bVal - aVal;
            }

            if (isFecha) {
                let aDate = parseFecha(aText);
                let bDate = parseFecha(bText);
                return dir === "asc" ? aDate - bDate : bDate - aDate;
            }

            return dir === "asc"
                ? aText.localeCompare(bText)
                : bText.localeCompare(aText);
        });

        // LIMPIAMOS el tbody y REINSERTAMOS filas principales y expandidas (expandidas ocultas)
        tbody.innerHTML = '';

        rows.forEach(item => {
            tbody.appendChild(item.mainRow);
            item.expandedRows.forEach(expRow => {
                expRow.style.display = 'none';  // nos aseguramos que estén ocultas
                tbody.appendChild(expRow);
            });
        });
    }

        $('#btnFiltrar').on('click', function () {
            let idRegion = $('#filtroRegion').val();
            let whsCode = $('#filtroTienda').val();
            let slpCode = $('#filtroAsesor').val();
            let fechaInicio = $('#fechaI').val();
            let fechaFin = $('#fechaF').val();
            let refSac = $('#chkReferidos').prop('checked');

            // Ejecutar la carga de datos
            cargarTabla(idRegion, whsCode, slpCode, fechaInicio, fechaFin, refSac);
        });

    function cargarTabla(idRegion, whsCode, slpCode, fechai, fechaf, refSac) {
        console.log(refSac);
    // Mostrar loading si lo usas
        $("#globalLoading").show();

        $.ajax({
            url: '@Url.Action("CargarData", "BolsonPerdidas")',
            type: "POST",
            data: { IdRegion: idRegion, WhsCode: whsCode, SlpCode: slpCode, FechaI: fechai, FechaF: fechaf, ReferidoSac: refSac == true ? -2000 : null },
            success: function (data) {
                const $tbody = $('tbody.BolsonActivo');
                $tbody.empty();

                $('#txtActivos').text("Q 0.00");
                $('#txtNuevos').text("Q 0.00");
                $('#txtFacturados').text("Q 0.00");
                $('#txtPerdidos').text("Q 0.00");

                if (data && data.length > 0) {
                    $.each(data, function (index, item) {
                        const fila = $('<tr class="fila-principal">');

                        // Botón expandir
                        fila.append(`
                            <td style="text-align: center;">
                                <button class="btn btn-sm btn-expandir" type="button" title="Expandir" style="background-color: #0d6efd; color: white; border: none; width: 34px; height: 34px;
                                           font-weight: bold; font-size: 18px; border-radius: 50%; display: flex; align-items: center; justify-content: center; box-shadow: 0 2px 6px rgba(0,0,0,0.15); transition: background-color 0.2s ease;">
                                    +
                                </button>
                            </td>
                        `);

                        fila.append(`<td class="oculto">${item.DocEntry}</td>`);
                        fila.append(`<td class="oculto">${item.DocNum}</td>`);
                        fila.append(`<td class="oculto">${item.IdRegion}</td>`);
                        fila.append(`<td class="oculto">${item.Region}</td>`);
                        fila.append(`<td class="oculto">${item.WhsCode}</td>`);
                        fila.append(`<td class="oculto">${item.WhsName}</td>`);
                        fila.append(`<td class="oculto">${item.SlpCode}</td>`);
                        fila.append(`<td>${item.SlpName}</td>`);
                        fila.append(`<td>${item.Nit}</td>`);
                        fila.append(`<td>${item.Nombre}</td>`);
                        fila.append(`<td>${item.Telefono ? item.Telefono : '--'}</td>`);                        
                        fila.append(`<td style="text-align:right">${formatearTotal(item.DocTotal)}</td>`);
                        fila.append(`<td style="text-align:center">${formatearFecha(item.DocDate)}</td>`);
                        fila.append(`<td style="text-align:center">${formatearFecha(item.FechaPerdida)}</td>`);
                        let icono = '';
                        switch (item.Estado) {
                            case 'Aprobado':
                                icono = '<i class="fas fa-check-circle text-success"></i>'; // verde
                                break;                            
                            default:
                                icono = '<i class="fas fa-question-circle text-secondary"></i>'; // gris
                                break;
                        }

                        fila.append(`<td style="text-align:center" title="${item.NotaPerdida}">${icono} ${item.MotivoPerdida}</td>`);

                        fila.append(`<td style="text-align: center; vertical-align: middle;">
                                      <div style="display: inline-flex; gap: 5px; justify-content: center; align-items: center;">
                                        <button type="button" class="btn btn-sm btn-danger btn-btnDetalle" title="Recuperar">🔄</button>
                                      </div>
                                    </td>`);

                        $tbody.append(fila);
                        // Fila expandida oculta
                        const filaExpandida = $(`
                            <tr class="fila-expandida" style="display: none;">
                                <td colspan="15" class="bg-light">
                                    <div class="contenido-expandido">
                                        <div>Cargando detalles...</div>
                                    </div>
                                </td>
                            </tr>
                        `);
                        $tbody.append(filaExpandida);                     
                    });
                } else {
