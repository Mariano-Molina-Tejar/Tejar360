@model Entity.BolsonActivoEntity
@{
    ViewBag.Title = "Bolson perdidas";

    var sessions = (Entity.SessionLoginEntity)Session["PropertiesEntity"];
}

<style>
    body {
        background-color: #f4f6f8;
        font-family: 'Segoe UI', sans-serif;
        margin: 0;
    }

    .filtros-container {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 1rem;
        margin-bottom: 2rem;
    }

        .filtros-container label {
            font-weight: 600;
            margin-bottom: 0.3rem;
            display: block;
            color: black;
        }

        .filtros-container select {
            padding: 0.5rem;
            border: 1px solid #ccc;
            border-radius: 8px;
            width: 100%;
            font-size: 0.95rem;
        }

        .filtros-container .derecha {
            display: flex;
            align-items: end;
            gap: 0.5rem;
        }

        .filtros-container button {
            padding: 0.55rem 1.2rem;
            background-color: black;
            color: white;
            border: none;
            border-radius: 8px;
            font-weight: bold;
            font-size: 0.95rem;
            transition: background 0.3s ease;
        }

            .filtros-container button:hover {
                background-color: black;
            }

    .paneles-container {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
        margin-bottom: 2rem;
    }

    .panel {
        flex: 1 1 150px;
        background-color: white;
        padding: 1rem;
        border-radius: 12px;
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.05);
        text-align: center;
    }

        .panel h3 {
            margin: 0;
            font-size: 1rem;
            color: #555;
        }

        .panel span {
            display: block;
            margin-top: 0.5rem;
            font-size: 1.4rem;
            font-weight: bold;
            color: black;
        }

    .oculto {
        display: none;
    }

    .tab-content {
        display: none;
    }

        .tab-content.active {
            display: block;
        }

    .tab-buttons {
        display: flex;
        margin-bottom: 10px;
    }

    .tab-button {
        padding: 8px 16px;
        cursor: pointer;
        border: 1px solid #ccc;
        margin-right: 5px;
        background-color: #f0f0f0;
    }

        .tab-button.active {
            background-color: #d0d0d0;
            font-weight: bold;
        }
</style>
<h1 class="text-center my-4" style="font-weight: bold; font-size: 1.5rem; color: #343a40; border-bottom: 3px solid #007bff; display: inline-block; padding-bottom: 10px;">
    ❗Bolson de cotizaciones perdidas
</h1>


<div style="padding:20px;padding-bottom:40px">
    <div class="row g-2 mb-3">
        <div class="col-auto">
            <div class="d-flex align-items-center">
                <input type="date" id="fechaI" class="form-control form-control-sm shadow-sm border-secondary" />
            </div>
        </div>
        <div class="col-auto">
            <div class="d-flex align-items-center">
                <input type="date" id="fechaF" class="form-control form-control-sm shadow-sm border-secondary" />
            </div>
        </div>
        <div class="col-auto">
            <div class="d-flex align-items-center" style="height: 100%;">
                <button class="btn btn-sm btn-dark shadow-sm btn-update" id="btnFiltrar">
                    <i class="fas fa-sync-alt me-1"></i> Actualizar Datos
                </button>
            </div>
        </div>
    </div>
    <div class="filtros-container">
        <div>
            <label>Región</label>
            <select id="filtroRegion">
                <option value="-101">-- Seleccionar --</option>
            </select>
            <script>
                $(document).ready(function () {
                    CargarRegiones();
                });

                $('#filtroRegion').on('change', function () {
                    let idRegion = $(this).val();
                    CargarTiendas(idRegion);
                });

                function CargarRegiones(){
                    $.ajax({
                        url: '@Url.Action("ListadoRegiones", "BolsonActivo")',
                        type: "POST",
                        success: function (data) {
                            if (data && data.length > 0) {
                                $.each(data, function (index, item) {
                                    $('#filtroRegion').append(
                                        $('<option>', {
                                            value: item.IdRegion,
                                            text: item.Region
                                        })
                                    );
                                });

                                if (data.length === 1) {
                                    // Solo una opción, seleccionarla y bloquear el select
                                    $('#filtroRegion').val(data[0].IdRegion).trigger('change');
                                    CargarTiendas(data[0].IdRegion);
                                    $('#filtroRegion').prop('disabled', true); // bloquear select
                                } else {
                                    // Más de una opción, seleccionar '-1' y desbloquear el select
                                    $('#filtroRegion').val('-1').trigger('change');
                                    CargarTiendas(-1);
                                    $('#filtroRegion').prop('disabled', false); // desbloquear select
                                }

                            } else {
                                // No hay datos, mantener seleccionado el -1
                                $('#filtroRegion').val('-1');
                            }
                        },
                        error: function (xhr, status, error) {
                            console.error("Error al cargar las regiones:", error);
                            $('#filtroRegion').val('-1');
                        },
                        complete: function () {
                            $("#globalLoading").hide(); // Oculta el loading si lo estás usando
                        }
                    });
                }
            </script>
        </div>
        <div>
            <label>Tienda</label>
            <select id="filtroTienda">
                <option value="-1">-- Seleccionar --</option>
            </select>

            <script>

                $(document).ready(function () {
                    const today = new Date();

                    // Fecha inicial: primer día del mes actual
                    const firstDay = new Date(today.getFullYear(), today.getMonth(), 1);

                    // Fecha final: último día del mes actual
                    const lastDay = new Date(today.getFullYear(), today.getMonth() + 1, 0);

                    // Función para formatear la fecha en formato yyyy-mm-dd
                    function formatDate(date) {
                        const year = date.getFullYear();
                        const month = String(date.getMonth() + 1).padStart(2, '0');
                        const day = String(date.getDate()).padStart(2, '0');
                        return `${year}-${month}-${day}`;
                    }

                    // Asignar a los inputs
                    $('#FechaI').val(formatDate(firstDay));
                    $('#FechaF').val(formatDate(lastDay));

                    CargarData();
                    $('.btn-expandir').first().click();
                    //setTimeout(function () {
                    //    $('.btn-expandir').first().click(); // Expande el primer panel después de cargar la data
                    //}, 600); // Pequeño retraso para asegurar que los datos estén listos
                });

                $('#filtroTienda').on('change', function () {
                    let idRegion = $('#filtroRegion').val();
                    let WhsCode = $(this).val();
                    CargarUsuarios(idRegion, WhsCode);
                });

                function CargarTiendas(idRegion) {
                    $('#filtroTienda')
                        .html('') // limpiar todo
                        .append($('<option>', { value: '-1', text: '-- Seleccionar --' }))
                        .val('-1')
                        .trigger('change');

                    $.ajax({
                        url: '@Url.Action("ListadoTiendas", "BolsonActivo")',
                        type: "POST",
                        data: { IdRegion: idRegion },
                        success: function (data) {
                            if (data && data.length > 0) {
                                $.each(data, function (index, item) {
                                    $('#filtroTienda').append(
                                        $('<option>', {
                                            value: item.WhsCode,
                                            text: item.WhsName
                                        })
                                    );
                                });

                                    if (data.length === 1) {
                                        $('#filtroTienda').val(data[0].WhsCode).trigger('change');
                                        $('#filtroTienda').prop('disabled', true);
                                        CargarUsuarios(idRegion, data[0].WhsCode);
                                    } else {
                                        $('#filtroTienda').val('-1').trigger('change');
                                        $('#filtroTienda').prop('disabled', false);
                                        CargarUsuarios(idRegion, -1);
                                    }
                                } else {
                                    $('#filtroTienda').val('-1');
                                }
                            },
                            error: function (xhr, status, error) {
                                console.error("Error al cargar las tiendas:", error);
                                $('#filtroTienda').val('-1');
                            },
                            complete: function () {
                                $("#globalLoading").hide();
                            }
                    });
                }
            </script>
        </div>

        <div class="derecha">
            <div style="flex: 1;">
                <label>Asesor</label>
                <select id="filtroAsesor">
                    <option value="">-- Seleccionar --</option>
                </select>
                <script>
                    function CargarUsuarios(idRegion, whsCode) {
                        $('#filtroAsesor').html(''); // limpiar todo

                        $.ajax({
                            url: '@Url.Action("ListaDeAsesores", "BolsonActivo")',
                            type: "POST",
                            data: { IdRegion: idRegion, WhsCode: whsCode },
                            success: function (data) {
                                if (data && data.length > 0) {

                                    // Si NO son 2, agregar "-- Seleccionar --"
                                    if (data.length > 1) {
                                        $('#filtroAsesor')
                                            .append($('<option>', { value: '-101', text: '-- Seleccionar --' }));
                                    }

                                    $.each(data, function (index, item) {
                                        $('#filtroAsesor').append(
                                            $('<option>', {
                                                value: item.SlpCode,
                                                text: item.SlpName
                                            })
                                        );
                                    });

                                    if (data.length === 1) {
                                        // Seleccionar automáticamente el único valor útil
                                        $('#filtroAsesor').val(data[1].SlpCode).trigger('change');
                                        $('#filtroAsesor').prop('disabled', true); // si quieres bloquearlo
                                    } else {
                                        $('#filtroAsesor').val('-101').trigger('change');
                                        $('#filtroAsesor').prop('disabled', false);
                                    }
                                } else {
                                    $('#filtroAsesor')
                                        .html('')
                                        .append($('<option>', { value: '-101', text: '-- Seleccionar --' }))
                                        .val('-101')
                                        .prop('disabled', false);
                                }
                            },
                            error: function (xhr, status, error) {
                                console.error("Error al cargar los asesores:", error);
                                $('#filtroAsesor').val('-101').prop('disabled', false);
                            },
                            complete: function () {
                                $("#globalLoading").hide();
                            }
                        });
                    }
                </script>

