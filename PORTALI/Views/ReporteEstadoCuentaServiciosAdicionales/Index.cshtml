@model Entity.Filtros.FiltroServiciosAdicionalesEntity
@{
    ViewBag.Title = "Reporte Estado de Cuenta Servicios Adicionales";
    var resultados = ViewBag.Resultado as List<Entity.ReporteEstadoCuentaServiciosAdicionales>;
}

<div class="container-fluid mt-4">
    <h2 class="mb-4">Reporte Estado de Cuenta Servicios Adicionales</h2>

    <div class="card shadow-sm mb-4">
        <div class="card-header bg-light">
            <h5 class="mb-0">Filtros de búsqueda</h5>
        </div>

        <div class="card-body">
            <!-- Formulario de Filtros -->
            @using (Html.BeginForm("Index", "ReporteEstadoCuentaServiciosAdicionales", FormMethod.Post, new { @class = "row g-3 mb-4" }))
            {
                <div class="col-12 col-md-4">
                    <label for="FechaInicio" class="form-label">Fecha de Inicio</label>
                    <input type="date"
                           id="FechaInicio"
                           name="FechaInicio"
                           class="form-control"
                           value="@ViewBag.FechaInicio"
                           aria-describedby="fechaInicioHelp" />
                    <small id="fechaInicioHelp" class="form-text text-muted">
                        Seleccione la fecha desde la cual desea consultar.
                    </small>
                </div>

                <div class="col-12 col-md-4">
                    <label for="FechaFin" class="form-label">Fecha de Fin</label>
                    <input type="date"
                           id="FechaFin"
                           name="FechaFin"
                           class="form-control"
                           value="@ViewBag.FechaFin"
                           aria-describedby="fechaFinHelp" />
                    <small id="fechaFinHelp" class="form-text text-muted">
                        Seleccione la fecha hasta la cual desea consultar.
                    </small>
                </div>

                <div class="col-md-4">
                    <label for="OrdenCompra" class="form-label">Orden Compra</label>
                    <input type="text" name="OrdenCompra" class="form-control" value="@Model.OrdenCompra" placeholder="Ingrese el número de la orden de compra" />
                </div>

                //127343

                <div class="col-12 col-md-4">
                    <label for="Factura" class="form-label">Factura</label>
                    <input type="text"
                           id="Factura"
                           name="Factura"
                           class="form-control form-control-lg"
                           value="@Model.Factura"
                           placeholder="Ej. 1266110360"
                           aria-describedby="FacturaHelp"
                           maxlength="20" />
                    <small id="FacturaHelp" class="form-text text-muted">
                        Ingrese la Factura
                    </small>
                </div>

                <div class="col-12 col-md-4">
                    <label for="Proveedor" class="form-label">Proveedor</label>
                    @Html.DropDownListFor(m => m.Proveedor,
                         ViewBag.Proveedores as SelectList,
                            "-- Seleccione un Proveedor --",
                     new
                     {
                         @class = "form-select dropdown-toggle form-control",
                         aria_label = "Seleccione Proveedor",
                         style = "border-radius: 3px; box-shadow: 0 4px 6px rgba(0, 45, 145, 0.1);"
                     })
                    <small id="proveedorHelp" class="form-text text-muted">
                        Seleccione el proveedor el cual desea buscar.
                    </small>
                </div>





                <div class="col-12 text-end mt-3">
                    <button type="submit" class="btn btn-primary btn-lg px-4 py-2 me-2 shadow-sm">
                        <i class="bi bi-funnel-fill me-1"></i> Filtrar
                    </button>

                    <a href="@Url.Action("Index", "ReporteEstadoCuentaServiciosAdicionales")" class="btn btn-outline-secondary btn-lg px-4 py-2 shadow-sm">
                        <i class="bi bi-arrow-repeat me-1"></i> Restablecer
                    </a>
                </div>
            }
        </div>

    </div>

    

    <!-- Formulario separado para Exportar Excel -->
    <div class="row g-3 mb-4">
        <div class="col-md-2 d-flex align-items-end">
            @using (Html.BeginForm("ExportarExcel", "ReporteEstadoCuentaServiciosAdicionales", FormMethod.Post))
            {
                @Html.HiddenFor(m => m.FechaInicio)
                @Html.HiddenFor(m => m.FechaFin)
                @Html.HiddenFor(m => m.Proveedor)
                @Html.HiddenFor(m => m.OrdenCompra)
                @Html.HiddenFor(m => m.Factura)

                <button type="submit" class="btn btn-success btn-lg w-100 shadow-sm">
                    <i class="bi bi-file-earmark-excel-fill me-1"></i> Exportar Excel
                </button>
            }
        </div>
    </div>


    <!-- Tabla de Resultados -->
    @if (resultados != null && resultados.Any())
    {
        <div class="table-responsive mt-4">
            <table class="table table-bordered table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Código</th>
                        <th>Nombre</th>
                        <th>Fecha OC</th>
                        <th>Monto OC</th>
                        <th>Orden Compra</th>
                        <th>Fecha FacProv</th>
                        <th>Factura Proveedor</th>
                        <th>Monto FP</th>
                        <th>Serie</th>
                        <th>Factura</th>
                        <th>Fecha Pago</th>
                        <th>Pago</th>
                        <th>Monto Pagado</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in resultados)
                    {
                        <tr>
                            <td>@item.Codigo</td>
                            <td>@item.Nombre</td>
                            <td>@item.FechaOC.ToString("dd/MM/yyyy")</td>
                            <td>@item.MontoOC.ToString("C")</td>
                            <td>@item.OrdenCompra</td>
                            <td>@item.FechaFacProv.ToString("dd/MM/yyyy")</td>
                            <td>@item.FacProv</td>
                            <td>@item.MontoFP.ToString("C")</td>
                            <td>@item.Serie</td>
                            <td>@item.Factura</td>
                            <td>@item.FechaPago.ToString("dd/MM/yyyy")</td>
                            <td>@item.Pago</td>
                            <td>@item.MontoPagado.ToString("C")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else if (Request.HttpMethod == "POST")
    {
        <div class="alert alert-warning mt-3">
            No se encontraron resultados para los filtros aplicados.
        </div>
    }
</div>
