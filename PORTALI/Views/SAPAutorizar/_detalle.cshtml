@model Entity.CotizacionCompraEntity
    @{ int j = 1;
        if(Model.DocNumCoti > 0)
        {
            <script>
                window.location.href = '/SAPAutorizar/AutorizarSolicitudes'
            </script>
            return;
        }
}

<style>
    body {
        font-size: 14px;
    }
    /* Estilos del panel */
    .panel {
        width: 98%;
        margin: 20px auto;
        border: 1px solid #dddddd;
        border-radius: 6px;
        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
        background-color: #ffffff;
        overflow: hidden;
    }

    .panel-header {
        background-color: #009879;
        color: white;
        padding: 15px;
        text-align: center;
        font-size: 20px;
        font-weight: bold;
        text-transform: uppercase;
    }

    .panel-body {
        padding: 20px;
    }

    /* Estilos de la tabla */
    .styled-table {
        width: 100%;
        border-collapse: collapse;
        font-family: Arial, sans-serif;
        font-size: 16px;
        margin: 20px 0;
        background-color: #f3f3f3;
        box-shadow: 0 2px 5px rgba(0, 0, 0, 0.2);
    }

        .styled-table thead tr {
            background-color: #009879;
            color: #ffffff;
            text-align: left;
        }

        .styled-table th, .styled-table td {
            padding: 12px 15px;
            text-align: center;
            border: 1px solid #dddddd;
        }

        .styled-table tbody tr {
            transition: background-color 0.3s ease;
        }

            .styled-table tbody tr:nth-child(even) {
                background-color: #f3f3f3;
            }

            .styled-table tbody tr:hover {
                background-color: #d1e7dd;
            }

        .styled-table tbody td {
            color: #333333;
        }
</style>


<div class="card-body p-2"> 
    <div class="row">
        <div class="col-lg-8">
            <div class="panel">
                <div class="panel-header">
                    Datos del proveedor
                </div>
                <div class="panel-body">
                    <form class="mt-4">
                        <div class="row col-lg-12">
                            <div data-mdb-input-init class="col-lg-3">
                                <label class="form-label" for="typeName">Número de solicitud</label>
                                <input type="text" id="typeName" class="form-control form-control-lg" siez="17" placeholder="" value="@Model.DocNumSolC" readonly style="background-color:white" />
                            </div>
                            <div data-mdb-input-init class="col-lg-9">
                                <label class="form-label" for="typeName">Nombre del proveedor</label>
                                <input type="text" id="typeName" class="form-control form-control-lg" siez="17" placeholder="" value="@Model.CardName" readonly style="background-color:white" />
                            </div>
                        </div>
                        <div class="row col-lg-12" style="margin-top:5px">
                            <div data-mdb-input-init class="col-lg-3">
                                <label class="form-label" for="typeText">Correo electronico</label>
                                <input type="text" id="typeText" class="form-control form-control-lg" siez="17" value="@Model.Email" readonly style="background-color:white" placeholder="" />
                            </div>
                            <div data-mdb-input-init class="col-lg-3">
                                <label class="form-label" for="typeText">Fecha requerida</label>
                                <input type="date" class="form-control form-control-lg" id="txtDocDate" value="@Model.FechaEntrega.ToString("yyyy-MM-dd")" readonly style="background-color:white">
                            </div>

                            <div data-mdb-input-init class="col-lg-3">
                                <label class="form-label" for="typeText">Fecha entrega</label>
                                <input type="date" class="form-control form-control-lg" id="txtDocDate" value="@Model.FechaEntrega.ToString("yyyy-MM-dd")" readonly style="background-color:white">
                            </div>

                            <div data-mdb-input-init class="col-lg-3">
                                <label class="form-label" for="typeText">Forma de pago</label>
                                <input type="text" id="typeText" class="form-control form-control-lg" siez="17" value="@Model.FormaPago" readonly style="background-color:white"
                                       placeholder="" minlength="19" maxlength="19" />

                            </div>
                        </div>
                        <div data-mdb-input-init class="col-lg-6">
                            <label class="form-label" for="typeText">Observaciones</label>
                            <div data-mdb-input-init class="form-outline form-white mb-1">
                                <textarea type="text" id="typeText" class="form-control form-control-lg" siez="17" readonly style="background-color:white">@Model.ComentariosCoti</textarea>

                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="panel">
                <div class="panel-header">
                    Presupuesto
                </div>
                <div class="panel-body">
                    <form class="mt-4">
                        <div class="table-responsive">
                            <table class="table table-bordered table-hover" style="background-color: #f7f7f7; color: #333; border-radius: 10px; box-shadow: 0 4px 8px rgba(0,0,0,0.1);">
                                <thead class="thead-light">
                                    <tr style="text-align: center; background-color: #4e73df; color: white;">
                                        <th>Nombre de la Cuenta</th>
                                        <th>Presupuesto</th>
                                        <th>Cotización</th>
                                        <th>Saldo</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model.DetallePresupuesto)
                                    {
                                        <tr style="text-align: center;">
                                            <td>
                                                <strong>@item.AcctName</strong>
                                            </td>
                                            <td>
                                                <strong>Q.@string.Format("{0:#,##0.00}", @item.Saldo)</strong>
                                            </td>
                                            <td>
                                                <strong class="label-custom" style="background-color: #ff7043; color: white; padding: 5px 15px; border-radius: 5px;">
                                                    -Q.@string.Format("{0:#,##0.00}", @item.GastoActual)
                                                </strong>
                                            </td>
                                            <td>
                                                <strong class="label-custom" style="background-color: #008080; color: white; padding: 5px 15px; border-radius: 5px;">
                                                    Q.@string.Format("{0:#,##0.00}", @item.SaldoActual)
                                                </strong>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </form>
                </div>
            </div>
        </div>
        <div class="col-lg-12">
            <div class="panel">
                <div class="panel-header">
                    Detalle
                </div>
                <div class="panel-body">
                    <table class="styled-table">
                        <thead>
                            <tr>
                                <th>Código</th>
                                <th>Nombre del producto</th>
                                <th>Detalle</th>
                                <th>Cantidad</th>
                                <th>Precio</th>
                                <th>Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Detalle.Count > 0)
                            {
                                foreach (var item in Model.Detalle)
                                {
                                    <tr>
                                        <td>@item.ItemCode</td>
                                        <td>@item.Dscription</td>
                                        <td>@item.LineText</td>
                                        <td>@item.Quantity.ToString("N2")</td>
                                        <td>@item.Price.ToString("N2")</td>
                                        <td>@item.LineTotal.ToString("N2")</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="7" class="no-data">No hay datos para mostrar</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <div class="col-lg-12 my-3">
            <div id="totales" class="card shadow rounded-4 col-lg-3 ms-auto p-4" style="border-top: 5px solid #008037; float: right;">
                <h5 class="text-center fw-bold mb-4" style="color: #008037;">Resumen de Totales</h5>

                <div class="d-flex justify-content-between mb-3">
                    <span class="text-secondary">Subtotal:</span>
                    <span class="fw-bold">@string.Format("Q.{0:#,##0.00}", @Model.SubTotal)</span>
                </div>

                <div class="d-flex justify-content-between mb-3">
                    <span class="text-secondary">IVA:</span>
                    <span class="fw-bold">@string.Format("Q.{0:#,##0.00}", @Model.Iva)</span>
                </div>

                <div class="d-flex justify-content-between mb-4 border-top pt-3">
                    <span class="text-secondary">Total Compra:</span>
                    <span class="fw-bold text-success fs-5">@string.Format("Q.{0:#,##0.00}", @Model.Total)</span>
                </div>

                @if (Model.CountCoti > 0)
                {
                    <button id="btnAutoCoti" type="button" class="btn btn-success btn-block btn-lg">
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="fw-bold">@string.Format("Q.{0:#,##0.00}", @Model.Total)</span>
                            <span>Autorizar Cotización <i class="fas fa-arrow-right ms-2"></i></span>
                        </div>
                    </button>
                }
            </div>
        </div>
    </div>
</div>
<script>
    $(document).ready(function () {
        $('#btnAutoCoti').on('click', function () {
            $('#globalLoading').show();

            var parametrosEnviar = {
                'DocEntry': @Model.DocEntry,
                'DocEntrySol': @Model.DocEntrySolC
            };

            $.ajax({
                url: '@Url.Action("ValidaAutorizacion", "SAPAutorizar")',
                type: 'POST',
                data: JSON.stringify(parametrosEnviar),
                contentType: 'application/json; charset=utf-8',
                dataType: 'json',
                success: function (respuesta) {
                    console.log(respuesta);
                    if (respuesta.Id == 1000) {
                        $("#globalLoading").hide();
                        document.getElementById("tituloEncabezado").innerText = "Autorización supervisada";
                        document.getElementById("tituloPregunta").innerText = respuesta.Dscription;
                        $('#vistaCondicion').modal('show');
                    } else if (respuesta.data == "R") {
                        window.location.href = '/SAPAutorizar/AutorizarSolicitudes'
                    } else if (respuesta.Id == 117) {
                        $("#globalLoading").hide();
                        document.getElementById("tituloEncabezado").innerText = "Autorización";
                        document.getElementById("tituloPregunta").innerText = respuesta.Dscription;
                        $('#vistaCondicion').modal('show');
                    } else if (respuesta.Id == -118) {
                        $("#globalLoading").hide();                        
                        window.location.href = '/SAPAutorizar/AutorizarSolicitudes'                        
                    }
            },
            error: function (xhr, status, error) {                
                $("#globalLoading").hide();
                }
            });
        });
    });
</script>