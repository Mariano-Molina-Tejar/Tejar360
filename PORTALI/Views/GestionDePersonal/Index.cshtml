                result.data.forEach((item) => {
                    console.log(item);
                    divCartas += `<div class="list-group-item list-group-item-action p-3">
                                <div class="d-flex w-100 justify-content-between align-items-center">
                                    <h6 class="mb-1 fw-bold text-dark">${item.Falta}</h6>
