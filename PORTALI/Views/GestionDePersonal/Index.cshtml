@using Entity;
@model IEnumerable<DatosEmpleados>
@{
    ViewData["Title"] = "Gestión de Personal";
}

<head>
    <style>
    </style>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="stylesheet" href="~/Css/GestionDePersonal/style.css">

</head>
<div class="container mt-4">
    <div class="card shadow-sm border-0 rounded-4">

        <!-- HEADER -->
        <div class="card-header d-flex justify-content-between align-items-center px-4"
             style="background: linear-gradient(135deg, #3a7bd5, #3a6073); color:white;">
            <h5 class="mb-0 fw-semibold">
                <i class="bi bi-people-fill me-2"></i> Gestión de Personal
            </h5>

            <div class="d-flex gap-2">
                <button class="btn btn-light btn-sm" id="btnProcesoAutorizacion"
                        data-bs-toggle="modal" data-bs-target="#modalSeguimiento">
                    <i class="bi bi-clipboard-check me-1"></i> Proceso
                </button>

                <button class="btn btn-light btn-sm" id="btnNuevaPlaza"
                        data-bs-toggle="modal" data-bs-target="#modalNuevaPlaza">
                    <i class="bi bi-person-plus-fill me-1"></i> Nueva plaza
                </button>
            </div>
        </div>

        <!-- BODY -->
        <div class="card-body bg-light">

            @if (ViewData["Error"] != null)
            {
                <div class="alert alert-danger d-flex align-items-center" role="alert" id="divError">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    <span id="msgError">@ViewData["Error"]</span>
                </div>
            }

            <table class="table align-middle text-center tabla-personal">

                <thead>
                    <tr>
                        <th>Código</th>
                        <th class="text-start">Nombres</th>
                        <th class="text-start">Puesto</th>
                        <th>Creado SAP</th>
                        <th>Estado</th>
                        <th>Acción</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var empleados in Model)
                        {
                            <tr>
                                <td>@empleados.EmpID</td>

                                <td class="text-start fw-medium">
                                    @empleados.Nombre
                                </td>

                                <td class="text-start">
                                    <div class="d-flex align-items-center justify-content-between">
                                        <span>@empleados.Puesto</span>

                                        <button id="btnPerfil-@(empleados.EmpID)"
                                                class="btn btn-sm rounded-circle @(empleados.Perfil ? "btn-outline-success" : "btn-outline-danger")"
                                                data-bs-toggle="tooltip"
                                                title="@(empleados.Perfil ? "Ver perfil" : "Agregar perfil")"
                                                onclick="abrirModalPerfilPuesto('@empleados.Puesto',@empleados.PuestoId, @empleados.Perfil.ToString().ToLower(),'btnPerfil-@(empleados.EmpID)')">
                                            <i id="ibtnPerfil-@(empleados.EmpID)"
                                               class="bi bi-file-earmark-text"></i>
                                        </button>
                                    </div>
                                </td>

                                <td>@empleados.CreadoSAP.ToString("dd/MM/yyyy")</td>

                                <td>
                                    <span class="badge bg-success @(empleados.Activo == "Y" ? "" : "d-none")">Activo</span>
                                    <span class="badge bg-danger @(empleados.Activo == "N" ? "" : "d-none")">Inactivo</span>
                                    <span class="badge bg-warning text-dark @(empleados.Activo == "-" ? "" : "d-none")">Pendiente</span>
                                </td>

                                <td>
                                    <button class="btn btn-sm btn-outline-primary rounded-pill px-3"
                                            onclick="verPerfil(this)"
                                            data-nombre="@empleados.Nombre"
                                            data-id="@empleados.EmpID"
                                            data-puesto="@empleados.Puesto"
                                            data-departamento="@empleados.Departamento"
                                            data-activo="@empleados.Activo"
                                            data-telefono="@empleados.Telefono"
                                            data-correo="@empleados.Correo"
                                            data-sexo="@empleados.Sexo"
                                            data-empId="@empleados.EmpID"
                                            data-creadoSAP="@empleados.CreadoSAP.ToString("dd/MM/yyyy")">
                                        <i class="bi bi-person-vcard me-1"></i> Perfil
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4">
                                <i class="bi bi-info-circle"></i> No se encontraron datos
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

        </div>
    </div>

</div>

<<div class="modal fade" id="modalNuevaPlaza" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content modal-plaza-modern">

            <!-- HEADER -->
            <div class="modal-header modal-plaza-header">
                <h5 class="modal-title">
                    <i class="bi bi-person-fill-add me-2"></i> Registrar nueva plaza
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <!-- BODY -->
            <div class="modal-body">
                <form id="formNuevaPlaza" class="plaza-form">

                    <!-- Puesto -->
                    <div class="form-group-modern">
                        <label class="form-label">Puesto</label>
                        <select class="form-select" id="selectNuevaPlaza">
                        </select>
                    </div>

                    <!-- Nuevo puesto -->
                    <div class="form-group-modern d-none" id="divNuevoPuesto">
                        <label class="form-label">Nuevo puesto</label>
                        <input type="text"
                               id="inputNuevoPuesto"
                               class="form-control"
                               placeholder="Ingrese el nuevo puesto">
                    </div>

                    <!-- Observaciones -->
                    <div class="form-group-modern">
                        <label class="form-label">Observaciones</label>
                        <textarea id="PerfilObservaciones"
                                  class="form-control"
                                  rows="4"
                                  placeholder="Agregue observaciones relevantes..."
                                  required></textarea>
                    </div>

                </form>
            </div>

            <!-- FOOTER -->
            <div class="modal-footer modal-plaza-footer">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">
                    Cancelar
                </button>

                <button type="button" class="btn btn-primary" id="btnGuardar">
                    <i class="bi bi-send me-1"></i>
                    Enviar solicitud
                </button>
            </div>

        </div>
    </div>
</div>

<div class="modal fade" id="modalPerfilEmpleado" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content perfil-modern">

            <!-- Header -->
            <div class="modal-header perfil-modern-header">
                <h5 class="modal-title">
                    <i class="bi bi-person-circle me-2"></i> Perfil del Empleado
                </h5>
                <button onclick="cerrarModalPerfil()"
                        type="button"
                        class="btn-close">
                </button>
            </div>

            <!-- Body -->
            <div class="modal-body">
                <div class="row g-4 align-items-center">

                    <!-- Perfil -->
                    <div class="col-md-4 text-center perfil-modern-side">
                        <img id="imgPerfil"
                             src="~/Img/PerfilMale.png"
                             class="perfil-avatar"
                             alt="Foto empleado">

                        <h5 id="perfilNombre" class="mt-3 mb-1 fw-semibold"></h5>
                        <input class="d-none" id="perfilEmpId" />

                        <span id="perfilActivo" class="badge badge-status mb-1"></span><br>
                        <span id="perfilSexo" class="text-muted small"></span>
                        <span id="perfilId" hidden></span>
                    </div>

                    <!-- Datos -->
                    <div class="col-md-8">
                        <div class="perfil-data">
                            <div class="perfil-row">
                                <span>Puesto</span>
                                <strong id="perfilPuesto"></strong>
                            </div>
                            <div class="perfil-row">
                                <span>Departamento</span>
                                <strong id="perfilDepartamento"></strong>
                            </div>
                            <div class="perfil-row">
                                <span>Registro SAP</span>
                                <strong id="perfilCreadoSAP"></strong>
                            </div>
                            <div class="perfil-row">
                                <span>Correo</span>
                                <strong id="perfilCorreo"></strong>
                            </div>
                            <div class="perfil-row">
                                <span>Teléfono</span>
                                <strong id="perfilTelefono"></strong>
                            </div>
                        </div>
                    </div>

                </div>
            </div>

            <!-- Footer -->
            <div class="modal-footer perfil-modern-footer">
                <button onclick="cerrarModalPerfil()"
                        type="button"
                        class="btn btn-light">
                    Cerrar
                </button>

                <div class="d-flex gap-2">
                    <button id="btn-DetalleProceso"
                            class="btn btn-warning hidden-input"
                            onclick="verProcesoBaja()">
                        Ver Proceso
                    </button>

                    <button id="btn-SolicitaBaja"
                            class="btn btn-dark btn-sm hidden-input"
                            onclick="verSolicitudBaja()">
                        Solicitar Baja
                    </button>
                </div>
            </div>

        </div>
    </div>
</div>


<!-- Modal -->
<div class="modal fade" id="modalSolicitudBaja" tabindex="-1" aria-labelledby="modalSolicitudBajaLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-2">

            <!-- Encabezado -->
            <div class="modal-header  text-white" style="background-color:darkred">
                <h5 class="modal-title fw-semibold" id="modalSolicitudBajaLabel">
                    <i class="bi bi-person-x-fill me-2"></i> Solicitud de baja
                </h5>
                <button type="button" class="btn-close btn-close-white" aria-label="Cerrar" onclick="cerrarModalSolicitud()"></button>
            </div>

            <!-- Cuerpo -->
            <div class="modal-body px-4">
                <form id="formSolicitudBaja" class="row g-3">
                    <div class="alert alert-info d-flex align-items-center" role="alert">
                        <i class="bi bi-info-circle-fill me-2"></i>
                        Los campos marcados con un <span class="text-danger fw-bold"> * </span> son obligatorios.
                    </div>

                    <!-- Id y nombre -->
                    <div class="col-md-6">
                        <label for="idEmpleadoSolicitud" class="form-label">Id Empleado</label>
                        <input type="text" id="idEmpleadoSolicitud" class="form-control" readonly>
                    </div>
                    <div class="col-md-6">
                        <label for="nombreEmpleadoSolicitud" class="form-label">Nombre</label>
                        <input type="text" id="nombreEmpleadoSolicitud" class="form-control" readonly>
                    </div>

                    <!-- Motivo -->
                    <div class="col-md-6">
                        <label for="motivo" class="form-label">Motivo <span class="text-danger fw-bold">*</span></label>
                        <select id="motivo" class="form-control" required>
                            <option value="">-Seleccione un motivo-</option>
                            <option value="1">Renuncia</option>
                            <option value="2">Despido</option>
                            <option value="3">Abandono</option>
                        </select>
                    </div>

                    <!-- Causas -->
                    <div class="col-md-6 mt-3 hidden-input" id="causasInput">
                        <label class="form-label">Causas</label>
                        <div class="border rounded-3 p-3">
                            <div class="d-flex flex-wrap gap-2" id="contenedorCausas">
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6 hidden-input" id="cartaInput">
                        <label for="cartaRenuncia" class="form-label">Carta de renuncia</label>
                        <input type="file" class="form-control" id="cartaRenuncia" name="cartaRenuncia" accept=".pdf">
                    </div>

                    <!-- Observaciones -->
                    <div class="col-12">
                        <label for="observaciones" class="form-label">Observaciones <span class="text-danger fw-bold">*</span></label>
                        <textarea id="observaciones" class="form-control" rows="3" placeholder="Ingrese observaciones adicionales..." required></textarea>
                    </div>
                </form>
                <br />
                <div id="msg-advertencia" class="alert alert-warning d-flex align-items-center hidden-input" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    Debes completar todos los campos obligatorios antes de continuar.
                </div>
            </div>

            <!-- Pie -->
            <div class="modal-footer d-flex justify-content-between">
                <button type="button" class="btn btn-outline-secondary" onclick="cerrarModalSolicitud()">
                    <i class="bi bi-x-circle me-1"></i> Cancelar
                </button>
                <button type="button" class="btn btn-danger" id="btnConfirmarBaja">
                    <i class="bi bi-send-fill me-1"></i> Solicitar
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Modal -->
<div class="modal fade" id="modalAgregarCorreo" tabindex="-1" aria-labelledby="modalAgregarCorreoLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form id="formCorreoElectronico">
                <!-- Encabezado -->
                <div class="modal-header bg-warning">
                    <h5 class="modal-title" id="modalAgregarCorreoLabel">
                        <i class="bi bi-exclamation-triangle-fill text-warning"></i>
                        Falta correo electrónico
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar" onclick="cerrarModalCorreo()"></button>
                </div>

                <!-- Cuerpo -->
                <div class="modal-body">
                    <p class="mb-3">
                        No tienes un correo electrónico agregado. Debes ingresar tu correo para continuar con la solicitud.
                    </p>

                    <!-- Input correo -->
                    <div class="mb-3">
                        <label for="correoElectronico" class="form-label fw-semibold">Correo electrónico</label>
                        <input type="email" class="form-control" id="correoElectronico" placeholder="ejemplo@eltejar.com.gt" required>
                    </div>

                    <!-- Mensaje informativo -->
                    <div class="alert alert-info mb-0" role="alert">
                        Es necesario el correo electrónico para recibir las notificaciones del proceso de baja.
                    </div>
                    <br />
                    <div id="msg-AdvertenciaCorreo" class="alert alert-warning d-flex align-items-center hidden-input" role="alert">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                        Debes agregar un correo electronico.
                    </div>
                </div>

                <!-- Pie -->
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal" onclick="cerrarModalCorreo()">
                        <i class="bi bi-x-circle"></i> Cancelar
                    </button>
                    <button type="button" class="btn btn-primary" id="btnAgregarCorreo">
                        <i class="bi bi-envelope-plus"></i> Agregar
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
<!-- Modal Seguimiento de Proceso -->
<div class="modal fade" id="modalTrackingProceso" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-fullscreen modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">

            <!-- Header -->
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title">
                    <i class="bi bi-arrow-repeat me-2"></i> Seguimiento del Proceso de Baja
                </h5>
                <button type="button"
                        class="btn-close btn-close-white"
                        data-bs-dismiss="modal"
                        onclick="cerrarModalTrackinDeBaja()">
                </button>
            </div>

            <!-- Body -->
            <div class="modal-body px-5">
                <div class="timeline">

                    <!-- Estado 0 -->
                    <div id="TrackingPendienteColor" class="timeline-item completed">
                        <div class="timeline-icon"><i id="TrackingPendienteIcono" class="bi bi-check-circle-fill"></i></div>
                        <div class="timeline-content">Pendiente</div>
                    </div>

                    <!-- Estado 1 -->
                    <div id="TrackingAutorizadoGTHColor" class="timeline-item completed">
                        <div class="timeline-icon"><i id="TrackingAutorizadoGTHIcono" class="bi bi-check-circle-fill"></i></div>
                        <div class="timeline-content">Autorizado por GTH</div>
                    </div>

                    <!-- Estado 2 - CARTA -->
                    <div id="TrackingCartaColor" class="timeline-item completed">
                        <div class="timeline-icon">
                            <i id="TrackingCartaIcono" class="bi bi-check-circle-fill"></i>
                        </div>
                        <div class="timeline-content ">
                            Carta de despido | Renuncia

                            <div id="btnCargarCarta" class="mt-3">
                                <button class="btn btn-outline-primary btn-sm"
                                        onclick="emitirCartaDespido()">
                                    <i class="bi bi-file-earmark-plus"></i> Cargar carta
                                </button>
                            </div>
                        </div>
                    </div>
                    <!-- Estado 4 -->
                    <div id="TrackingSolvenciaColor" class="timeline-item">
                        <div class="timeline-icon"><i id="TrackingSolvenciaIcono" class="bi bi-circle"></i></div>
                        <div class="timeline-content">Emisión de solvencia administrativa</div>
                    </div>

                    <!-- Estado 5 -->
                    <div id="TrackingUsuariosOperativosColor" class="timeline-item">
                        <div class="timeline-icon"><i id="TrackingUsuariosOperativosIcono" class="bi bi-circle"></i></div>
                        <div class="timeline-content">Bloqueo de usuarios operativos</div>
                    </div>

                    <!-- Estado 6 -->
                    <div id="TrackingConfirmacionPagoColor" class="timeline-item">
                        <div class="timeline-icon"><i id="TrackingConfirmacionPagoIcono" class="bi bi-circle"></i></div>
                        <div class="timeline-content">Confirmación de emisión de pago</div>
                    </div>

                    <!-- Estado 7 -->
                    <div id="TrackingCargaLiquidacionColor" class="timeline-item">
                        <div class="timeline-icon"><i id="TrackingCargaLiquidacionIcono" class="bi bi-circle"></i></div>
                        <div class="timeline-content">Carga de liquidación autorizada</div>
                    </div>

                    <!-- Estado 8 -->
                    <div id="TrackingUsuariosContablesColor" class="timeline-item">
                        <div class="timeline-icon"><i id="TrackingUsuariosContablesIcono" class="bi bi-circle"></i></div>
                        <div class="timeline-content">Bloqueo de usuarios contables</div>
                    </div>

                </div>
            </div>

            <!-- Footer -->
            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="bi bi-x-circle"></i> Cerrar
                </button>
            </div>

        </div>
    </div>
</div>

<div class="modal fade" id="modalPerfilPuesto" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow">

            <!-- Header -->
            <div class="modal-header text-white" style="background-color: steelblue; ">
                <h5 class="modal-title">
                    <i class="bi bi-person-badge"></i>
                    Perfil del Puesto: <span id="tituloPuesto"></span>
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" onclick="cerrarModalPerfilPuesto()"></button>
            </div>

            <!-- Body -->
            <div class="modal-body">
                <form id="formPerfilPuesto">

                    <div class="row g-3">
                        <!-- Experiencia -->
                        <div class="col-md-4">
                            <label class="form-label fw-bold">Experiencia mínima (años)</label>
                            <input type="number" class="form-control" id="U_ExperienciaMinima" required>
                            <input type="number" id="U_IdPuesto" class="d-none" />
                            <input type="text" id="U_IdButton" class="d-none" />
                        </div>

                        <!-- Rango edad -->
                        <div class="col-md-4">
                            <label class="form-label fw-bold">Edad mínima</label>
                            <input type="number" class="form-control" id="U_RangoEdadMin" required>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label fw-bold">Edad máxima</label>
                            <input type="number" class="form-control" id="U_RangoEdadMax" required>
                        </div>

                        <!-- Sexo -->
                        <div class="col-md-4">
                            <label class="form-label fw-bold">Sexo</label>
                            <select class="form-select" id="U_Sexo" required>
                                <option value="I">Indistinto</option>
                                <option value="M">Masculino</option>
                                <option value="F">Femenino</option>
                            </select>
                        </div>

                        <!-- Nivel Estudio -->
                        <div class="col-md-8">
                            <label class="form-label fw-bold">Nivel de estudio</label>
                            <select class="form-select" id="U_NivelEstudio" required>
                                <option value="Basico">Básico</option>
                                <option value="Diversificado">Diversificado</option>
                                <option value="Universitario">Universitario</option>
                                <option value="Otro">Otro (Especificar en observaciones)</option>
                            </select>
                        </div>

                        <!-- Salario -->
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Salario mínimo (Q) <span class="text-muted">(Opcional)</span></label>
                            <input type="number" class="form-control" id="U_SalarioMin" step="0.01">
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-bold">Salario máximo (Q) <span class="text-muted">(Opcional)</span></label>
                            <input type="number" class="form-control" id="U_SalarioMax" step="0.01">
                        </div>

                        <!-- Observaciones -->
                        <div class="col-12">
                            <label class="form-label fw-bold">Observaciones</label>
                            <textarea class="form-control" rows="3" id="U_Observaciones" required></textarea>
                        </div>
                    </div>
                </form>
            </div>

            <!-- Footer -->
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal" onclick="cerrarModalPerfilPuesto()">
                    <i class="bi bi-x-circle"></i> Cancelar
                </button>
                <button type="button" class="btn btn-primary" id="btnGuardarPerfil">
                    <i class="bi bi-save"></i> Guardar Perfil
                </button>
            </div>
        </div>
    </div>
</div>
<!-- Modal Seguimiento Solicitudes -->
<div class="modal fade" id="modalSeguimiento" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content modal-seguimiento-modern">

            <!-- Header -->
            <div class="modal-header modal-seguimiento-header">
                <h5 class="modal-title">
                    <i class="bi bi-clock-history me-2"></i> Seguimiento de solicitudes
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <!-- Body -->
            <div class="modal-body">

                <div class="table-responsive">
                    <table class="table align-middle tabla-seguimiento">
                        <thead>
                            <tr>
                                <th style="width:170px;">Fecha de solicitud</th>
                                <th>Posición</th>
                                <th style="width:150px; text-align:center;">Estado</th>
                            </tr>
                        </thead>
                        <tbody id="tablaSeguimiento">
                            <!-- dinámico -->
                        </tbody>
                    </table>
                </div>

            </div>

            <!-- Footer -->
            <div class="modal-footer modal-seguimiento-footer">
                <button class="btn btn-light" data-bs-dismiss="modal">
                    Cerrar
                </button>
            </div>

        </div>
    </div>
</div>


<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

@section Scripts {
    <script>

        const modalPerfil = new bootstrap.Modal(document.getElementById('modalPerfilEmpleado'));
        const modalSolicitud = new bootstrap.Modal(document.getElementById('modalSolicitudBaja'));
        const modalAgregarCorreo = new bootstrap.Modal(document.getElementById('modalAgregarCorreo'));
