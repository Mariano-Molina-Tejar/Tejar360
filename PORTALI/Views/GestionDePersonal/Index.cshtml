        async function subirCarta() {
            let tipoFalta = document.getElementById("cartaTipo").value
            let fechaFalta = document.getElementById("cartaFecha").value
            let documento = document.getElementById("inputCartaFile").files[0]
            let observaciones = document.getElementById("cartaDescripcion").value
            const empId = document.getElementById("perfilEmpId").value

            if (tipoFalta == "" || documento == undefined || observaciones == "" || empId == 0 || fechaFalta == "") {
                Toast.fire({ icon: "warning", title: "Debes llenar todos los campos" })
                return
            }

            const formData = new FormData();
            formData.append("tipoDeFalta", tipoFalta)
            formData.append("fechaDeIncidente", fechaFalta)
            formData.append("carta", documento)
            formData.append("observaciones", observaciones)
            formData.append("empId", empId)

            const response = await fetch('/GestionDePersonal/guardarCartaLlamadaAtencion',
                {
                    method: "POST",
                    body: formData
                });

            const result = await response.json();

            if (result.success) {

                document.getElementById("formNuevaCarta").reset();

                document.getElementById("perfilConteoCartas").innerText = Number(document.getElementById("perfilConteoCartas").textContent) + 1;
                cargarDataCartas();
                Toast.fire({ icon: "success", title: "El archivo se cargo con éxito" })
            }
            else {
                Toast.fire({ icon: "warning", title: "Ocurrio un error al cargar el archivo" })
            }
        }

