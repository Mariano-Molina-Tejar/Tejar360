        async function solicitarNuevaPlaza() {

            const selectPuesto = document.getElementById("selectNuevaPlaza");
            const inputNuevoPuesto = document.getElementById("selectNuevaPlaza");
            const observaciones = document.getElementById("PerfilObservaciones").value;
            const observacionesReclutamiento = document.getElementById("ObsReclutamiento").value;
            console.log(inputNuevoPuesto.value);


            if (observaciones == "" || observacionesReclutamiento == "") {
                Toast.fire({ icon: 'warning', title: "Debes llenar todos los campos" });
                return
            }

            const responseExistePerfil = await fetch(`/GestionDePersonal/VerificarSiExistePerfil?idPuesto=${inputNuevoPuesto.value}`);
            const resultExistePerfil = await responseExistePerfil.json();

            if (!resultExistePerfil.success) {
                Toast.fire({ icon: 'warning', title: "No existe perfil para dicho puesto, por favor comunicarse con GTH" });
                return
            }

            $("#globalLoading").show();
            const data = new FormData();

            try {
                let plaza = selectPuesto.value == -500 ? inputNuevoPuesto.value : selectPuesto.options[selectPuesto.selectedIndex].text
                let nuevo = selectPuesto.value == -500 ? true : false;

                data.append("puesto", plaza);
                data.append("puestoId", selectPuesto.value);
                data.append("observaciones", observaciones);
                data.append("observacionesReclu", observacionesReclutamiento);
                data.append("nuevo", nuevo);

                const response = await fetch('/GestionDePersonal/EnviarSolicitudNuevoPuesto',
                    {
                        method: "POST",
                        body: data
                    }
                )

                const result = await response.json();

                if (result.success) {
                    Toast.fire({ icon: 'success', title: "Se envio la solicitud de nueva plaza con éxito" });

                    inputNuevoPuesto.value = "";
                    selectPuesto.value = "-1";
                    observaciones.value = ""
                    observacionesReclutamiento.value = ""
                    modalNuevaPlaza.hide();
                }
                else {
                    Toast.fire({ icon: 'error', title: "Ocurrio un error al enviar la solicitud" });
                }
            }
            catch (error) {
                Toast.fire({ icon: 'error', title: "Ocurrio un error al enviar la solicitud" });
            }
            finally {
                $("#globalLoading").hide();
            }
        }

        async function verProcesoDeAutorizacion() {

            const response = await fetch('/GestionDePersonal/ObtenerProcesoDeAutorizacion')
            const result = await response.json();
            const container = document.getElementById("tablaSeguimiento");
            if (result.success) {
                body = "";
                color = "";
                estado = "";

                result.data.forEach((item) => {

                    let color = "";
                    let estado = "";

                    switch (item.Estado) {
                        case "A":
                            color = "badge bg-success";
                            estado = "Autorizado";
                            break;
                        case "R":
                            color = "badge bg-danger";
                            estado = "Rechazado";
                            break;
                        case "P":
                            color = "badge bg-warning text-dark";
                            estado = "Pendiente";
                            break;
                        default:
                            color = "badge bg-secondary";
                            estado = "Desconocido";
                            break;
                    }

                    body += `
                                    <tr>
                                        <td>${convertirFechaDotNet(item.FechaDeSolicitud)}</td>
                                        <td>${item.Posicion}</td>
                                        <td class="text-center">
                                            <span class="${color}">${estado}</span>
                                        </td>
                                        <td class="text-truncate" style="max-width: 250px;">
                                            ${item.Observaciones}
                                        </td>
                                    </tr>`;
                });


                container.innerHTML = body;
            }
            else {

            }
        }

