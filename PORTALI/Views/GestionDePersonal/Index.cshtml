        document.getElementById('btnGuardarPerfil').addEventListener('click', () => guardarPerfilDeUsuario());
        document.getElementById('btnGuardar').addEventListener('click', () => solicitarNuevaPlaza());
        document.getElementById('btnProcesoAutorizacion').addEventListener('click', () => verProcesoDeAutorizacion());
