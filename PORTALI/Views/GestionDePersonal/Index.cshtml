<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://code.jquery.com/ui/1.13.2/jquery-ui.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

@section Scripts {
    <script>

        const modalPerfil = new bootstrap.Modal(document.getElementById('modalPerfilEmpleado'));
        const modalSolicitud = new bootstrap.Modal(document.getElementById('modalSolicitudBaja'));
        const modalAgregarCorreo = new bootstrap.Modal(document.getElementById('modalAgregarCorreo'));
        const modalTrackingProceso = new bootstrap.Modal(document.getElementById('modalTrackingProceso'));
        const modalPerfilPuesto = new bootstrap.Modal(document.getElementById('modalPerfilPuesto'));
        const modalSeguimiento = new bootstrap.Modal(document.getElementById('modalSeguimiento'));
        const modalGestionPuesto = new bootstrap.Modal(document.getElementById('modalGestionPuesto'));
        const modalNuevaPlaza = new bootstrap.Modal(document.getElementById('modalNuevaPlaza'));
        const modalVerPdf = new bootstrap.Modal(document.getElementById('modalPDF'));
        const modalTipoSolicitud = new bootstrap.Modal(document.getElementById('modalTipoSolicitud'));
        const modalGestionCartas = new bootstrap.Modal(document.getElementById('modalGestionCartas'));
        const modalNuevaCarta = new bootstrap.Modal(document.getElementById('modalNuevaCarta'));
        const modalSolvenciaJefe = new bootstrap.Modal(document.getElementById('modalSolvenciaJefe'));
        let codigoProcesoBaja = 0;

        const listaCausas = [];

        const Toast = Swal.mixin({
            toast: true,
            position: 'top-end',
            showConfirmButton: false,
            timer: 5000,
            timerProgressBar: true
        })

        function convertirFechaDotNet(fechaDotNet) {
            if (!fechaDotNet) return "";

            const match = /\/Date\((\d+)\)\//.exec(fechaDotNet);
            if (!match) return "";

            // Convierte los milisegundos a fecha
            const fecha = new Date(parseInt(match[1]));

            // Formatea en dd/MM/yyyy
            const dia = fecha.getDate().toString().padStart(2, '0');
            const mes = (fecha.getMonth() + 1).toString().padStart(2, '0');
            const anio = fecha.getFullYear();

            return `${dia}/${mes}/${anio}`;
        }

        function convertirFechaNetSeguro(fechaNet) {
            const partes = fechaNet.split(' ')[0].split('/');
            const mes = partes[0];
            const dia = partes[1];
            const anio = partes[2];

            return `${dia}/${mes}/${anio}`;
        }

        async function obtenerPuestos() {

            const select = document.getElementById("selectNuevaPlaza");
            try {
                const response = await fetch('/GestionDePersonal/ObtenerPuestos', {
                    method: 'GET'
                });

                const reply = await response.json();

                let option = '<option value="-1" disabled selected>--Seleccionar--</option>';

                reply.data.forEach(puesto => {
                    option += `<option value = '${puesto.Id}'>${puesto.Nombre}</option>`;
                });

                select.innerHTML = option;
            } catch (error) {
                Toast.fire({ icon: 'error', title: 'Hubo un error al cargar los puestos, por favor comunicarse al area de Sistemas' });
            }
        }

        async function ObtenerCausasDespido() {
            const select = document.getElementById("contenedorCausas");
            try {
                const response = await fetch('/GestionDePersonal/ObtenerCausasDespido',
                    {
                        method: "GET"
                    });

                const reply = await response.json();

                let button = '';

                reply.data.forEach(causa => {
                    button += `<button id="causa-${causa.Code}" type="button" class="btn btn-outline-secondary btn-sm" data-IdCausa="${causa.Code}" onclick="marcarCausa(this)">${causa.Name}</button>`;
                });

                select.innerHTML = button;
            }
            catch (error) {

            }
        }

        function marcarCausa(button) {
            const idCausa = button.getAttribute("Id");
            const classCausa = button.getAttribute("Class");
            const causasAgregadas = button.getAttribute("data-IdCausa");//

            if (classCausa.includes("buttonMarcado")) {
                document.getElementById(idCausa).classList.remove("buttonMarcado");

                const indice = listaCausas.indexOf(causasAgregadas);

                if (indice !== -1) {
                    listaCausas.splice(indice, 1);
                }
            }
            else {
                document.getElementById(idCausa).classList.add("buttonMarcado");
                listaCausas.push(causasAgregadas);
            }

            console.log(listaCausas);
        }

        async function verPerfil(button) {

            document.getElementById("perfilId").innerText = button.getAttribute("data-id");
            document.getElementById("perfilNombre").innerText = button.getAttribute("data-nombre");
            document.getElementById("perfilPuesto").innerText = button.getAttribute("data-puesto");
            document.getElementById("perfilDepartamento").innerText = button.getAttribute("data-departamento");
            document.getElementById("perfilActivo").innerText = button.getAttribute("data-activo");
            document.getElementById("perfilTelefono").innerText = button.getAttribute("data-telefono");
            document.getElementById("perfilCorreo").innerText = button.getAttribute("data-correo");
            document.getElementById("perfilSexo").innerText = button.getAttribute("data-sexo");
            document.getElementById("perfilCreadoSAP").innerText = button.getAttribute("data-creadoSAP");
            document.getElementById("perfilEmpId").value = button.getAttribute("data-empId");
            document.getElementById("perfilConteoCartas").innerText = button.getAttribute("data-llamadas");

            const verifacion = await VerSolicitudPendiente(button.getAttribute("data-id"));

            if (verifacion === 1) {
                document.getElementById('btn-SolicitaBaja').classList.add('disabled');
                document.getElementById('btn-SolicitaBaja').classList.add('hidden-input')
                document.getElementById('btn-DetalleProceso').classList.remove('hidden-input')
            }
            else {
                document.getElementById('btn-SolicitaBaja').classList.remove('disabled');
                document.getElementById('btn-SolicitaBaja').classList.remove('hidden-input')
                document.getElementById('btn-DetalleProceso').classList.add('hidden-input')
            }

            if (button.getAttribute("data-activo") === 'Y') {
                document.getElementById("perfilActivo").innerHTML =
                    '<i class="bi bi-check-circle-fill text-success"></i> Activo';
            } else if (button.getAttribute("data-activo") === '-') {
                document.getElementById("perfilActivo").innerHTML =
                    '<i class="fas fa-minus-circle text-warning"></i> Pendiente de baja';
            } else {
                document.getElementById("perfilActivo").innerHTML =
                    '<i class="bi bi-x-circle-fill text-danger"></i> Inactivo';
            }

            if (button.getAttribute("data-sexo") === 'M') {
                document.getElementById("perfilSexo").innerHTML =
                    '<i class="bi bi-gender-male text-primary"></i> Masculino';
                document.getElementById('imgPerfil').setAttribute('src', "/Img/PerfilMale.png");
            } else {
                document.getElementById("perfilSexo").innerHTML =
                    '<i class="bi bi-gender-female text-danger"></i> Femenino';
                document.getElementById('imgPerfil').setAttribute('src', "/Img/PerfilFemale.png");
            }

            modalPerfil.show();
        };

        function cerrarModalPerfil() {
            modalPerfil.hide();
        };

        function cerrarModalSolicitud() {
            modalSolicitud.hide();
            document.getElementById('formSolicitudBaja').reset();
            document.getElementById('cartaInput').classList.add("hidden-input");
            document.getElementById('causasInput').classList.add("hidden-input");
            document.getElementById('msg-advertencia').classList.add('hidden-input');
        };

        function verSolicitudBaja() {

            document.getElementById('idEmpleadoSolicitud').value = document.getElementById("perfilId").textContent;
            document.getElementById('nombreEmpleadoSolicitud').value = document.getElementById("perfilNombre").textContent;

            ObtenerCausasDespido()
            cerrarModalPerfil();
            modalSolicitud.show();
        };

        function cambiarInputs() {
            const causas = document.getElementById('causasInput');
            const carta = document.getElementById('cartaInput');
            const motivo = document.getElementById('motivo').value;
            const fecha = document.getElementById('fechaRetiro');

            if (motivo == 1) {
                carta.classList.remove("hidden-input");
                causas.classList.add("hidden-input");
                fecha.value = "";
            }
            else if (motivo == 2) {
                carta.classList.add("hidden-input");
                causas.classList.remove("hidden-input");
                fecha.value = '@DateTime.Now.ToString("yyyy-MM-dd")';
            }
            else {
                carta.classList.add("hidden-input");
                causas.classList.add("hidden-input");
                fecha.value = '@DateTime.Now.ToString("yyyy-MM-dd")';
            }
        };

        async function confimacionDeBaja() {

            const resplyEmail = await verificarCorreo()
            const form = document.getElementById('formSolicitudBaja');
            const observacionesRequisicion = document.getElementById("txtObservacionesPlaza").value
            const checked = document.getElementById("chkRequisicionPersonal").checked;
            if (checked) {
                if (observacionesRequisicion == "") {
                    Toast.fire({ icon: 'warning', title: "Debes llenar el campo de observaciones para la plaza" });
                    return
                }
            }


            if (form.checkValidity()) {

                if (!resplyEmail.success)
                    return modalAgregarCorreo.show();

                try {
                    Swal.fire({
                        title: 'Creando la solicitud...',
                        text: 'Por favor espere',
                        allowOutsideClick: false,
                        didOpen: () => {
                            Swal.showLoading();
                        }
                    });

                    const formData = new FormData();
                    formData.append("id", document.getElementById("idEmpleadoSolicitud").value);
                    formData.append("motivo", document.getElementById("motivo").value);
                    formData.append("observaciones", document.getElementById("observaciones").value);
                    formData.append("carta", document.getElementById("cartaRenuncia").files[0]);
                    formData.append("causas", JSON.stringify(listaCausas));
                    formData.append("nombre", document.getElementById("nombreEmpleadoSolicitud").value);
                    formData.append("motivoCadena", document.getElementById("motivo").options[document.getElementById("motivo").selectedIndex].text);
                    formData.append("solicitarRequisicion", document.getElementById("chkRequisicionPersonal").checked);
                    formData.append("observacionRequisicion", document.getElementById("txtObservacionesPlaza").value);
                    formData.append("FechaRetiro", document.getElementById("FechaRetiro").value);

                    console.log(document.getElementById("chkRequisicionPersonal").checked)

                    const response = await fetch('/GestionDePersonal/EnviarSolicitudDeBaja',
                        {
                            method: "POST",
                            body: formData
                        });

                    if (response.ok) {
                        listaCausas.length = 0;
                        const reply = await response.json();

                        if (reply.successS) {
                            Swal.close();
                            cerrarModalSolicitud();
                            Toast.fire({ icon: 'success', title: "Se creo la solicitud de baja de personal con exito" });
                            setTimeout(() => { location.reload(); }, 5000)
                        }
                        else {
                            Swal.close();
                            Toast.fire({ icon: 'error', title: "Ocurrio un error al crear la solicitud" });
                        }
                    }
                    else {
                        Swal.close();
                        Toast.fire({ icon: 'error', title: "Ocurrio un error al conectarse con el servidor" });
                    }
                }
                catch (error) {
                    Swal.close();
                    Toast.fire({ icon: 'error', title: error });
                }
            } else {
                document.getElementById('msg-advertencia').classList.remove('hidden-input');
            }
        };

        async function VerSolicitudPendiente(id) {
            const response = await fetch(`/GestionDePersonal/VerificarSolicitudBajaPendiente?id=${id}`, {
                method: "GET"
            })

            const reply = await response.json();
            let pendiente = 0;

            if (reply.pendiente)
                pendiente = 1;

            return pendiente;
        }

        async function verificarCorreo() {
            const response = await fetch(`/GestionDePersonal/VerificarExistenciaDeCorreo`, {
                method: "GET"
            })

            const reply = await response.json();

            return reply;
        }

        function cerrarModalCorreo() {
            modalAgregarCorreo.hide();
            document.getElementById('msg-AdvertenciaCorreo').classList.add('hidden-input');

        }

        async function guardarCorreo() {
            const _id = document.getElementById("idEmpleadoSolicitud").value;
            const _email = document.getElementById("correoElectronico").value;
            const form = document.getElementById("formCorreoElectronico");

            if (form.checkValidity()) {

                try {

                    const formData = new FormData();
                    formData.append("idUsuario", _id);
                    formData.append("email", _email);

                    const response = await fetch('/GestionDePersonal/AgregarEmail',
                        {
                            method: "POST",
                            body: formData
                        });

                    const reply = await response.json();

                    if (reply.success) {
                        modalAgregarCorreo.hide();
                        Toast.fire({ icon: 'success', title: "El correo se agrego correctamente" });
                    } else {
                        Toast.fire({ icon: 'error', title: "Ocurrio un error al guardar el correo electronico" });
                    }
                }
                catch (error) {
                    Toast.fire({ icon: 'error', title: "Ocurrio un error al guardar el correo electronico" });
                }
            }
            else {
                document.getElementById('msg-AdvertenciaCorreo').classList.remove('hidden-input');
            }

        }

        async function verProcesoBaja() {
            const empId = document.getElementById("perfilEmpId").value;

            const response = await fetch(`/GestionDePersonal/ObtenerTrackingDeBaja?empId=${empId}`)
            const result = await response.json();

            const responseCarta = await fetch(`/GestionDePersonal/VerExistenciaDeDocumento?solicitud=${codigoProcesoBaja}&id=${empId}&carta=CartaDespido`)
            const resultCarta = await responseCarta.json();

            if (result.success) {
                codigoProcesoBaja = result.data.Code;

                console.log(result.data.Motivo);
                if (result.data.Motivo == 1) {
                    document.getElementById("TrackingCartaMostrarColor").classList.add("d-none");
                    document.getElementById("TrackingCartaColor").classList.add("d-none")
                    document.getElementById("TrackingCartaRenunciaColor").classList.remove("d-none")
                }
                else if (result.data.Motivo == 2) {

                    if (resultCarta.success) {
                        document.getElementById("TrackingCartaMostrarColor").classList.remove("d-none");
                        document.getElementById("TrackingCartaColor").classList.add("d-none")
                    }
                    else {
                        document.getElementById("TrackingCartaMostrarColor").classList.add("d-none");
                        document.getElementById("TrackingCartaColor").classList.remove("d-none")
                    }
                    document.getElementById("TrackingCartaRenunciaColor").classList.add("d-none")
                }
                else {
                    document.getElementById("TrackingCartaColor").classList.add("d-none")
                    document.getElementById("TrackingCartaRenunciaColor").classList.add("d-none")
                    document.getElementById("TrackingCartaMostrarColor").classList.add("d-none");

                }
                //Agregar comentarios
                document.getElementById("TrackingAutorizadoGTHComentario").textContent = result.data.ComentarioAutorizadoGTH ?? "Pendiente de autorizacion..."
                document.getElementById("TrackingAutorizadoGTHAutoriza").textContent = result.data.ComentaAutorizadoGTH ?? ""
                document.getElementById("TrackingAutorizadoGTHFechaYHora").textContent = result.data.FechaYHoraAutorizadoGTH ?? ""



                if (result.data.Pendiente) {
                    document.getElementById("TrackingPendienteColor").classList.add("completed");
                    document.getElementById("TrackingPendienteIcono").classList.add("bi-check-circle-fill");
                    document.getElementById("TrackingPendienteIcono").classList.remove("bi-circle");
                }
                else {
                    document.getElementById("TrackingPendienteColor").classList.remove("completed");
                    document.getElementById("TrackingPendienteIcono").classList.remove("bi-check-circle-fill");
                    document.getElementById("TrackingPendienteIcono").classList.add("bi-circle");
                }

                if (result.data.AutorizadoGTH) {
                    document.getElementById("TrackingAutorizadoGTHColor").classList.add("completed");
                    document.getElementById("TrackingAutorizadoGTHIcono").classList.add("bi-check-circle-fill");
