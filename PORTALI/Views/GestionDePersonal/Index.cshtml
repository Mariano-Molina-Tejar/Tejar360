@using Entity;
@model IEnumerable<DatosEmpleados>
@{
    ViewData["Title"] = "Gestión de Personal";
}

<head>
    <style>

        /* Contenedor de opciones */
        .selection-card {
            cursor: pointer;
            transition: all 0.3s ease;
            border: 2px solid #f0f2f5;
            border-radius: 12px;
            padding: 1.5rem;
            height: 100%;
            display: flex;
            flex-direction: column;
            align-items: center;
            text-align: center;
            background: #fff;
        }

            /* Efecto Hover */
            .selection-card:hover {
                border-color: #4682b4;
                transform: translateY(-5px);
                box-shadow: 0 10px 20px rgba(0,0,0,0.08);
            }

                .selection-card:hover .icon-box {
                    background-color: #4682b4;
                    color: #fff;
                }

        /* Caja de icono */
        .icon-box {
            width: 60px;
            height: 60px;
            background-color: #f8f9fa;
            color: #4682b4;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.8rem;
            margin-bottom: 1rem;
            transition: all 0.3s ease;
        }

        .selection-title {
            font-weight: 700;
            color: #333;
            margin-bottom: 0.5rem;
        }

        .selection-desc {
            font-size: 0.9rem;
            color: #6c757d;
            line-height: 1.4;
        }

        <style >
        .modal-plaza-modern {
            border: none;
            border-radius: 16px;
            box-shadow: 0 15px 35px rgba(0,0,0,0.2);
        }

        .modal-plaza-header {
            background-color: #ffffff; /* Fondo blanco para limpieza */
            border-bottom: 1px solid #f0f0f0;
            padding: 1.5rem;
            border-radius: 16px 16px 0 0;
        }

            .modal-plaza-header .modal-title {
                color: #333;
                font-weight: 700;
                font-size: 1.25rem;
            }

            /* Icono sutil al lado del título */
            .modal-plaza-header .bi-person-fill-add {
                color: #4682b4; /* El SteelBlue que te gustó */
            }

        .form-group-modern {
            margin-bottom: 1.5rem;
        }

            .form-group-modern .form-label {
                font-weight: 600;
                color: #555;
                font-size: 0.9rem;
                margin-bottom: 8px;
                display: block;
            }

        /* Mejora del Select y Textarea */
        .plaza-form .form-select,
        .plaza-form .form-control {
            border: 1px solid #e0e0e0;
            border-radius: 10px;
            padding: 12px;
            background-color: #f9f9f9;
            transition: all 0.3s ease;
        }

            .plaza-form .form-select:focus,
            .plaza-form .form-control:focus {
                background-color: #fff;
                border-color: #4682b4;
                box-shadow: 0 0 0 4px rgba(70, 130, 180, 0.1);
                outline: none;
            }

        .modal-plaza-footer {
            border-top: none;
            padding: 1.5rem;
            display: flex;
            gap: 10px;
        }

        /* Botones con estilo */
        .btn-save-plaza {
            background: #4682b4;
            border: none;
            border-radius: 10px;
            padding: 10px 20px;
            font-weight: 600;
            flex: 1; /* Hace que el botón crezca */
        }

        .btn-cancel-plaza {
            background: #f8f9fa;
            color: #666;
            border: 1px solid #ddd;
            border-radius: 10px;
            padding: 10px 20px;
            font-weight: 600;
        }
        /* Estilo para los pies de página de los inputs (small) */
        .form-group-modern small {
            display: block;
            margin-top: 5px;
            color: #888 !important;
            font-style: italic;
        }

        /* Asegura que el modal-header no tenga bordes feos */
        .modal-plaza-header {
            border-bottom: none;
            border-radius: 15px 15px 0 0 !important;
        }

        /* Efecto suave al pasar el mouse por los textareas */
        .plaza-form .form-control:hover {
            border-color: #adb5bd;
        }
        /* Header elegante */
        .header-perfil {
            background: linear-gradient(45deg, #4682b4, #5a9bd5);
            padding: 1.5rem;
            border-top-left-radius: 12px;
            border-top-right-radius: 12px;
        }

        .perfil-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 8px 0;
        }

            /* Estilo para que el botón de gestión no rompa la estética moderna */
            .perfil-row .btn-outline-danger:hover {
                background-color: #fff5f5;
                color: #dc3545;
            }

        .bg-danger-subtle {
            background-color: #f8d7da; /* Un rojo muy clarito para el fondo del número */
        }

        .perfil-row {
            min-height: 40px; /* Asegura que la fila tenga espacio suficiente */
        }

        #listaCartas .list-group-item {
            transition: all 0.2s ease;
            border-left: 4px solid transparent;
        }

            #listaCartas .list-group-item:hover {
                background-color: #fcfcfc;
                border-left: 4px solid #dc3545; /* Rojo para denotar advertencia */
            }

        #listaCartas::-webkit-scrollbar {
            width: 5px;
        }

        #listaCartas::-webkit-scrollbar-thumb {
            background: #e0e0e0;
            border-radius: 10px;
        }
        /* CONTENEDOR */
        .modal-solvencia {
            border-radius: 20px;
            border: none;
            overflow: hidden;
            box-shadow: 0 25px 60px rgba(0,0,0,.25);
            font-family: 'Segoe UI', sans-serif;
        }

        /* HEADER */
        .modal-solvencia-header {
            position: relative;
            padding: 20px 30px;
            background: linear-gradient(135deg, #4f8cff, #3f6ad8);
            color: #fff;
        }

            .modal-solvencia-header h5 {
                margin: 0;
                font-weight: 600;
            }

            .modal-solvencia-header span {
                font-size: 13px;
                opacity: .9;
            }

        .btn-close-solvencia {
            position: absolute;
            right: 20px;
            top: 15px;
            background: transparent;
            border: none;
            font-size: 26px;
            color: #fff;
            cursor: pointer;
        }

        /* BODY */
        .modal-solvencia-body {
            padding: 25px 30px;
            background: #f8faff;
        }

        /* ITEM */
        .solvencia-item {
            background: #fff;
            border-radius: 16px;
            padding: 18px 20px;
            margin-bottom: 18px;
            box-shadow: 0 10px 25px rgba(0,0,0,.08);
        }

        .solvencia-label {
            font-weight: 600;
            margin-bottom: 12px;
            color: #2c3e50;
        }

        /* OPCIONES */
        .solvencia-options {
            display: flex;
            gap: 12px;
        }

            .solvencia-options label {
                cursor: pointer;
            }

            .solvencia-options input {
                display: none;
            }

            .solvencia-options span {
                padding: 8px 18px;
                border-radius: 999px;
                background: #eef2ff;
                color: #3f6ad8;
                font-weight: 500;
                transition: all .25s ease;
            }

            .solvencia-options input:checked + span {
                background: linear-gradient(135deg, #4f8cff, #3f6ad8);
                color: #fff;
                box-shadow: 0 8px 18px rgba(79,140,255,.45);
            }

        /* TEXTAREA */
        .solvencia-textarea {
            width: 100%;
            min-height: 90px;
            border-radius: 14px;
            border: 1px solid #dbe3ff;
            padding: 12px;
            resize: none;
        }

        /* FOOTER DATA */
        .solvencia-footer-data {
            display: flex;
            gap: 15px;
        }

            .solvencia-footer-data input {
                flex: 1;
                border-radius: 14px;
                border: 1px solid #dbe3ff;
                padding: 10px 12px;
            }

        /* FOOTER */
        .modal-solvencia-footer {
            padding: 18px 30px;
            display: flex;
            justify-content: flex-end;
            gap: 12px;
            background: #fff;
        }

        .btn-cancel {
            background: #e0e6f5;
            border: none;
            padding: 10px 20px;
            border-radius: 999px;
            font-weight: 500;
        }

        .btn-save {
            background: linear-gradient(135deg, #4f8cff, #3f6ad8);
            color: #fff;
            border: none;
            padding: 10px 26px;
            border-radius: 999px;
            font-weight: 600;
        }
    </style>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="stylesheet" href="~/Css/GestionDePersonal/styleProceso.css">
    <link rel="stylesheet" href="~/Css/GestionDePersonal/style.css">

</head>
<div class="container mt-4">
    <div class="card shadow-sm border-0 rounded-4">

        <!-- HEADER -->
        <div class="card-header d-flex justify-content-between align-items-center px-4"
             style="background: linear-gradient(135deg, #3a7bd5, #3a6073); color:white;">
            <h5 class="mb-0 fw-semibold">
                <i class="bi bi-people-fill me-2"></i> Gestión de Personal
            </h5>

            <div class="d-flex gap-2">
                <button class="btn btn-light btn-sm" id="btnProcesoAutorizacion"
                        data-bs-toggle="modal" data-bs-target="#modalSeguimiento">
                    <i class="bi bi-clipboard-check me-1"></i> Proceso
                </button>

                <button class="btn btn-light btn-sm" id="btnNuevaPlaza"
                        @*data-bs-toggle="modal" data-bs-target="#modalTipoSolicitud">*@
                        onclick="modalTipoSolicitud.show()">
                    <i class="bi bi-person-plus-fill me-1"></i> Nueva plaza
                </button>
            </div>
        </div>

        <!-- BODY -->
        <div class="card-body bg-light">
            @if (ViewData["Error"] != null)
            {
                <div class="alert alert-danger d-flex align-items-center" role="alert" id="divError">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    <span id="msgError">@ViewData["Error"]</span>
                </div>
            }

            <table class="table align-middle text-center tabla-personal">

                <thead>
                    <tr>
                        <th>Código</th>
                        <th class="text-start">Nombres</th>
                        <th class="text-start">Puesto</th>
                        <th>Creado SAP</th>
                        <th>Estado</th>
                        <th>Acción</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var empleados in Model)
                        {
                            <tr>
                                <td>@empleados.EmpID</td>

                                <td class="text-start fw-medium">
                                    @empleados.Nombre
                                </td>

                                <td class="text-start">
                                    <div class="d-flex align-items-center justify-content-between">
                                        <span>@empleados.Puesto</span>

                                        <button id="btnPerfil-@(empleados.EmpID)"
                                                class="btn btn-sm rounded-circle @(empleados.Perfil ? "btn-outline-success" : "btn-outline-danger")"
                                                data-bs-toggle="tooltip"
                                                title="@(empleados.Perfil ? "Ver perfil" : "Agregar perfil")"
                                                onclick="abrirModalPerfilPuesto('@empleados.Puesto',@empleados.PuestoId, @empleados.Perfil.ToString().ToLower(),'btnPerfil-@(empleados.EmpID)')">
                                            <i id="ibtnPerfil-@(empleados.EmpID)"
                                               class="bi bi-file-earmark-text"></i>
                                        </button>
                                    </div>
                                </td>

                                <td>@empleados.CreadoSAP.ToString("dd/MM/yyyy")</td>

                                <td>
                                    <span class="badge bg-success @(empleados.Activo == "Y" ? "" : "d-none")">Activo</span>
                                    <span class="badge bg-danger @(empleados.Activo == "N" ? "" : "d-none")">Inactivo</span>
                                    <span class="badge bg-warning text-dark @(empleados.Activo == "-" ? "" : "d-none")">Pendiente</span>
                                </td>

                                <td class="d-flex justify-content-end">

                                    @if (empleados.EstadoSolicitudDeBaja == 1)
                                    {
                                        <button class="btn btn-sm btn-outline-primary rounded-pill px-3 me-1"
                                                onclick="verSolvenciaAdministrativa('@empleados.EmpID')">
                                            <i class="bi bi-clipboard-check me-1"></i>
                                            Solvencia
                                        </button>
                                    }
                                    <button class="btn btn-sm btn-outline-primary rounded-pill px-3"
                                            onclick="verPerfil(this)"
                                            data-nombre="@empleados.Nombre"
                                            data-id="@empleados.EmpID"
                                            data-puesto="@empleados.Puesto"
                                            data-departamento="@empleados.Departamento"
                                            data-activo="@empleados.Activo"
                                            data-telefono="@empleados.Telefono"
                                            data-correo="@empleados.Correo"
                                            data-sexo="@empleados.Sexo"
                                            data-empId="@empleados.EmpID"
                                            data-llamadas="@empleados.LlamadasAtencion"
                                            data-creadoSAP="@empleados.CreadoSAP.ToString("dd/MM/yyyy")">
                                        <i class="bi bi-person-vcard me-1"></i> Perfil
                                    </button>

                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4">
                                <i class="bi bi-info-circle"></i> No se encontraron datos
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

        </div>
    </div>

</div>

<div class="modal fade" id="modalNuevaPlaza" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content modal-plaza-modern">

            <div class="modal-header modal-plaza-header" style="background-color: #4682b4;">
                <h5 class="modal-title d-flex align-items-center" style="color:white">
                    <i class="bi bi-person-plus-fill me-2 fs-4"></i>
                    Registrar Nueva Plaza
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" onclick="modalNuevaPlaza.hide()"></button>
            </div>

            <div class="modal-body p-4">
                <form id="formNuevaPlaza" class="plaza-form">

                    @*<div class="form-group-modern mb-3">
                            <label class="form-label">
                                <i class="bi bi-briefcase-fill me-1 text-primary"></i> Seleccione el Puesto
                            </label>
                            <select class="form-select shadow-sm" id="selectNuevaPlaza">
                            </select>
                        </div>*@
                    <div class="form-group-modern mb-3">
                        <label class="form-label">
                            <i class="bi bi-briefcase me-1"></i> Seleccione el Puesto
                        </label>
                        <div class="input-group">
                            <select class="form-select shadow-sm" id="selectNuevaPlaza">
                                <option value="">Seleccione un puesto...</option>
                            </select>
                            <button class="btn btn-outline-primary btn-ver-perfil" type="button" id="btnVerPerfilSeleccionado" title="Ver detalles del perfil">
                                <i class="bi bi-eye-fill"></i>
                            </button>
                        </div>
                        <small class="text-muted mt-1 d-block" style="font-size: 0.75rem;">
                            Haga clic en el icono para ver los requisitos de este puesto.
                        </small>
                    </div>

                    <div class="form-group-modern mb-3">
                        <label class="form-label">
                            <i class="bi bi-search me-1 text-primary"></i> Notas para Reclutamiento *
                        </label>
                        <textarea id="ObsReclutamiento"
                                  class="form-control shadow-sm"
                                  rows="3"
                                  placeholder="Ej: Urge cubrir, competencias deseadas, fuentes de reclutamiento..."
                                  required></textarea>
                        <small class="text-muted" style="font-size: 0.75rem;">Estas notas ayudan al equipo de selección.</small>
                    </div>

                    <div class="form-group-modern mb-0">
                        <label class="form-label">
                            <i class="bi bi-shield-check me-1 text-primary"></i> Justificación para Autorización *
                        </label>
                        <textarea id="PerfilObservaciones"
                                  class="form-control shadow-sm"
                                  rows="3"
                                  placeholder="Indique el motivo de la vacante (sustitución, crecimiento, etc.)"
                                  required></textarea>
                        <small class="text-muted" style="font-size: 0.75rem;">Este texto será revisado por la gerencia.</small>
                    </div>

                </form>
            </div>

            <div class="modal-footer modal-plaza-footer bg-light-subtle border-0">
                <button type="button" class="btn btn-cancel-plaza" data-bs-dismiss="modal" onclick="modalNuevaPlaza.hide()">
                    Descartar
                </button>
                <button type="button" class="btn btn-primary btn-save-plaza" id="btnGuardar">
                    <i class="bi bi-check-circle-fill me-2"></i>
                    Enviar Solicitud
                </button>
            </div>

        </div>
    </div>
</div>

<div class="modal fade" id="modalPerfilEmpleado" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content perfil-modern">

            <!-- Header -->
            <div class="modal-header perfil-modern-header">
                <h5 class="modal-title">
                    <i class="bi bi-person-circle me-2"></i> Perfil del Empleado
                </h5>
                <button onclick="cerrarModalPerfil()"
                        type="button"
                        class="btn-close">
                </button>
            </div>

            <!-- Body -->
            <div class="modal-body">
                <div class="row g-4 align-items-center">

                    <!-- Perfil -->
                    <div class="col-md-4 text-center perfil-modern-side">
                        <img id="imgPerfil"
                             src="~/Img/PerfilMale.png"
                             class="perfil-avatar"
                             alt="Foto empleado">

                        <h5 id="perfilNombre" class="mt-3 mb-1 fw-semibold"></h5>
                        <input class="d-none" id="perfilEmpId" />

                        <span id="perfilActivo" class="badge badge-status mb-1"></span><br>
                        <span id="perfilSexo" class="text-muted small"></span>
                        <span id="perfilId" hidden></span>
                    </div>

                    <!-- Datos -->
                    <div class="col-md-8">
                        <div class="perfil-data">
                            <div class="perfil-row">
                                <span>Puesto</span>
                                <strong id="perfilPuesto"></strong>
                            </div>
                            <div class="perfil-row">
                                <span>Departamento</span>
                                <strong id="perfilDepartamento"></strong>
                            </div>
                            <div class="perfil-row">
                                <span>Registro SAP</span>
                                <strong id="perfilCreadoSAP"></strong>
                            </div>
                            <div class="perfil-row">
                                <span>Correo</span>
                                <strong id="perfilCorreo"></strong>
                            </div>
                            <div class="perfil-row">
                                <span>Teléfono</span>
                                <strong id="perfilTelefono"></strong>
                            </div>

                            <div class="perfil-row border-top mt-2 pt-2 d-flex justify-content-between align-items-center">
                                <span class="text-muted">Llamadas de Atención</span>
                                <div class="d-flex align-items-center gap-2">
                                    <span id="perfilConteoCartas" class="badge rounded-pill bg-danger-subtle text-danger px-2">0</span>
                                    <button type="button"
                                            class="btn btn-sm btn-link text-danger p-0 text-decoration-none fw-bold"
                                            onclick="gestionarCartas()"
                                            style="font-size: 0.85rem;">
                                        <i class="bi bi-pencil-square"></i> Gestionar
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>
            </div>

            <!-- Footer -->
            <div class="modal-footer perfil-modern-footer">
                <button onclick="cerrarModalPerfil()"
                        type="button"
                        class="btn btn-light">
                    Cerrar
                </button>

                <div class="d-flex gap-2">
                    <button id="btn-DetalleProceso"
                            class="btn btn-warning hidden-input"
                            onclick="verProcesoBaja()">
                        Ver Proceso
                    </button>

                    <button id="btn-SolicitaBaja"
                            class="btn btn-dark btn-sm hidden-input"
                            onclick="verSolicitudBaja()">
                        Solicitar Baja
                    </button>
                </div>
            </div>

        </div>
    </div>
</div>


<!-- Modal -->
<div class="modal fade" id="modalSolicitudBaja" tabindex="-1" aria-labelledby="modalSolicitudBajaLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-2">

            <!-- Encabezado -->
            <div class="modal-header  text-white" style="background-color:darkred">
                <h5 class="modal-title fw-semibold" id="modalSolicitudBajaLabel">
                    <i class="bi bi-person-x-fill me-2"></i> Solicitud de baja
                </h5>
                <button type="button" class="btn-close btn-close-white" aria-label="Cerrar" onclick="cerrarModalSolicitud()"></button>
            </div>

            <!-- Cuerpo -->
            <div class="modal-body px-4">
                <form id="formSolicitudBaja" class="row g-3">
                    <div class="alert alert-info d-flex align-items-center" role="alert">
                        <i class="bi bi-info-circle-fill me-2"></i>
                        Los campos marcados con un <span class="text-danger fw-bold"> * </span> son obligatorios.
                    </div>

                    <!-- Id y nombre -->
                    <div class="col-md-6">
                        <label for="idEmpleadoSolicitud" class="form-label">Id Empleado</label>
                        <input type="text" id="idEmpleadoSolicitud" class="form-control" readonly>
                    </div>
                    <div class="col-md-6">
                        <label for="nombreEmpleadoSolicitud" class="form-label">Nombre</label>
                        <input type="text" id="nombreEmpleadoSolicitud" class="form-control" readonly>
                    </div>

                    <!-- Motivo -->
                    <div class="col-md-6">
                        <label for="motivo" class="form-label">Motivo <span class="text-danger fw-bold">*</span></label>
                        <select id="motivo" class="form-control" required>
                            <option value="">-Seleccione un motivo-</option>
                            <option value="1">Renuncia</option>
                            <option value="2">Despido</option>
                            <option value="3">Abandono</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label for="fechaRetiro" class="form-label">
                            Fecha de retiro <span class="text-danger fw-bold">*</span>
                        </label>
                        <input type="date"
                               id="fechaRetiro"
                               class="form-control"
                               required>
                    </div>
                    <!-- Causas -->
                    <div class="col-md-6 mt-3 hidden-input" id="causasInput">
                        <label class="form-label">Causas</label>
                        <div class="border rounded-3 p-3">
                            <div class="d-flex flex-wrap gap-2" id="contenedorCausas">
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6 hidden-input" id="cartaInput">
                        <label for="cartaRenuncia" class="form-label">Carta de renuncia</label>
                        <input type="file" class="form-control" id="cartaRenuncia" name="cartaRenuncia" accept=".pdf">
                    </div>

                    <!-- Observaciones -->
                    <div class="col-12">
                        <label for="observaciones" class="form-label">Observaciones <span class="text-danger fw-bold">*</span></label>
                        <textarea id="observaciones" class="form-control" rows="3" placeholder="Ingrese observaciones adicionales..." required></textarea>
                    </div>
