@using Entity;
@model AutorizacionesGTHViewModel
@{
    ViewData["Title"] = "Gestión de Personal";
}

<head>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <link href="~/Css/GestionDePersonal/styleProceso.css" rel="stylesheet">
    <style>
    </style>
</head>
<div class="container mt-4">
    <!-- NAV TABS -->
    <ul class="nav nav-tabs nav-tabs-modern mb-3" id="myTab" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active"
                    id="solicitudes-tab"
                    data-bs-toggle="tab"
                    data-bs-target="#solicitudes"
                    type="button"
                    role="tab">
                <i class="bi bi-inbox me-1"></i> Solicitudes
            </button>
        </li> 

        <li class="nav-item" role="presentation">
            <button class="nav-link"
                    id="procesos-tab"
                    data-bs-toggle="tab"
                    data-bs-target="#procesos"
                    type="button"
                    role="tab">
                <i class="bi bi-diagram-3 me-1"></i> Procesos
            </button>
        </li>
    </ul>

    <!-- TAB CONTENT -->
    <div class="tab-content" id="myTabContent">

        <!-- TAB SOLICITUDES -->
        <div class="tab-pane fade show active" id="solicitudes" role="tabpanel">

            <div class="card card-dashboard">
                <div class="card-header card-dashboard-header">
                    <h5 class="mb-0">
                        <i class="bi bi-people-fill me-2"></i> Solicitudes de baja de personal
                    </h5>
                </div>

                <div class="card-body bg-light">
                    <table class="table align-middle text-center tabla-dashboard">
                        <thead>
                            <tr>
                                <th>No.</th>
                                <th>Fecha</th>
                                <th>Nombre</th>
                                <th>Puesto</th>
                                <th>Departamento</th>
                                <th>Solicita</th>
                                <th>Motivo</th>
                                <th>Estado</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>

                        <tbody>
                            @if (Model.Autorizaciones != null && Model.Autorizaciones.Any())
                            {
                                foreach (var autorizacion in Model.Autorizaciones)
                                {
                                    <tr>
                                        <td>@autorizacion.Code</td>
                                        <td>@autorizacion.FechaSolicitud.ToString("dd-MM-yyyy")</td>
                                        <td>@autorizacion.Nombre</td>
                                        <td>@autorizacion.Puesto</td>
                                        <td>@autorizacion.Departamento</td>
                                        <td>@autorizacion.Solicita</td>
                                        <td>@autorizacion.Motivo</td>

                                        <td>
                                            @switch (autorizacion.Estado)
                                            {
                                                case 0:
                                                    <span class="badge bg-warning text-dark">Pendiente</span>
                                                    break;
                                                case 1:
                                                    <span class="badge bg-success">Autorizado</span>
                                                    break;
                                                case -1:
                                                    <span class="badge bg-danger">Rechazado</span>
                                                    break;
                                            }
                                        </td>

                                        <td>
                                            <div class="d-flex justify-content-center gap-2">
                                                @if (autorizacion.Estado == 0)
                                                {
                                                    <button class="btn btn-sm btn-outline-danger rounded-circle"
                                                            onclick="rechazar(@autorizacion.Code)">
                                                        <i class="bi bi-x"></i>
                                                    </button>

                                                    <button class="btn btn-sm btn-outline-success rounded-circle"
                                                            onclick="autorizar(@autorizacion.Code)">
                                                        <i class="bi bi-check"></i>
                                                    </button>
                                                }

                                                <button class="btn btn-sm btn-outline-primary rounded-circle"
                                                        onclick="verDetalle(@autorizacion.Code)">
                                                    <i class="bi bi-eye"></i>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="9" class="text-center text-muted py-4">
                                        <i class="bi bi-info-circle"></i> No se encontraron solicitudes
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

        </div>

        <!-- TAB PROCESOS -->
        <div class="tab-pane fade" id="procesos" role="tabpanel">

            <div class="card card-dashboard">
                <div class="card-header card-dashboard-header">
                    <h5 class="mb-0">
                        <i class="bi bi-people-fill me-2"></i> Procesos de baja de personal
                    </h5>
                </div>

                <div class="card-body bg-light">
                    <table class="table align-middle text-center tabla-dashboard">
                        <thead>
                            <tr>
                                <th>No.</th>
                                <th>Fecha</th>
                                <th>Nombre</th>
                                <th>Puesto</th>
                                <th>Departamento</th>
                                <th>Solicita</th>
                                <th>Motivo</th>
                                <th>Estado</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>

                        <tbody>
                            @if (Model.Procesos != null && Model.Procesos.Any())
                            {
                                foreach (var proceso in Model.Procesos)
                                {
                                    <tr>
                                        <td>@proceso.Code</td>
                                        <td>@proceso.FechaSolicitud.ToString("dd-MM-yyyy")</td>
                                        <td>@proceso.Nombre</td>
                                        <td>@proceso.Puesto</td>
                                        <td>@proceso.Departamento</td>
                                        <td>@proceso.Solicita</td>
                                        <td>@proceso.Motivo</td>

                                        <td>
                                            <span class="badge bg-info">En proceso</span>
                                        </td>

                                        <td>
                                            <div class="d-flex justify-content-center gap-2">
                                                <button class="btn btn-sm btn-outline-primary rounded-circle"
                                                        onclick="verDetalleProceso(@proceso.Code)">
                                                    <i class="bi bi-eye"></i>
                                                </button>

                                                <button class="btn btn-sm btn-outline-secondary rounded-circle"
                                                        onclick="verProcesoBaja(@proceso.Code)">
                                                    <i class="bi bi-repeat"></i>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="9" class="text-center text-muted py-4">
                                        <i class="bi bi-info-circle"></i> No se encontraron procesos
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

        </div>
    </div>

</div>
<!-- Modal Detalle Empleado -->
<div class="modal fade" id="detalleModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content modal-detalle-modern">

            <!-- HEADER -->
            <div class="modal-header modal-detalle-header">
                <div class="d-flex align-items-center gap-2">
                    <h5 class="modal-title mb-0">
                        <i class="bi bi-person-vcard me-2"></i> Detalle de Solicitud
                    </h5>
                    <span id="estadoDetalle" class="badge badge-detalle"></span>
                </div>

                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal">
                </button>
            </div>

            <!-- BODY -->
            <div class="modal-body">

                <!-- CARD INFO -->
                <div class="detalle-card">
                    <div class="row g-3">

                        <div class="col-md-6">
                            <span class="detalle-label">Empleado ID</span>
                            <p id="detEmpleadoId" class="detalle-value"></p>
                        </div>

                        <div class="col-md-6">
                            <span class="detalle-label">Nombre</span>
                            <p id="detNombre" class="detalle-value"></p>
                        </div>

                        <div class="col-md-6">
                            <span class="detalle-label">Puesto</span>
                            <p id="detPuesto" class="detalle-value"></p>
                        </div>

                        <div class="col-md-6">
                            <span class="detalle-label">Departamento</span>
                            <p id="detDepartamento" class="detalle-value"></p>
                        </div>

                        <div class="col-md-6">
                            <span class="detalle-label">Solicita</span>
                            <p id="detSolicita" class="detalle-value"></p>
                        </div>

                        <div class="col-md-6">
                            <span class="detalle-label">Motivo</span>
                            <p id="detMotivo" class="detalle-value"></p>
                        </div>

                    </div>
                </div>

                <!-- CAUSAS -->
                <div id="div-Causas" class="detalle-section hidden-input">
                    <span class="detalle-label">Causas</span>
                    <div id="detCausas" class="detalle-value"></div>
                </div>

                <!-- CARTA -->
                <div id="div-Carta" class="detalle-section hidden-input">
                    <span class="detalle-label">Carta de renuncia</span>
                    <div id="detCartaRenuncia" class="detalle-value"></div>
                </div>

                <!-- OBSERVACIONES -->
                <div class="detalle-section">
                    <span class="detalle-label">Observaciones</span>
                    <p id="detObservaciones" class="detalle-value"></p>
                </div>

            </div>

            <!-- FOOTER -->
            <div class="modal-footer modal-detalle-footer">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">
                    Cerrar
                </button>

                <button id="btn-DetalleProceso"
                        type="button"
                        class="btn btn-warning hidden-input"
                        onclick="verProcesoBaja()">
                    <i class="bi bi-arrow-repeat me-1"></i> Ver Proceso
                </button>
            </div>

        </div>
    </div>
</div>

<div class="modal fade" id="modalPDF" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered modal-pdf-dialog">
        <div class="modal-content modal-pdf-modern">

            <!-- HEADER -->
            <div class="modal-header modal-pdf-header">
                <h5 class="modal-title">
                    <i class="bi bi-file-earmark-pdf me-2"></i> Vista del Documento
                </h5>

                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal"
                        aria-label="Cerrar">
                </button>
            </div>

            <!-- BODY -->
            <div class="modal-body modal-pdf-body">
                <iframe id="visorPDF"
                        src=""
                        class="visor-pdf"
                        loading="lazy">
                </iframe>
            </div>

        </div>
    </div>
</div>

<!-- Modal Seguimiento de Proceso -->
<div class="modal fade" id="modalTrackingProceso" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl  modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">

            <!-- Header -->
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title">
                    <i class="bi bi-arrow-repeat me-2"></i> Seguimiento del Proceso de Baja
                </h5>
                <button type="button"
                        class="btn-close btn-close-white"
                        data-bs-dismiss="modal"
                        onclick="cerrarModalTrackinDeBaja()">
                </button>
            </div>

            <!-- Body -->
            <div class="modal-body px-5">
                <div class="timeline">

                    <!-- Estado 0 -->
                    <div id="TrackingPendienteColor" class="timeline-item completed">
                        <div class="timeline-icon"><i id="TrackingPendienteIcono" class="bi bi-check-circle-fill"></i></div>
                        <div class="timeline-content">Pendiente</div>
                    </div>

                    <!-- Estado 1 -->
                    <div id="TrackingAutorizadoGTHColor" class="timeline-item completed">
                        <div class="timeline-icon"><i id="TrackingAutorizadoGTHIcono" class="bi bi-check-circle-fill"></i></div>
                        <div class="timeline-content">Autorizado por GTH</div>
                    </div>

                    <!-- Estado 2 - CARTA -->
                    <div id="TrackingCartaColor" class="timeline-item completed">
                        <div class="timeline-icon">
                            <i id="TrackingCartaIcono" class="bi bi-check-circle-fill"></i>
                        </div>
                        <div class="timeline-content ">
                            Carta de despido | Renuncia

                            <div id="btnCargarCarta" class="mt-3">
                                <button class="btn btn-outline-primary btn-sm"
                                        onclick="emitirCartaDespido()">
                                    <i class="bi bi-file-earmark-plus"></i> Cargar carta
                                </button>
                            </div>
                        </div>
                    </div>
                    <!-- Estado 5 -->
                    <div id="TrackingUsuariosOperativosColor" class="timeline-item">
                        <div class="timeline-icon"><i id="TrackingUsuariosOperativosIcono" class="bi bi-circle"></i></div>
                        <div class="timeline-content">Bloqueo de usuarios operativos</div>
                    </div>

                    <!-- Estado 4 -->
                    <div id="TrackingSolvenciaColor" class="timeline-item">
                        <div class="timeline-icon"><i id="TrackingSolvenciaIcono" class="bi bi-circle"></i></div>
                        <div class="timeline-content">Emisión de solvencia administrativa</div>
                    </div>


                    <!-- Estado 6 -->
                    <div id="TrackingConfirmacionPagoColor" class="timeline-item">
                        <div class="timeline-icon"><i id="TrackingConfirmacionPagoIcono" class="bi bi-circle"></i></div>
                        <div class="timeline-content">Confirmación de emisión de pago</div>
                    </div>

                    <!-- Estado 7 -->
                    <div id="TrackingCargaLiquidacionColor" class="timeline-item">
                        <div class="timeline-icon"><i id="TrackingCargaLiquidacionIcono" class="bi bi-circle"></i></div>
                        <div class="timeline-content">Carga de liquidación autorizada</div>
                    </div>

                    <!-- Estado 8 -->
                    <div id="TrackingUsuariosContablesColor" class="timeline-item">
                        <div class="timeline-icon"><i id="TrackingUsuariosContablesIcono" class="bi bi-circle"></i></div>
                        <div class="timeline-content">Bloqueo de usuarios contables</div>
                    </div>

                </div>
            </div>

            <!-- Footer -->
            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="bi bi-x-circle"></i> Cerrar
                </button>
            </div>

        </div>
    </div>
</div>


<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://code.jquery.com/ui/1.13.2/jquery-ui.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>

    const Toast = Swal.mixin({
        toast: true,
        position: 'top-end',
        showConfirmButton: false,
        timer: 5000,
        timerProgressBar: true
    })

    const modalVerDetalle = new bootstrap.Modal(document.getElementById('detalleModal'));
    const modalVerPdf = new bootstrap.Modal(document.getElementById('modalPDF'));
    const modalTrackingProceso = new bootstrap.Modal(document.getElementById('modalTrackingProceso'));

    const datos = @Html.Raw(Json.Encode(Model.Autorizaciones));
    const datosProcesos = @Html.Raw(Json.Encode(Model.Procesos));
    const causas = @Html.Raw(Json.Encode(Model.Causas));

    async function verDetalle(id) {
        const datosDetalle = datos.find(x => x.Code === id)
        const causasPorId = causas.filter(x => x.Code === id)
        const contenedorCausas = document.getElementById('detCausas');
        const estadoDetalle = document.getElementById('estadoDetalle');
        let cartaRenuncia = false;

        console.log("Datos : ",datosDetalle);
        console.log("Id : ", id);

        cartaRenuncia = await verificarExistenciaDeDocumento(datosDetalle.Code, datosDetalle.EmpleadoId)

        console.log(datos);
        let button = '';

        document.getElementById('detEmpleadoId').textContent = datosDetalle.EmpleadoId;
        document.getElementById('detNombre').textContent = datosDetalle.Nombre;
        document.getElementById('detPuesto').textContent = datosDetalle.Puesto;
        document.getElementById('detDepartamento').textContent = datosDetalle.Departamento;
        document.getElementById('detSolicita').textContent = datosDetalle.Solicita;
        document.getElementById('detMotivo').textContent = datosDetalle.Motivo;
        document.getElementById('detObservaciones').textContent = datosDetalle.Observaciones;

        switch (datosDetalle.Estado) {
            case 0:
                estadoDetalle.classList.add("bg-warning");
                estadoDetalle.classList.remove("bg-success");
                estadoDetalle.classList.remove("bg-danger");
                estadoDetalle.innerHTML = 'Pendiente';

                document.getElementById('btn-DetalleProceso').classList.add('hidden-input');

                break;
            case 1:
                estadoDetalle.classList.add("bg-success");
                estadoDetalle.classList.remove("bg-warning");
                estadoDetalle.classList.remove("bg-danger");
                estadoDetalle.innerHTML = 'Autorizado';

                document.getElementById('btn-DetalleProceso').classList.remove('hidden-input');

                break;
            case -1:
                estadoDetalle.classList.add("bg-danger");
                estadoDetalle.classList.remove("bg-success");
                estadoDetalle.classList.remove("bg-warning");
                estadoDetalle.innerHTML = 'Rechazado';

                document.getElementById('btn-DetalleProceso').classList.add('hidden-input');

                break;
        }

        switch (datosDetalle.Motivo) {
            case "Despido":
                document.getElementById('div-Causas').classList.remove('hidden-input');
                document.getElementById('div-Carta').classList.add('hidden-input');

                if (causasPorId.length != 0) {

                    causasPorId.forEach(causa => {
                        button += `<button type="button" class="btn btn-outline-danger btn-sm m-1">${causa.Name}</button>`;
                    })
                }
                else {
                    button += `<p>No se agregaron causas</p>`;
                }
                contenedorCausas.innerHTML = button;
                break;
            case "Renuncia":

                document.getElementById('div-Causas').classList.add('hidden-input');
                document.getElementById('div-Carta').classList.remove('hidden-input');

                if (cartaRenuncia.success) {
                    document.getElementById('detCartaRenuncia').innerHTML = `<button class="btn btn-primary btn-sm" onclick="verCartaPdf(${datosDetalle.Code},${datosDetalle.EmpleadoId})"><i class="bi bi-file-earmark-text-fill me-1"></i> Ver carta</button>`;
                } else {
                    document.getElementById('detCartaRenuncia').innerHTML = '<p>No se adjunto carta de renuncia</p>';
                }
                break;
        }
        modalVerDetalle.show();
    }

    async function verDetalleProceso(id) {
        const datosDetalle = datosProcesos.find(x => x.Code === id)
        const causasPorId = causas.filter(x => x.Code === id)
        const contenedorCausas = document.getElementById('detCausas');
        const estadoDetalle = document.getElementById('estadoDetalle');
        let cartaRenuncia = false;

        console.log("Datos : ", datosDetalle);
        console.log("Id : ", id);

        cartaRenuncia = await verificarExistenciaDeDocumento(datosDetalle.Code, datosDetalle.EmpleadoId)

        console.log(datos);
        let button = '';

        document.getElementById('detEmpleadoId').textContent = datosDetalle.EmpleadoId;
        document.getElementById('detNombre').textContent = datosDetalle.Nombre;
        document.getElementById('detPuesto').textContent = datosDetalle.Puesto;
        document.getElementById('detDepartamento').textContent = datosDetalle.Departamento;
        document.getElementById('detSolicita').textContent = datosDetalle.Solicita;
        document.getElementById('detMotivo').textContent = datosDetalle.Motivo;
        document.getElementById('detObservaciones').textContent = datosDetalle.Observaciones;

        switch (datosDetalle.Estado) {
            case 0:
                estadoDetalle.classList.add("bg-warning");
                estadoDetalle.classList.remove("bg-success");
                estadoDetalle.classList.remove("bg-danger");
                estadoDetalle.innerHTML = 'Pendiente';

                document.getElementById('btn-DetalleProceso').classList.add('hidden-input');

                break;
            case 1:
                estadoDetalle.classList.add("bg-success");
                estadoDetalle.classList.remove("bg-warning");
                estadoDetalle.classList.remove("bg-danger");
                estadoDetalle.innerHTML = 'Autorizado';

                document.getElementById('btn-DetalleProceso').classList.remove('hidden-input');

                break;
            case -1:
                estadoDetalle.classList.add("bg-danger");
                estadoDetalle.classList.remove("bg-success");
                estadoDetalle.classList.remove("bg-warning");
                estadoDetalle.innerHTML = 'Rechazado';

                document.getElementById('btn-DetalleProceso').classList.add('hidden-input');

                break;
        }

        switch (datosDetalle.Motivo) {
            case "Despido":
                document.getElementById('div-Causas').classList.remove('hidden-input');
                document.getElementById('div-Carta').classList.add('hidden-input');

                if (causasPorId.length != 0) {

                    causasPorId.forEach(causa => {
                        button += `<button type="button" class="btn btn-outline-danger btn-sm m-1">${causa.Name}</button>`;
                    })
                }
                else {
                    button += `<p>No se agregaron causas</p>`;
                }
                contenedorCausas.innerHTML = button;
                break;
            case "Renuncia":

                document.getElementById('div-Causas').classList.add('hidden-input');
                document.getElementById('div-Carta').classList.remove('hidden-input');

                if (cartaRenuncia.success) {
                    document.getElementById('detCartaRenuncia').innerHTML = `<button class="btn btn-primary btn-sm" onclick="verCartaPdf(${datosDetalle.Code},${datosDetalle.EmpleadoId})"><i class="bi bi-file-earmark-text-fill me-1"></i> Ver carta</button>`;
                } else {
                    document.getElementById('detCartaRenuncia').innerHTML = '<p>No se adjunto carta de renuncia</p>';
                }
                break;
        }
        modalVerDetalle.show();
    }

    async function verCartaPdf(_solicitud, _id) {

        const response = await fetch(`/GestionDePersonal/VerDocumentos?solicitud=${_solicitud}&id=${_id}`,{
            method: "GET"
        })

        if (response.ok) {
            document.getElementById('visorPDF').setAttribute('src', `/GestionDePersonal/VerDocumentos?solicitud=${_solicitud}&id=${_id}`);
            modalVerPdf.show();
        }
        else {
            Toast.fire({ icon: 'error', title: "Ocurrio un error al mostrar la carta en pdf" });
        }
    }

    async function obtenerCausas(_id) {
        try {
            const response = await fetch(`/GestionDePersonal/ObtenerCausasPorId?id=${_id}`, {
                method: "GET"
            });

            if (!response.ok) {
                console.log("Error al obtener las causas")
            }

            const data = await response.json();
            return data;
        }
        catch (error) {
            console.log(error)
        }
    }

    async function autorizar(id) {
        const { value: observaciones } = await Swal.fire({
            title: '¿Autorizar solicitud?',
            text: 'Por favor, ingresa las observaciones (opcional):',
            input: 'textarea',
            inputPlaceholder: 'Escribe aquí tus observaciones...',
            inputAttributes: { 'aria-label': 'Observaciones' },
            showCancelButton: true,
            confirmButtonText: 'Autorizar',
            cancelButtonText: 'Cancelar',
            confirmButtonColor: '#198754',
            cancelButtonColor: '#6c757d',
            inputValidator: (value) => {
                if (!value) {
                    return 'Debes ingresar al menos una observación para autorizar';
                }
            }
        });

        if (observaciones) {

            const datosDetalle = datos.find(x => x.Code === id);
            const response = await autorizarBaja(id, 1, datosDetalle.Nombre, datosDetalle.Departamento, datosDetalle.Motivo, datosDetalle.Observaciones, datosDetalle.Solicita, observaciones, datosDetalle.DepartamentoId, datosDetalle.PuestoId, datosDetalle.SolicitaId);
            Swal.fire({
                icon: response.success,
                title: 'Solicitud autorizada',
                text: 'La solicitud fue autorizada correctamente.',
                timer: 1800,
                showConfirmButton: false
            });

            location.reload();
        }
    }

    async function rechazar(id) {
        const { value: observaciones } = await Swal.fire({
            title: '¿Rechazar solicitud?',
            text: 'Por favor, indica las razones del rechazo:',
            input: 'textarea',
            inputPlaceholder: 'Escribe aquí tus observaciones...',
            inputAttributes: { 'aria-label': 'Motivo de rechazo' },
            showCancelButton: true,
            confirmButtonText: 'Rechazar',
            cancelButtonText: 'Cancelar',
            confirmButtonColor: '#dc3545',
            cancelButtonColor: '#6c757d',
            inputValidator: (value) => {
                if (!value) {
                    return 'Debes ingresar un motivo para rechazar';
                }
            }
        });

        if (observaciones) {

            const datosDetalle = datos.find(x => x.Code === id)
            const response = await autorizarBaja(id, -1, datosDetalle.Nombre, datosDetalle.Departamento, datosDetalle.Motivo, datosDetalle.Observaciones, datosDetalle.Solicita, observaciones, datosDetalle.DepartamentoId, datosDetalle.PuestoId, datosDetalle.SolicitaId);

            Swal.fire({
                icon: 'error',
                title: 'Solicitud rechazada',
                text: 'La solicitud fue rechazada correctamente.',
                timer: 1800,
                showConfirmButton: false
            });
            location.reload();
        }
    }

    async function autorizarBaja(id, estado, nombreEmpleado, departamento, motivo, observaciones, nombreSolicitante, comentariosGTH, departamentoId, puestoId, solicitaId)
    {
        try {
            isLoading(true);
            console.log("Autorizar baja");
            const formData = new FormData();

            formData.append("id", id);
            formData.append("estado", estado);
            formData.append("nombreEmpleado", nombreEmpleado);
            formData.append("departamento", departamento);
            formData.append("motivo", motivo);
            formData.append("observaciones", observaciones);
            formData.append("nombreSolicitante", nombreSolicitante);
            formData.append("comentariosGTH", comentariosGTH);
            formData.append("departamentoId", departamentoId);
            formData.append("puestoId", puestoId);
            formData.append("solicitaId", solicitaId);

            const response = await fetch(`/GestionDePersonal/AutorizarBaja`, {
                method: "POST",
                body: formData
            });

            if (!response.ok)
                console.log(response)
                //return { success: "error", message: response };

            const reply = await response.json();
            return reply;

        } catch (error) {
            return { success: false, message: error };
        }

        isLoading(false);
    }

    async function verificarExistenciaDeDocumento(solicitud, id ) {
        const response = await fetch(`/GestionDePersonal/ExistenciaDeDocumento?solicitud=${solicitud}&id=${id}`, {
            method: "GET"
        })

        const reply = await response.json();

        return reply;
    }

    function verProcesoBaja(codeBaja) {
        modalTrackingProceso.show();

    }

    function cerrarModalTrackinDeBaja() {
        modalTrackingProceso.hide();
    }

    function isLoading(isLoading) {

        if (isLoading)
        {
            $("#globalLoading").show();
        }
        else
        {
            $("#globalLoading").hide();
        }
        return;
    }
</script>