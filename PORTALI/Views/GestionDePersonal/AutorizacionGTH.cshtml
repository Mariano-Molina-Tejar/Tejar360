@using Entity;
@model AutorizacionesGTHViewModel
@{
    ViewData["Title"] = "Gestión de Personal";
}

<head>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <style>
        .text-secondary-perfil {
            color: dimgray;
        }

        .hidden-input {
            display: none !important;
        }

        .buttonMarcado {
            background-color: #6C757D;
            color: white;
        }

        .buttonMarcado {
            background-color: #6C757D;
            color: white;
        }

        .timeline {
            position: relative;
            margin: 20px 0;
            padding-left: 30px;
            border-left: 3px solid #dee2e6;
        }

        .timeline-item {
            position: relative;
            margin-bottom: 20px;
        }

        .timeline-icon {
            position: absolute;
            left: -16px;
            top: 0;
            background-color: #fff;
            color: #6c757d;
            border-radius: 50%;
            width: 28px;
            height: 28px;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 2px solid #dee2e6;
        }

        .timeline-item.completed .timeline-icon {
            background-color: #198754;
            color: #fff;
            border-color: #198754;
        }

        .timeline-item.active .timeline-icon {
            background-color: #ffc107;
            color: #212529;
            border-color: #ffc107;
        }

        .timeline-content {
            margin-left: 20px;
            color: #212529;
        }

        .timeline-item.completed .timeline-content {
            color: #198754;
        }

        .timeline-item.active .timeline-content {
            color: #ffc107;
            font-weight: bold;
        }
    </style>
</head>
<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="mb-0"><i class="bi bi-people-fill me-2"></i>Solicitudes de baja de personal</h4>
    </div>

    <div class="table-responsive shadow-sm rounded">
        <table class="table table-striped align-middle text-center">
            @if (ViewData["Error"] != null)
            {
                <div class="alert alert-danger d-flex align-items-center" role="alert" id="divError" style="display:none;">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    <span id="msgError">@ViewData["Error"]</span>
                </div>
            }
            <thead class="table-dark">
                <tr>
                    <th>No.</th>
                    <th>Fecha</th>
                    <th>Nombre</th>
                    <th>Puesto</th>
                    <th>Departamento</th>
                    <th>Solicita</th>
                    <th>Motivo</th>
                    <th>Estado</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Autorizaciones != null && Model.Autorizaciones.Any())
                {
                    foreach (var autorizacion in Model.Autorizaciones)
                    {
                        <tr>
                            <td>@autorizacion.Code</td>
                            <td>@autorizacion.FechaSolicitud.ToString("dd-MM-yyyy")</td>
                            <td>@autorizacion.Nombre</td>
                            <td>@autorizacion.Puesto</td>
                            <td>@autorizacion.Departamento</td>
                            <td>@autorizacion.Solicita</td>
                            <td>@autorizacion.Motivo</td>
                            <td class="text-center">
                                @switch (autorizacion.Estado)
                                {
                                    case 0:
                                        <i class="bi bi-hourglass-split text-warning" title="Pendiente"></i>
                                        break;
                                    case 1:
                                        <i class="bi bi-check-circle-fill text-success" title="Autorizado"></i>
                                        break;
                                    case -1:
                                        <i class="bi bi-x-circle-fill text-danger" title="Rechazado"></i>
                                        break;
                                    default:
                                        <i class="bi bi-question-circle text-secondary" title="Desconocido"></i>
                                        break;
                                }
                            </td>
                            <td class="text-center">
                                <div class="d-flex justify-content-end gap-2">
                                    @if (autorizacion.Estado == 0)
                                    {
                                        <button type="button" class="btn btn-outline-danger btn-sm" data-bs-toggle="tooltip" title="Rechazar" onclick="rechazar(@autorizacion.Code)">
                                            <i class="bi bi-x-circle"></i>
                                        </button>

                                        <button type="button" class="btn btn-outline-success btn-sm" data-bs-toggle="tooltip" title="Autorizar" onclick="autorizar(@autorizacion.Code)">
                                            <i class="bi bi-check-circle"></i>
                                        </button>
                                    }

                                    <button type="button" class="btn btn-outline-primary btn-sm" data-bs-toggle="tooltip" title="Ver detalle" onclick="verDetalle(@autorizacion.Code)">
                                        <i class="bi bi-eye"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="9" class="text-center text-muted py-3" style="font-style: italic;">
                            <i class="bi bi-info-circle"></i> No se encontraron solicitudes
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
<!-- Modal Detalle Empleado -->
<div class="modal fade" id="detalleModal" tabindex="-1" aria-labelledby="detalleModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header text-white" style="background-color:steelblue;">
                <h5 class="modal-title" id="detalleModalLabel">
                    <i class="bi bi-person-vcard"></i> Detalle de Solicitud
                </h5>
                <p id="estadoDetalle" class="rounded-2 ml-2 pr-2 pl-2"></p>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>

            <div class="modal-body">
                <div class="row mb-2">
                    <div class="col-md-6">
                        <label class="fw-bold">Empleado ID:</label>
                        <p id="detEmpleadoId" class="mb-0"></p>
                    </div>
                    <div class="col-md-6">
                        <label class="fw-bold">Nombre:</label>
                        <p id="detNombre" class="mb-0"></p>
                    </div>
                </div>

                <div class="row mb-2">
                    <div class="col-md-6">
                        <label class="fw-bold">Puesto:</label>
                        <p id="detPuesto" class="mb-0"></p>
                    </div>
                    <div class="col-md-6">
                        <label class="fw-bold">Departamento:</label>
                        <p id="detDepartamento" class="mb-0"></p>
                    </div>
                </div>

                <div class="row mb-2">
                    <div class="col-md-6">
                        <label class="fw-bold">Solicita:</label>
                        <p id="detSolicita" class="mb-0"></p>
                    </div>
                    <div class="col-md-6">
                        <label class="fw-bold">Motivo:</label>
                        <p id="detMotivo" class="mb-0"></p>
                    </div>
                </div>

                <div id="div-Causas" class="mb-2 hidden-input">
                    <label class="fw-bold">Causas:</label>
                    <div id="detCausas" class="mb-0"></div>
                </div>

                <div id="div-Carta" class="mb-2 hidden-input">
                    <label class="fw-bold">Carta de renuncia:</label>
                    <div id="detCartaRenuncia" class="mb-0"></div>
                </div>

                <div>
                    <label class="fw-bold">Observaciones:</label>
                    <p id="detObservaciones" class="mb-0"></p>
                </div>
            </div>

            <div class="modal-footer  d-flex justify-content-between">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="bi bi-x-circle"></i> Cerrar
                </button>
                <button id="btn-DetalleProceso" type="button" class="btn btn-warning hidden-input" onclick="verProcesoBaja()">
                    <i class="bi bi-arrow-repeat"></i> Ver Proceso
                </button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalPDF" tabindex="-1" aria-labelledby="modalPDFLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="modalPDFLabel"><i class="bi bi-file-earmark-pdf me-2"></i> Vista del Documento</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body p-0" style="height: 80vh;">
                <iframe id="visorPDF" src="" width="100%" height="100%" style="border: none;"> </iframe>
            </div>
        </div>
    </div>
</div>
<!-- Modal Seguimiento de Proceso -->
<div class="modal fade" id="modalTrackingProceso" tabindex="-1" aria-labelledby="modalTrackingLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow-lg">

            <!-- Header -->
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="modalTrackingLabel">
                    <i class="bi bi-arrow-repeat me-2"></i> Seguimiento del Proceso de Baja
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar" onclick="cerrarModalTrackinDeBaja()"></button>
            </div>

            <!-- Body -->
            <div class="modal-body">
                <div class="timeline">

                    <!-- Estado 0 -->
                    <div class="timeline-item completed">
                        <div class="timeline-icon"><i class="bi bi-check-circle-fill"></i></div>
                        <div class="timeline-content">Pendiente</div>
                    </div>

                    <!-- Estado 1 -->
                    <div class="timeline-item completed">
                        <div class="timeline-icon"><i class="bi bi-check-circle-fill"></i></div>
                        <div class="timeline-content">Autorizado por GTH</div>
                    </div>

                    <!-- Estado 2 -->
                    <div class="timeline-item completed">
                        <div class="timeline-icon"><i class="bi bi-check-circle-fill"></i></div>
                        <div class="timeline-content">Tablero de Obligaciones</div>
                    </div>

                    <!-- Estado 3 -->
                    <div class="timeline-item active">
                        <div class="timeline-icon"><i class="bi bi-hourglass-split"></i></div>
                        <div class="timeline-content fw-semibold">Emisión de solvencia administrativa</div>
                    </div>

                    <!-- Estado 4 -->
                    <div class="timeline-item">
                        <div class="timeline-icon"><i class="bi bi-circle"></i></div>
                        <div class="timeline-content">Carta de despido - Emisión</div>
                    </div>

                    <!-- Estado 5 -->
                    <div class="timeline-item">
                        <div class="timeline-icon"><i class="bi bi-circle"></i></div>
                        <div class="timeline-content">Bloqueo de usuarios operativos</div>
                    </div>

                    <!-- Estado 6 -->
                    <div class="timeline-item">
                        <div class="timeline-icon"><i class="bi bi-circle"></i></div>
                        <div class="timeline-content">Confirmación de emisión de pago</div>
                    </div>

                    <!-- Estado 7 -->
                    <div class="timeline-item">
                        <div class="timeline-icon"><i class="bi bi-circle"></i></div>
                        <div class="timeline-content">Carga de liquidación autorizada</div>
                    </div>

                    <!-- Estado 8 -->
                    <div class="timeline-item">
                        <div class="timeline-icon"><i class="bi bi-circle"></i></div>
                        <div class="timeline-content">Bloqueo de usuarios contables</div>
                    </div>

                </div>
            </div>

            <!-- Footer -->
            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal" onclick="cerrarModalTrackinDeBaja()">
                    <i class="bi bi-x-circle"></i> Cerrar
                </button>
            </div>
        </div>
    </div>
</div>


<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>

    const Toast = Swal.mixin({
        toast: true,
        position: 'top-end',
        showConfirmButton: false,
        timer: 5000,
        timerProgressBar: true
    })

    const modalVerDetalle = new bootstrap.Modal(document.getElementById('detalleModal'));
    const modalVerPdf = new bootstrap.Modal(document.getElementById('modalPDF'));
    const modalTrackingProceso = new bootstrap.Modal(document.getElementById('modalTrackingProceso'));

    const datos = @Html.Raw(Json.Encode(Model.Autorizaciones));
    const causas = @Html.Raw(Json.Encode(Model.Causas));

    async function verDetalle(id) {
        const datosDetalle = datos.find(x => x.Code === id)
        const causasPorId = causas.filter(x => x.Code === id)
        const contenedorCausas = document.getElementById('detCausas');
        const estadoDetalle = document.getElementById('estadoDetalle');
        let cartaRenuncia = false;

        cartaRenuncia = await verificarExistenciaDeDocumento(datosDetalle.Code, datosDetalle.EmpleadoId)

        console.log(datos);
        let button = '';

        document.getElementById('detEmpleadoId').textContent = datosDetalle.EmpleadoId;
        document.getElementById('detNombre').textContent = datosDetalle.Nombre;
        document.getElementById('detPuesto').textContent = datosDetalle.Puesto;
        document.getElementById('detDepartamento').textContent = datosDetalle.Departamento;
        document.getElementById('detSolicita').textContent = datosDetalle.Solicita;
        document.getElementById('detMotivo').textContent = datosDetalle.Motivo;
        document.getElementById('detObservaciones').textContent = datosDetalle.Observaciones;

        switch (datosDetalle.Estado) {
            case 0:
                estadoDetalle.classList.add("bg-warning");
                estadoDetalle.classList.remove("bg-success");
                estadoDetalle.classList.remove("bg-danger");
                estadoDetalle.innerHTML = 'Pendiente';

                document.getElementById('btn-DetalleProceso').classList.add('hidden-input');

                break;
            case 1:
                estadoDetalle.classList.add("bg-success");
                estadoDetalle.classList.remove("bg-warning");
                estadoDetalle.classList.remove("bg-danger");
                estadoDetalle.innerHTML = 'Autorizado';

                document.getElementById('btn-DetalleProceso').classList.remove('hidden-input');

                break;
            case -1:
                estadoDetalle.classList.add("bg-danger");
                estadoDetalle.classList.remove("bg-success");
                estadoDetalle.classList.remove("bg-warning");
                estadoDetalle.innerHTML = 'Rechazado';

                document.getElementById('btn-DetalleProceso').classList.add('hidden-input');

                break;
        }

        switch (datosDetalle.Motivo) {
            case "Despido":
                document.getElementById('div-Causas').classList.remove('hidden-input');
                document.getElementById('div-Carta').classList.add('hidden-input');

                if (causasPorId.length != 0) {

                    causasPorId.forEach(causa => {
                        button += `<button type="button" class="btn btn-outline-danger btn-sm m-1">${causa.Name}</button>`;
                    })
                }
                else {
                    button += `<p>No se agregaron causas</p>`;
                }
                contenedorCausas.innerHTML = button;
                break;
            case "Renuncia":

                document.getElementById('div-Causas').classList.add('hidden-input');
                document.getElementById('div-Carta').classList.remove('hidden-input');

                if (cartaRenuncia.success) {
                    document.getElementById('detCartaRenuncia').innerHTML = `<button class="btn btn-primary btn-sm" onclick="verCartaPdf(${datosDetalle.Code},${datosDetalle.EmpleadoId})"><i class="bi bi-file-earmark-text-fill me-1"></i> Ver carta</button>`;
                } else {
                    document.getElementById('detCartaRenuncia').innerHTML = '<p>No se adjunto carta de renuncia</p>';
                }
                break;
        }
        modalVerDetalle.show();
    }

    async function verCartaPdf(_solicitud, _id) {

        const response = await fetch(`/GestionDePersonal/VerDocumentos?solicitud=${_solicitud}&id=${_id}`,{
            method: "GET"
        })

        if (response.ok) {
            document.getElementById('visorPDF').setAttribute('src', `/GestionDePersonal/VerDocumentos?solicitud=${_solicitud}&id=${_id}`);
            modalVerPdf.show();
        }
        else {
            Toast.fire({ icon: 'error', title: "Ocurrio un error al mostrar la carta en pdf" });
        }
    }

    async function obtenerCausas(_id) {
        try {
            const response = await fetch(`/GestionDePersonal/ObtenerCausasPorId?id=${_id}`, {
                method: "GET"
            });

            if (!response.ok) {
                console.log("Error al obtener las causas")
            }

            const data = await response.json();
            return data;
        }
        catch (error) {
            console.log(error)
        }
    }

    async function autorizar(id) {
        const { value: observaciones } = await Swal.fire({
            title: '¿Autorizar solicitud?',
            text: 'Por favor, ingresa las observaciones (opcional):',
            input: 'textarea',
            inputPlaceholder: 'Escribe aquí tus observaciones...',
            inputAttributes: { 'aria-label': 'Observaciones' },
            showCancelButton: true,
            confirmButtonText: 'Autorizar',
            cancelButtonText: 'Cancelar',
            confirmButtonColor: '#198754',
            cancelButtonColor: '#6c757d',
            inputValidator: (value) => {
                if (!value) {
                    return 'Debes ingresar al menos una observación para autorizar';
                }
            }
        });

        if (observaciones) {

            const datosDetalle = datos.find(x => x.Code === id);
            const response = await autorizarBaja(id, 1, datosDetalle.Nombre, datosDetalle.Departamento, datosDetalle.Motivo, datosDetalle.Observaciones, datosDetalle.Solicita, observaciones, datosDetalle.DepartamentoId, datosDetalle.PuestoId, datosDetalle.SolicitaId);
            Swal.fire({
                icon: response.success,
                title: 'Solicitud autorizada',
                text: 'La solicitud fue autorizada correctamente.',
                timer: 1800,
                showConfirmButton: false
            });

            location.reload();
        }
    }

    async function rechazar(id) {
        const { value: observaciones } = await Swal.fire({
            title: '¿Rechazar solicitud?',
            text: 'Por favor, indica las razones del rechazo:',
            input: 'textarea',
            inputPlaceholder: 'Escribe aquí tus observaciones...',
            inputAttributes: { 'aria-label': 'Motivo de rechazo' },
            showCancelButton: true,
            confirmButtonText: 'Rechazar',
            cancelButtonText: 'Cancelar',
            confirmButtonColor: '#dc3545',
            cancelButtonColor: '#6c757d',
            inputValidator: (value) => {
                if (!value) {
                    return 'Debes ingresar un motivo para rechazar';
                }
            }
        });

        if (observaciones) {

            const datosDetalle = datos.find(x => x.Code === id)
            const response = await autorizarBaja(id, -1, datosDetalle.Nombre, datosDetalle.Departamento, datosDetalle.Motivo, datosDetalle.Observaciones, datosDetalle.Solicita, observaciones, datosDetalle.DepartamentoId, datosDetalle.PuestoId, datosDetalle.SolicitaId);

            Swal.fire({
                icon: 'error',
                title: 'Solicitud rechazada',
                text: 'La solicitud fue rechazada correctamente.',
                timer: 1800,
                showConfirmButton: false
            });

            location.reload();
        }
    }

    async function autorizarBaja(id, estado, nombreEmpleado, departamento, motivo, observaciones, nombreSolicitante, comentariosGTH, departamentoId, puestoId, solicitaId)
    {
        try {

            console.log("Autorizar baja");
            const formData = new FormData();

            formData.append("id", id);
            formData.append("estado", estado);
            formData.append("nombreEmpleado", nombreEmpleado);
            formData.append("departamento", departamento);
            formData.append("motivo", motivo);
            formData.append("observaciones", observaciones);
            formData.append("nombreSolicitante", nombreSolicitante);
            formData.append("comentariosGTH", comentariosGTH);
            formData.append("departamentoId", departamentoId);
            formData.append("puestoId", puestoId);
            formData.append("solicitaId", solicitaId);


            const response = await fetch(`/GestionDePersonal/AutorizarBaja`, {
                method: "POST",
                body: formData
            });

            if (!response.ok)
                console.log(response)
                //return { success: "error", message: response };

            const reply = await response.json();
            return reply;

        } catch (error) {
            return { success: false, message: error };
        }
    }

    async function verificarExistenciaDeDocumento(solicitud, id ) {
        const response = await fetch(`/GestionDePersonal/ExistenciaDeDocumento?solicitud=${solicitud}&id=${id}`, {
            method: "GET"
        })

        const reply = await response.json();

        return reply;
    }

    function verProcesoBaja() {
        modalTrackingProceso.show();
    }

    function cerrarModalTrackinDeBaja() {
        modalTrackingProceso.hide();
    }

</script>