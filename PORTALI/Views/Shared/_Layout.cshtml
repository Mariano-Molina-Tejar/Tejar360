                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="@Url.Action("Recepcion", "Delivery")">
                            <i class="nav-icon icon-basket-loaded"></i>Recepción
                        </a>
                    </li>
                    @*<li class="nav-item">
            <a class="nav-link" href="@Url.Action("AutorizacionSuperior", "SAPAutorizaSuperior")">
                <i class="nav-icon icon-basket-loaded"></i>Autorización superior
            </a>
        </li>*@
                    <li class="divider"></li>
                    <li class="nav-title">Herramientas</li>
                    <li class="nav-item nav-dropdown">
                        <a class="nav-link nav-dropdown-toggle" href="#">
                            <i class="nav-icon icon-settings"></i> Configuración
                        </a>
                        <ul class="nav-dropdown-items">
                            <li class="nav-item">
                                <a class="nav-link" href="@Url.Action("Perfil", "Profile")" target="_top">
                                    <i class="nav-icon icon-user"></i> Perfil
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="register.html" target="_top">
                                    <i class="nav-icon icon-star"></i> Acerca de
                                </a>
                            </li>
                        </ul>
                    </li>
                </ul>
            </nav>
            <button class="sidebar-minimizer brand-minimizer" type="button"></button>
        </div>
        <main class="main">
            <div id="globalLoading" class="loading-overlay">
                @*<img src="~/Img/tejar-ico.png" alt="Loading..." class="loading-image">*@
                <img src="~/img/loading_circulo.gif" alt="loading..." class="loading-image">
                @*<div class="spinner-border text-primary" role="status">
            <span class="sr-only">Loading...</span>
        </div>*@
            </div>
            @RenderBody()
            <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
            <script>
                $(document).ready(function () {
                    $("#globalLoading").fadeOut("slow");
                });

                $(document).ajaxStart(function () {
                    $("#globalLoading").fadeIn("fast");
                }).ajaxStop(function () {
                    $("#globalLoading").fadeOut("slow");
                });
            </script>
        </main>
    </div>
    <footer class="app-footer fixed-bottom p-xl-2">
        <div>
            <span>&copy; 2024 Desarrollo ElTejar</span>
        </div>
    </footer>
    <!-- Bootstrap and necessary plugins-->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/popper.js/dist/umd/popper.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.min.js"></script>
