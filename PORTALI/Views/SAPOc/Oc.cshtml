@model Entity.PortalMantSolicitudCompraEntity
@{   
    int suss = 0;
    if (@Model == null)
    {
        return;
    }
    var reportDocument = ViewBag.ReportDocument as CrystalDecisions.CrystalReports.Engine.ReportDocument;
}
<head>
    <script src="~/Scripts/bootstrap.min.js"></script>
    <link href="~/Css/font-awesome.min.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
    <link rel="stylesheet" href="https://fonts.googleapis.com/icon?family=Material+Icons">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.5.1/jquery.min.js"></script>
    <style type="text/css">
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background-color: white;
            position: relative;
        }

        .card-header {
            display: flex;
            height: 35px;
            align-items: center;
            justify-content: center;
            color: white;
            font-family: Arial;
            font-size: 12px;
            font-weight: bold;
            background-color: cornflowerblue;
            border-top-left-radius: 4px;
            border-top-right-radius: 4px
        }

        #btn-mas {
            display: none;
        }

        .container {
            width: 80px;
            position: fixed;
            bottom: 37px;
            right: 10px;
        }

        .redes a, .btn-mas label {
            display: block;
            text-decoration: none;
            background: cornflowerblue;
            color: #fff;
            width: 55px;
            height: 55px;
            line-height: 55px;
            text-align: center;
            border-radius: 50%;
            box-shadow: 0px 1px 10px rgba(0,0,0,0.4);
            transition: all 800ms ease;
        }

            .redes a:hover {
                background: #fff;
                color: cornflowerblue;
            }

        .redes a {
            margin-bottom: -15px;
            opacity: 0;
            visibility: hidden;
        }

        #btn-mas:checked ~ .redes a {
            margin-bottom: 5px;
            opacity: 1;
            visibility: visible;
        }

        .btn-mas label {
            cursor: pointer;
            background: cornflowerblue;
            font-size: 23px;
        }

        #btn-mas:checked ~ .btn-mas label {
            transform: rotate(135deg);
            font-size: 25px;
        }

        .CampoTexto {
            width: 100%;
            height: 35px;
        }

            .CampoTexto::placeholder {
                color: #999;
                font-style: italic;
                font-size: 12px;
            }

        .modal-confirm {
            color: #636363;
            width: 400px;
        }

            .modal-confirm .modal-content {
                padding: 20px;
                border-radius: 5px;
                border: none;
                text-align: center;
                font-size: 14px;
            }

            .modal-confirm .modal-header {
                border-bottom: none;
                position: relative;
            }

            .modal-confirm h4 {
                text-align: center;
                font-size: 26px;
                margin: 30px 0 -10px;
            }

            .modal-confirm .close {
                position: absolute;
                top: -5px;
                right: -2px;
            }

            .modal-confirm .modal-body {
                color: #999;
            }

            .modal-confirm .modal-footer {
                border: none;
                text-align: center;
                border-radius: 5px;
                font-size: 13px;
                padding: 10px 15px 25px;
            }

                .modal-confirm .modal-footer a {
                    color: #999;
                }

            .modal-confirm .icon-box {
                width: 80px;
                height: 80px;
                margin: 0 auto;
                border-radius: 50%;
                z-index: 9;
                text-align: center;
                border: 3px solid #f15e5e;
            }

                .modal-confirm .icon-box i {
                    color: #f15e5e;
                    font-size: 46px;
                    display: inline-block;
                    margin-top: 13px;
                }

            .modal-confirm .btn, .modal-confirm .btn:active {
                color: #fff;
                border-radius: 4px;
                background: #60c7c1;
                text-decoration: none;
                transition: all 0.4s;
                line-height: normal;
                min-width: 120px;
                border: none;
                min-height: 40px;
                border-radius: 3px;
                margin: 0 5px;
            }

            .modal-confirm .btn-secondary {
                background: #c1c1c1;
            }

                .modal-confirm .btn-secondary:hover, .modal-confirm .btn-secondary:focus {
                    background: #a8a8a8;
                }

            .modal-confirm .btn-danger {
                background: #f15e5e;
            }

                .modal-confirm .btn-danger:hover, .modal-confirm .btn-danger:focus {
                    background: #ee3535;
                }

        ul#listError li {
            text-align: left; /* Alinea el contenido de cada elemento */
            list-style-image: url('../../Img/cancel_16.png');
        }

        .select-blanco {
            background-color: white; /* Fondo blanco */
            color: black; /* Texto negro, o puedes ajustar según prefieras */
        }

        .estilo {
            text-align: right;
            border: none;
        }

        .estiloDinamico {
            vertical-align: middle;
        }

        #tablaAgrupada {
            border-radius: 5px;
            overflow: hidden; /* Importante para que el border-radius se aplique correctamente */
            border-collapse: separate; /* Para evitar problemas con el border-radius */
        }

            /* Aplicar border-radius a las esquinas del encabezado */
            #tablaAgrupada thead th:first-child {
                border-top-left-radius: 5px;
            }

            #tablaAgrupada thead th:last-child {
                border-top-right-radius: 5px;
            }

            /* Aplicar border-radius a las esquinas inferiores */
            #tablaAgrupada tbody td:first-child {
                border-bottom-left-radius: 5px;
            }

            #tablaAgrupada tbody td:last-child {
                border-bottom-right-radius: 5px;
            }

        #attachButton {
            text-transform: none !important;
        }

        #vistaBuscar .modal-dialog {
            max-width: 50%; /* Ajusta el porcentaje según el ancho deseado */
        }

        #vistaBuscar .modal-content {
            max-height: 90vh; /* Ajusta el porcentaje según tus necesidades */
            overflow: hidden; /* Evita el desbordamiento del contenido */
        }

        /* Permite el scroll solo en el área de la tabla */
        #vistaBuscar .modal-body {
            overflow-y: auto;
            max-height: 90vh; /* Ajusta el tamaño de la tabla dentro del modal */
        }

        #tblBusqueda {
            width: 100%;
            table-layout: auto; /* Ajusta el ancho de las columnas según el contenido */
            border: 1px solid #ddd;
        }

            /* Bordes y estilo de celdas */
            #tblBusqueda th, #tblBusqueda td {
                border: 1px solid #ddd;
                padding: 8px;                
            }

            /* Estilo para el encabezado de la tabla */
            #tblBusqueda thead {
                background-color: #f2f2f2;
            }

        /* Personalización del botón de búsqueda */
        #btnBuscar .input-group-text {
            background-color: #FF8C00; /* Color naranja */
            color: white;
            border: none;
            cursor: pointer;
        }

        /* Input con bordes redondeados a la izquierda */
        #txtBuscar {
            border-top-left-radius: 20px;
            border-bottom-left-radius: 20px;
        }

            /* Quitar borde del input cuando el botón está dentro */
            #txtBuscar:focus {
                box-shadow: none;
            }

        /* Input más alto */
        .input-group .form-control {
            height: 45px;
        }
    </style>
</head>
<body>
    <div class="main-content animated fadeIn">
        <div class="" style="padding:20px" id="contentArea">
            <form>
                <div class="row">
                    <div class="col-xl-7">
                        <div class="card shadow" style="border-radius:5px; border-top-left-radius:5px; border-top-right-radius:5px">
                            <div class="card-header">Datos Generales</div>
                            <div class="card-body">
                                <div class="col-xl-12">
                                    <div class="form-row">
                                        <div class="form-group col-xl-2">
                                            <label for="inputState">Número solicitud</label>
                                            <input id="txtDocNum" type="text" class="form-control" value="" readonly style="background-color:white">
                                        </div>
                                        <div class="form-group col-xl-2">
                                            <label for="inputState">Llave</label>
                                            <input id="txtDocEntry" type="text" class="form-control" value="" readonly style="background-color:white">
                                        </div>
                                    </div>
                                    <div class="form-row">
                                        <div class="form-group col-md-3">
                                            <label for="inputState">Sucursal</label>
                                            <select id="lstSucursal" class="form-control" style="background-color:white">
                                                <option value="0" selected>Seleccionar...</option>
                                                @{
                                                    if (Model != null)
                                                    {
                                                        if (Model.ListaSucursales != null)
                                                        {
                                                            for (int i = 0; i < Model.ListaSucursales.Count; i++)
                                                            {
                                                                <option value="@Model.ListaSucursales[i].IdSucursal">@Model.ListaSucursales[i].Name</option>
                                                            }
                                                        }
                                                    }
                                                }
                                            </select>
                                        </div>
                                        <div class="form-group col-md-3">
                                            <label for="inputState">Departamento</label>
                                            <select id="lstDepto" class="form-control" style="background-color:white">
                                                <option value="0" selected>Seleccionar...</option>
                                                @{
                                                    if (@Model != null)
                                                    {
                                                        if (@Model.ListadoDeptos != null)
                                                        {
                                                            for (int i = 0; i < @Model.ListadoDeptos.Count; i++)
                                                            {
                                                                <option value="@Model.ListadoDeptos[i].IdDepto" @Model.ListadoDeptos[i].Selected>@Model.ListadoDeptos[i].Depto</option>
                                                            }
                                                        }
                                                    }
                                                }
                                            </select>
                                        </div>
                                        <div class="form-group col-md-3">
                                            <label for="inputState">Fecha documento</label>
                                            <input type="date" class="form-control" id="txtDocDate" value="@Model.FechaHoy.ToString("yyyy-MM-dd")" style="background-color:white">
                                        </div>
                                        <div class="form-group col-md-3">
                                            <label for="inputState">Fecha necesaria</label>
                                            <input type="date" class="form-control" id="txtDocDueDate" value="">
                                        </div>
                                        <div class="form-group col-md-3">
                                            <label for="inputState">Centro de costo</label>
                                            <select id="lstTienda" class="form-control" style="background-color:white">
                                                <option selected>Seleccionar...</option>
                                            </select>
                                        </div>
                                        <div class="form-group col-md-4">
                                            <label for="inputState">Correo</label>
                                            <input id="txtCorreo" type="email" class="form-control" value="">
                                        </div>
                                    </div>
                                    <div class="form-row">
                                        <div class="form-group col-xl-6">
                                            <label for="inputState">Notas</label>
                                            <textarea id="txtObservaciones" type="text" class="form-control" value="" maxlength="254"></textarea>
                                        </div>
                                    </div>
                                    <div class="form-row">
                                        <div class="col-xl-12">
                                            <input type="file" id="fileInput" multiple style="display: none;" />
                                            <ul id="fileList" style="font-size: 12px; margin-top: 5px; list-style-type: none; "></ul>
                                            <div id="message"></div>                                            
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-xl-5">
                        <div class="card shadow" style="border-radius:5px; border-top-left-radius:5px; border-top-right-radius:5px; height:95%">
                            <div class="card-header">Tabla de presupuesto</div>
                            <div class="card-body">
                                <div class="col-xl-12">
                                    <div class="table-responsive col-xl-12">
                                        <table id="tablaAgrupada" class="table table-bordered">
                                            <thead class="" style="text-align:center; background-color:gray;color:white">
                                                <tr>
                                                    <th scope="col" style="width:200px">Cuenta</th>
                                                    <th scope="col" style="width:120px">Presupuesto</th>
                                                    <th scope="col" style="width:110px">Gasto</th>
                                                    <th scope="col" style="width:110px">Saldo</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                            <td colspan="4" style="text-align:center;height:100px;color:gray;vertical-align:middle;font-size:12px"><i>No hay datos</i></td>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-xl-12">
                        <div class="card shadow" style="border-radius:5px; border-top-left-radius:5px; border-top-right-radius:5px">
                            <div class="card-header">Detalle</div>
                            <div class="card-body col-xl-12">
                                <div class="row">
                                    <div class="table-responsive col-xl-12">
                                        <table id="tblDetalles" class="table table-bordered">
                                            <thead class="thead-dark" style="text-align:center">
                                                <tr>
                                                    <th scope="col" style="width:50px">#</th>
                                                    <th scope="col" style="width:90px">Código</th>
                                                    <th scope="col">Descripción del producto</th>
                                                    <th scope="col">Notas</th>
                                                    <th scope="col">Cuenta</th>
                                                    <th scope="col" style="display:none">Pepto</th>
                                                    <th scope="col" style="width:100px">Cantidad</th>
                                                    <th scope="col" style="width:120px">Precio</th>
                                                    <th scope="col" style="width:120px">Total</th>
                                                    <th scope="col" style="width:80px">Opciones</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                            <td colspan="10" style="text-align:center;height:100px;color:gray;vertical-align:middle;font-size:12px"><i>No hay datos</i></td>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <input type="file" id="inputSeleccionarDocumento" style="display: none;" accept=".xls, .xlsx" />
                <input type="text" id="isTableCleared" value="false" style="display:none" />
                <p id="nombreArchivo"></p>
                @*Lista de botones*@
                <div class="container">
                    <input type="checkbox" id="btn-mas">
                    <div class="redes">
                        <a href="#" class="fa fa-paperclip" id="attachButton" data-toggle="tooltip" data-placement="left" title="Adjuntar documentos"></a>
                        <a href="#" class="fa-solid fa-file-import" id="btnSeleccionarDocumento" data-toggle="tooltip" data-placement="left" title="Importar datos"></a>
                        <a href="#vistaCondicion" class="fa fa-save trigger-btn" data-toggle="modal" data-placement="left" title="Guardar solicitud" id="btnGuardar"></a>
                        <a href="" class="fa-sharp fa-solid fa-magnifying-glass-plus" data-toggle="modal" data-placement="left" id="btnModalBuscar" title="Buscar producto"></a>
                        @*<a href="" class="fa-sharp fa-solid fa-magnifying-glass-plus" data-toggle="modal" data-placement="left" data-target=".bd-example-modal-lg" id="btnModalBuscar" title="Buscar producto"></a>*@
                    </div>
                    <div class="btn-mas">
                        <label for="btn-mas" class="fa fa-plus"></label>
                    </div>
                </div>
            </form>
        </div>
    </div>
    @*MODAL BUSQUEDA DE PRODUCTOS*@
    <div id="vistaBuscar" class="modal fade bd-example-modal-lg" tabindex="-1" role="dialog" aria-labelledby="myLargeModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header" role="document">
                    <h5 class="modal-title" id="exampleModalLabel">Buscar producto</h5>
                    <button type="button" class="close" onclick="$('#vistaBuscar').modal('hide')" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <div id="modal-content">
                        <div class="col-lg-12">
                            <div class="row">
                                <div class="col-lg-12">
                                    <div class="row justify-content-center">
                                        <div class="col-xl-8">
                                            <div class="input-group">
                                                <input id="txtBuscar" autocomplete="off" type="text" class="form-control text-uppercase" placeholder="Buscar producto..." />
                                                <div id="btnBuscar" class="input-group-append">
                                                    <span class="input-group-text">
                                                        <i class="fa fa-search"></i>
                                                    </span>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <br />
                            <div class="row">
                                <div class="col-lg-12">
                                    <table id="tblBusqueda" class="table table-hover table-responsive" style="width:100%">
                                        <thead class="thead-dark" style="text-align:center; width:100%">
                                            <tr>
                                                <th style="width:110px">Código</th>
                                                <th style="width:50%">Descripcion del producto</th>
                                                <th style="width:350px">Cuenta</th>
                                                <th style="width:110px">Cantidad</th>
                                                <th style="width:80px;"></th>
                                            </tr>
                                        </thead>
                                        <tbody id="resultadosBusqueda">
                                            <td id="titulo2" colspan="10" style="text-align:center;height:100px;color:gray;vertical-align:middle;font-size:12px">
                                                <i>No hay datos</i>
                                            </td>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div id="vistaCondicion" class="modal fade">
        <div class="modal-dialog modal-confirm">
            <div class="modal-content">
                <div class="modal-header flex-column">
                    <div class="icon-box">
                        <i class="material-icons">&#xE8FD;</i>
                    </div>
                    <h4 class="modal-title w-100" id="tituloCompra">¿Crear solicitud de compra?</h4>
                    <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
                </div>
                <div class="modal-body">
                    <p id="tituloBody">Este documento necesita una autorización del jefe del departamento<br />¿Continuar?</p>
                </div>
                <div class="modal-footer justify-content-center">
                    <button type="button" class="btn btn-danger" data-dismiss="modal">No</button>
                    <button id="btnSalvar" type="button" class="btn btn-success" data-dismiss="modal">Si</button>
                </div>
            </div>
        </div>
    </div>
    <div id="vistaResultado" class="modal fade" tabindex="-1" aria-labelledby="miModalLabel" aria-hidden="true" data-bs-backdrop="static" data-bs-keyboard="false">
        <div class="modal-dialog modal-confirm">
            <div class="modal-content">
                <div class="modal-header d-flex justify-content-center align-items-center">
                    <img id="imgMsg" width="50" height="50" />
                </div>
                <div class="modal-body">
                    <p class="text-center" id="txtMensaje"></p>
                    <ul id="listError"></ul>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-success btn-block" data-dismiss="modal" onclick="btnCerrarMsg()">Cerrar</button>
                </div>
            </div>
        </div>
    </div>
</body>
<script src="~/Scripts/jquery-3.4.1.min.js"></script>
<script type="text/javascript">
    var deleteBtn = document.createElement('span');
    var selectedFiles = [];

    document.getElementById('attachButton').addEventListener('click', function (event) {
        event.preventDefault(); // Prevenir comportamiento por defecto
        document.getElementById('fileInput').click();
    });

    document.getElementById('fileInput').addEventListener('change', function (event) {
        var files = event.target.files;

        // Agregar los archivos seleccionados al array de selectedFiles
        for (var i = 0; i < files.length; i++) {
            selectedFiles.push(files[i]);
        }

        // Actualizar el listado de archivos
        updateFileList();
    });

    /* CARGA LA IMAGEN AL LISTADO*/
    function updateFileList() {
        var fileList = document.getElementById('fileList');
        fileList.innerHTML = '';

        for (var i = 0; i < selectedFiles.length; i++) {
            var li = document.createElement('li');

            var deleteBtn = document.createElement('span');
            var img = document.createElement('img');
            img.src = '/Img/cancelar.png';
            img.alt = 'Eliminar';
            img.style.width = '16px';
            img.style.cursor = 'pointer';
            img.style.marginRight = '10px';

            (function (index) {
                img.addEventListener('click', function () {
                    selectedFiles.splice(index, 1);
                    updateFileList();
                });
            })(i);

            deleteBtn.appendChild(img);
            li.appendChild(deleteBtn);
            li.appendChild(document.createTextNode(selectedFiles[i].name));
            fileList.appendChild(li);
        }
    }

    function uploadFiles() {
        if (selectedFiles.length === 0) {
            $("#message").text("No hay archivos adjuntos");
            return;
        }

        var formData = new FormData();
        for (var i = 0; i < selectedFiles.length; i++) {
            formData.append('files', selectedFiles[i]);
        }

        $.ajax({
            url: '@Url.Action("SubirData", "SAPOc")',
            type: 'POST',
            data: formData,
            processData: false,
            contentType: false,
            success: function (response) {
                $("#message").text("Archivos subidos correctamente.");
                //selectedFiles = [];
                //updateFileList();
            },
            error: function (jqXHR, textStatus, errorThrown) {
                $("#message").text("Error al cargar los archivos adjuntos.");
            }
        });
    }

    /*---------------------------------------------------------------------------------------*/

    let isTableCleared = false;
    document.getElementById('btnSeleccionarDocumento').addEventListener('click', function () {
        document.getElementById('inputSeleccionarDocumento').click();
    });

    /* CARGA DE DATA DESDE EXCEL */
    document.getElementById('inputSeleccionarDocumento').addEventListener('change', function (e) {
        const file = e.target.files[0];

        if (file) {
            const reader = new FileReader();
            reader.onload = function (event) {
                const data = new Uint8Array(event.target.result);
                const workbook = XLSX.read(data, { type: 'array' });

                // Leer la primera hoja del archivo Excel
                const sheetName = workbook.SheetNames[0];
                const sheet = workbook.Sheets[sheetName];

                // Convertir la hoja a JSON
                const jsonData = XLSX.utils.sheet_to_json(sheet, { header: 1 });
                const headers = jsonData[0];

                const result = jsonData.slice(1).map(row => {
                    let obj = {};
                    headers.forEach((header, index) => {
                        obj[header] = row[index] || null;
                    });
                    return obj;
                });

                $.ajax({
                    url: '@Url.Action("CargaDataExcel", "SAPOc")',
                    type: 'POST',
                    data: { DataExcelJson: JSON.stringify(result)},
                    success: function (respuesta) {
                        var rows = '';
                        var rows2 = '';
                        $.each(respuesta.ListaUno, function (index, item) {
                            rows += '<tr>' +
                                '<td style="vertical-align:middle; text-align:center">' + item.Rw + '</td>' +
                                '<td style="vertical-align:middle;">' + item.ItemCode + '</td>' +
                                '<td style="vertical-align:middle;">' + item.Dscription + '</td>' +
