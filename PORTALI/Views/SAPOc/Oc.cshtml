    function calcularTotal(fila) {
        var cantidad = parseFloat(fila.querySelector('#cantidad').value) || 0;
        var precio = parseFloat(fila.querySelector('#precio').value) || 0;
        var total = precio * cantidad;
        fila.querySelector('#Total').innerHTML = Number(total).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    }

    //LISTA DE PRESPUESTO
    function ObtenerPepto() {
        const filas = document.querySelectorAll('#tblDetalles tbody tr');
        // Creamos un objeto para almacenar los totales agrupados
        const agrupados = {};

        // Recorremos cada fila de la tabla
        filas.forEach((fila) => {
            // Obtenemos el valor de la columna "Producto"
            const NombrePepto = fila.querySelector('td:nth-child(5)').textContent;

            // Obtenemos los valores de las columnas "Presupuesto", "Saldo" y "Total"
            const presupuesto = fila.querySelector('td:nth-child(6)').textContent;
            const total = parseFloat(fila.querySelector('#Total').textContent.replace("Q.","").replace(",",""));
            const saldo = parseFloat("0.00");

            // Si el producto ya existe en el objeto 'agrupados', solo sumamos 'saldo' y 'total'
            if (agrupados[NombrePepto]) {
                agrupados[NombrePepto].total += total;
                agrupados[NombrePepto].saldo = saldo;
            } else {
                // Si no existe, lo inicializamos con los valores actuales, incluyendo el presupuesto solo una vez
                agrupados[NombrePepto] = {
                    presupuesto: presupuesto, // El presupuesto solo se captura una vez
                    saldo: saldo,
                    total: total
                };
            }
        });

        // Obtenemos el cuerpo de la tabla donde se mostrarán los totales agrupados
        const tbodyAgrupado = document.querySelector('#tablaAgrupada tbody');

        // Limpiamos el contenido actual de la tabla de resultados agrupados
        tbodyAgrupado.innerHTML = '';

        // Iteramos sobre los productos agrupados y agregamos filas a la tabla
        for (const producto in agrupados) {
            // Creamos una nueva fila
            const fila = document.createElement('tr');
            // Creamos las celdas para el producto, presupuesto, saldo y total agrupado
            const celdaProducto = document.createElement('td');
            celdaProducto.textContent = producto;
            celdaProducto.style.fontSize = "10px";
            celdaProducto.style.width = "200px";

            const celdaPresupuesto = document.createElement('td');
            /*celdaPresupuesto.textContent = agrupados[producto].presupuesto;*/
            celdaPresupuesto.textContent = "Q." + Number(agrupados[producto].presupuesto).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })
            celdaPresupuesto.style.fontSize = "10px";
            celdaPresupuesto.style.textAlign = "right";

            const celdaTotal = document.createElement('td');
            celdaTotal.textContent = 'Q.' + agrupados[producto].total.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
            celdaTotal.style.fontSize = "10px";
            celdaTotal.style.textAlign = "right";

            const _saldo = celdaPresupuesto.textContent.replace("Q.", "").replace(",", "") - celdaTotal.textContent.replace("Q.", "").replace(",", "");
            const celdaSaldo = document.createElement('td');
            celdaSaldo.textContent = 'Q.' + _saldo.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
            celdaSaldo.style.fontSize = "10px";
            celdaSaldo.style.textAlign = "right";

            // Agregamos las celdas a la fila
            fila.appendChild(celdaProducto);
            fila.appendChild(celdaPresupuesto);
            fila.appendChild(celdaTotal);
            fila.appendChild(celdaSaldo);

            // Agregamos la fila al cuerpo de la tabla
            console.log(fila);
            tbodyAgrupado.appendChild(fila);
        }
    }

