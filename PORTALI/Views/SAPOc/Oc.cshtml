                var WhsCode = $("#lstTienda").val();

                if (textarea.length > 0) {
                     valor = textarea.val();
                }

                if (textCant.length > 0) {
                    valorCant = textCant.val();
                }

                if (textPrice.length > 0) {
                    valorPrice = textPrice.val();
                }

                var fila = {
                    ItemCode: $(this).find("td:eq(1)").text(),
                    Quantity: valorCant,
                    Price: valorPrice,
                    LineNum: 0,
                    WhsCode: WhsCode,
                    NotasLine: valor
                };
                tablaDatos.push(fila);
            });

            var formData = new FormData();
            for (var i = 0; i < selectedFiles.length; i++) {
                formData.append('files', selectedFiles[i]);
            }

            $("#globalLoading").show();
            var jsonData = {
                DocEntry: (document.getElementById('txtDocEntry').value == "" ? 0 : document.getElementById('txtDocEntry').value),
                DocNum: 0,
                IdSucursal: $("#lstSucursal").val(),
                IdDepto: $("#lstDepto").val(),
