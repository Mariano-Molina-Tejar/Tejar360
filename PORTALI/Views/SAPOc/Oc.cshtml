                DocDueDate: document.getElementById("txtDocDueDate").value,
                Email: $("#txtCorreo").val(),
                Observaciones: $("#txtObservaciones").val(),
                UserCode: '@(Model?.UserCode ?? "")',
                DetalleTabla: (tablaDatos.length == 0 ? null : tablaDatos)
            };

            formData.append('jsonData', JSON.stringify(jsonData));
            $.ajax({
                url: '@Url.Action("AddSolicitud", "SAPOc")',
                type: 'POST',
                data: formData,
                processData: false,
                contentType: false,
                success: function (respuesta) {
                    $("#globalLoading").hide();
                    $("#vistaResultado").modal('show');
                    $("#txtMensaje").text(respuesta.message);
                    $('#listError').empty();

                    if (respuesta.result == 1) {
                        suss = 1;
                        document.getElementById('imgMsg').src = '@Url.Content("~/Img/check_512.png")';
                    } else if (respuesta.result == 101) {
                        suss = 0;
                        console.log(respuesta);
                        $('#listError').empty();
                        document.getElementById('imgMsg').src = '@Url.Content("~/Img/cancel_512.png")';
                        respuesta.data.forEach(function (elemento) {
                            $('#listError').append('<li>' + elemento + '</li>');
                        });
                    } else {
                        suss = 0;
                        document.getElementById('imgMsg').src = '@Url.Content("~/Img/cancel_512.png")';
                    }
                },
                error: function (xhr, status, error) {
                    suss = 0;
                    $("#globalLoading").hide();
                    document.getElementById('imgMsg').src = '@Url.Content("~/Img/cancel_512.png")';
                    $("#vistaResultado").modal('show');
                    $("#txtMensaje").text(error);
                }
            });
        });
    });

