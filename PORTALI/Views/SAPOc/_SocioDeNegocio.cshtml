@model List<Entity.SocioNegocioEntity>

@if (Model != null)
{
    if (Model.Count == 0)
    {
        <td id="titulo2" colspan="10" style="text-align:center;height:100px;color:gray;vertical-align:middle;font-size:12px"><i>No hay datos</i></td>
        return;
    }

    foreach (var item in Model)
    {
        <tr>
            <td>@item.CardCode</td>
            <td>@item.CardName</td>            
            <td style="width:80px;"><button type="button" class="btn btn-outline-primary fa fa-plus-circle" onclick="OtenerValorSocioNegocio(this)"></button></td>
        </tr> 
    }
}
else
{
    <td id="titulo2" colspan="10" style="text-align:center;height:100px;color:gray;vertical-align:middle;font-size:12px"><i>No hay datos</i></td>
}