            }

            .label-custom.warning {
                background-color: #ffc107; /* amarillo */
            }

            .label-custom.danger {
                background-color: #dc3545; /* rojo */
            }

            .label-custom.info {
                background-color: #4c7fb0; /* rojo */
            }

            .label-custom.SinOC {
                background-color: #ff0000; /* rojo */
            }

        .table-hover tbody tr:hover {
            background-color: #dddddd; /* Cambia este color al que prefieras */
            /*color: blue;*/ /* También puedes cambiar el color del texto si es necesario */
        }

        #miTextarea {
            border: none; /* Quitar el borde por defecto */
            outline: none; /* Quitar el borde al hacer clic */
            background-color: white;
        }

            /* Asegurarse de que no se remarca al recibir el foco */
            #miTextarea:focus {
                border: none;
                outline: none;
                background-color: white;
            }


        body {
            margin: 0; /* Eliminar margen por defecto */
            padding: 0; /* Eliminar padding por defecto */
            font-family: Arial, sans-serif; /* Fuente más legible */
        }

        /*.tabla-con-scroll {
            width: 100%;*/ /* Ancho total de la ventana */
            /*height: 100%;*/ /* Altura del contenedor (ajusta según necesites) */
            /*overflow-y: auto;*/ /* Scroll vertical automático */
            /*border: 0px solid #ccc;*/ /* Borde alrededor de la tabla */

            /*position: relative;*/ /* Posicionamiento relativo */
        /*}*/

        /* Estilos del panel */
        .panel {
            width: 90%;
            margin: 20px auto;
            border: 1px solid #dddddd;
            border-radius: 10px;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
            background-color: #ffffff;
            overflow: hidden;
        }

        .panel-header {
            background-color: #009879;
            color: white;
            padding: 15px;
            text-align: center;
            font-size: 20px;
            font-weight: bold;
            text-transform: uppercase;
        }

        .panel-body {
            padding: 20px;
        }

        /* Estilos de la tabla */
        .styled-table {
            width: 100%;
            border-collapse: collapse;
            font-family: Arial, sans-serif;
            font-size: 16px;
            margin: 20px 0;
            background-color: #f3f3f3;
            box-shadow: 0 2px 5px rgba(0, 0, 0, 0.2);
        }

            .styled-table thead tr {
                background-color: #009879;
                color: #ffffff;
                text-align: left;
            }

            .styled-table th, .styled-table td {
                padding: 12px 15px;
                text-align: center;
                border: 1px solid #dddddd;
            }

            .styled-table tbody tr {
                transition: background-color 0.3s ease;
            }

                .styled-table tbody tr:nth-child(even) {
                    background-color: #f3f3f3;
                }

                .styled-table tbody tr:hover {
                    background-color: #d1e7dd;
                }

            .styled-table tbody td {
                color: #333333;
            }

        /* Estilos del botón */
        .btn-show {
            border: none;
            padding: 8px 12px;
            cursor: pointer;
            border-radius: 5px;
            font-size: 14px;
            color: white;
            background-color: #007bff;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 5px;
        }

            .btn-show:hover {
                background-color: #0056b3;
            }

            .btn-show i {
                font-size: 16px;
            }

        /* Estilo para el mensaje de "No hay datos" */
        .no-data {
            font-style: italic;
            color: #777777;
            text-align: center;
        }






        /*th, td {
            border: 1px solid black;*/ /* Borde para celdas */
            /*padding: 8px;*/ /* Espacio interior */
            /*text-align: left;*/ /* Alinear texto a la izquierda */
        /*}*/

        /* Estilo para el encabezado de tabla */
        /*thead th {
            position: sticky;*/ /* Fijar encabezado */
            /*top: 0;*/ /* Mantener en la parte superior al hacer scroll */
            /*background-color: #f2f2f2;*/ /* Fondo del encabezado */
            /*z-index: 1;*/ /* Mantener por encima del contenido */
        /*}*/
    </style>
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/2.1.3/jquery.min.js"></script>
    <script src="https://maxcdn.bootstrapcdn.com/bootstrap/3.3.5/js/bootstrap.min.js"></script>
</head>

<div class="panel">
    <div class="panel-header">
        Listado solicitud de compras
    </div>
    <div class="panel-body">
        <div class="panel-body" style="background-color: white; padding: 15px;">
            <div class="row">
                <div class="col-md-6 text-right">
                    <a class="btn" href="@Url.Action("Oc", "SAPOc")"
                       style="font-weight: bold;
                background-color: #00796b;
                color: white;
                border-radius: 5px;
                padding: 10px 10px;
                border: 2px solid #00796b;
                text-decoration: none;
                margin-bottom:10px;
                font-size:13px;
                width:200px;
                transition: all 0.3s ease;
                box-shadow: 0px 4px 6px rgba(0, 0, 0, 0.1);"
                       onmouseover="this.style.backgroundColor='#004d40'; this.style.borderColor='#004d40';"
                       onmouseout="this.style.backgroundColor='#00796b'; this.style.borderColor='#00796b';">
                        Nueva solicitud
                    </a>
                </div>
            </div>

            <!-- Tabla con scroll -->
            <div class="tabla-con-scroll" style="overflow-x: auto;">
                <table class="styled-table" id="tblSolicitudes">
                    <!-- Cabecera de la Tabla -->
                    <thead style="background-color: #00796b; color: white; text-align: center;">
                        <tr>
                            <th style="width:25px">#</th>
                            <th style="width:45px">Llave</th>
                            <th style="width:60px">Temporal</th>
                            <th>Creado</th>
                            <th>Usuario</th>
                            <th>Proveedor</th>
                            <th>Comentarios</th>
                            <th style="width:200px">Estado</th>
                            <th style="width:105px">Opciones</th>
                        </tr>
                    </thead>
                    <!-- Cuerpo de la Tabla -->
                    <tbody style="text-align: center; color: #666;">
                        @if (Model != null && Model.Count > 0)
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <th scope="row" style="vertical-align: middle">@item.Rw</th>
                                    <td style="vertical-align: middle">@item.DocEntry</td>
                                    <td style="vertical-align: middle">@item.DocNum</td>
                                    <td style="vertical-align: middle">@item.DocDate.ToShortDateString()</td>
                                    <td style="vertical-align: middle">@item.UserName</td>
                                    <td style="vertical-align: middle">@item.CardName</td>
                                    <td style="vertical-align: middle">
                                        <textarea id="miTextarea_@item.Rw" class="form-control"
                                                  style="height: 35px; font-size: 12px; background-color: white; border: none; outline: none"
                                                  readonly>
                                            @item.Comentarios
                                        </textarea>
                                    </td>
                                    <td style="vertical-align: middle">
                                        <span class="label-custom @item.ColorEstado">@item.Estado</span>
                                    </td>
                                    <td class="p-1" style="text-align: center; vertical-align: middle">
                                        <a id="btnEditar_@item.Rw" class="btn btn-outline-primary fa fa-edit"
                                           onclick="Editar(this);" title="Editar"></a>
                                        @if (item.IdEstado == "5")
                                        {
                                            <a id="generatePdf_@item.Rw"
                                               class="btn btn-outline-warning fa fa-file-pdf-o"
                                               title="Orden de compra @item.DocNumOc"
                                               data-docnumoc="@item.DocEntryOc"
                                               onclick="GenerarPdf(this);"></a>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="9" style="text-align: center; height: 100px; color: gray; vertical-align: middle; font-size: 12px;">
                                    <i>No hay datos</i>
                                </td>
                            </tr>
                        }

                    </tbody>
                </table>
            </div>
        </div>
        <!-- Paginación -->
        <nav aria-label="Page navigation">
            <ul class="pagination justify-content-center" id="pagination" style="margin: 15px 0;">
                <!-- Los elementos de paginación se generarán aquí -->
            </ul>
        </nav>
    </div>
</div>

<script>
    function Editar(elemento) {        
        const fila = elemento.closest('tr');
        const textarea = fila.querySelector('textarea');
        textarea.removeAttribute('readonly');
        textarea.focus();
    }

    function GenerarPdf(elemento) {
        $("#globalLoading").show();
        const docEntryOc = elemento.getAttribute("data-docnumoc");
        fetch('/SAPOc/GeneratePdfAjax', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify({ docEntry: docEntryOc }),
        }).then(response => response.blob())
            .then(blob => {
                $("#globalLoading").hide();
                const url = window.URL.createObjectURL(blob);
                window.open(url, '_blank');
            })
            .catch(error => console.error('Error al generar el PDF:', error));
    }


    $(document).ready(function () {
        var itemsPerPage = 10;
        var items = $("#tblSolicitudes tbody tr");
        var numItems = items.length;
        var numPages = Math.ceil(numItems / itemsPerPage);
        
        items.slice(itemsPerPage).hide();
        for (var i = 1; i <= numPages; i++) {
            $("#pagination").append("<li class='page-item'><a class='page-link' href='#'>" + i + "</a></li>");
        }

        $("#pagination li:first-child").addClass("active");
        $("#pagination li").on("click", function () {
            var page = $(this).index();
            $("#pagination li").removeClass("active");
            $(this).addClass("active");

            // Mostrar los elementos correspondientes a la página seleccionada
            var start = page * itemsPerPage;
            var end = start + itemsPerPage;
            items.hide().slice(start, end).show();
        });
    });

    function Editar(getValue) {
        var row = getValue.parentNode.parentNode;
        DocEntry = row.cells[1].innerText;
        var url = '@Url.Action("Oc", "SAPOc", new { DocEntry = "__valor__" })';
        url = url.replace("__valor__", DocEntry);
        window.location.href = url;
    }
</script>