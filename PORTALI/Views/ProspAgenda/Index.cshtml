<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Agenda de Programación</title>
    <link href="~/Css/ProspeccionAgenda.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
        body {
            background-color: white;
        }

        .btn-disabled {
            background-color: #ccc !important;
            color: #666 !important;
            cursor: not-allowed;
            opacity: 0.7;
        }

            .btn-disabled i {
                color: #666 !important;
            }

        .btn-expand {
            background: none;
            border: none;
            cursor: pointer;
            font-size: 16px;
        }

        .tabla-detalle {
            width: 100%;
            border: 1px solid #ddd;
            border-collapse: collapse;
            margin-top: 5px;
        }

            .tabla-detalle th, .tabla-detalle td {
                border: 1px solid #ddd;
                padding: 5px;
                text-align: center;
            }

        .tabs {
            display: flex;
            border-bottom: 2px solid #ccc;
            margin-bottom: 10px;
        }

        .tab-button {
            padding: 10px 20px;
            cursor: pointer;
            border: none; /* quita el borde */
            background: none; /* fondo transparente */
            outline: none; /* quita el borde al focus */
            font-weight: bold;
        }

            .tab-button:focus {
                outline: none; /* quita el borde al hacer focus */
                box-shadow: none; /* quita cualquier sombra de enfoque */
            }


            .tab-button.active {
                border-bottom: 3px solid #007bff;
                color: #007bff;
            }

        .tab-content {
            display: none;
        }

        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 10px;
        }

        .btn {
            padding: 5px 10px;
            cursor: pointer;
            border: none; /* quita el borde */
            outline: none; /* quita el borde al focus */
            background-color: #007bff; /* color de fondo opcional */
            color: white; /* color del texto */
            border-radius: 4px; /* bordes redondeados opcionales */
        }

            .btn:focus {
                outline: none; /* quita borde al hacer focus */
                box-shadow: none; /* quita sombra de enfoque */
            }

        .btn2 {
            padding: 5px 10px;
            cursor: pointer;
            border: none; /* quita el borde */
            outline: none; /* quita el borde al focus */
            background-color: green; /* color de fondo opcional */
            color: white; /* color del texto */
            border-radius: 4px; /* bordes redondeados opcionales */
        }

            .btn2:focus {
                outline: none; /* quita borde al hacer focus */
                box-shadow: none; /* quita sombra de enfoque */
            }


        table {
            width: 100%;
            border-collapse: collapse;
        }

        table, th, td {
            border: 1px solid #ccc;
        }

        th, td {
            padding: 8px;
            text-align: left;
        }

        .no-data {
            text-align: center;
            color: #777;
        }

        #tablaRevisitas thead {
            background-color: #000; /* Fondo negro */
            color: #fff; /* Letras blancas */
        }

        #tablaRevisitas th {
            border: 1px solid #fff; /* Borde blanco opcional */
            padding: 8px; /* Espaciado interno */
        }

    </style>
</head>
<body>
