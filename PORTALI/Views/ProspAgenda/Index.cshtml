                    if (data && data.length > 0) {
                        if (data.length > 1) {
                            $('#filtroMunicipio').append($('<option>', { value: '-101', text: '-- Seleccionar --' }));
                        }
                        $.each(data, function (index, item) {
                            $('#filtroMunicipio').append(
                                $('<option>', {
                                    value: item.Id,
                                    text: item.Nombre
                                })
                            );
                        });
                        if (data.length === 1) {
                            $('#filtroMunicipio').val(data[0].Id).trigger('change');
                            $('#filtroMunicipio').prop('disabled', true);
                        } else {
                            $('#filtroMunicipio').val('-101').trigger('change');
                            $('#filtroMunicipio').prop('disabled', false);
                        }
                    } else {
                        $('#filtroMunicipio')
                            .html('')
                            .append($('<option>', { value: '-101', text: '-- Seleccionar --' }))
                            .val('-101')
                            .prop('disabled', false);
                    }
                },
                error: function (xhr, status, error) {
                    console.error("Error al cargar los municipios:", error);
                    $('#filtroMunicipio').val('-101').prop('disabled', false);
                },
                complete: function () {
                    $("#globalLoading").hide();
                }
            });
        }

        function CargarZonas() {
            $('#filtroZonas')
                .html('') // limpiar todo
                /*.append($('<option>', { value: '-1', text: '-- Seleccionar --' }))*/
                .val('-1')
                .trigger('change');

            $.ajax({
                url: '@Url.Action("ListadoZonas", "ProspAgenda")',
                type: "POST",
                success: function (data) {
                    if (data && data.length > 0) {
                        if (data.length > 1) {
                            $('#filtroZonas').append($('<option>', { value: '-101', text: '-- Seleccionar --' }));
                        }
                        $.each(data, function (index, item) {
                            $('#filtroZonas').append(
                                $('<option>', {
                                    value: item.Id,
                                    text: item.Nombre
                                })
                            );
                        });
                        if (data.length === 1) {
                            $('#filtroZonas').val(data[0].Id).trigger('change');
                            $('#filtroZonas').prop('disabled', true);
                        } else {
                            $('#filtroZonas').val('-101').trigger('change');
                            $('#filtroZonas').prop('disabled', false);
                        }
                    } else {
                        $('#filtroZonas')
                            .html('')
                            .append($('<option>', { value: '-101', text: '-- Seleccionar --' }))
                            .val('-101')
                            .prop('disabled', false);
                    }
                },
                error: function (xhr, status, error) {
                    console.error("Error al cargar los municipios:", error);
                    $('#filtroZonas').val('-101').prop('disabled', false);
                },
                complete: function () {
                    $("#globalLoading").hide();
                }
            });
        }

        $('#filtroMunicipio').on('change', function () {

        });

        function openModal() {
            document.getElementById('agregarModal').style.display = 'flex';
        }

        function closeModal() {
            document.getElementById('agregarModal').style.display = 'none';
            document.getElementById('formProgramacion').reset();
        }

        function Save() {
            Swal.fire({
                title: '¿Desea guardar?',
                text: "Se guardarán los cambios realizados.",
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#3085d6',
                cancelButtonColor: '#d33',
                confirmButtonText: 'Sí, guardar',
                cancelButtonText: 'Cancelar'
            }).then((result) => {
                if (result.isConfirmed) {

                    $("#globalLoading").show();

                    var parametrosEnviar = {
                        U_UserId: $('#filtroAsesor').val(),
                        U_IdDepto: $('#filtroDepto').val(),
                        U_IdMunicipio: $('#filtroMunicipio').val(),
                        U_IdColonia: $('#aldea').val(),
                        U_WhsCode: $('#filtroTienda').val(),
                        U_IdZona: $('#filtroZonas').val(),
                        U_FechaInicio: $('#fechaInicial').val(),
                        U_FechaFinal: $('#fechaFinal').val(),
                        U_Notas: $('#observacion').val(),
                        U_Estado: "Y"
                    };

                    $.ajax({
                        url: '@Url.Action("GuardarProgramacion", "ProspAgenda")',
                        type: 'POST',
                        data: JSON.stringify(parametrosEnviar),
                        contentType: 'application/json; charset=utf-8',
                        dataType: 'json',
                        success: function (respuesta) {
                            $("#globalLoading").hide();

                            Swal.fire({
                                title: '¡Éxito!',
                                text: 'Los datos se guardaron correctamente.',
                                icon: 'success',
                                confirmButtonText: 'Aceptar',
                                allowOutsideClick: false, // 🔒 no se puede cerrar clickeando afuera
                                allowEscapeKey: false     // 🔒 no se cierra con la tecla ESC
                            }).then(() => {
                                location.reload(); // 🔄 recarga la página al cerrar el swal
                            });
                        },
                        error: function (xhr, status, error) {
                            $("#globalLoading").hide();

                            Swal.fire({
                                title: 'Error',
                                text: 'Ocurrió un problema al guardar los datos. Detalle: ' + error,
                                icon: 'error',
                                confirmButtonText: 'Cerrar'
                            });
                        }
                    });
                }
            });
        }

        function cargarProgramacion() {

            let tbody = $("#tablaProgramacion");
            tbody.html(`
                        <tr>
                            <td colspan="9" style="text-align:center;">
                                <img src="/img/loading_circulo.gif" alt="Cargando" style="width:50px; height:50px;"><br />
                                Cargando datos...
                            </td>
                        </tr>
                    `);

            $.ajax({
                url: '/ProspAgenda/CargarData',
                type: 'GET',
                dataType: 'json',
                success: function (data) {
                    let tbody = $("#tablaProgramacion");
                    tbody.empty();
                    console.log("Programcion", data);
                    if (data && data.length > 0) {
                        $.each(data, function (i, item) {
                            // Botón Play/Stop
                            let icono = item.EstadoPlay ? 'fas fa-stop' : 'fas fa-play';
                            let texto = item.EstadoPlay ? 'Stop' : 'Play';

                            let disabledAttr = '';
                            let disabledClass = '';
                            if (!item.Enableds) {
                                disabledAttr = 'disabled';
                                disabledClass = 'btn-disabled';
                            }

                            // Link Visita: bloqueado si EstadoPlay es false
                            let visitaDisabledClass = '';
                            let visitaClick = '';
                            if (!item.EstadoPlay) { // aquí verificamos si es false
                                visitaDisabledClass = 'btn-disabled';
                                visitaClick = 'return false;';
                            }

                            //<a href="/ProspVisita/Index" class="btn visita-btn ${visitaDisabledClass}" onclick="${visitaClick}" title="Visita">
                            //    <i class="fas fa-eye"></i>
                            //    <span class="texto">Visita</span>
                            //</a>

                            let fila = `
                                <tr class="fila-principal" data-id="${item.Id}">
                                    <td class="expand-btn">
                                        <button class="btn-expand">
                                            <i class="fas fa-chevron-right"></i>
                                        </button>
                                    </td>
                                    <td>${item.Region}</td>
                                    <td>${item.WhsName}</td>
                                    <td>${item.SlpName}</td>
                                    <td>${item.AreaAsignada}</td>
                                    <td>${formatearFecha(item.FechaInicio)} - ${formatearFecha(item.FechaFinal)}</td>
                                    <td></td>
                                    <td></td>
                                    <td style="display: flex; gap: 5px;">
                                        <button class="btn ${disabledClass}" title="${texto}" ${disabledAttr} onclick="iniciarProceso(${item.Id}, ${item.EstadoPlay}, ${item.IdPunto})">
                                            <i class="${icono}"></i>
                                            <span class="texto">${texto}</span>
                                        </button>
                                    </td>
                                </tr>

                                <!-- Fila oculta para la tabla hija -->
                                <tr class="fila-detalle" style="display:none;">
                                    <td colspan="9">
                                        <table class="tabla-detalle">
                                            <thead>
                                                <tr>
                                                    <th>Id</th>
                                                    <th>Fecha</th>
                                                    <th>Visitas</th>
                                                    <th>Re-visitas</th>
                                                    <th>Opciones</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <tr>
                                                    <td>1</td>
                                                    <td>${formatearFecha(item.FechaInicio)}</td>
                                                    <td>${item.NumVisitas ?? 0}</td>
                                                    <td></td>
                                                </tr>
                                            </tbody>
                                        </table>
                                    </td>
                                </tr>
                            `;
                            tbody.append(fila);
                        });

                        $(document).on("click", ".btn-expand", function () {
                            const button = $(this);
                            const tr = button.closest("tr");
                            const IdPlan = tr.data("id");

                            // 🔹 Cierra todas las filas abiertas antes de abrir la seleccionada
                            $(".btn-expand").not(button).find("i")
                                .removeClass("fa-chevron-down")
                                .addClass("fa-chevron-right");
                            $(".fila-detalle").remove();
                            $("tr.expanded").removeClass("expanded");

                            // 🔹 Si ya estaba abierta, la cerramos y salimos
                            if (tr.hasClass("expanded")) return;

                            // 🔹 Marca como expandida y cambia ícono
                            tr.addClass("expanded");
                            button.find("i").removeClass("fa-chevron-right").addClass("fa-chevron-down");

                            // 🔹 Llamada AJAX para traer el detalle
                            $.ajax({
                                url: '/ProspAgenda/CargarDetalle',
                                type: 'GET',
                                data: { IdPlan: IdPlan },
                                dataType: 'json',
                                success: function (data) {
                                    // 🔹 Construye las filas del detalle
                                    let detalleHtml = '';
                                    if (data && data.length > 0) {
                                        data.forEach(function (item, index) {
                                            const botonVisita = !item.U_FechaFinal
                                                ? `<a href="/ProspVisita/Index?code=${item.Code}" class="btn visita-btn" title="Visita">
                                                        <i class="fas fa-eye"></i>
                                                        <span class="texto">Visita 5/2</span>
                                                   </a>`
                                                : '';

                                            const botonReVisita = !item.U_FechaFinal
                                                ? `<button class="btn2 visita-btn" title="Re-Visita" onclick="abrirModalReVisita(${item.Code})">
                                                        <i class="fas fa-eye"></i>
                                                        <span class="texto">Re-Visita</span>
                                                   </button>`
                                                : '';

                                            detalleHtml += `
                                                <tr>
                                                    <td>${index + 1}</td>
                                                    <td>${formatearFecha2(item.U_FechaInicio)}</td>
                                                    <td>${item.U_FechaFinal ? formatearFecha2(item.U_FechaFinal) : ''}</td>
                                                    <td>${item.U_Lugar}</td>
                                                    <td>${item.U_LugarFinal ? item.U_LugarFinal : ''}</td>
                                                    <td>${botonVisita}</td>
                                                    <td>${botonReVisita}</td>
                                                </tr>
                                            `;
                                        });
                                    } else {
                                        detalleHtml = `<tr><td colspan="5">No hay detalles</td></tr>`;
                                    }

                                    // 🔹 Agrega la fila detalle debajo de la principal
                                    const filaDetalle = `
                                    <tr class="fila-detalle">
                                        <td colspan="9">
                                            <table class="tabla-detalle">
                                                <thead>
                                                    <tr>
                                                        <th>#</th>
                                                        <th>Fecha inicial</th>
                                                        <th>Fecha final</th>
                                                        <th>Punto de inicio</th>
                                                        <th>Punto final</th>
                                                        <th>Visitas</th>
                                                        <th>Re-visitas</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    ${detalleHtml}
                                                </tbody>
                                            </table>
                                        </td>
                                    </tr>
                                `;
                                    tr.after(filaDetalle);
                                },
                                error: function (xhr, status, error) {
                                    console.error("Error cargando detalle:", error);
                                }
                            });
                        });
                    } else {
                        tbody.append('<tr><td colspan="8" class="no-data">No hay datos</td></tr>');
                    }
                },
                error: function (xhr, status, error) {
                    console.error("Error cargando datos:", error);
                }
            });
        }

        function abrirModalReVisita(codeObra) {
            const tbody = document.getElementById("tablaReVisita");

            // Aquí puedes hacer un fetch / AJAX para traer los datos según el codeObra
            // Por ejemplo:
            // fetch(`/api/getReVisitas?code=${codeObra}`).then(res => res.json()).then(data => {...})

            // Por ahora voy a poner un ejemplo estático
            const datos = [
                { noObra: "001", fecha: "22/09/2025", nombre: "Obra A", estado: "Pendiente", contacto: "Juan Pérez", telefono: "555-1234" },
                { noObra: "002", fecha: "25/09/2025", nombre: "Obra B", estado: "Realizada", contacto: "Ana López", telefono: "555-5678" }
            ];

            // Limpiar tabla
            tbody.innerHTML = "";

            if (datos.length === 0) {
                tbody.innerHTML = `<tr><td colspan="6" class="text-center text-muted fst-italic">No hay visitas registradas</td></tr>`;
            } else {
                datos.forEach(d => {
                    const tr = document.createElement("tr");
                    tr.innerHTML = `
                <td>${d.noObra}</td>
                <td>${d.fecha}</td>
                <td>${d.nombre}</td>
                <td>${d.estado}</td>
                <td>${d.contacto}</td>
                <td>${d.telefono}</td>
            `;
                    tbody.appendChild(tr);
                });
            }

            // Abrir modal
            const modal = new bootstrap.Modal(document.getElementById("modalReVisita"));
            modal.show();
        }


        function iniciarProceso(id, EstadoPlay, IdPunto) {
            $("#globalLoading").show();
            if (!navigator.geolocation) {
                Swal.fire({
                    title: 'Error',
                    text: 'La geolocalización no está soportada en este navegador.',
                    icon: 'error'
                });
                return;
            }

            navigator.geolocation.getCurrentPosition(async (position) => {
                let lat = position.coords.latitude;
                let lon = position.coords.longitude;

                // 🔥 Intentamos obtener nombre del lugar usando OpenStreetMap (gratis)
                let lugar = 'Ubicación desconocida';
                try {
                    const response = await fetch(`https://nominatim.openstreetmap.org/reverse?format=json&lat=${lat}&lon=${lon}`);
                    const data = await response.json();
                    if (data && data.display_name) {
                        lugar = data.display_name;
                    }
                } catch (error) {
                    console.warn('No se pudo obtener el nombre del lugar:', error);
                }

                $("#globalLoading").hide();
                Swal.fire({
                    title: EstadoPlay == false ? '¿Empezar recorrido?' : '¿Finalizar recorrido?',
                    html: `
                        <p><b>Latitud:</b> ${lat.toFixed(6)}</p>
                        <p><b>Longitud:</b> ${lon.toFixed(6)}</p>
                        <p><b>Lugar identificado:</b> ${lugar}</p>
                    `,
                    icon: 'question',
                    showCancelButton: true,
                    confirmButtonText: EstadoPlay == false ? 'Sí, iniciar' : 'Sí, finalizar',
                    cancelButtonText: 'Cancelar'
                }).then((result) => {
                    if (result.isConfirmed) {
                        let datos = {
                            Code: IdPunto,
                            U_Planificacion: id,
                            U_Longitud: lon.toFixed(6),
                            U_Latitud: lat.toFixed(6),
                            U_FechaHora: null,
                            U_Lugar: lugar,
                            U_Estado: "Y",
                            validar: EstadoPlay
                        };
                        $.ajax({
                            url: '/ProspAgenda/GuardarPuntoDePartida',
                            type: 'POST',
                            dataType: 'json',
                            data: datos,
                            success: function (data) {
                                Swal.fire({
                                    title: EstadoPlay == false ? 'Proceso iniciado' : 'Proceso finalizado',
                                    text: EstadoPlay == false ? `Se ha iniciado correctamente en ${lugar}` : `Se ha finalizado correctamente en ${lugar}`,
                                    icon: 'success',
                                    timer: 4500,
                                    showConfirmButton: false,
                                    didClose: () => {
                                        // 🔄 recarga la página cuando el Swal se cierra
                                        window.location.reload();
                                    }
                                });
                            },
                            error: function (xhr, status, error) {
                                console.error("Error cargando datos:", error);
                            }
                        });
                    }
                });
            }, (error) => {
                Swal.fire({
                    title: 'Error',
                    text: 'No se pudo obtener la ubicación. Activa el GPS o permisos de ubicación.',
                    icon: 'error'
                });

                $("#globalLoading").hide();
            });
        }

        function formatearFecha(fechaJson) {
            if (!fechaJson) return '--'; // Si viene null, undefined o vacío
            try {ValidityState
                const timestamp = parseInt(fechaJson.match(/\d+/)[0]);
                const fecha = new Date(timestamp);
                const dia = fecha.getDate().toString().padStart(2, '0');
                const mes = (fecha.getMonth() + 1).toString().padStart(2, '0');
                const anio = fecha.getFullYear();
                return `${dia}/${mes}/${anio}`;
            } catch (e) {
                return '--'; // Si falla el parseo, también muestra --
            }
        }

        function formatearFecha2(fechaJson) {
            if (!fechaJson) return '--'; // Si viene null, undefined o vacío
            try {
                const timestamp = parseInt(fechaJson.match(/\d+/)[0]);
                const fecha = new Date(timestamp);

                const dia = fecha.getDate().toString().padStart(2, '0');
                const mes = (fecha.getMonth() + 1).toString().padStart(2, '0');
                const anio = fecha.getFullYear();

                const horas = fecha.getHours().toString().padStart(2, '0');
                const minutos = fecha.getMinutes().toString().padStart(2, '0');
                const segundos = fecha.getSeconds().toString().padStart(2, '0');

                return `${dia}/${mes}/${anio} ${horas}:${minutos}:${segundos}`;
            } catch (e) {
                return '--'; // Si falla el parseo, también muestra --
            }

        }
    </script>
