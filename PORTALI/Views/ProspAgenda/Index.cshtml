    <script>

        function openTab(evt, tabName) {
            // Ocultar todos los tab-content
            var tabContents = document.querySelectorAll(".tab-content");
            tabContents.forEach(tc => tc.style.display = "none");

            // Quitar la clase active de todos los botones
            var tabButtons = document.querySelectorAll(".tab-button");
            tabButtons.forEach(tb => tb.classList.remove("active"));

            // Mostrar el tab seleccionado
            document.getElementById(tabName).style.display = "block";
            evt.currentTarget.classList.add("active");
        }

        function openModal() {
            alert("Aquí abres modal para agregar programación");
        }

        function openModalRevisita() {
            alert("Aquí abres modal para agregar re-visita");
        }

        $(document).ready(function () {
            CargarRegiones();
            CargarDepartamentos(-1);
            cargarProgramacion();
            CargarZonas();
        });

        function CargarRegiones() {
            $.ajax({
                url: '@Url.Action("ListadoRegiones", "BolsonActivo")',
                type: "POST",
                success: function (data) {
                    if (data && data.length > 0) {
                        $.each(data, function (index, item) {
                            $('#filtroRegion').append(
                                $('<option>', {
                                    value: item.IdRegion,
                                    text: item.Region
                                })
                            );
                        });
                        if (data.length === 1) {
                            $('#filtroRegion').val(data[0].IdRegion).trigger('change');
                            CargarTiendas(data[0].IdRegion);
                            $('#filtroRegion').prop('disabled', true);
                        } else {
                            $('#filtroRegion').val('-1').trigger('change');
                            CargarTiendas(-1);
                            $('#filtroRegion').prop('disabled', false);
                        }
                    } else {
                        $('#filtroRegion').val('-1');
                    }
                },
                error: function (xhr, status, error) {
                    console.error("Error al cargar las regiones:", error);
                    $('#filtroRegion').val('-1');
                },
                complete: function () {
                    $("#globalLoading").hide();
                }
            });
        }

        $('#filtroRegion').on('change', function () {
            let idRegion = $('#filtroRegion').val();
            let whsCode = $('#filtroTienda').val();
            CargarTiendas(idRegion);
            CargarDepartamentos(idRegion, whsCode);
            CargarMunicipios(-1)
            CargarZonas();
        });

        function CargarTiendas(idRegion) {
            let $filtroTienda = $('#filtroTienda');

            $filtroTienda
                .empty()
                .append($('<option>', { value: '-1', text: '-- Seleccionar --' }))
                .val('-1')
                .trigger('change')
                .prop('disabled', true);

            $.ajax({
                url: '@Url.Action("ListadoTiendas", "BolsonActivo")',
                type: "POST",
                data: { IdRegion: idRegion },
                success: function (data) {
                    if (data && data.length > 0) {
                        $.each(data, function (index, item) {
                            $filtroTienda.append(
                                $('<option>', {
                                    value: item.WhsCode,
                                    text: item.WhsName
                                })
                            );
                        });

                        if (data.length === 1) {
                            // 🔹 Solo una tienda → selecciona automáticamente
                            $filtroTienda.val(data[0].WhsCode).trigger('change');
                            $filtroTienda.prop('disabled', true);

                            CargarUsuarios(idRegion, data[0].WhsCode);
                            /*CargarDepartamentos(idRegion, data[0].WhsCode);*/
                        } else {
                            // 🔹 Varias tiendas → dejar en -1
                            $filtroTienda.val('-1').trigger('change');
                            $filtroTienda.prop('disabled', false);
                            /*CargarDepartamentos(idRegion, -1);*/
                        }
                    } else {
                        // 🔹 Si no hay data → dejar en -1
                        $filtroTienda.val('-1').trigger('change');
                    }
                },
                error: function (xhr, status, error) {
                    console.error("Error al cargar las tiendas:", error);
                    $filtroTienda.val('-1').trigger('change');
                },
                complete: function () {
                    $("#globalLoading").hide();
                }
            });
        }

        $('#filtroTienda').on('change', function () {
            let idRegion = $('#filtroRegion').val();
            let WhsCode = $('#filtroTienda').val();
            CargarDepartamentos(idRegion, WhsCode);
            CargarUsuarios(idRegion, WhsCode);
            CargarZonas();
        });

        function CargarUsuarios(idRegion, whsCode) {
            $('#filtroAsesor').html('');
            $.ajax({
                url: '@Url.Action("ListaDeAsesores", "BolsonActivo")',
                type: "POST",
                data: { IdRegion: idRegion, WhsCode: whsCode },
                success: function (data) {
                    if (data && data.length > 0) {
                        if (data.length > 1) {
                            $('#filtroAsesor').append($('<option>', { value: '-101', text: '-- Seleccionar --' }));
                        }
                        $.each(data, function (index, item) {
                            $('#filtroAsesor').append(
                                $('<option>', {
                                    value: item.SlpCode,
                                    text: item.SlpName
                                })
                            );
                        });
                        if (data.length === 1) {
                            $('#filtroAsesor').val(data[0].SlpCode).trigger('change');
                            $('#filtroAsesor').prop('disabled', true);
                        } else {
                            $('#filtroAsesor').val('-101').trigger('change');
                            $('#filtroAsesor').prop('disabled', false);
                        }
                    } else {
                        $('#filtroAsesor')
                            .html('')
                            .append($('<option>', { value: '-101', text: '-- Seleccionar --' }))
                            .val('-101')
                            .prop('disabled', false);
                    }
                },
                error: function (xhr, status, error) {
                    console.error("Error al cargar los asesores:", error);
                    $('#filtroAsesor').val('-101').prop('disabled', false);
                },
                complete: function () {
                    $("#globalLoading").hide();
                }
            });
        }

        function CargarDepartamentos(idRegion, whsCode) {
            $('#filtroDepto')
                .html('') // limpiar todo
                .append($('<option>', { value: '-1', text: '-- Seleccionar --' }))
                .val('-1')
                .trigger('change');

            $.ajax({
                url: '@Url.Action("ListadoDeptos", "ProspAgenda")',
                type: "POST",
                data: { IdRegion: idRegion, WhsCode: whsCode },
                success: function (data) {
                    if (data && data.length > 0) {
                        if (data.length > 1) {
                            $('#filtroDepto').append($('<option>', { value: '-101', text: '-- Seleccionar --' }));
                        }
                        $.each(data, function (index, item) {
                            $('#filtroDepto').append(
                                $('<option>', {
                                    value: item.Id,
                                    text: item.Nombre
                                })
                            );
                        });
                        if (data.length === 1) {
                            $('#filtroDepto').val(data[0].Id).trigger('change');
                            $('#filtroDepto').prop('disabled', true);
                            CargarMunicipios(data[0].Id);
                        } else {
                            $('#filtroDepto').val('-101').trigger('change');
                            $('#filtroDepto').prop('disabled', false);
                            CargarMunicipios(-1);
                        }
                    } else {
                        $('#filtroDepto')
                            .html('')
                            .append($('<option>', { value: '-101', text: '-- Seleccionar --' }))
                            .val('-101')
                            .prop('disabled', false);
                    }
                },
                error: function (xhr, status, error) {
                    console.error("Error al cargar los departamentos:", error);
                    $('#filtroDepto').val('-101').prop('disabled', false);
                },
                complete: function () {
                    $("#globalLoading").hide();
                }
            });
        }

        function CargarMunicipios(depto) {
            $('#filtroMunicipio')
                .html('') // limpiar todo
                /*.append($('<option>', { value: '-1', text: '-- Seleccionar --' }))*/
                .val('-1')
                .trigger('change');

            $.ajax({
                url: '@Url.Action("ListadoMunicipios", "ProspAgenda")',
                type: "POST",
