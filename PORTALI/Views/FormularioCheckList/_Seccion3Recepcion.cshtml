        <!-- Pregunta PR1 -->
        <div class="card shadow-sm mb-4 border-0">
            <div class="card-body">
                <h5 class="card-title text-primary">
                    <i class="bi bi-map-fill"></i> ¿Se planifican los espacios de almacenamiento para las rutas de abastecimiento?
                </h5>
                <div class="d-flex align-items-center mb-3">
                    <h2 class="mb-0 fw-bold" style="font-size: 1rem;">35. PR1</h2>
                </div>
                <div class="mb-3">
                    <div class="form-check form-check-inline">
                        @Html.RadioButtonFor(m => m.U_Recep_PR1, "Y", new { @class = "form-check-input", id = "PR1_SI" })
                        <label class="form-check-label" for="PR1">Sí</label>
                    </div>
                    <div class="form-check form-check-inline">
                        @Html.RadioButtonFor(m => m.U_Recep_PR1, "N", new { @class = "form-check-input", id = "PR1_NO" })
                        <label class="form-check-label" for="PR1_NO">No</label>
                    </div>
                </div>
                <br />
                <br />
                <div class="d-flex align-items-center mb-3">
                    <h2 class="mb-0 fw-bold" style="font-size: 1rem;">36. ADPR1</h2>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Fotografías de evidencia</label>
                    @if (Model.U_Estado == 1)
                    {
                        <a href="#" data-toggle="modal" data-target="#imagenModal" data-src="/FormularioCheckList/VerImagen?archivo=@(Model.U_IdFormulario)-ADPR1.png">
                            <img alt="fotografía de evidencia" class="img-preview d-block mt-2" src="/FormularioCheckList/VerImagen?archivo=@(Model.U_IdFormulario)-ADPR1.png" />
                        </a>
                    }
                    else
                    {
                        <input type="file" name="U_Recep_ADPR1" class="form-control" accept="image/*" id="ADPR1" />
                    }
                </div>
                <br />
                <div class="d-flex align-items-center mb-3">
                    <h2 class="mb-0 fw-bold" style="font-size: 1rem;">37. IAPR1</h2>
                </div>
                <div>
