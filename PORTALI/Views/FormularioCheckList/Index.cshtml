@using Entity
@using DAL
@using System.Threading.Tasks;
@model List<CheckListInfo>
@{
    DALFormularioCheckList _dal = new DALFormularioCheckList();

    var sessions = (Entity.SessionLoginEntity)Session["PropertiesEntity"];
    async Task<int> verFormularioPendiente()
    {
        return await _dal.FormularioPendiente(sessions.CodeEmpleado.ToString());
    }
}
@{
    ViewBag.Title = "Información General CheckList";
}
<style>
    .form-row, .row {
        display: flex;
        flex-wrap: wrap;
        margin-right: -5px;
        margin-left: -5px;
    }

        .form-row .col-md-3, .row .col-md-3 {
            padding-right: 5px;
            padding-left: 5px;
        }
</style>

<div class="container-fluid mt-4">

    <!-- 🔹 Sección de Filtros -->
    <div class="card shadow-sm mb-4 border-0">
        <div class="card-header bg-primary text-white">
            <h6 class="mb-0"><i class="bi bi-funnel-fill"></i> Filtros</h6>
        </div>
        <div class="card-body">
            <form class="row g-3 align-items-end">
                <div class="col-md-2">
                    <label class="form-label">Fecha Inicial</label>
                    <input type="date" class="form-control" name="fechaInicial" value="@ViewBag.FechaI" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Fecha Final</label>
                    <input type="date" class="form-control" name="fechaFinal" value="@ViewBag.FechaF" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Estado</label>
                    <select class="form-control" name="Estado">
                        <option value="-1" @(ViewBag.Estado == -1 ? "Selected" : "")>Todos</option>
                        <option value="0" @(ViewBag.Estado == 0 ? "Selected" : "")>Incompleto</option>
                        <option value="1" @(ViewBag.Estado == 1 ? "Selected" : "")>Completo</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Tienda</label>
                    <select class="form-control" name="Tienda" @(ViewBag.DisabledTienda ? "Disabled" : "")>
                        <option value="" @(ViewBag.Tienda == "" ? "Selected" : "")>Todas</option>
                        @foreach (var items in @ViewBag.TiendasRegiones)
                        {
                            <option value="@items.WhsCode" @(ViewBag.Tienda == items.WhsCode ? "Selected" : "")>@items.WhsName</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Region</label>
                    <select class="form-control" name="Region" @(ViewBag.DisabledRegion ? "Disabled" : "")>
                        <option value="-1" @(ViewBag.Region == -1 ? "Selected" : "")>Todas</option>
                        @foreach (var items in ((IEnumerable<dynamic>)ViewBag.TiendasRegiones)
                        .GroupBy(x => new { x.Code, x.Location })
                        .Select(g => g.First()))
                        {
                            <option value="@items.Code" @(ViewBag.Region == items.Code ? "Selected" : "")>@items.Location</option>
                        }
                    </select>
                </div>
                <div class="col-md-2 text-end">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-search"></i> Aplicar filtro
                    </button>
                    <button type="reset" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-clockwise"></i> Limpiar
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- 🔹 Tabla de Resultados -->
    <div class="card shadow-sm mb-4">
        <div class="card-header bg-light d-flex justify-content-between align-items-center">
            <h5 class="mb-0">Información General CheckList</h5>
            <div>
                <a href="@Url.Action("ExportarExcel", "FormularioCheckList")"
                   class="btn btn-outline-success btn-sm" id="btnDescargarExcel">
                    <i class="bi bi-file-earmark-excel"></i> Descargar Excel
                </a>
                <a href="@Url.Action("Checklist", "FormularioCheckList", new { nuevo = 0 })"
                   class="btn btn-outline-primary btn-sm" id="btnNuevoFormulario">
                    <i class="bi bi-file-earmark-plus"></i> Nuevo Formulario
                </a>
            </div>
        </div>
        <div class="card-body">
            <table class="table table-bordered table-hover table-striped table-sm align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Correlativo</th>
                        <th>Fecha</th>
                        <th>Nombre</th>
                        <th>Tienda</th>
                        <th>Bodega</th>
                        <th>Estado</th>
                        <th>Puntaje</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (string.IsNullOrEmpty(@Model[0].Error))
                    {
                        foreach (var lista in @Model)
                        {
                            <tr>
                                <td>@lista.Correlativo</td>
                                <td>@lista.Fecha.ToString("dd/MM/yyyy")</td>
                                <td>@lista.Nombre</td>
                                <td>@lista.Tienda</td>
                                <td>@lista.Bodega</td>

                                @{
                                    string clase = "bg-success";
                                    string Estado = "Completo";

                                    if (lista.Estado == 0)
                                    {
                                        clase = "bg-warning";
                                        Estado = "Incompleto";
                                    }
                                }

                                <td><span class="badge @clase">@Estado</span></td>
                                <td>@lista.Puntaje.ToString("F2")%</td>

                                @{
                                    if (lista.Estado == 0)
                                    {
                                        <td>
                                            <a href="@Url.Action("Checklist", "FormularioCheckList", new { nuevo = -1, NumeroFormulario = lista.Correlativo })">
                                                <button type="button" class="btn btn-outline-danger btn-sm ver-detalle-btn">
                                                    <i class="bi bi-exclamation-circle"></i> Completar
                                                </button>
                                            </a>
                                        </td>
                                    }
                                    else
                                    {
                                        <td>
                                            <a href="@Url.Action("Checklist", "FormularioCheckList", new { nuevo = 1, NumeroFormulario = lista.Correlativo })">
                                                <button type="button" class="btn btn-outline-primary btn-sm ver-detalle-btn">
                                                    <i class="bi bi-eye-fill"></i> Ver detalle
                                                </button>
                                            </a>
                                            @if (sessions.UserId == 330)
                                            {
                                                <a href="@Url.Action("ActivaCheckList", "FormularioCheckList", new { nuevo = 1, NumeroFormulario = lista.Correlativo })">
                                                    <button type="button" class="btn btn-outline-success btn-sm ver-detalle-btn">
                                                        <i class="bi bi-toggle-on"></i>
                                                    </button>
                                                </a>
                                            }
                                        </td>
                                    }
                                }
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8">
                                <div class="alert alert-warning" style="text-align:center" role="alert">
                                    @Model[0].Error ⚠️
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>

        const Toast = Swal.mixin({
            toast: true,
            position: 'top-end',
            showConfirmButton: false,
            timer: 3000,
            timerProgressBar: true
        });

        $(document).ready(function () {
            var estadoCheckList = "completo"; // Simulación

            if (estadoCheckList === "completo") {
                $('#btnNuevoFormulario').show();
            } else {
                $('#btnNuevoFormulario').hide();
            }

            // Inicializar tooltips de Bootstrap
            var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'))
            tooltipTriggerList.map(function (tooltipTriggerEl) {
                return new bootstrap.Tooltip(tooltipTriggerEl)
            });
        });

        window.addEventListener("pageshow", function (event) {
            if (event.persisted) {
                // Si la página viene del cache del navegador
                window.location.reload();
            }
        });

        if (@(ViewBag.Pendient) === 1) {
            Toast.fire({ icon: 'error', title: "Tienes un formulario incompleto, completalo para poder crear uno nuevo" });
        }
    </script>
}
