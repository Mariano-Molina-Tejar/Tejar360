@*@model Entity.FormularioCheckListEntity*@
@model Entity.FormularioCheckList1Entity

<head>
    <link href="~/Css/styleFormularioCheckList.css" rel="stylesheet" type="text/css" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" rel="stylesheet">
</head>
<style>
    /* Opcional: Estilo personalizado para las tarjetas y el texto */
    .card-porcentaje .card-body {
        min-height: 150px; /* Asegura un tamaño mínimo para las tarjetas */
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
    }

    .card-title-porcentaje {
        font-size: 1rem; /* Tamaño de fuente para el título */
        margin-bottom: 0.5rem;
    }

    .porcentaje-valor {
        font-size: 2.5rem; /* Tamaño de fuente para el porcentaje */
    }
    .img-preview {
        width: 150px;
        height: 150px;
        object-fit: cover;
        border-radius: 5px;
        border: 1px solid #ddd;
        transition: transform 0.3s ease; /* animación suave */
        cursor: pointer; /* cambia cursor al pasar encima */
    }

        .img-preview:hover {
            transform: scale(1.2); /* aumenta 20% al pasar el mouse */
            z-index: 10; /* evita que quede detrás de otros elementos */
        }
</style>

@using (Html.BeginForm("EnviarSeccion", "FormularioCheckList", FormMethod.Post, new { enctype = "multipart/form-data" }))
{
    <div id="seccion1" class="wizard-section">
        @Html.Partial("_Seccion1DatosGenerales", Model)
    </div>

    <div id="seccion2" class="wizard-section d-none">
        @Html.Partial("_Seccion2Almacenamiento", Model)
    </div>

    <div id="seccion3" class="wizard-section d-none">
        @Html.Partial("_Seccion3Recepcion", Model)
    </div>

    <div id="seccion4" class="wizard-section d-none">
        @Html.Partial("_Seccion4Despacho", Model)
    </div>

    <div id="seccion5" class="wizard-section d-none">
        @Html.Partial("_Seccion5Daniado", Model)
    </div>

    <div id="seccion6" class="wizard-section d-none">
        @Html.Partial("_Seccion6_5S", Model)
    </div>
    <div style="margin-bottom:30px">
    </div>
    //MODAL RESULTADOS
    <div class="modal fade" id="modalResultados" tabindex="-1" aria-labelledby="modalResultadosLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white m-1">
                    <h5 class="modal-title" id="modalResultadosLabel">📊 Porcentajes del Checklist</h5>
                    <button type="button" class="btn-close btn-close-white" aria-label="Close" onclick="cerrarModal()"></button>
                </div>

                <div class="modal-body">
                    <!-- Fila 1 -->
                    <div class="row g-4 justify-content-center mb-3">
                        <div class="col-sm-6 col-md-4">
                            <div class="card h-100 shadow-sm border-primary">
                                <div class="card-body text-center">
                                    <i class="bi bi-box-seam fs-1 text-primary mb-2"></i>
                                    <h6 class="card-title text-muted text-uppercase fw-bold">Almacenaje</h6>
                                    <p class="card-text display-6 text-primary fw-bold" id="porcentaje-almacenamiento">0%</p>
                                </div>
                            </div>
                        </div>

                        <div class="col-sm-6 col-md-4">
                            <div class="card h-100 shadow-sm border-success">
                                <div class="card-body text-center">
                                    <i class="bi bi-arrow-down-square fs-1 text-success mb-2"></i>
                                    <h6 class="card-title text-muted text-uppercase fw-bold">Recepción</h6>
                                    <p class="card-text display-6 text-success fw-bold" id="porcentaje-recepcion">0%</p>
                                </div>
                            </div>
                        </div>

                        <div class="col-sm-6 col-md-4">
                            <div class="card h-100 shadow-sm border-info">
                                <div class="card-body text-center">
                                    <i class="bi bi-truck fs-1 text-info mb-2"></i>
                                    <h6 class="card-title text-muted text-uppercase fw-bold">Despacho</h6>
                                    <p class="card-text display-6 text-info fw-bold" id="porcentaje-despacho">0%</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Fila 2 -->
                    <div class="row g-4 justify-content-center mb-3">
                        <div class="col-sm-6 col-md-4">
                            <div class="card h-100 shadow-sm border-warning">
                                <div class="card-body text-center">
                                    <i class="bi bi-x-octagon fs-1 text-warning mb-2"></i>
                                    <h6 class="card-title text-muted text-uppercase fw-bold">Dañado</h6>
                                    <p class="card-text display-6 text-warning fw-bold" id="porcentaje-danado">0%</p>
                                </div>
                            </div>
                        </div>

                        <div class="col-sm-6 col-md-4">
                            <div class="card h-100 shadow-sm border-danger">
                                <div class="card-body text-center">
                                    <i class="bi bi-check-circle fs-1 text-danger mb-2"></i>
                                    <h6 class="card-title text-muted text-uppercase fw-bold">5S</h6>
                                    <p class="card-text display-6 text-danger fw-bold" id="porcentaje-5s">0%</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Punteo General -->
                    <div class="row">
                        <div class="col-12">
                            <div class="card shadow-sm border-dark">
                                <div class="card-body text-center bg-light">
                                    <i class="bi bi-bar-chart-line fs-1 text-dark mb-2"></i>
                                    <h5 class="card-title text-uppercase fw-bold">Punteo General</h5>
                                    <p class="card-text display-5 text-dark fw-bold" id="porcentaje-general" style="font-size:25px; font-weight:bold">0%</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" onclick="cerrarModal()">
                        @(Model.U_Estado == 1 ? "Cerrar":"Finalizar")
                    </button>
                </div>
            </div>
        </div>
    </div>


    @*<div class="modal fade" id="imagenModal" tabindex="-1" aria-labelledby="imagenModalLabel" aria-hidden="true">
