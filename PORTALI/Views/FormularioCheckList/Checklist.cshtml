    function mensajeInicioFormulario() {
        var result = @ViewBag.Error.result;
        var message = '@ViewBag.Error.message';

        if (result === 1) {
            // No se debe mostrar nada si es 1
        } else if (result === 2) {
            Toast.fire({ icon: 'warning', title: message });
        } else {
            Toast.fire({ icon: 'error', title: message });
        }
    }

