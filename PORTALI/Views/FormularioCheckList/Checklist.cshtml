<script>
    function subirArchivo(input) {

        const file = input.files[0];

        if (file) {

            const formData = new FormData();
            formData.append("Imagen", file);
            formData.append("Id", input.id);
            formData.append("Name", input.name);
            formData.append("IdFormulario", "@Model.U_IdFormulario");
            formData.append("Code", "@Model.Code");
            $("#globalLoading").show?.();
            fetch("/FormularioCheckList/MoverImagen", {
                method: "POST",
                body: formData
            })
                .then(response => response.json())
                .then(data => {
                    console.log("Respuesta del servidor:", data);
                    $("#globalLoading").hide?.();
                    Toast.fire({ icon: 'success', title:"Archivo subido con éxito" });

                    //alert("Archivo subido con éxito: " + data.nombre);
                })
                .catch(error => {
                    $("#globalLoading").hide?.();
                    //console.error("Error al subir:", error);
                    Toast.fire({ icon: 'error', title: "Error al subir" });

                });
        }
    }
</script>
<script>
    function mostrarResultados(seccionFinal = 0, data = null) {
        let datos = {};

        if (seccionFinal === 0) {
             datos = @Html.Raw(Json.Encode(Model));
        }
        else {
            datos = data;
        }

        const resultados = {
            almacenamiento: datos.U_PuntajeAlmacenaje, // Porcentaje de almacenamiento
            recepcion: datos.U_PuntajeRecepcion,      // Porcentaje de recepción
            despacho: datos.U_PuntajeDespacho,       // Porcentaje de despacho
            danado: datos.U_PuntajeDaniado,         // Porcentaje de dañado
            '5s': datos.U_Puntaje5S,

            general: (datos.U_PuntajeAlmacenaje + datos.U_PuntajeRecepcion + datos.U_PuntajeDespacho + datos.U_PuntajeDaniado + datos.U_Puntaje5S) / 5,
            // Porcentaje de 5S (usa comillas por el guion)
        };

        // Actualiza el texto de cada tarjeta
        document.getElementById('porcentaje-almacenamiento').innerText = resultados.almacenamiento.toFixed(2) + '%';
        document.getElementById('porcentaje-recepcion').innerText = resultados.recepcion.toFixed(2) + '%';
        document.getElementById('porcentaje-despacho').innerText = resultados.despacho.toFixed(2) + '%';
        document.getElementById('porcentaje-danado').innerText = resultados.danado.toFixed(2) + '%';
        document.getElementById('porcentaje-5s').innerText = resultados['5s'].toFixed(2) + '%';
        document.getElementById('porcentaje-general').innerText = resultados.general.toFixed(2) + '%';

         //Muestra el modal
        //var myModal = new bootstrap.Modal(document.getElementById('modalResultados'));
        //myModal.show();

        var modalElement = document.getElementById('modalResultados');
        myModalInstance = new bootstrap.Modal(modalElement);
        myModalInstance.show();
    }

    function cerrarModal() {
        // Busca el elemento del modal por su ID
        if (myModalInstance) {
            myModalInstance.hide();
        }

        if (finalSeccion === 1 ) {
            window.location.href = '/FormularioCheckList/Index';
        }
    }

    function VolverInformacionGeneral(event) {
        event.preventDefault()  ;
        window.location.href = '/FormularioCheckList/Index';
    }


    window.addEventListener('beforeunload', (event) => {
        event.preventDefault(); // necesario para algunos navegadores
        event.returnValue = "¿Seguro que quieres salir?";
        return event.returnValue;
    });
</script>
<script>
    $(document).ready(function () {
        // Intercepta el click en cualquier link que abra el modal
        $(document).on("click", "[data-target='#imagenModal']", function (event) {
            var imgSrc = $(this).data("src");

            // 🚫 Si la imagen es NoPhoto, cancela la apertura
            if (imgSrc && imgSrc.toLowerCase().includes("nophoto")) {
                console.warn("⚠️ Placeholder detectado, no se abrirá el modal");
                event.preventDefault(); // evita que Bootstrap abra el modal
                return false;
            }
        });

        // Si llega aquí, sí se abre el modal y asigna la imagen
        $('#imagenModal').on('show.bs.modal', function (event) {
            var link = $(event.relatedTarget);   // el <a> que abre el modal
            var imgSrc = link.data('src');       // obtiene data-src
            console.log("➡️ Asignando al modal:", imgSrc);
            $('#imagenAmpliada').attr('src', imgSrc);
        });

        // Debug: ver si la imagen falla
        $('#imagenAmpliada').on('error', function () {
            console.error("❌ No se pudo cargar:", $(this).attr('src'));
        });
    });


</script>


