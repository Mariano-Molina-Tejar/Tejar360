        <div class="card shadow-sm mb-4 border-0">
            <div class="card-body">
                <h5 class="card-title text-primary">
                    <i class="bi bi-boxes"></i> ¿Los pasillos y carriles de almacenaje se mantienen limpios y ordenados?
                </h5>
                <p class="text-muted mb-4">Ingresa total, cantidad que cumple, evidencia y observaciones.</p>

                <div class="row g-3">
                    <div class="col-md-3">
                        <label class="form-label fw-bold">07. PA1T</label>
                        @Html.LabelFor(m => m.U_U_Alma_PA1T, "Total de pasillos", new { @class = "form-label fw-semibold", })
                        @Html.TextBoxFor(m => m.U_U_Alma_PA1T, new { @class = "form-control", placeholder = "Ej. 10", id = "PA1T", Value = Model.U_U_Alma_PA1T == null ? "" : Model.U_U_Alma_PA1T.ToString() })
                    </div>

                    <div class="col-md-3">
                        <label class="form-label fw-bold">08. PA1C</label>
                        @Html.LabelFor(m => m.U_Alma_PAIC, "Cantidad que cumple", new { @class = "form-label fw-semibold", })
                        @Html.TextBoxFor(m => m.U_Alma_PAIC, new { @class = "form-control", placeholder = "Ej. 8", id = "PAIC", Value = Model.U_Alma_PAIC == null ? "" : Model.U_Alma_PAIC.ToString() })
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-bold">09. ADPA1</label>
                        @Html.LabelFor(m => m.U_Alma_ADPA1, "Fotografía de Evidencia", new { @class = "form-label fw-semibold" })
                        @if (Model.U_Estado == 1)
                        {
                            <a href="#" data-toggle="modal" data-target="#imagenModal" data-src="/FormularioCheckList/VerImagen?archivo=@(Model.U_IdFormulario)-ADPA1.png">
                                <img alt="fotografía de evidencia" class="img-preview d-block mt-2" src="/FormularioCheckList/VerImagen?archivo=@(Model.U_IdFormulario)-ADPA1.png" />
                            </a>
                        }
                        else
                        {
                            <input type="file" name="U_Alma_ADPA1" class="form-control mt-2" accept="image/*" id="ADPA1" onchange="subirArchivo(this)" />
                        }

                    </div>
                </div>

            </div>
        </div>

