@model Entity.FormularioCheckList1Entity
<style>
    .img-preview {
        width: 150px; /* Ancho deseado */
        height: 150px; /* Alto deseado */
        object-fit: cover; /* Esto es útil para que la imagen se recorte y no se deforme */
        border-radius: 5px; /* Opcional: para darle bordes redondeados */
        border: 1px solid #ddd; /* Opcional: un borde sutil */
    }
</style>
<div class="card mb-4 shadow-sm">
    <div class="card-header bg-teal text-white fw-bold">
        <i class="bi bi-archive-fill me-2"></i>
