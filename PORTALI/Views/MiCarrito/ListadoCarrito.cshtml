@model Entity.CarritoComprasEntity
@{
    ViewBag.Title = "ListadoCarrito";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<style>
    body {
        background: #eee;
    }

    /* Contenedor de la barra de progreso */
    .progress-container {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin: 20px auto;
        padding: 0 15px;
        max-width: 600px;
        position: relative;
    }

        /* Línea de progreso */
        .progress-container::before {
            content: '';
            position: absolute;
            top: 50%;
            left: 0;
            right: 0;
            height: 4px;
            background: #e0e0e0;
            z-index: 0;
            transform: translateY(-50%);
        }

    /* Paso individual */
    .step {
        position: relative;
        display: flex;
        flex-direction: column;
        align-items: center;
        z-index: 1;
    }

        /* Círculo del paso */
        .step .circle {
            width: 30px;
            height: 30px;
            border-radius: 50%;
            background-color: #e0e0e0;
            display: flex;
            justify-content: center;
            align-items: center;
            font-weight: bold;
            color: #ffffff;
            font-size: 14px;
            transition: all 0.3s ease-in-out;
        }

        /* Texto debajo del círculo */
        .step p {
            margin-top: 8px;
            font-size: 14px;
            color: #757575;
        }

        /* Estado activo del paso */
        .step.active .circle {
            background-color: #ff8c00;
            box-shadow: 0 0 8px rgba(255, 140, 0, 0.6);
        }

        .step.active p {
            color: #ff8c00;
        }

        /* Línea activa */
        .step.active ~ .step .circle {
            background-color: #e0e0e0;
        }

        .step:not(:last-child)::after {
            content: '';
            position: absolute;
            top: 50%;
            right: calc(50% + 15px);
            height: 4px;
            width: 100%;
            background-color: red;
            background-color: #ff8c00;
            transform: translateY(-50%);
            z-index: -1;
        }

        /* ESTA ES LA LINEA DEL FINAL */
        .step.active ~ .step::after {
            background-color: #e0e0e0;
        }

    /* Botones de navegación */
    .navigation-buttons {
        display: flex;
        justify-content: space-between;
        max-width: 600px;
        margin: 20px auto;
    }

        .navigation-buttons button {
            padding: 10px 20px;
            font-size: 14px;
            font-weight: bold;
            color: #ffffff;
            background-color: #ff8c00;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
            transition: all 0.3s ease-in-out;
        }

            .navigation-buttons button:disabled {
                background-color: #e0e0e0;
                color: #9e9e9e;
                cursor: not-allowed;
            }

            .navigation-buttons button:hover:not(:disabled) {
                background-color: #ff751a;
                box-shadow: 0 6px 8px rgba(0, 0, 0, 0.15);
            }

    .payment-method {
        font-family: Arial, sans-serif;
    }

    h3 {
        margin-bottom: 10px;
        font-size: 16px;
    }

    .payment-buttons {
        display: flex;
        gap: 10px;
    }

    .btn {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 5px;
        padding: 10px 20px;
        border: 2px solid #00c2a8;
        border-radius: 20px;
        font-size: 14px;
        font-weight: bold;
        cursor: pointer;
        transition: background-color 0.3s ease, color 0.3s ease;
    }

    /* .btn .icon {
        font-size: 18px;
    }*/

</style>

<link href="https://maxcdn.bootstrapcdn.com/font-awesome/4.3.0/css/font-awesome.min.css" rel="stylesheet">
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<div class="progress-container">
    <div class="step active" id="step1" data-step="1">
        <div class="circle">1</div>
        <p>Mi carrito</p>
    </div>
    <div class="step" id="step2" data-step="2">
        <div class="circle">2</div>
        <p>Socio de negocio</p>
    </div>
    <div class="step" id="step3" data-step="3">
        <div class="circle">3</div>
        <p>Finalizar</p>
    </div>
</div>
<div class="text-center my-3 d-none" id="DatoEditar">
    <span class="badge bg-danger px-5 py-3" style="font-size: 0.90rem;">
        <i class="bi bi-pencil-square me-2"></i>
        Editando cotización No. <span id="txtNoCotizacionEditar">0</span>
    </span>
</div>

<div id="partialViewContainer">
    @Html.Partial("MiCarrito")
</div>

<!-- Botones de navegación -->
<div class="navigation-buttons" style="display:none">
    <button id="prevButton" onclick="loadStep(-1)" disabled>Anterior</button>
    <button id="nextButton" onclick="loadStep(1)">Siguiente</button>
</div>

<script>
    let currentStep = 1;
    const totalSteps = 3;

    // Función para cargar el siguiente paso
    function loadStep(stepChange) {
        $("#globalLoading").show();
        currentStep += stepChange;

        // Validar límites
        if (currentStep < 1) currentStep = 1;
        if (currentStep > totalSteps) currentStep = totalSteps;

        // Actualizar botones de navegación
        document.getElementById('prevButton').disabled = (currentStep === 1);
        document.getElementById('nextButton').disabled = (currentStep === totalSteps);

        // **Actualizar la barra de progreso antes del AJAX**
        updateProgress();

        // Llamar al controlador para cargar la PartialView
        $.ajax({
            url: '/MiCarrito/LoadPartialView', // Ruta al método del controlador
            type: 'GET',
            data: { step: currentStep },
            success: function (data) {
                $('#partialViewContainer').html(data);
                $("#globalLoading").hide();
            }
        });
    }

    //Función para actualizar visualmente la barra de progreso
    function updateProgress() {
        $('.step').each(function () {
            let stepIndex = parseInt($(this).attr('data-step'));

            if (stepIndex <= currentStep) {
                $(this).addClass('active');
            } else {
                $(this).removeClass('active');
            }
        });

        /*Actualiza la línea de progreso*/
        let progress = ((currentStep - 2) / ($('.step').length - 2)) * 100;
        $('.progress-bar').css('width', progress + '%');
    }
</script>