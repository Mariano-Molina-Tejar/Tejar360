@model Entity.LoginEntity

@{
    ViewBag.Title = "Login";
    Layout = null;
}

<head>
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <title>- El Tejar -</title>
    <link rel="icon" href="@Url.Content("~/Img/icono.ico")" />
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.1.3/css/bootstrap.min.css" integrity="sha384-MCw98/SFnGE8fJT3GXwEOngsV7Zt27NXFoaoApmYm81iuXoPkFOJwJ8ERdknLPMO" crossorigin="anonymous">
    <link rel="stylesheet" href="https://use.fontawesome.com/releases/v5.3.1/css/all.css" integrity="sha384-mzrmE5qonljUremFsqc01SB46JvROS7bZs3IO2EmfFsd15uHvIt+Y8vEf7N7fWAU" crossorigin="anonymous">
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <link href="~/Css/Login/Style.css" rel="stylesheet" />
    <link href="~/Css/Profile.css" rel="stylesheet" />
    <style>
    </style>
</head>

<div class="container">
    <div class="d-flex justify-content-center h-100">
        <div class="card">
            <div class="card-header">
                <h3>Inicio de sesión</h3>
            </div>
            <div class="card-body">
                <!-- Formulario de inicio de sesión -->
                <form id="loginForm" method="post">
                    <div>
                        <div class="input-group form-group-lg">
                            <div class="input-group-prepend">
                                <span class="input-group-text"><i class="fas fa-user"></i></span>
                            </div>
                            @Html.TextBoxFor(model => model.Usuario, new { @class = "form-control", @placeholder = "Usuario" })
                        </div>
                        @Html.ValidationMessage("Usuario", new { @class = "text-danger" })
                    </div>
                    <br />
                    <div id="p1" class="input-container">
                        <div class="input-group form-group-lg">
                            <div class="input-group-prepend">
                                <span class="input-group-text"><i class="fas fa-key"></i></span>
                            </div>
                            @Html.TextBoxFor(model => model.Password, new { @class = "form-control", @placeholder = "Contraseña", @type = "password" })
                            <div class="input-group-prepend">
                                <span class="input-group-text" style="background-color:white"><i class="material-icons visibility">visibility_off</i></span>
                            </div>
                        </div>
                    </div>
                    @Html.ValidationMessage("Password", new { @class = "text-danger" })
                    <br />
                    <div class="row align-items-center remember">
                        <input type="checkbox"> Recuerdame
                    </div>
                    <div class="form-group">
                        <button type="submit" class="btn float-right login_btn">Acceder</button>
                    </div>
                </form>
            </div>
            <div class="card-footer">
                <div class="d-flex justify-content-center">
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal de error -->
<div class="modal fade" id="statusErrorsModal" tabindex="-1" role="dialog" data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-dialog-centered modal-sm" role="document">
        <div class="modal-content">
            <div class="modal-body text-center p-lg-4">
                <svg version="1.1" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 130.2 130.2">
                    <circle class="path circle" fill="none" stroke="#db3646" stroke-width="6" stroke-miterlimit="10" cx="65.1" cy="65.1" r="62.1" />
                    <line class="path line" fill="none" stroke="#db3646" stroke-width="6" stroke-linecap="round" stroke-miterlimit="10" x1="34.4" y1="37.9" x2="95.8" y2="92.3" />
                    <line class="path line" fill="none" stroke="#db3646" stroke-width="6" stroke-linecap="round" stroke-miterlimit="10" x1="95.8" y1="38" x2="34.4" y2="92.2" />
                </svg>
                <h4 class="text-danger mt-3">Error!</h4>
                <p class="mt-3" id="modalMessage">Usuario o contraseña no son válidos</p>
                <button type="button" class="btn btn-sm mt-3 btn-danger" data-bs-dismiss="modal">Ok</button>
            </div>
        </div>
    </div>
</div>
<script>
    const visibilityToggle1 = document.querySelector(".visibility");
    const input = document.querySelector("#p1 input");
    var password1 = true;
    visibilityToggle1.addEventListener('click', function () {
        if (password1) {
            input.setAttribute('type', 'text');
            visibilityToggle1.innerHTML = "visibility";
        } else {
            input.setAttribute('type', 'password');
            visibilityToggle1.innerHTML = "visibility_off";
        }
        password1 = !password1;
    });

    $(document).ready(function() {
        $('form').on('submit', function(event) {
            event.preventDefault(); // Evita el envío automático del formulario

            $.ajax({
                url: '@Url.Action("Login", "Account")', // Cambia "TuControlador" al nombre correcto
                type: 'POST',
                data: $(this).serialize(),
                success: function(response) {
                    if (response.success) {
                        // Redirige en caso de éxito
                        window.location.href = response.redirectUrl;
                    } else {
                        // Muestra el mensaje de error en el modal
                        $('#statusErrorsModal .modal-body p').text(response.message);
                        $('#statusErrorsModal').modal('show');
                    }
                },
                error: function() {
                    $('#statusErrorsModal .modal-body p').text("Error al procesar la solicitud.");
                    $('#statusErrorsModal').modal('show');
                }
            });
        });
    });
</script>

<script src='https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js'></script>
<script src='https://cdnjs.cloudflare.com/ajax/libs/twitter-bootstrap/5.2.0/js/bootstrap.min.js'></script>