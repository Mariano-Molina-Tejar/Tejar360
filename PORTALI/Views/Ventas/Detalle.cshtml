        function regresarId() {
            let cookieName = obtenerNombreCookieMasReciente("T-OneCotizacion-");
            const cookieData = getCookie(cookieName);
            let lineId = 1; // Valor inicial en caso de que no exista la cookie

            if (cookieData) {
                try {
                    const cotizacion = JSON.parse(cookieData);
                    // Acceder al array de productos
                    if (Array.isArray(cotizacion.productos) && cotizacion.productos.length > 0) {
                        // Obtener el último producto en la lista
                        const ultimoProducto = cotizacion.productos[cotizacion.productos.length - 1];

                        // Obtener el último LineId y sumar 1
                        return (ultimoProducto.LineId || 0) + 1;
                    }
                } catch (error) {
                    console.error('Error al parsear la cookie:', error);
                    return -1
                }
            }
            return 1;
        }      
        // Función para obtener el valor de una cookie
        function getCookie(name) {
            const cookies = document.cookie.split("; ");
            for (const cookie of cookies) {
                const [key, value] = cookie.split("=");
                if (key === name) return value;
            }
            return null;
        }

        $(document).ready(function () {
            cargarSeguimiento();
        });

        function formatFecha(fechaSAP) {
            if (!fechaSAP) return ""; // Si la fecha es nula o vacía, devolver vacío

            let timestamp = parseInt(fechaSAP.match(/\d+/)[0]); // Extraer el número de la fecha
            let fecha = new Date(timestamp); // Convertir a objeto Date

            let dia = fecha.getDate().toString().padStart(2, "0");
            let mes = (fecha.getMonth() + 1).toString().padStart(2, "0");
            let año = fecha.getFullYear();

            return `${dia}/${mes}/${año}`;
        }

        function cargarSeguimiento() {
            let docEntry = '@Model.Encabezado.DocEntry'; // Obtener el valor desde Razor
            $.ajax({
                url: '/Ventas/CargarSeguimientos',
                type: 'GET',
                data: { DocEntry: docEntry }, // Pasar el parámetro en la solicitud
                dataType: 'json',
                success: function (data) {
                    let tbody = $('#seguimiento-body');
                    tbody.empty(); // Limpiar la tabla antes de agregar nuevos datos

                    if (data.length > 0) {
                        $.each(data, function (index, item) {
                            let fechaFormateada = formatFecha(item.FechaSeg);
                            let vencimientoFormateado = formatFecha(item.FechaVencimiento);
                            let fila = `
                                <tr>
                                    <td>${item.Creado}</td>
                                    <td>${fechaFormateada}</td>
                                    <td>${vencimientoFormateado}</td>
                                    <td>${item.DescrEstado}</td>
                                    <td>${item.TipoDeContacto}</td>
                                    <td>${item.Accion}</td>
                                    <td>${item.Notas}</td>
                                    <td>${item.Usuario}</td>
                                </tr>
                            `;
                            tbody.append(fila);
                        });
                    } else {
                        tbody.append('<tr><td colspan="8">No hay seguimientos registrados</td></tr>');
                    }
                },
                error: function (xhr, status, error) {
                    console.error('Error al cargar los seguimientos:', error);
                }
            });
        }

        $(document).ready(function () {
            $.ajax({
                url: "/Ventas/getAllTipsCRM", // Ajusta la URL según tu backend
                type: "GET",
                dataType: "json",
                success: function (data) {
                    let $select = $("#crmEstado");
                    $select.empty(); // Limpiar el select antes de agregar opciones
                    $select.append('<option value="-1">-- Seleccione --</option>');
                    $select.append('<option value="-2">Mostrar todos</option>');

                    // Recorrer los datos y agregarlos al select
                    $.each(data, function (index, item) {
                        $select.append(`<option value="${item.Id}">${item.Dscription}</option>`);
                    });
                },
                error: function () {
                    console.error("Error al cargar los estados.");
                }
            });

            $.ajax({
                url: "/Ventas/getAllTiposCrm", // Ajusta la URL según tu backend
                type: "GET",
                dataType: "json",
                success: function (data) {
                    let $select = $("#txttipoContacto");
                    $select.empty(); // Limpiar el select antes de agregar opciones
                    $select.append('<option value="-1">-- Seleccione --</option>');
                    // Recorrer los datos y agregarlos al select
                    $.each(data, function (index, item) {
                        $select.append(`<option value="${item.Id}">${item.Dscription}</option>`);
                    });
                },
                error: function () {
                    console.error("Error al cargar los estados.");
                }
            });
        });

        document.getElementById("btnSaveSeguimiento").addEventListener("click", function () {
            $("#globalLoading").show();
            // Capturar los valores de los inputs
            var data = {
                DocEntry: @Model.Encabezado.DocEntry, // Si es un número directamente
                DocNum: @Model.Encabezado.DocNum,
                FechaSeg: document.getElementById("txtfechaSeguimiento").value,
                FechaVenc: document.getElementById("txtfechaVencimiento").value,
                IdEstado: document.getElementById("crmEstado").value,
                IdTipoCont: document.getElementById("txttipoContacto").value,
                AccionRealizada: document.getElementById("txtaccionRealizada").value, // Asegúrate de que exista este ID
                Notas: document.getElementById("txtNotas").value
            };
            // Enviar datos con AJAX
            $.ajax({
                url: "/Ventas/SaveSeguimiento", // Ruta a tu backend en ASP.NET
                type: "POST",
                contentType: "application/json",
                data: JSON.stringify(data),
                success: function (response) {
                    if (response.result === 1) {
                        alert("Seguimiento guardado correctamente.");
                        window.location.href = "/Ventas/Listado";
                        $("#globalLoading").hide();
                    } else {
                        alert("Error: " + response.message);
                        $("#globalLoading").hide();
                    }
                },
                error: function () {
                    alert("Error al enviar la solicitud.");
                    $("#globalLoading").hide();
                }
            });
        });

        document.getElementById("agregarSeguimiento").addEventListener("click", function () {
            $("#modalSeguimiento").modal('show');
        });

        document.addEventListener("DOMContentLoaded", function () {
            let total = 0;
            document.querySelectorAll(".line-total").forEach(function (element) {
                let valor = parseFloat(element.textContent.replace("Q", "").trim());
                if (!isNaN(valor)) {
                    total += valor;
                }
            });
            document.getElementById("gran-total").innerHTML = `<strong>Q ${total.toFixed(2)}</strong>`;
        });



