        <script>
            $(document).on('input', '.cantidad', function () {
                const input = $(this);
                const fila = input.closest('tr');

                let cantidad = parseFloat(input.val()) || 1;
                if (cantidad < 1) {
                    cantidad = 1;
                    input.val(cantidad);
                }

                const precioUnitario = parseFloat(fila.find('.precio').data('precio')) || 0;
                const descuento = parseFloat(fila.find('td').eq(6).text().trim()) || 0;

                // Calcular precio con descuento
                const precioConDescuento = precioUnitario - (precioUnitario * descuento / 100);
                const totalLinea = cantidad * precioConDescuento;

                // Actualizar DOM
                /*fila.find('.precio-descuento').text('Q ' + precioConDescuento.toLocaleString('es-GT', { minimumFractionDigits: 2 }));*/
                fila.find('.line-total').text('Q ' + totalLinea.toLocaleString('es-GT', { minimumFractionDigits: 2 }));

                // Recalcular totales
                recalcularTotales();
            });

            function recalcularTotales() {
                let subtotal = 0;
                let descuentoAcumulado = 0;
                let totalDescuentosAplicados = 0;
                let totalGeneral = 0;
                let totalItems = 0;

                $('#detProductos tr').each(function () {
                    const fila = $(this);
                    const cantidad = parseFloat(fila.find('.cantidad').val()) || 1;
                    const precioUnitario = parseFloat(fila.find('.precio').data('precio')) || 0;
                    const descuento = parseFloat(fila.find('td').eq(6).text().trim()) || 0;

                    const precioConDescuento = precioUnitario;
                    const totalLinea = cantidad * precioConDescuento;

                    totalGeneral += totalLinea;
                });
                $('#total-general').text('Q ' + totalGeneral.toLocaleString('es-GT', { minimumFractionDigits: 2 }));
            }
        </script>

