                    <script>
                        document.addEventListener('DOMContentLoaded', function () {
                            function calcularTotales() {
                                let totalGeneral = 0;

                                document.querySelectorAll('#detalle-body tr').forEach(function (fila) {
                                    const cantidad = parseFloat(fila.querySelector('.cantidad-input')?.value || 0);
                                    const descuento = parseFloat(fila.querySelector('.descuento-input')?.value || 0);
                                    const precio = parseFloat(fila.querySelector('.precio')?.dataset.precio || 0);

                                    const precioConDescuento = precio - descuento;
                                    const totalLinea = cantidad * precioConDescuento;

                                    // Mostrar en columna correspondiente
                                    fila.querySelector('.precio-descuento').textContent = precioConDescuento.toLocaleString('es-GT', { style: 'currency', currency: 'GTQ' });
                                    fila.querySelector('.line-total').textContent = totalLinea.toLocaleString('es-GT', { style: 'currency', currency: 'GTQ' });

                                    totalGeneral += totalLinea;
                                });

                                document.getElementById('gran-total').innerHTML = `<strong>${totalGeneral.toLocaleString('es-GT', { style: 'currency', currency: 'GTQ' })}</strong>`;
                            }

                            // Asignar evento
                            document.querySelectorAll('.cantidad-input, .descuento-input').forEach(function (input) {
                                input.addEventListener('input', calcularTotales);
                            });

                            // Calcular una vez al cargar
                            calcularTotales();
                        });
                    </script>


