@{
    var sessions = (Entity.SessionLoginEntity)Session["PropertiesEntity"];
    string _clienteCF = sessions.ClienteCf;

    bool puedeSeleccionar = false;

    if (sessions != null)
    {
        // Verificar si es manager o nivel permitido
        if (sessions.UserCode == "manager" || (sessions.Nivel >= 1 && sessions.Nivel <= 3))
        {
            puedeSeleccionar = true;
        }
    }
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Detalle de Cotización</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

    <!-- CSS de Bootstrap -->
    <!--<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">-->
    <!-- Font Awesome para íconos -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">

    <!-- JS de Bootstrap (requerido para modales) -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    @*<link href="~/Css/DetalleAutorizaVenta.css" rel="stylesheet" />*@
    <script src="/js/UpdateCarrito.js" defer></script>

    <style>
        body {
            background-color: #f5f7fa;
            font-family: 'Segoe UI', sans-serif;
            padding-bottom: 50px;
        }

        .title-box {
            background: linear-gradient(to right, #343a40, #212529);
            color: white;
            padding: 20px 30px;
            border-radius: 10px;
            margin-top: 30px;
            text-align: center;
            font-size: 1.8rem;
            font-weight: bold;
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.2);
        }

        .section-box {
            background-color: #ffffff;
            border-radius: 12px;
            padding: 25px;
            margin-top: 25px;
            box-shadow: 0 0 15px rgba(0,0,0,0.05);
        }

        .section-header {
            font-weight: 600;
            font-size: 1.3rem;
            color: #343a40;
            margin-bottom: 20px;
            border-left: 4px solid #0d6efd;
            padding-left: 10px;
        }

        .data-label {
            font-weight: 600;
            color: #495057;
        }

        .alert-note {
            background-color: #e9ecef;
            border-left: 5px solid #ffc107;
            padding: 10px 15px;
            border-radius: 8px;
            margin-top: 20px;
            font-size: 0.95rem;
        }

        .section-box {
            border: 1px solid #ddd;
            border-radius: 12px;
            padding: 20px;
            background-color: #fff;
            box-shadow: 0 2px 6px rgba(0, 0, 0, 0.05);
            margin-bottom: 20px;
        }

        .section-header {
            font-size: 20px;
            font-weight: bold;
            color: #333;
            margin-bottom: 15px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .custom-table-wrapper {
            overflow-x: auto;
        }

        .custom-table {
            width: 100%;
            border-collapse: collapse;
            font-family: 'Segoe UI', sans-serif;
            font-size: 14px;
        }

            .custom-table thead {
                background-color: #f5f5f5;
            }

                .custom-table thead th {
                    padding: 12px;
                    text-align: left;
                    border-bottom: 2px solid #ccc;
                    color: #444;
                }

            .custom-table tbody tr {
                transition: background-color 0.2s;
            }

                .custom-table tbody tr:hover {
                    background-color: #f9f9f9;
                }

            .custom-table td {
                padding: 10px;
                border-bottom: 1px solid #e0e0e0;
                color: #555;
            }


        .seguimiento-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 15px;
        }

        .btn-seguimiento {
            background-color: #198754;
            border: none;
            color: white;
            font-weight: bold;
            padding: 8px 15px;
            border-radius: 8px;
        }

            .btn-seguimiento:hover {
                background-color: #157347;
            }

        #txtMotivoPerdida {
            width: 100%;
            padding: 10px;
            font-size: 15px;
            border: 1px solid #ccc;
            border-radius: 6px;
            background-color: #f5f5f5; /* Gris claro al estar deshabilitado */
            color: #777;
            cursor: not-allowed;
        }

            #txtMotivoPerdida:enabled {
                background-color: #f5f5f5; /* Fondo cuando está habilitado */
                color: #000;
                cursor: pointer;
            }
    </style>
</head>
<body>
    <input type="hidden" id="clienteCF" value="@_clienteCF" />
    <div class="container">

        <!-- Título -->
        <div class="title-box" style="padding:10px; font-size:15px;">
            <i class="fas fa-file-invoice-dollar me-2"></i>Detalle de Cotización
        </div>

        <!-- Botones -->
        <div style="display: flex; justify-content: center; gap: 10px; margin-top: 20px;">

            <!-- Botón Editar -->

            @if (Model.Encabezado.Estado != "Pendiente" && Model.Encabezado.Estado != "Autorizado")
            {
                <button id="btnEditar" style="padding: 10px 20px; background-color: #007bff; color: white; border: none; border-radius: 5px; cursor: pointer;">
                    <i class="fas fa-save" style="margin-right: 5px;"></i> Guardar cambios
                </button>
            }


            <!-- Botón PDF -->
            <button id="btnPdf" style="padding: 10px 20px; background-color: #dc3545; color: white; border: none; border-radius: 5px; cursor: pointer;">
                <i class="fas fa-file-pdf" style="margin-right: 5px;"></i> PDF
            </button>
        </div>

        <!-- Librería SweetAlert2 -->
        <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

        <script>
            document.getElementById("btnEditar").addEventListener("click", function () {
                Swal.fire({
                    icon: 'question',
                    title: 'Confirmación de cambios',
                    text: '¿Está seguro de que desea guardar los cambios realizados en la cotización?',
                    showCancelButton: true,
                    confirmButtonText: 'Sí, guardar',
                    cancelButtonText: 'No, cancelar'
                }).then(result => {
                    if (result.isConfirmed) {
                        $("#globalLoading").show();
                        const itemCodes = [];
                        $('#detProductos tr').each(function () {
                            const lineNum = parseInt($(this).find('td').eq(1).text().trim());
                            const itemCode = $(this).find('td').eq(2).text().trim();
                            const quantity = parseFloat($(this).find('td').eq(4).find('input[type="number"]').val().trim()) || 0;
                            const precioTexto = $(this).find('td').eq(5).text().trim();
                            const precio = parseFloat(precioTexto.replace('Q', '').replace(/\s/g, '').replace(/,/g, '')) || 0;
                            const descuento = parseFloat($(this).find('td').eq(6).text().trim()) || 0;
                            const promocion = $(this).find('td').eq(9).text().trim();

                            if (itemCode !== '') {
                                itemCodes.push({
                                    LineNum: lineNum,
                                    ItemCode: itemCode,
                                    Precio: precio,
                                    Cantidad: quantity,
                                    Descuento: descuento,
                                    PrecioCDescto: descuento,
                                    LineTotal: 0,
                                    ListPrice: $('#tipoPrecio').val(),
                                    Promocion: promocion
                                });
                            }
                        });

                        // Encabezado
                        const encabezado = {
                            DocEntry: parseInt('@Model.Encabezado.DocEntry'),
                            DocNum: parseInt('@Model.Encabezado.DocNum'),
                            Nit: $('#Nit').val(),
                            CardCode: $('#CardCode').val(),
                            CardName: $('#CardName').val(),
                            Direccion: $('#Direccion').val(),
                            Contacto: $('#Contacto').val(),
                            Telefono: $('#Telefono').val(),
                            Correo: $('#Correo').val(),
                            Nota: $('#Comments').val()
                        };

                        // Objeto completo
                        const editarCotizacionEntity = {
                            Encabezado: encabezado,
                            Detalle: itemCodes
                        };

                        $.ajax({
                            url: '/Ventas/EditarCoti',
                            type: 'POST',
                            data: { EditarCotizacionEntity: editarCotizacionEntity },
                            success: function (response) {
                                Swal.fire('Éxito', response.message, 'success').then(() => {
                                    location.reload();
                                });
                                $("#globalLoading").hide();
                            },
                            error: function (xhr, status, error) {
                                $("#globalLoading").hide();
                                Swal.fire('Error', 'No se pudo actualizar.', 'error');
                            }
                        });
                    }
                });
            });

            document.getElementById("btnPdf").addEventListener("click", function () {
                Swal.fire({
                    title: '¿Deseas descargar el PDF?',
                    icon: 'question',
                    showCancelButton: true,
                    confirmButtonColor: '#dc3545',
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: 'Sí, descargar',
                    cancelButtonText: 'Cancelar'
                }).then((result) => {
                    if (result.isConfirmed) {
                        const params = new URLSearchParams(window.location.search);
                        const DocEntry = params.get("DocEntry");
                        if (DocEntry == '') {
                            alert("No se encuentra documento")
                            return;
                        }

                        $("#globalLoading").show();
                        $.ajax({
                            url: '/Ventas/GeneratePdfAjax',
                            type: 'POST',
                            data: JSON.stringify({ docEntry: DocEntry }), // Serializa a JSON
                            contentType: 'application/json',
                            xhrFields: {
                                responseType: 'blob' // Indica que la respuesta será un binario (PDF)
                            },
                            success: function (blob, status, xhr) {
                                $("#globalLoading").hide();
                                const url = window.URL.createObjectURL(blob);
                                window.open(url, '_blank');
                            },
                            error: function (xhr, status, error) {
                                $("#globalLoading").hide();
                                alert('Hubo un error al descargar la cotización.');
                            }
                        });
                    }
                });
            });
        </script>

        <!-- Datos generales -->
        <div class="section-box" style="font-size:12px;">
            <div class="section-header"><i class="fas fa-circle-info me-2"></i>Datos Generales</div>
            <div class="row">
                <div class="col-md-4">
                    <p><span class="data-label">Fecha:</span> @Model.Encabezado.DocDate.ToString("dd/MM/yyyy")</p>
                    <p><span class="data-label">Vencimiento:</span> @Model.Encabezado.DocDueDate.ToString("dd/MM/yyyy")</p>
                    <p><span class="data-label">No. Documento:</span> @Model.Encabezado.DocNum</p>
                    <p><span class="data-label">No. Factura:</span> @Model.Encabezado.DocNumFac</p>
                </div>
                <div class="col-md-4">
                    <p style="display: flex; align-items: center; gap: 10px;">
                        <span class="data-label">Código Cliente:</span>
                        <input type="text" id="CardCode" name="CardCode" value="@Model.Encabezado.CardCode" readonly style="flex: 1; border: none; outline: none; background-color: transparent;" />
                    </p>
                    <p style="display: flex; align-items: center; gap: 10px;">
                        <select id="tipoDocumento" name="tipoDocumento" style="border: none; outline: none; background: transparent; padding-right:5px">
                            <option value="1">Nit/DPI:</option>
                            <option value="2">CF</option>
                        </select>
                        <input type="text" id="Nit" name="Nit" value="@Model.Encabezado.NitDocto" style="flex: 1; border: none; border-bottom: 1px solid #ccc; outline: none; background-color: transparent; text-transform:uppercase" autocomplete="off" />
                        <button id="btnBuscarNit" type="button" class="btn btn-outline-secondary btn-sm" title="Buscar" onclick="BuscarCliente()"
                                style="padding-left: 12px; padding-right: 12px;">
                            <i class="fas fa-search"></i>
                        </button>
                    </p>
                    <p style="display: flex; align-items: center; gap: 10px;">
                        <span class="data-label">Nombre:</span>
                        <input type="text" id="CardName" name="CardName" value="@Model.Encabezado.CardName" style="flex: 1; border: none; border-bottom: 1px solid #ccc; outline: none; background-color: transparent; text-transform: uppercase" autocomplete="off" readonly />
                    </p>
                    <p style="display: flex; align-items: center; gap: 10px;">
                        <span class="data-label">Dirección:</span>
                        <input type="text" id="Direccion" name="Direccion" value="@Model.Encabezado.Address" style="flex: 1; border: none; border-bottom: 1px solid #ccc; outline: none; background-color: transparent; text-transform: uppercase" autocomplete="off" />
                    </p>
                </div>
                <div class="col-md-4">
                    <p style="display: flex; align-items: center; gap: 10px;">
                        <span class="data-label">Contacto:</span>
                        <input type="text" id="Contacto" name="Contacto" value="@Model.Encabezado.Contacto" style="flex: 1; border: none; border-bottom: 1px solid #ccc; outline: none; background-color: transparent; text-transform: uppercase" autocomplete="off" />
                    </p>
                    <p style="display: flex; align-items: center; gap: 10px;">
                        <span class="data-label">Teléfono:</span>
                        <input type="text" id="Telefono" name="Telefono" value="@Model.Encabezado.Telefono" style="flex: 1; border: none; border-bottom: 1px solid #ccc; outline: none; background-color: transparent; text-transform: uppercase" autocomplete="off" />
                    </p>
                    <p style="display: flex; align-items: center; gap: 10px;">
                        <span class="data-label">Correo:</span>
                        <input type="text" id="Correo" name="Correo" value="@Model.Encabezado.Correo" style="flex: 1; border: none; border-bottom: 1px solid #ccc; outline: none; background-color: transparent; text-transform: lowercase" autocomplete="off" />
                    </p>

                    <style>
                        #Asesor:disabled {
                            color: gray;
                            pointer-events: none;
                            opacity: 0.6;
                        }
                    </style>

                    <p style="display: flex; align-items: center; gap: 10px;">
                        <span class="data-label">Asesor:</span>
                        <select id="Asesor" name="Asesor"
                                style="flex: 1; border: none; border-bottom: 1px solid #ccc; outline: none; background-color: transparent; text-transform: lowercase;"
                                autocomplete="off"
                                @(puedeSeleccionar ? "" : "disabled")>
                        </select>
                    </p>

                    <script>
                        $(document).ready(function () {
                            let primeraCarga = true; // bandera para ignorar el primer change

                            function CargarUsuarios() {
                                $('#Asesor')
                                    .html('')
                                    .append($('<option>', { value: '-1', text: '-- Seleccionar --' }))
                                    .val('-1');
                                    // NO disparamos change aquí, para no ejecutar AJAX en la carga inicial

                                $.ajax({
                                    url: '@Url.Action("ListaDeAsesoresCotizaciones", "Ventas")',
                                    type: "POST",
                                    data: { WhsCode: '@Model.Encabezado.WhsCode' },
                                    success: function (data) {
                                        var slpSeleccionado = '@Model.Encabezado.SlpCode'; // valor desde el modelo
                                        var encontrado = false;

                                        if (data && data.length > 0) {
                                            $.each(data, function (index, item) {
                                                $('#Asesor').append(
                                                    $('<option>', {
                                                        value: item.SlpCode,
                                                        text: item.SlpName
                                                    })
                                                );

                                                if (item.SlpCode.toString() === slpSeleccionado.toString()) {
                                                    encontrado = true;
                                                }
                                            });

                                            if (encontrado) {
                                                $('#Asesor').val(slpSeleccionado);
                                            } else {
                                                $('#Asesor').val('-1');
                                            }
                                        } else {
                                            $('#Asesor').val('-1');
                                        }
                                    },
                                    error: function (xhr, status, error) {
                                        console.error("Error al cargar los asesores:", error);
                                        $('#Asesor').val('-1').prop('disabled', false);
                                    },
                                    complete: function () {
                                        $("#globalLoading").hide();
                                        primeraCarga = false; // listo para detectar cambios posteriores
                                    }
                                });
                            }

                            $('#Asesor').change(function () {
                                if (primeraCarga) {
                                    // Ignorar el primer cambio disparado al asignar valor
                                    return;
                                }

                                $("#globalLoading").show();
                                let asesorSeleccionado = $(this).val();
                                let docEntry = '@Model.Encabezado.DocEntry';

                                if (asesorSeleccionado) {
                                    $.ajax({
                                        url: '/Ventas/ActualizarAsesor',
                                        type: 'POST',
                                        data: {
                                            asesor: asesorSeleccionado,
                                            docEntry: docEntry
                                        },
                                        success: function (resp) {
                                            $("#globalLoading").hide();
                                            if (resp.success) {
                                                Swal.fire({
                                                    icon: 'success',
                                                    title: 'Actualización exitosa',
                                                    text: resp.message,
                                                    toast: true,
                                                    position: 'top-end',
                                                    showConfirmButton: false,
                                                    timer: 3000,
                                                    timerProgressBar: true
                                                });
                                            }
                                        },
                                        error: function (err) {
                                            $("#globalLoading").hide();
                                        }
                                    });
                                }
                            });

                            CargarUsuarios();
                        });

                    </script>
                </div>
            </div>

            <div class="alert-note" style="display: flex; align-items: start; gap: 10px; background-color: #fefae0; padding: 10px; border-radius: 8px;">
                <i class="fas fa-comment-dots text-warning" style="margin-top: 5px;"></i>
                <textarea id="Comments" name="Comments"
                          placeholder="Escribe tus comentarios..."
                          style="flex: 1; border: none; outline: none; background-color: transparent; resize: none;
                          min-height: 35px; font-family: inherit; font-size: 14px;">@Model.Encabezado.Comments</textarea>
            </div>
        </div>

        <script>
            $('#tipoDocumento').on('change', function () {
                $("#globalLoading").show();

                // Limpiar campos
                $('#CardName').val("");
                $('#Nit').val("");
                $('#CardCode').val("");
                $('#Direccion').val("");
                $('#Telefono').val("");
                $('#Contacto').val("");
                $('#Correo').val("");
                $('#Contacto').focus();

                const valor = $(this).val();

                if (valor == '1') {
                    // Nit/DPI seleccionado: habilitar campos
                    $('#CardName').prop('disabled', true);
                    $('#Nit').prop('disabled', false);
                    $('#btnBuscarNit').prop('disabled', false);
                    $('#Nit').focus();
                    $("#globalLoading").hide();
                    return;
                }

                if (valor === '2') {
                    // CF seleccionado: autocompletar y bloquear campos
                    var clienteCF = "@HttpUtility.JavaScriptStringEncode(_clienteCF)";
                    $('#CardName').val("CONSUMIDOR FINAL").prop('disabled', true);
                    $('#Nit').val(clienteCF).prop('disabled', true);
                    $('#btnBuscarNit').prop('disabled', true);
                    $("#globalLoading").hide();
                }
            });
        </script>

        <!-- Detalle de productos -->

        @if (Model.Encabezado.Estado == "Revision" || Model.Encabezado.Estado == "Autorizado")
        {
            <div class="section-box">
                <div class="section-header" style="display: flex; justify-content: space-between; align-items: center;">
                    <div style="display: flex; align-items: center; gap: 15px;">
                        <i class="fas fa-key me-2"></i>
                        <span>Autorización</span>
                    </div>
                </div>

                <!-- Tabla de autorizaciones -->
                <div class="table-responsive mt-3">
                    <table class="table table-bordered table-striped table-sm" style="font-size: 12px;">
                        <thead class="table-light">
                            <tr>
                                <th class="text-center p-1">Estado</th>
                                <th class="text-center p-1">Fecha y Hora</th>
                                <th class="text-center p-1">Usuario</th>
                                <th class="text-center p-1">Comentario</th>
                            </tr>
                        </thead>
                        <tbody id="tablaAutorizacion">
                            @foreach (var item in Model.HistorialAuto)
                            {
                                var rowClass = item.IdEstado == 1 ? "table-success" : ""; // Verde si IdEstado = 1
                                <tr class="@rowClass">
                                    <td class="text-center p-1">@item.Estado</td>
                                    <td class="text-center p-1">@item.FechaHora</td>
                                    <td class="text-center p-1">@item.Usuario</td>
                                    <td class="text-start p-1">@item.Notas</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

            </div>

        }

        <style>
            .tipo-precio-select {
                width: 220px;
                padding: 8px 12px;
                border: 1px solid #ccc;
                border-radius: 6px;
                font-size: 15px;
                background-color: #f4f4f4;
                transition: border-color 0.3s ease-in-out;
            }

                .tipo-precio-select:focus {
                    border-color: #007bff;
                    outline: none;
                    background-color: #fff;
                    box-shadow: 0 0 5px rgba(0, 123, 255, 0.3);
                }
        </style>


        <div class="section-box">
            <div class="section-header" style="display: flex; justify-content: space-between; align-items: center;">
                <div style="display: flex; align-items: center; gap: 15px;">
                    <i class="fas fa-box-open me-2"></i>
                    <span>Detalle de Productos</span>
                </div>

                <div style="display: flex; flex-direction: column; align-items: flex-end; gap: 5px;">
                    <button id="btnAbrirModalProducto" type="button" class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#modalBuscarProducto" style="display: flex; align-items: center; gap: 5px;">
                        <i class="fas fa-search"></i> Buscar producto
                    </button>
                </div>
            </div>

            <div style="margin-bottom:15px; font-size:12px;">
                <select id="tipoPrecio" class="tipo-precio-select" style="font-size: 12px;">
                    <option value="1" @(Model.Encabezado.PriceList == 1 ? "selected" : "")>💼 Precio beneficio</option>
                    <option value="9" @(Model.Encabezado.PriceList == 9 ? "selected" : "")>🏷️ Precio normal</option>
                </select>
            </div>

            <script>
                $(document).ready(function () {
                    $('#tipoPrecio').on('change', function () {
                        $("#globalLoading").show();
                        const tipoSeleccionado = $(this).val();
                        const itemCodes = [];
                        $('#detProductos tr').each(function () {
                            const itemCode = $(this).find('td').eq(2).text().trim();
                            const quantity = $(this).find('td').eq(4).find('input[type="number"]').val().trim();
                            const descuento = $(this).find('td').eq(6).text().trim();
                            const promocion = $(this).find('td').eq(9).text().trim();

                            if (itemCode !== '' && promocion !== 'P') {
                                itemCodes.push({ ItemCode: itemCode, Quantity: quantity, Descuento: descuento });
                            }
                        });

                        const textoJson = JSON.stringify(itemCodes, null, 2);
                        $.ajax({
                            url: '/Ventas/CambiarPrecios',
                            type: 'POST',
                            data: { tipoPrecio: tipoSeleccionado, Codigos: textoJson },
                            success: function (response) {
                                let totalGeneral = 0; // Inicializa acumulador

                                response.forEach(itemNuevo => {
                                    $('#detProductos tr').each(function () {
                                        const itemCode = $(this).find('td').eq(2).text().trim();
                                        if (itemCode === itemNuevo.ItemCode) {
                                            const nuevoPrecio = itemNuevo.Price;

                                            // Actualizar visualmente el precio unitario
                                            const tdPrecio = $(this).find('td.precio');
                                            tdPrecio.text(`Q ${nuevoPrecio.toLocaleString('es-GT', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`);
                                            tdPrecio.attr('data-precio', nuevoPrecio);

                                            // Obtener cantidad y calcular total de la línea
                                            const cantidad = parseFloat($(this).find('input[name="Cantidad"]').val()) || 1;
                                            const totalLinea = cantidad * nuevoPrecio;

                                            // Mostrar total de línea
                                            $(this).find('.line-total').text(`Q ${totalLinea.toLocaleString('es-GT', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`);

                                            // Sumar al total general
                                            totalGeneral += totalLinea;
                                        }
                                    });
                                });

                                // ✅ Mostrar el total general en el campo correspondiente
                                $('#total-general').text(`Q ${totalGeneral.toLocaleString('es-GT', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`);


                                $("#globalLoading").hide();
                            },
                            error: function (xhr, status, error) {
                                $("#globalLoading").hide();
                                Swal.fire('Error', 'No se pudo actualizar el tipo de precio.', 'error');
                            }
                        });
                    });
                });
            </script>

            <div class="table-responsive" style="font-size: 12px;">
