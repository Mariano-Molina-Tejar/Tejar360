            function generarSelectAlmacenes(almacenes, seleccionado) {
                let html = `<select class="form-select form-select-sm"
                                                                                        style="width: 100%; height: 100%; border: none; outline: none; background-color: transparent; box-shadow: none;"
                                                                                        onchange="this.value = this.getAttribute('data-current');"
                                                                                        data-current="${seleccionado}">`;

                almacenes.forEach(a => {
                    const texto = `${a.WhsName} (Stock: ${a.Stock}, Comprometido: ${a.Comprometido})`;
                    const selected = (a.Seleccionado != '') ? 'selected' : '';
                    html += `<option ${selected}>${texto}</option>`;
                });

                html += `</select>`;
                return html;
            }

            function cargarProductos(ItemName, esPromo) {
                $("#globalLoading").show();
                $.ajax({
                    url: '/Ventas/BuscarProductos', // Cambiá esta URL a tu endpoint real
                    type: 'GET',
                    async: false,
                    data: { NombreProducto: ItemName, Promos: esPromo },
                    success: function (productos) {
                        $("#globalLoading").hide();
                        let html = '';
                        $('#tablaProductosBody').html('<tr><td colspan="8" class="text-center text-danger">No hay promociones cargadas</td></tr>');
                        productos.forEach(p => {
                            const selectAlmacen = generarSelectAlmacenes(p.Almacenes, "");
                            html += `
                                                                                                <tr>
                                                                                                    <td style="width:125px; text-align: center;">
                                                                                                        <button type="button" class="btn btn-sm btn-success btn-seleccionar">
                                                                                                            <i class="fas fa-check-circle me-1"></i> Select
                                                                                                        </button>
                                                                                                    </td>
                                                                                                    <td style="text-align: center; vertical-align: middle; width:70px">
                                                                                                       <img src="${p.Imagen === '' ? '/Img/imagen-no-disponible.png' : p.Imagen}" alt="Icono" style="width: 32px; height: 32px;" />
                                                                                                    </td>
                                                                                                    <td style="width:125px;" id='ItemCode'>${p.ItemCode}</td>
                                                                                                    <td id='ItemName'>${p.ItemName}</td>
                                                                                                    <td style="text-align: center; vertical-align: middle; padding: 0; width: 125px;">
                                                                                                            <input id='txtCantidad' type="number" min="1" value="1" class="form-control form-control-sm text-center cantidad"
                                                                                                                   data-metraje="${p.Metraje}" style="width: 100%; border: none; outline: none; background-color: transparent; font-size:14px" />
                                                                                                    </td>
                                                                                                    <td style="text-align: center; width: 80px;" class="resultado">
                                                                                                        ${p.Metraje}
                                                                                                    </td>
                                                                                                    <td id="PrecioNormal" style="text-align: center; width: 130px;">Q${p.PrecioBeneficio.toLocaleString('es-GT', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}</td>
                                                                                                    <td id="PrecioEfectivo" style="text-align: center; width: 130px;">Q${p.PrecioVenta.toLocaleString('es-GT', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}</td>
                                                                                                    <td id="PrecioOferta" style="text-align: center; width: 130px;">
                                                                                                        Q${p.PrecioPromocion.toLocaleString('es-GT', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}
                                                                                                        ${p.PrecioPromocion > 0 ? '<i class="fas fa-tags text-danger ms-1" title="Producto en promoción"></i>' : ''}
                                                                                                    </td>
                                                                                                    <td style="text-align: center; vertical-align: middle; padding: 0; height: 100%;">${selectAlmacen}</td>
                                                                                                </tr>
                                                                                            `;
                        });

                        $(document).off('click', '.btn-seleccionar').on('click', '.btn-seleccionar', function () {
                            const fila = $(this).closest('tr');
                            fila.closest('tbody').find('tr').removeClass('table-primary');
                            fila.addClass('table-primary');

                            const itemCode = fila.find('#ItemCode').text().trim();
                            const itemName = fila.find('#ItemName').text().trim();
                            const cantidad = fila.find('#txtCantidad').val().trim();

                            const PrecioNormal = parseFloat(fila.find('#PrecioNormal').text().replace('Q', '').replace(',', '').trim()) || 0;
                            const PrecioEfectivo = parseFloat(fila.find('#PrecioEfectivo').text().replace('Q', '').replace(',', '').trim()) || 0;
                            const PrecioOferta = parseFloat(fila.find('#PrecioOferta').text().replace('Q', '').replace(',', '').trim()) || 0;

                            let PrecioFinal = 0.00;
                            const tipoSeleccionado = parseInt(document.getElementById("tipoPrecio").value);

                            if (tipoSeleccionado === 1) { // PRECIO BENEFICIO
                                if (PrecioOferta > 0) {
                                    PrecioFinal = PrecioOferta;
                                } else {
                                    PrecioFinal = PrecioEfectivo;
                                }
                            } else if (tipoSeleccionado === 9) { // PRECIO NORMAL
                                PrecioFinal = PrecioNormal;
                            }

                            let PrecioTotal = 0.00;
                            PrecioTotal = PrecioFinal * cantidad;
                            let nuevaFila = ``;
                            nuevaFila = `
                                                                                                <tr>
                                                                                                    <td style="vertical-align: middle;">
                                                                                                        <button type="button" class="btn btn-danger btn-sm" onclick="QuitarListado(this)">
                                                                                                            <i class="fas fa-trash-alt"></i>
                                                                                                        </button>
                                                                                                    </td>
                                                                                                    <td style="vertical-align: middle; display: none;">-1</td> <!-- LineNum -->
                                                                                                    <td style="vertical-align: middle;">${itemCode}</td>
                                                                                                    <td style="text-align:left; vertical-align: middle;">${itemName}</td>
                                                                                                    <td style="vertical-align: middle; text-align: center;">
                                                                                                    <input type="number" id="Cantidad" name="Cantidad" value="${cantidad}" min="1"
                                                                                                                   class="cantidad"
                                                                                                                   style="width: 60px; text-align: center; border: none; outline: none; border-bottom: 1px solid #ccc; background: transparent;" />
                                                                                                    </td>
                                                                                                    <td style="text-align: right; vertical-align: middle;" class="precio" data-precio="${PrecioFinal}">
                                                                                                      Q${PrecioFinal.toLocaleString('es-GT', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}
                                                                                                    </td>
                                                                                                    <td style="text-align: right; vertical-align: middle;">0.00</td>
                                                                                                    <td style="text-align: right; vertical-align: middle;" class="precio-descuento">Q 0.00</td>
                                                                                                     <td style="text-align: right; vertical-align: middle;" class="line-total" data-precio="${PrecioTotal}">
                                                                                                      Q${PrecioTotal.toLocaleString('es-GT', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}
                                                                                                    </td>
                                                                                                    <td style="text-align: right; vertical-align: middle; display: none;"></td>
                                                                                                </tr>
                                                                                            `;

                            // Agregar fila al tbody
                            console.log(nuevaFila);
                            $('#detProductos').append(nuevaFila);
                            /*const modal = bootstrap.Modal.getInstance(document.getElementById('modalBuscarProducto'));*/
                            //if (modal) modal.hide();
                            $('#modalBuscarProducto').modal('hide');

                        });

                        $(document).on('input', '.cantidad', function () {
                            const input = $(this);
                            const fila = input.closest('tr');

                            let cantidad = parseFloat(input.val()) || 1;
                            if (cantidad < 1) {
                                cantidad = 1;
                                input.val(cantidad);
                            }

                            const precioUnitario = parseFloat(fila.find('.precio').data('precio')) || 0;
                            const descuento = parseFloat(fila.find('td').eq(6).text().trim()) || 0;

                            // Calcular precio con descuento
                            const precioConDescuento = precioUnitario;
                            const totalLinea = cantidad * precioUnitario;

                            // Actualizar DOM
                            /*fila.find('.precio-descuento').text('Q ' + precioConDescuento.toLocaleString('es-GT', { minimumFractionDigits: 2 }));*/
                            fila.find('.line-total').text('Q ' + totalLinea.toLocaleString('es-GT', { minimumFractionDigits: 2 }));

                            // Recalcular totales
                            recalcularTotales();
                        });

                        $(document).on('input change', '.cantidad', function () {
                            const input = $(this);
                            let cantidad = parseInt(input.val());
                            const metraje = parseFloat(input.data('metraje')) || 0;
                            const resultado = cantidad * metraje;

                            input.closest('tr').find('.resultado').text(resultado.toFixed(2));
                        });

                        $('#tablaProductosBody').html(html);
                    },
                    error: function () {
                        $('#tablaProductosBody').html('<tr><td colspan="8" class="text-center text-danger">Error al cargar los productos</td></tr>');
                        $("#globalLoading").hide();
                    }
                });
            }

            function BuscarCliente() {
                $("#globalLoading").show();
                const nitDpi = document.getElementById('Nit').value;
                if (nitDpi.trim() === '') {
                    $("#globalLoading").hide();
                    alert('Por favor ingrese un NIT o DPI antes de buscar.');
                } else {
                    $.ajax({
                        url: '/MiCarrito/BuscarSocioNegocio', // Asegúrate de que esta URL sea la correcta
                        type: 'GET',
                        data: { Nit: nitDpi },
                        success: function (data) {
                            $("#globalLoading").hide();
                            console.log(data);
                            document.getElementById('CardCode').value = data.CardCode;
                            document.getElementById('CardName').value = data.FacturarNombre;
                            document.getElementById('Direccion').value = data.FacturarDireccion;
                        },
                        error: function (xhr, status, error) {
                            $("#globalLoading").hide();
                            alert('Hubo un error al realizar la búsqueda.');
                        }
                    });
                }
            }

            function QuitarListado(btn) {
                Swal.fire({
                    title: '¡Atención!',
                    text: '¿Eliminar la fila seleccionada',
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonText: 'Sí, estoy seguro',
                    cancelButtonText: 'No, cancelar',
                    confirmButtonColor: '#dc3545',
                    cancelButtonColor: '#6c757d',
                    reverseButtons: true,
                    backdrop: `rgba(255,0,0,0.1)`
                }).then((result) => {
                    if (result.isConfirmed) {
                        const fila = btn.closest('tr');
                        if (fila) {
                            fila.remove();
                            recalcularTotales();
                        }
                    }
                });
            }

            // Función para formatear número como "#,##0.00"
            function formatoNumero(num) {
                return num.toLocaleString('es-GT', {
                    minimumFractionDigits: 2,
                    maximumFractionDigits: 2
                });
            }

            window.addEventListener("DOMContentLoaded", () => {
                let total = 0;
                let descuentos = 0;
                let filas = 0;

                document.querySelectorAll("tbody tr").forEach(tr => {
                    const descuento = parseFloat(tr.children[4].textContent.replace('%', '').trim()) || 0;
                    const lineTotal = parseFloat(tr.querySelector('.line-total').textContent.replace('Q', '').replace(/,/g, '').trim()) || 0;

                    total += lineTotal;
                    descuentos += descuento;
                    filas++;
                });

                const promedioDescuento = filas > 0 ? (descuentos / filas) : 0;

                document.getElementById("descuento-total").textContent = formatoNumero(promedioDescuento) + " %";
                document.getElementById("total-general").textContent = "Q " + formatoNumero(total);
            });
        </script>
    </div>
</body>
</html>

<script>
    document.getElementById("txtMotivoPerdida").disabled = true;
    $(document).ready(function () {
        $.ajax({
            url: "/Ventas/getAllTiposCrm", // Ajusta la URL según tu backend
            type: "GET",
            dataType: "json",
            success: function (data) {
                let $select = $("#txtMedioContacto");
                $select.empty(); // Limpiar el select antes de agregar opciones
                $select.append('<option value="-1">-- Seleccione --</option>');
                // Recorrer los datos y agregarlos al select
                $.each(data, function (index, item) {
                    $select.append(`<option value="${item.Id}">${item.Dscription}</option>`);
                });
            },
            error: function () {
                console.error("Error al cargar los estados.");
            }
        });

        $.ajax({
            url: "/Ventas/getAllEstadoPerdidas", // Ajusta la URL según tu backend
            type: "GET",
            dataType: "json",
            success: function (data) {
                let $select = $("#txtMotivoPerdida");
                $select.empty(); // Limpiar el select antes de agregar opciones
                $select.append('<option value="-1">-- Seleccione --</option>');
                // Recorrer los datos y agregarlos al select
                $.each(data, function (index, item) {
                    $select.append(`<option value="${item.Id}">${item.Dscription}</option>`);
                });
            },
            error: function () {
                console.error("Error al cargar los estados.");
            }
        });
    });

    function guardarSeguimiento() {
            $("#globalLoading").show();
            // Capturar los valores de los inputs
            var data = {
                DocEntry: @Model.Encabezado.DocEntry,
                DocNum: @Model.Encabezado.DocNum,
                MedioContacto: document.getElementById("txtMedioContacto").value,
                Notas: document.getElementById("txtNotas").value,
                PosFechaCompra: document.getElementById("txtFechaCompra").value,
                FechaSeguimiento: document.getElementById("txtProximoSeg").value,
                EstadoPerdida: document.getElementById("chkPerdida").checked ? "Y" : "N",
                MotivoPerdida: document.getElementById("txtMotivoPerdida").value
            };

            // Enviar datos con AJAX
            $.ajax({
                url: "/Ventas/SaveSeguimiento", // Ruta a tu backend en ASP.NET
                type: "POST",
                contentType: "application/json",
                data: JSON.stringify(data),
                success: function (response) {
                    if (response.result === 1) {
                        alert("Seguimiento guardado correctamente.");
                        cargarSeguimiento();
                        $("#globalLoading").hide();
                    } else {
                        alert("Error: " + response.message);
                        $("#globalLoading").hide();
                    }
                },
                error: function () {
                    alert("Error al enviar la solicitud.");
                    $("#globalLoading").hide();
                }
            });
        }

    document.getElementById('btnSaveSeguimiento').addEventListener('click', function () {
        const chkPerdida = document.getElementById('chkPerdida');
        const medioContacto = document.getElementById('txtMedioContacto');
        const notas = document.getElementById('txtNotas');
        const fechaCompra = document.getElementById('txtFechaCompra');
        const proximoSeg = document.getElementById('txtProximoSeg');
        const motivoPerdida = document.getElementById('txtMotivoPerdida');

        if (!notas.value.trim()) {
            alert("Escribe alguna observación o acción realizada.");
            notas.focus();
            return;
        }

        if (chkPerdida.checked) {
            // Validaciones solo para cotización perdida
            if (!motivoPerdida.value || motivoPerdida.value === "0") {
                alert("Si marcaste que se perdió, dime por qué… ¡Vamos! selecciona el motivo de la cotización perdida");
                motivoPerdida.focus();
                return;
            }
        } else {
            // Validaciones normales
            if (!medioContacto.value || medioContacto.value === "0" || medioContacto.value == "-1") {
                alert("Selecciona un medio de contacto.");
                medioContacto.focus();
                return;
            }
            if (!fechaCompra.value) {
                alert("No olvides seleccionar la posible fecha de compra.");
                fechaCompra.focus();
                return;
            }
            if (!proximoSeg.value) {
                alert("¿Y cuándo le vas a dar seguimiento? Selecciona la fecha.");
                proximoSeg.focus();
                return;
            }
        }

        if (chkPerdida.checked) {
            Swal.fire({
                title: '¡Atención!',
                text: '¿Estás seguro de marcar esta cotización como perdida? Esta acción indica que no continuarás con el proceso.',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Sí, estoy seguro',
                cancelButtonText: 'No, cancelar',
                confirmButtonColor: '#dc3545',
                cancelButtonColor: '#6c757d',
                reverseButtons: true,
                backdrop: `rgba(255,0,0,0.1)`
            }).then((result) => {
                if (result.isConfirmed) {
                    guardarSeguimiento();
                } else {
                    Swal.fire({
                        title: 'Cotización NO marcada como perdida',
                        icon: 'info',
                        timer: 1800,
                        showConfirmButton: false
                    });
                }
            });
        } else {
            Swal.fire({
                title: '¿Está seguro?',
                text: '¿Desea guardar el seguimiento?',
                icon: 'question',
                showCancelButton: true,
                confirmButtonText: 'Sí, guardar',
                cancelButtonText: 'Cancelar',
                confirmButtonColor: '#28a745',
                cancelButtonColor: '#d33'
            }).then((result) => {
                if (result.isConfirmed) {
                    guardarSeguimiento();
                }
            });
        }
    });

    document.getElementById("agregarSeguimiento").addEventListener("click", function () {
        $("#modalSeguimiento").modal('show');
    });

    function cargarSeguimiento() {
        let docEntry = '@Model.Encabezado.DocEntry'; // Obtener el valor desde Razor
        $.ajax({
            url: '/Ventas/CargarSeguimientos',
            type: 'GET',
            data: { DocEntry: docEntry }, // Pasar el parámetro en la solicitud
            dataType: 'json',
            success: function (data) {
                let tbody = $('#seguimiento-body');
                tbody.empty(); // Limpiar la tabla antes de agregar nuevos datos
                if (data.length > 0) {
                    $.each(data, function (index, item) {
                        let fechaFormateada = formatFecha(item.FechaSeg);
                        let vencimientoFormateado = formatFecha(item.FechaVencimiento);
                        let fila = `
                                    <tr>
                                    <td>${item.Creado}</td>
                                    <td>${fechaFormateada}</td>
                                    <td>${vencimientoFormateado}</td>
                                    <td>${item.DescrEstado}</td>
                                    <td>${item.TipoDeContacto}</td>
                                    <td>${item.Accion}</td>
                                    <td>${item.Notas}</td>
                                    <td>${item.Usuario}</td>
                                </tr>
                            `;
                            tbody.append(fila);
                    });
                } else {
                    tbody.append('<tr><td colspan="8">No hay seguimientos registrados</td></tr>');
                }
            },
            error: function (xhr, status, error) {
                console.error('Error al cargar los seguimientos:', error);
            }
        });
    }
</script>