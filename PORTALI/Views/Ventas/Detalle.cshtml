                                <td style="text-align: right; vertical-align: middle;" class="precio-descuento">@item.DsctoNuevoPr.ToString("#,##0.00")</td>
                                <td style="text-align: right; vertical-align: middle;" class="line-total">Q @item.LineTotal.ToString("#,##0.00")</td>
