@{
    ViewBag.Title = "Liquidaciones por Renuncia";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<head>
    <link href="~/Css/Reclutamiento/style.css" rel="stylesheet">
</head>
<div class="container-fluid mt-4">

    <!-- CARD PRINCIPAL -->
    <div class="card card-dashboard">

        <!-- HEADER -->
        <div class="card-dashboard-header d-flex justify-content-between align-items-center">
            <div>
                <h5 class="mb-0 fw-semibold">Liquidaciones por Renuncia</h5>
                <small class="opacity-75">Control y autorización de pagos finales</small>
            </div>
            <i class="fas fa-user-slash fa-lg opacity-75"></i>
        </div>

        <!-- BODY -->
        <div class="card-body">

            <!-- FILTROS -->
            <div class="row g-3 mb-4">
                <div class="col-md-3">
                    <input type="text"
                           class="form-control form-control-sm"
                           placeholder="Buscar empleado..." />
                </div>

                <div class="col-md-3">
                    <select class="form-select form-select-sm">
                        <option value="">Estado</option>
                        <option>Pendiente</option>
                        <option>Autorizado</option>
                        <option>Rechazado</option>
                    </select>
                </div>

                <div class="col-md-3">
                    <input type="date" class="form-control form-control-sm" />
                </div>
            </div>

            <!-- TABLA -->
            <div class="table-responsive">
                <table class="table tabla-dashboard align-middle">

                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Empleado</th>
                            <th>Puesto</th>
                            <th>Fecha Renuncia</th>
                            <th class="text-end">Total</th>
                            <th>Estado</th>
                            <th class="text-center">Acciones</th>
                        </tr>
                    </thead>

                    <tbody>

                        <!-- ROW -->
                        <tr>
                            <td>1</td>

                            <td>
                                <div class="fw-semibold">Juan Pérez</div>
                            </td>

                            <td>Auxiliar Contable</td>

                            <td>15/01/2026</td>

                            <td class="text-end fw-semibold">
                                Q 8,750.00
                            </td>

                            <td>
                                <span class="badge bg-warning text-dark">
                                    Pendiente
                                </span>
                            </td>

                            <td class="text-center">
                                <button class="btn btn-outline-primary btn-sm rounded-circle me-1"
                                        title="Ver detalle">
                                    <i class="fas fa-eye"></i>
                                </button>
                            </td>
                        </tr>

                        <!-- ROW -->
                        <tr>
                            <td>2</td>

                            <td>
                                <div class="fw-semibold">María López</div>
                            </td>

                            <td>Supervisora</td>

                            <td>18/01/2026</td>

                            <td class="text-end fw-semibold">
                                Q 12,300.00
                            </td>

                            <td>
                                <span class="badge bg-success">
                                    Autorizado
                                </span>
                            </td>

                            <td class="text-center">
                                <button class="btn btn-outline-primary btn-sm rounded-circle me-1"
                                        title="Ver detalle">
                                    <i class="fas fa-eye"></i>
                                </button>

                            </td>
                        </tr>

                    </tbody>

                </table>
            </div>

        </div>
    </div>

</div>
