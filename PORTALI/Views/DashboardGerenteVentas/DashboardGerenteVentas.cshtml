        // Simulación de datos (luego los traerás de tu API en C#)
        let ventasPorAsesor = [
            { nombre: "VCHIQ-Silvia Soto", ventas: 25000, meta: 50000 },
            { nombre: "VCHIQ-Jessica Pérez", ventas: 30000, meta: 30000 },
            { nombre: "VCHIQ-Yendelyn Amabilia Vásquez González", ventas: 20000, meta: 20000 },
            { nombre: "VCHIQ-Hector Armando España Pérez", ventas: 35000, meta: 50000 }
        ];

        // Función para abreviar nombres
        function abreviarNombre(nombre) {
            let partes = nombre.split("-");
            if (partes.length > 1) {
                let nombresApellidos = partes[1].split(" ");    
                return `${nombresApellidos[0]} ${nombresApellidos[nombresApellidos.length - 1]}`;
            }
            return nombre;
        }

        // Configuración del gráfico con Chart.js
        let ctx = document.getElementById("ventasChart").getContext("2d");
        let ventasChart = new Chart(ctx, {
            type: "bar",
            data: {
                labels: ventasPorAsesor.map(a => abreviarNombre(a.nombre)), // Abreviar nombres
                datasets: [
                    {
                        label: "Ventas",
                        backgroundColor: "rgba(54, 162, 235, 0.6)",
                        data: ventasPorAsesor.map(a => a.ventas)
                    },
                    {
                        label: "Meta",
                        backgroundColor: "rgba(255, 99, 132, 0.6)",
                        data: ventasPorAsesor.map(a => a.meta)
                    }
                ]
            },
            options: {
                responsive: true,
                scales: {
                    x: {
                        ticks: {
                            autoSkip: false,
                            maxRotation: 45, // Rotar etiquetas para mejor visibilidad
                            minRotation: 45
                        }
                    },
                    y: { beginAtZero: true }
                },
