@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";

    List<Entity.PortalGerencialRankingTrimestralEntity> trimestral = new List<Entity.PortalGerencialRankingTrimestralEntity>();
    if (Session["PortalGerencialRankingTrimestral"] != null)
    {
        trimestral = Session["PortalGerencialRankingTrimestral"] as List<Entity.PortalGerencialRankingTrimestralEntity>;
    }

    if (((Entity.SessionLoginEntity)Session["PropertiesEntity"]) == null)
    {
        return;
    }
    var UserLogin = Session["PropertiesEntity"] as Entity.SessionLoginEntity;
}

<head>
    <title>Ranking trimestral</title>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <style type="text/css">
        .stars-outer {
            display: inline-block;
            position: relative;
            font-family: FontAwesome;
        }

            .stars-outer::before {
                content: "\f006 \f006 \f006 \f006 \f006";
            }

        .stars-inner {
            position: absolute;
            top: 0;
            left: 0;
            white-space: nowrap;
            overflow: hidden;
            width: 0;
        }

            .stars-inner::before {
                content: "\f005 \f005 \f005 \f005 \f005";
                color: #f8ce0b;
            }

        .card {
            
            border: none;
            border-radius: 15px;
            padding: 2px;
            background-color: #fff;
            position: relative;
            height: 260px;
        }

        .upper {
            height: 40px;
        }

            .upper img {
                width: 100%;
                border-top-left-radius: 10px;
                border-top-right-radius: 10px;
            }

        .user {
            position: relative;
        }

        .profile img {
            height: 80px;
            width: 80px;
            margin-top: 2px;
        }

        .profile {
           
           
        }

        

    </style>
</head>

<body>
    <ol class="breadcrumb">
        <li class="breadcrumb-item">Gerencia</li>
        @*<li class="breadcrumb-item">
            <a href="#">Ranking trimestral</a>
        </li>*@
        <li class="breadcrumb-item active">Ranking</li>
    </ol>
    <div class="container-fluid animated fadeIn">
        <div class="animated fadeIn">
            <div class="row col-12">
                <div class="col-xl-3 col-xs-12 col-sm-12 col-md-3 col-lg-3">
                    <div class="card">
                        <div style="">
                            <div class="upper">
                                <figure>
                                    <img src="https://i.imgur.com/Qtrsrk5.jpg" class="img-fluid">
                                </figure>
                            </div>
                        </div>
                        <div class="user text-center">
                            <div class="profile">                                
                                <img src="~/Img/usuario.png" class="rounded-circle" width="80" />
                            </div>
                        </div>
                        <div class="mt-3 text-center">
                            <h4 class="mb-0">@UserLogin.UserName</h4>
                            <div class="d-flex justify-content-between align-items-center mt-4 px-4">
                                @{
                                    if (trimestral.Count > 0)
                                    {
                                        for (int i = 0; i < trimestral[0].ListaTrimestral.Count; i++)
                                        {
                                            <div class="stats">
                                                <h6 class="mb-0">@trimestral[0].ListaTrimestral[i].Nombre</h6>
                                                <span>@trimestral[0].ListaTrimestral[i].Posicion</span><br />
                                                <span>Posición</span>
                                            </div>
                                        }
                                    }
                                }
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-xl-9 col-xs-12 col-sm-12 col-md-9 col-lg-9">
                    <div>
                        @for (int i = 0; i < trimestral.Count; i++)
                        {
                            <div class="d-flex justify-content-center row">
                                <div class="col-md-12">
                                    <div class="row p-2 bg-white border rounded">
                                        <div class="col-md-2 mt-1"><strong>@trimestral[i].No </strong><img class="img-fluid img-responsive rounded product-image rounded-circle" src="~/Img/vendedor.png" width="60" height="60"></div>
                                        <div class="col-md-6 mt-1">
                                            <h5 style="color: @if(i >= (trimestral.Count - 5))
                                                {
                                                    @Convert.ToString("Red");
                                                }">
                                                @trimestral[i].SlpName
                                            </h5>
                                            <div class="mt-1 mb-1 spec-1"><span style="font-style:oblique">@trimestral[i].Tienda</span><span class="dot"></span></div>
                                            <div class="@Convert.ToString("dato_"+ trimestral[i].No)">
                                                <div class="stars-outer" style="display:
                                                @if(i >=5)
                                                {
                                                    @Convert.ToString("none");
                                                }">
                                                    <div class="stars-inner"></div>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="align-items-center align-content-center col-md-3 border-left mt-1">
                                            <div class="d-flex flex-row align-items-center">
                                                <h4 class="mr-1" style="color:@if(i >= (trimestral.Count - 5))
                                                {
                                                    @Convert.ToString("Red");
                                                }">
                                                    @string.Format("{0:#,##0.00}", trimestral[i].Indice)%
                                                </h4>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>



<script type="text/javascript">
    const ratings = {
        dato_1: 5.0,
        dato_2: 4.0,
        dato_3: 3.0,
        dato_4: 2.0,
        dato_5: 1.0
    };

    // total number of stars
    const starTotal = 5;

    for (const rating in ratings) {
        const starPercentage = (ratings[rating] / starTotal) * 100;
        const starPercentageRounded = `${(Math.round(starPercentage / 10) * 10)}%`;
        document.querySelector(`.${rating} .stars-inner`).style.width = starPercentageRounded;
    }
</script>