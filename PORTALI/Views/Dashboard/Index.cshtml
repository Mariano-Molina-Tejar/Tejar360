@model Entity.DashboardAsesoresEntity
<head>
    <title>- Dashboard El Tejar -</title>
    <style>
        body {
            background-color: white;
        }

        .text-red {
            color: red;
        }

        .text-blue {
            color: blue;
        }

        .card {
            border: none;
            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
            border-radius: 8px;
            overflow: hidden;
        }

            .card h5 {
                color: #6c757d;
                font-size: 1rem;
                margin-bottom: 5px;
            }

            .card h3 {
                font-weight: bold;
                margin-bottom: 10px;
            }

            .card .text-success {
                color: #28a745 !important;
            }

            .card .text-danger {
                color: #dc3545 !important;
            }

        canvas {
            max-width: 100%;
            height: 300px; /* Altura fija para evitar problemas de diseño */
        }

        .chartjs-legend {
            display: none !important;
        }

        .table-responsive {
            max-height: 400px; /* Altura máxima del contenedor */
            overflow-y: auto; /* Scroll vertical */
            border: 1px solid #dee2e6; /* Opcional: añade borde al contenedor */
        }

        #ventasTable {
            width: 100%; /* Asegura que la tabla use todo el espacio del contenedor */
            table-layout: auto; /* Permite que las columnas se ajusten automáticamente */
        }

        /* Estilo general para la tabla */
        .table-responsive {
            border: 1px solid #ddd; /* Borde alrededor del contenedor */
            border-radius: 8px; /* Bordes redondeados */
            background-color: #f9f9f9; /* Fondo del contenedor */
            padding: 10px; /* Espaciado interno */
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1); /* Sombra ligera */
            overflow: hidden; /* Esconde contenido que se desborda */
        }

        table {
            width: 100%;
            border-collapse: collapse; /* Colapsar bordes de celdas */
            font-family: Arial, sans-serif;
            font-size: 14px;
            background-color: #ffffff; /* Fondo blanco para la tabla */
        }

            /* Estilo del encabezado */
            table thead {
                background-color: #007bff; /* Color de fondo azul */
                color: white; /* Color del texto */
                text-align: left; /* Alineación del texto */
            }

                table thead th {
                    padding: 12px; /* Espaciado interno */
                    text-transform: uppercase; /* Texto en mayúsculas */
                    font-size: 12px; /* Tamaño del texto */
                    letter-spacing: 0.5px; /* Espaciado entre letras */
                }

            /* Estilo de las filas */
            table tbody tr {
                border-bottom: 1px solid #ddd; /* Borde entre filas */
            }

                table tbody tr:nth-child(odd) {
                    background-color: #f8f9fa; /* Fondo claro para filas impares */
                }

                table tbody tr:hover {
                    background-color: #e9ecef; /* Fondo más oscuro al pasar el mouse */
                    cursor: pointer;
                }

            /* Estilo de las celdas */
            table td, table th {
                padding: 10px; /* Espaciado interno */
                text-align: center; /* Centrar texto */
                vertical-align: middle; /* Alinear verticalmente */
            }

                /* Ajuste para columnas específicas */
                table td img {
                    max-width: 50px; /* Limitar el tamaño de las imágenes */
                    height: auto; /* Mantener proporción */
                    border-radius: 4px; /* Bordes redondeados en imágenes */
                }

                table td:nth-child(6), table td:nth-child(7), table td:nth-child(8) {
                    font-weight: bold; /* Resaltar Ganancia, Base y Margen */
                    color: #28a745; /* Color verde */
                }

        /* Scroll interno */
        .table-responsive {
            max-height: 400px; /* Limitar altura */
            overflow-y: auto; /* Scroll vertical */
        }

            /* Ajuste de la barra de scroll */
            .table-responsive::-webkit-scrollbar {
                width: 8px; /* Ancho de la barra */
            }

            .table-responsive::-webkit-scrollbar-thumb {
                background-color: #007bff; /* Color de la barra */
                border-radius: 8px; /* Bordes redondeados */
            }

            .table-responsive::-webkit-scrollbar-track {
                background-color: #f1f1f1; /* Color de fondo de la barra */
            }

    </style>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded" rel="stylesheet">
    <link href="~/Css/Login/styleDashboardAsesores.css" rel="stylesheet" />   

</head>

