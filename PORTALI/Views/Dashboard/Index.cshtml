                                        <div class="col-auto">
                                            <label class="sr-only" for="inlineFormInputGroup">Indice Proyectado</label>
                                            <div class="input-group mb-2">
                                                <div class="input-group-prepend">
                                                    <div class="input-group-text" style="background-color: #e59866; width: 150px "></div>
                                                </div>
                                                <input type="text" class="form-control" id="inlineFormInputGroup" placeholder="" style="background-color:white" readonly onmousedown="return false;" value="0.00">
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-xl-6" style="padding: 10px;">
                                <div class="card">
                                    <div class="card-header">
                                        Utilidad
                                    </div>
                                    <div class="card-body">
                                        <div class="col-auto">
                                            <label class="sr-only" for="inlineFormInputGroup">Meta</label>
                                            <div class="input-group mb-2">
                                                <div class="input-group-prepend">
                                                    <div class="input-group-text" style="background-color: #FAD803; width:150px">Meta de Utilidad</div>
                                                </div>
                                                <input type="text" class="form-control" id="inlineFormInputGroup" placeholder="0.00" style="background-color:white" readonly onmousedown="return false;" value="0.00" />
                                            </div>
                                        </div>
                                        <div class="col-auto">
                                            <label class="sr-only" for="inlineFormInputGroup">Venta</label>
                                            <div class="input-group mb-2">
                                                <div class="input-group-prepend">
                                                    <div class="input-group-text" style="background-color: #FAD803; width:150px">Utilidad Generada</div>
                                                </div>
                                                <input type="text" class="form-control" id="inlineFormInputGroup" placeholder="0.00" style="background-color:white" readonly onmousedown="return false;" value="0.00">
                                            </div>
                                        </div>
                                        <div class="col-auto">
                                            <label class="sr-only" for="inlineFormInputGroup">Indice</label>
                                            <div class="input-group mb-2">
                                                <div class="input-group-prepend">
                                                    <div class="input-group-text" style="background-color: #FAD803; width:150px">Proyectado</div>
                                                </div>
                                                <input type="text" class="form-control" id="inlineFormInputGroup" placeholder="0.00" style="background-color:white" readonly onmousedown="return false;" value="0.00%">
                                            </div>
                                        </div>
                                        <div class="col-auto">
                                            <label class="sr-only" for="inlineFormInputGroup">Venta Proyectada</label>
                                            <div class="input-group mb-2">
                                                <div class="input-group-prepend">
                                                    <div class="input-group-text" style="background-color: #e59866; width: 150px ">% sobre alcance</div>
                                                </div>
                                                <input type="text" class="form-control" id="inlineFormInputGroup" placeholder="0.00" style="background-color:white" readonly onmousedown="return false;" value="0.00">
                                            </div>
                                        </div>
                                        <div class="col-auto">
                                            <label class="sr-only" for="inlineFormInputGroup">Indice Proyectado</label>
                                            <div class="input-group mb-2">
                                                <div class="input-group-prepend">
                                                    <div class="input-group-text" style="background-color: #e59866; width: 150px ">Margen a la fecha %</div>
                                                </div>
                                                <input type="text" class="form-control" id="inlineFormInputGroup" placeholder="0.00" style="background-color:white" readonly onmousedown="return false;" value="0.00%">
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
