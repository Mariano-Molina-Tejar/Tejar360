<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="~/Scripts/jquery-3.4.1.min.js"></script>
<script>
    document.addEventListener("DOMContentLoaded", function () {
        const abortController = new AbortController();
        const signal = abortController.signal;

        fetch('@Url.Action("DataMensualAsync", "Dashboard")', { signal })
            .then(response => response.json())
            .then(data => {
                const ctx = document.getElementById('myChart').getContext('2d');
                new Chart(ctx, {
                    type: 'line',
                    data: {
                        labels: data.labels,
                        datasets: [{
                            label: '',
                            data: data.data,
                            borderColor: 'green',
                            borderWidth: 2,
                            fill: false,
                            tension: 0.1
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: {
                                display: false
                            }
                        },
                        scales: {
                            y: {
                                beginAtZero: true
                            }
                        }
                    }
                });
            })
            .catch(error => {
                if (error.name === 'AbortError') {
                    console.log('La solicitud fue cancelada');
                } else {
                    console.error('Error al obtener los datos:', error);
                }
            });

        window.addEventListener('beforeunload', function () {
            abortController.abort();
        });
    });


    document.addEventListener("DOMContentLoaded", function () {
    // Llamar al endpoint para obtener los datos del gráfico
    fetch('@Url.Action("DataSemanal", "Dashboard")')
        .then(response => response.json())
        .then(data => {
            // Crear el gráfico con los datos obtenidos
            const ctx = document.getElementById('myChartSemanal').getContext('2d');
            new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: data.labels, // Etiquetas (meses)
                    datasets: [{
                        label: '', // Etiqueta vacía para evitar undefined
                        backgroundColor: 'rgba(0, 123, 255, 0.5)', // Color de fondo (azul con transparencia)
                        data: data.data, // Datos
                        borderColor: 'blue',
                        borderWidth: 2,
                        fill: false,
                        tension: 0.1 // Suavizar las líneas
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            display: false // Ocultar la leyenda por completo
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true
                        }
                    }
                }
            });
        })
        .catch(error => console.error('Error al obtener los datos:', error));
    });

    function formatASPDate(aspDate) {
        const timestamp = parseInt(aspDate.match(/\d+/)[0]);
        const date = new Date(timestamp);

        // Extraer día, mes y año
        const day = String(date.getDate()).padStart(2, '0'); // Asegurar que tenga 2 dígitos
        const month = String(date.getMonth() + 1).padStart(2, '0'); // Mes es 0-indexado
        const year = date.getFullYear();

        // Retornar en formato dd/MM/yyyy
        return `${day}/${month}/${year}`;
    }



    $(document).ready(function () {        
        $('#ventasTable tbody').html('<tr><td colspan="9" class="text-center">Cargando...</td></tr>');

        $.ajax({
            url: '/Dashboard/GetDetalleProductos',
            method: 'GET',
            dataType: 'json',
            success: function (response) {
                if (response.success) {
                    var data = response.data;
                    var tableBody = $('#ventasTable tbody');
                    tableBody.empty();

                    data.forEach(function (item) {
                        var row = `
                    <tr>
                        <td>${item.Tipo}</td>
                        <td>${formatASPDate(item.DocDate)}</td>
                        <td>${item.ItemCode}</td>
                        <td>${item.Dscription}</td>
                        <td>${item.Quantity}</td>
                        <td>${item.Ganancia.toLocaleString('es-ES', { style: 'currency', currency: 'QTZ' })}</td>
                        <td>${item.Base.toLocaleString('es-ES', { style: 'currency', currency: 'QTZ' })}</td>
                        <td>${item.Margen}%</td>
                        <td>
                            ${item.Imagen ? `<img src="${item.Imagen}" alt="Imagen del producto" style="width:50px; height:auto;">` : 'Sin imagen'}
                        </td>
                    </tr>
                `;
                        tableBody.append(row);
                    });
                } else {
                    alert(response.message || 'Error al cargar los datos');
                }
            },
            error: function (xhr, status, error) {
                console.error('Error al cargar los datos:', error);
                alert('No se pudieron cargar los datos.');
            }
        });
    });
</script>