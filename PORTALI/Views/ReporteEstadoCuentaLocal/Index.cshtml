
@model Entity.Filtros.FiltroEstadoCuentaLocal
@{
    ViewBag.Title = "Reporte Estado de Cuenta Local";
    var resultados = ViewBag.Resultado as List<Entity.ReporteEstadoCuentaLocalEntity>;
}

<div class="container-fluid mt-4">
    <h2 class="mb-4">Reporte Estado de Cuenta Local</h2>

    <div class="card shadow-sm mb-4">
        <div class="card-header bg-light">
            <h5 class="mb-0">Filtros de búsqueda</h5>
        </div>

        <div class="card-body">
            @using (Html.BeginForm("Index", "ReporteEstadoCuentaLocal", FormMethod.Post, new { @class = "row g-3" }))
            {
                <div class="col-12 col-md-4">
                    <label for="FechaInicio" class="form-label">Fecha de Inicio</label>
                    <input type="date"
                           id="FechaInicio"
                           name="FechaInicio"
                           class="form-control"
                           value="@ViewBag.FechaInicio"
                           aria-describedby="fechaInicioHelp"
                            />
                    <small id="fechaInicioHelp" class="form-text text-muted">
                        Seleccione la fecha desde la cual desea consultar.
                    </small>
                </div>

                <div class="col-12 col-md-4">
                    <label for="FechaFin" class="form-label">Fecha de Fin</label>
                    <input type="date"
                           id="FechaFin"
                           name="FechaFin"
                           class="form-control"
                           value="@ViewBag.FechaFin"
                           aria-describedby="fechaFinHelp"
                           />
                    <small id="fechaFinHelp" class="form-text text-muted">
                        Seleccione la fecha hasta la cual desea consultar.
                    </small>
                </div>

                <div class="col-12 col-md-4">
                    <label for="Proveedor" class="form-label">Proveedor</label>
                    @Html.DropDownListFor(m => m.Proveedor,
                         ViewBag.Proveedores as SelectList,
                            "-- Seleccione un Proveedor --",
                     new
                     {
                         @class = "form-select dropdown-toggle form-control",
                         aria_label = "Seleccione Proveedor",
                         style = "border-radius: 3px; box-shadow: 0 4px 6px rgba(0, 45, 145, 0.1);"
                     })
                    <small id="proveedorHelp" class="form-text text-muted">
                        Seleccione el proveedor con el que desea realizar la transacción.
                    </small>
                </div>

                <div class="col-12 col-md-4">
                    <label for="Destino" class="form-label">Destino</label>
                    @Html.DropDownListFor(m => m.Destino,
                     ViewBag.Tiendas as SelectList,
                     "-- Seleccione un Destino --",
                     new
                     {
                         @class = "form-select dropdown-toggle form-control",
                         aria_label = "Seleccione Destino",
                         style = "border-radius: 3px; box-shadow: 0 4px 6px rgba(0, 45, 145, 0.1);"
                     })
                    <small id="destinoHelp" class="form-text text-muted">
                        Seleccione el Destino a buscar.
                    </small>
                </div>

                <div class="col-12 col-md-4">
                    <label for="Ruta" class="form-label">Ruta</label>
                    <input type="text"
                           id="Ruta"
                           name="Ruta"
                           class="form-control form-control-lg"
                           value="@Model.Ruta"
                           placeholder="Ej. 4055"
                           aria-describedby="RutaHelp"
                           maxlength="20" />
                    <small id="RutaHelp" class="form-text text-muted">
                        Ingrese la ruta
                    </small>
                </div>

                <div class="col-12 col-md-4">
                    <label for="Factura" class="form-label">Factura</label>
                    <input type="text"
                           id="Factura"
                           name="Factura"
                           class="form-control form-control-lg"
                           value="@Model.Factura"
                           placeholder="Ej. 1840728761"
                           aria-describedby="FacturaHelp"
                           maxlength="20" />
                    <small id="FacturaHelp" class="form-text text-muted">
                        Ingrese la Factura
                    </small>
                </div>

                <div class="col-12 text-end mt-3">
                    <button type="submit" class="btn btn-primary btn-lg px-4 py-2 me-2 shadow-sm">
                        <i class="bi bi-funnel-fill me-1"></i> Filtrar
                    </button>

                    <a href="@Url.Action("Index", "ReporteEstadoCuentaLocal")" class="btn btn-outline-secondary btn-lg px-4 py-2 shadow-sm">
                        <i class="bi bi-arrow-repeat me-1"></i> Restablecer
                    </a>
                </div>

            }
        </div>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-body text-end">
            <div class="row g-3 mb-4">
                <div class="col-md-2 d-flex align-items-end">
                    @using (Html.BeginForm("ExportarExcel", "ReporteEstadoCuentaLocal", FormMethod.Post))
                    {
                        @Html.HiddenFor(m => m.FechaInicio)
                        @Html.HiddenFor(m => m.FechaFin)
                        @Html.HiddenFor(m => m.Ruta)
                        @Html.HiddenFor(m => m.Proveedor)
                        @Html.HiddenFor(m => m.Destino)
                        @Html.HiddenFor(m => m.Factura)

                        <button type="submit" class="btn btn-success btn-lg w-100 shadow-sm">
                            <i class="bi bi-file-earmark-excel-fill me-1"></i> Exportar Excel
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Tabla de Resultados -->
    @if (resultados != null && resultados.Any())
    {
        <div class="table-responsive">
            <table class="table table-bordered table-hover table-striped table-sm align-middle">
                <thead class="table-dark">
                    <tr>
                        <th class="text-nowrap">Ruta</th>
                        <th class="text-nowrap">Origen</th>
                        <th class="text-nowrap">Destino</th>
                        <th class="text-nowrap">Código</th>
                        <th class="text-nowrap">Nombre</th>
                        <th class="text-nowrap">Fecha OC</th>
                        <th class="text-nowrap">Numero OC</th>
                        <th class="text-nowrap">Monto OC</th>
                        <th class="text-nowrap">Fecha Fac Prov</th>
                        <th class="text-nowrap">Monto FP</th>
                        <th class="text-nowrap">Num FP</th>
                        <th class="text-nowrap">Detalle FP</th>
                        <th class="text-nowrap">Fecha Pago</th>
                        <th class="text-nowrap">Num Pago</th>
                        <th class="text-nowrap">Monto Pago</th>
                        <th class="text-nowrap">Detalle Pago</th>
                        <th class="text-nowrap">Serie</th>
                        <th class="text-end">Factura</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in resultados)
                    {
                        <tr>

                            <td>@item.Ruta</td>
                            <td>@item.Origen</td>
                            <td>@item.Destino</td>
                            <td>@item.Codigo</td>
                            <td>@item.Nombre</td>
                            <td>@item.FechaOC.ToString("dd/MM/yyyy")</td>
                            <td>@item.NumOC</td>
                            <td>@item.MontoOC.ToString("C")</td>
                            <td>@item.FechaFacProv.ToString("dd/MM/yyyy")</td>
                            <td>@item.MontoFP.ToString("C")</td>
                            <td>@item.NumFP</td>
                            <td>@item.DetalleFP</td>
                            <td>@item.FechaPago.ToString("dd/MM/yyyy")</td>
                            <td>@item.NumPago</td>
                            <td>@item.MontoPago.ToString("C")</td>
                            <td>@item.DetallePago</td>
                            <td>@item.Serie</td>
                            <td class="text-end">@item.Factura</td>

                        </tr>
                    }
                </tbody>
            </table>
        </div>



    }
    else if (Request.HttpMethod == "POST")
    {
        <div class="alert alert-warning d-flex align-items-center" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            No se encontraron resultados para los filtros aplicados.
        </div>
    }

</div>

