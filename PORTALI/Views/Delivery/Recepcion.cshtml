@model List<Entity.RecepcionProductosEntity>

<style>
    /* Estilos del panel */
    .panel {
        width: 90%;
        margin: 20px auto;
        border: 1px solid #dddddd;
        border-radius: 10px;
        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
        background-color: #ffffff;
        overflow: hidden;
    }

    .panel-header {
        background-color: #009879;
        color: white;
        padding: 15px;
        text-align: center;
        font-size: 20px;
        font-weight: bold;
        text-transform: uppercase;
    }

    .panel-body {
        padding: 20px;
    }

    /* Estilos de la tabla */
    .styled-table {
        width: 100%;
        border-collapse: collapse;
        font-family: Arial, sans-serif;
        font-size: 16px;
        margin: 20px 0;
        background-color: #f3f3f3;
        box-shadow: 0 2px 5px rgba(0, 0, 0, 0.2);
    }

        .styled-table thead tr {
            background-color: #009879;
            color: #ffffff;
            text-align: left;
        }

        .styled-table th, .styled-table td {
            padding: 12px 15px;
            text-align: center;
            border: 1px solid #dddddd;
        }

        .styled-table tbody tr {
            transition: background-color 0.3s ease;
        }

            .styled-table tbody tr:nth-child(even) {
                background-color: #f3f3f3;
            }

            .styled-table tbody tr:hover {
                background-color: #d1e7dd;
            }

        .styled-table tbody td {
            color: #333333;
        }

    /* Estilos del botón */
    .btn-show {
        border: none;
        padding: 8px 12px;
        cursor: pointer;
        border-radius: 5px;
        font-size: 14px;
        color: white;
        background-color: #007bff;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 5px;
    }

        .btn-show:hover {
            background-color: #0056b3;
        }

        .btn-show i {
            font-size: 16px;
        }

    /* Estilo para el mensaje de "No hay datos" */
    .no-data {
        font-style: italic;
        color: #777777;
        text-align: center;
    }

    .modal-full {
        width: 60%; /* Ocupa el 100% del ancho de la ventana */
        max-width: none; /* Evita que Bootstrap aplique un límite en el ancho */
    }

    .modal-header {
        flex-shrink: 0;
    }

    .modal-content {
        max-height: 90vh; /* Hasta el 90% del alto de la ventana */
        overflow-y: auto; /* Añadir scroll si el contenido excede el alto disponible */
    }

    .modal-body {
        overflow-y: auto;
        flex-grow: 1;
    }

</style>

<div class="panel">
    <div class="panel-header">
        Recepción de Órdenes de Compra
    </div>
    <div class="panel-body">
        <table class="styled-table">
            <thead>
                <tr>
                    <th>Cotización</th>
                    <th>Orden compra</th>
                    <th>Socio negocio</th>
                    <th>Fecha</th>
                    <th>Requerido</th>
                    <th>Total</th>
                    <th style="width:100px">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Count > 0)
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.DocEntryOc</td>
                            <td>@item.DocNumOc</td>
                            <td>@item.CardName</td>
                            <td>@item.DocDateOc.ToString("dd/MM/yyyy")</td>
                            <td>@item.DocDateReq.ToString("dd/MM/yyyy")</td>
                            <td>@item.DocTotal.ToString("N2")</td>
                            <td style="text-align:center">
                                <button class="btn-show" onclick="cargarModal(@item.DocNumOc)">
                                    Mostrar
                                    @*<i class="fas fa-eye"></i> Mostrar*@
                                </button>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="no-data">No hay datos para mostrar</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div id="detalleModal" class="modal fade bd-example-modal-lg" tabindex="-1" role="dialog" aria-labelledby="myLargeModalLabel" aria-hidden="true" data-backdrop="static" data-keyboard="false">
    <div class="modal-dialog modal-full">
        <div class="modal-content">
            <div class="modal-header" role="document">
                <h5 class="modal-title" id="exampleModalLabel">Orden de compra</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <div id="modal-content"></div>
            </div>
        </div>
    </div>
</div>

<script src="https://kit.fontawesome.com/a076d05399.js" crossorigin="anonymous"></script>
<script>
    function mostrarDetalle(docNum) {
        /*alert('Mostrando detalles de la orden con número: ' + docNum);*/
    }

    function cargarModal(_docNum) {
        $("#globalLoading").show();
        $.ajax({
            url: '@Url.Action("DetalleModal", "Delivery")', // Cambia por la ruta de tu vista
            type: 'GET',
            data: { DocNum: _docNum },
            success: function (data) {
                $("#globalLoading").hide();
                // Llenar el contenido del modal con la vista parcial
                $('#modal-content').html(data);
                // Mostrar el modal
                $('#detalleModal').modal('show');
            },
            error: function () {
                $("#globalLoading").hide();
                alert('Hubo un error al cargar el contenido.');
            }
        });
    }

</script>
