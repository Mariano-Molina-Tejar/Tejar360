<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>

<script>
    let chartAsignado, chartPrioridad, chartCategoria;
    // 🔹 Función para convertir minutos a "X h Y min"
    function formatearHorasMinutos(minutos) {
        if (!minutos || minutos <= 0) return "0 min";

        let dias = Math.floor(minutos / 1440); // 1440 min = 24h
        let horas = Math.floor((minutos % 1440) / 60);
        let mins = Math.floor(minutos % 60);

        let texto = "";
        if (dias > 0) texto += dias + (dias > 1 ? " días " : " día ");
        if (horas > 0) texto += horas + " h ";
        if (mins > 0) texto += mins + " min";

        return texto.trim();
    }

    const categorias = [
        "Desarrollo - Soporte SAP",
        "Desarrollo - Tableros PBI",
        "Requerimiento de Compra de Equipo, Configuración y Asignación",
        "Microsoft Office",
        "Soporte R1",
        "Red/Infraestructura",
        "Problemas de Comunicaciones | Externo",
        "Anulaciones R1",
        "Soporte de Impresión/Impresoras",
        "Problema de Hardware",
        "Error/Problema de Correos"
    ];

    function cargarKPIs(fechaInicio, fechaFin) {

        let tbodyUC = $('#tablaUsuariosCategorias tbody').empty();
        let usuariosCategorias = [];
        $.ajax({
            url: '@Url.Action("ObtenerKPIs", "KPISIt")',
            type: 'GET',
            data: { fechaInicio, fechaFin },
            success: function(data) {

                // Totales
                let totalTickets = data.Asignado.reduce((a,b)=>a+b.Cantidad,0);
                let totalPrioridad = data.Prioridad.reduce((a,b)=>a+b.Cantidad,0);
                let totalCategoria = data.Categoria.reduce((a, b) => a + b.Cantidad, 0);

                $('#totalTickets').text(totalTickets);
                $('#totalPrioridad').text(totalPrioridad);
                $('#totalCategoria').text(totalCategoria);

                // KPIs
                let count = data.Asignado.length;
                let totalCierre = count ? data.Asignado.reduce((a, b) => a + b.PromedioCierre, 0) / count : 0;
                let totalRespuesta = count ? data.Asignado.reduce((a, b) => a + b.PromedioRespuesta, 0) / count : 0;

                // 👇 Mostrar en horas:minutos en lugar de solo minutos
                $('#tiempoCierre').text(formatearHorasMinutos(totalCierre));
                $('#tiempoRespuesta').text(formatearHorasMinutos(totalRespuesta));


                // Tablas
                let tbodyA = $('#tablaAsignado tbody').empty();
                data.Asignado.forEach(t => {
                    tbodyA.append(`<tr>
                    <td>${t.Key}</td>
                    <td>${t.Cantidad}</td>
                    <td>${formatearHorasMinutos(t.PromedioCierre)}</td>
                    <td>${formatearHorasMinutos(t.PromedioRespuesta)}</td>
                </tr>`);
                });


                let tbodyP = $('#tablaPrioridad tbody').empty();
                data.Prioridad.forEach(t => {
                    tbodyP.append(`<tr><td>${t.Key}</td><td>${t.Cantidad}</td></tr>`);
                });

                let tbodyC = $('#tablaCategoria tbody').empty();
                data.Categoria.forEach(t => {
                    tbodyC.append(`<tr>
                    <td>${t.Key}</td>
                    <td>${t.Cantidad}</td>
                    <td>${formatearHorasMinutos(t.PromedioSLA)}</td>
                    <td>${formatearHorasMinutos(t.PromedioCierre)}</td>
                </tr>`);
                });


                let tbodyCU = $('#tablaCategoriaUsuario tbody').empty();

                // Crear un diccionario de usuarios
                let usuarios = {};

                // Recorrer los datos
                data.CategoriaUsuario.forEach(t => {
                    if (!usuarios[t.Usuario]) {
                        usuarios[t.Usuario] = { Usuario: t.Usuario, Cantidad: 0 };
                        // inicializar todas las categorías en 0
                        categorias.forEach(cat => {
                            usuarios[t.Usuario][cat] = 0;
                        });
                    }

                    usuarios[t.Usuario][t.Categoria] = formatearHorasMinutos(t.PromedioCierre);

                    usuarios[t.Usuario]["SLA"] = formatearHorasMinutos(t.PromedioSLA);
                    usuarios[t.Usuario]["Cierre"] = formatearHorasMinutos(t.PromedioCierre);
                });

                // Volcar al tbody
                Object.values(usuarios).forEach(u => {
                    let fila = `<tr>
                    <td>${u.Usuario}</td>`;

                    categorias.forEach(cat => {
                        fila += `<td>${u[cat]}</td>`;
                    });
                    tbodyCU.append(fila);
                });


                // Gráficos
                if(chartAsignado) chartAsignado.destroy();
                if(chartPrioridad) chartPrioridad.destroy();
                if(chartCategoria) chartCategoria.destroy();

                chartAsignado = new Chart(document.getElementById('chartAsignado').getContext('2d'), {
                    type: 'bar',
                    data: {
                        labels: data.Asignado.map(x => x.Key),
                        datasets: [{ label: 'Tickets cerrados', data: data.Asignado.map(x => x.Cantidad), backgroundColor: 'rgba(54, 162, 235, 0.6)' }]
                    }
                });

                chartPrioridad = new Chart(document.getElementById('chartPrioridad').getContext('2d'), {
                    type: 'pie',
                    data: {
                        labels: data.Prioridad.map(x => x.Key),
                        datasets: [{ data: data.Prioridad.map(x => x.Cantidad), backgroundColor: ['#ff6384','#36a2eb','#ffce56','#4bc0c0'] }]
                    }
                });

                var chartCategoria = new Chart(document.getElementById('chartCategoria').getContext('2d'), {
                    type: 'bar',
                    data: {
                        labels: data.Categoria.map(x => x.Key),
                        datasets: [{
                            label: 'Tickets por Categoría',
                            data: data.Categoria.map(x => x.Cantidad),
                            backgroundColor: ['#ff9999', '#66b3ff', '#99ff99', '#ffcc99']
                        }]
                    },
                    options: {
                        indexAxis: 'y', // ❌ Esto acuesta las barras
                        responsive: true,
                        plugins: {
                            legend: { display: false },
                            tooltip: { enabled: true }
                        },
                        scales: {
                            x: { beginAtZero: true },
                            y: { ticks: { autoSkip: false } }
                        }
                    }
                });

                // Agrupar por usuario y categoría
                data.Asignado.forEach(user => {
                    user.Categorias.forEach(cat => {
                        usuariosCategorias.push({
                            Usuario: user.Key,
                            Categoria: cat.Key,
                            Cantidad: cat.Cantidad,
                            PromedioRespuesta: cat.PromedioRespuesta,
                            PromedioCierre: cat.PromedioCierre
                        });
                    });
                });

                // Ordenar por usuario
                usuariosCategorias.sort((a, b) => a.Usuario.localeCompare(b.Usuario));

                usuariosCategorias.forEach(uc => {
                    tbodyUC.append(`<tr>
            <td>${uc.Usuario}</td>
            <td>${uc.Categoria}</td>
            <td>${uc.Cantidad}</td>
            <td>${uc.PromedioRespuesta.toFixed(2)}</td>
            <td>${uc.PromedioCierre.toFixed(2)}</td>
        </tr>`);
                });
            }
        });
    }

$(document).ready(function() {
    cargarKPIs(null, null);

    $('#filtroFechas').submit(function(e) {
        e.preventDefault();
        var fechaInicio = $(this).find('input[name="fechaInicio"]').val();
        var fechaFin = $(this).find('input[name="fechaFin"]').val();
        cargarKPIs(fechaInicio, fechaFin);
    });
});
</script>
