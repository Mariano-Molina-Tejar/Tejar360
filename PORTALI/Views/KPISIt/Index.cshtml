@{
    var primerDiaMes = new DateTime(DateTime.Now.Year, DateTime.Now.Month, 1).ToString("yyyy-MM-dd");
    var ultimoDiaMes = new DateTime(DateTime.Now.Year, DateTime.Now.Month, DateTime.DaysInMonth(DateTime.Now.Year, DateTime.Now.Month)).ToString("yyyy-MM-dd");
}

<style>
    body {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        background-color: #f4f6f8;
        color: #333;
        margin: 0;
    }

    h1 {
        text-align: center;
        margin-bottom: 30px;
        color: #1f3c88;
    }

    form#filtroFechas {
        display: flex;
        justify-content: center;
        gap: 15px;
        margin-bottom: 30px;
        flex-wrap: wrap;
        background-color: #fff;
        padding: 15px 20px;
        border-radius: 10px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }

        form#filtroFechas input[type="date"] {
            padding: 5px 10px;
            border-radius: 5px;
            border: 1px solid #ccc;
        }

        form#filtroFechas button {
            padding: 6px 15px;
            border: none;
            background-color: #1f3c88;
            color: #fff;
            font-weight: bold;
            border-radius: 5px;
            cursor: pointer;
            transition: background-color 0.3s;
        }

            form#filtroFechas button:hover {
                background-color: #3954b3;
            }

    .totales-cards, .kpi-cards {
        display: flex;
        justify-content: center;
        gap: 20px;
        margin-bottom: 30px;
        flex-wrap: wrap;
    }

    .total-card, .kpi-card {
        background-color: #fff;
        padding: 20px;
        border-radius: 10px;
        flex: 1;
        min-width: 220px;
        text-align: center;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }

        .total-card h2, .kpi-card h2 {
            margin: 0;
            color: #1f3c88;
        }

    .lists-container {
        display: flex;
        gap: 20px;
        margin-bottom: 30px;
        flex-wrap: wrap;
        justify-content: center;
    }

    .list-card {
        background-color: #fff;
        flex: 1;
        min-width: 300px;
        padding: 15px;
        border-radius: 10px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        overflow-y: auto;
    }

        .list-card h3 {
            margin-top: 0;
            color: #1f3c88;
            text-align: center;
        }

        .list-card table {
            width: 100%;
            border-collapse: collapse;
        }

        .list-card th, .list-card td {
            padding: 8px;
            text-align: left;
            border-bottom: 1px solid #ddd;
        }

    .charts-container {
        display: flex;
        flex-wrap: wrap;
        gap: 30px;
        justify-content: center;
        margin-bottom: 30px;
    }

    canvas {
        background-color: #fff;
        padding: 15px;
        border-radius: 10px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        max-width: 600px;
    }

    #tablaCategoriaUsuario {
        width: 100%;
        border-collapse: collapse;
    }

        #tablaCategoriaUsuario thead {
            background-color: #1f3c88;
            color: white;
            display: table;
            width: 100%;
            table-layout: fixed; /* mantiene alineación */
        }

        #tablaCategoriaUsuario tbody {
            display: block;
            max-height: 400px; /* ajusta según lo que quieras */
            overflow-y: auto;
            width: 100%;
        }

            #tablaCategoriaUsuario tbody tr {
                display: table;
                width: 100%;
                table-layout: fixed; /* para que coincidan las columnas con thead */
            }
</style>

<style>
