@model Entity.ViewModels.ReporteDañadoViewModel
@using Newtonsoft.Json

@{
    ViewBag.Title = "Reporte Dañados";
}

<h2>Reporte Dañados</h2>


<div class="card mb-4 shadow-sm w-100">
    <div class="card-body">
        <h5 class"card-title mb-3">Filtros</h5>

        @using (Html.BeginForm("ReporteDañado", "ReporteDañado", FormMethod.Post))
        {
            <div class="row">
                <div class="col-md-3">
                    @Html.LabelFor(m => m.Filtro.FechaInicio, "Fecha Inicio")
                    @Html.TextBoxFor(m => m.Filtro.FechaInicio, new { @class = "form-control", type = "date" })
                </div>
                <div class="col-md-3">
                    @Html.LabelFor(m => m.Filtro.FechaFin, "Fecha Fin")
                    @Html.TextBoxFor(m => m.Filtro.FechaFin, new { @class = "form-control", type = "date" })
                </div>
                <div class="col-md-3">
                    <label>Almacén</label>
                    @Html.DropDownListFor(m => m.Filtro.AlmacenSeleccionado,
                        new SelectList(Model.Almacenes ?? new List<string>(), Model.Filtro.AlmacenSeleccionado),
                        "Todos",
                        new { @class = "form-control" })
                </div>
                <div class="col-md-3">
                    <label>Transportista</label>
                    @Html.DropDownListFor(m => m.Filtro.TranportistaSeleccionado,
                        new SelectList(Model.Transportistas ?? new List<string>(), Model.Filtro.TranportistaSeleccionado),
                        "Todos",
                        new { @class = "form-control" })
                </div>
            </div>
            <br />
            <button type="submit" class="btn btn-primary">Filtrar</button>
            <a href="@Url.Action("ReporteDañado", "ReporteDañado")" class="btn btn-secondary ml-2">Restablecer</a>

        }
    </div>
</div>

<hr />

@Html.Partial("_Indicadores")

<hr />

@Html.Partial("_Graficos")

