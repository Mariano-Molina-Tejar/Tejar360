    <canvas id="chartStackedDañado" width="400" height="300"></canvas>

    <script>
    const labelsStacked = @Html.Raw(JsonConvert.SerializeObject(Model.ChartRelacionDañadoProcesos.Select(x => x.Mes)));
    const dataRuta = @Html.Raw(JsonConvert.SerializeObject(Model.ChartRelacionDañadoProcesos.Select(x => Math.Round(x.PorcentajeRuta, 2))));
    const dataAlmacen = @Html.Raw(JsonConvert.SerializeObject(Model.ChartRelacionDañadoProcesos.Select(x => Math.Round(x.PorcentajeAlmacen, 2))));

    const ctxStacked = document.getElementById('chartStackedDañado').getContext('2d');
    new Chart(ctxStacked, {
        type: 'bar',
        data: {
            labels: labelsStacked,
            datasets: [
                {
                    label: '% Dañado en Ruta',
                    data: dataRuta,
                    backgroundColor: 'rgba(255, 99, 132, 0.7)'
                },
                {
                    label: '% Dañado en Almacén',
                    data: dataAlmacen,
                    backgroundColor: 'rgba(54, 162, 235, 0.7)'
                }
            ]
        },
        options: {
            responsive: true,
            indexAxis: 'y',
            plugins: {
                title: {
                    display: true,
                    text: '% Dañado Total por Mes (Ruta + Almacén)'
                },
                tooltip: {
                    callbacks: {
                        label: function(context) {
                            return context.dataset.label + ': ' + context.raw.toFixed(2) + '%';
                        }
                    }
                },
                datalabels: {
                    color: '#000',
                    anchor: 'center',
                    align: 'center',
                    font: {
                        weight: 'bold'
                    },
                    formatter: function(value) {
                        return value.toFixed(2) + '%';
                    }
                }
            },
            scales: {
                x: {
                    stacked: true,
                    title: {
                        display: true,
                        text: 'Porcentaje (%)'
                    }
                },
                y: {
                    stacked: true,
                    title: {
                        display: true,
                        text: 'Mes'
                    }
                }
            }
        },
        plugins: [ChartDataLabels]
    });
    </script>






