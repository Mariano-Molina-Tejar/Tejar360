@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2.2.0"></script>

    <!--Script para grafica dañado en ruta por pdv-->
    <script>
        // Datos desde el Model a JavaScript
        const tiendas = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.ChartDañadoPorTienda.Select(x => x.Tienda)));
        const montoNC = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.ChartDañadoPorTienda.Select(x => x.MontoNC)));
        const porcentajeDañado = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.ChartDañadoPorTienda.Select(x => x.PorcentajeDañadoRutas * 100)));

        // Crear gráfica combinada: barras (MontoNC) + línea (% dañado rutas)
        const ctx = document.getElementById('chartDañadoPorTienda').getContext('2d');
        const chart = new Chart(ctx, {
            type: 'bar',
            data: {
                labels: tiendas,
                datasets: [
                    {
                        type: 'bar',
                        label: 'Monto NC',
                        data: montoNC,
                        backgroundColor: 'rgba(54, 162, 235, 0.7)',
                        yAxisID: 'y',
                    },
                    {
                        type: 'line',
                        label: '% Dañado Rutas',
                        data: porcentajeDañado,
                        borderColor: 'rgba(255, 99, 132, 1)',
                        backgroundColor: 'rgba(255, 99, 132, 0.2)',
                        yAxisID: 'y1',
                        fill: false,
                        tension: 0.1,
                        borderWidth: 3,
                        pointRadius: 5
                    }
                ]
            },
            options: {
                responsive: true,
                interaction: {
                    mode: 'index',
                    intersect: false
                },
                plugins: {
                    tooltip: {
                        callbacks: {
                            label: function(context) {
                                if (context.dataset.label === '% Dañado Rutas') {
                                    return context.dataset.label + ': ' + context.parsed.y.toFixed(2) + '%';
                                }
                                return context.dataset.label + ': Q ' + context.parsed.y.toFixed(2);
                            }
                        }
                    }
                },
                stacked: false,
                scales: {
                    y: {
                        type: 'linear',
                        display: true,
                        position: 'left',
                        title: {
                            display: true,
                            text: 'Monto NC (Q)'
                        }
                    },
                    y1: {
                        type: 'linear',
                        display: true,
                        position: 'right',
                        grid: {
                            drawOnChartArea: false
                        },
                        title: {
                            display: true,
                            text: '% Dañado Rutas'
                        },
                        ticks: {
                            callback: function(value) {
                                return value.toFixed(2) + '%';
                            },
                            max: 100,
                            min: 0
                        }
                    }
                }
            }
        });
    </script>

    <!--Script para Grafico Dañado por categoria-->
    <script>

    const categorias = @Html.Raw(JsonConvert.SerializeObject(Model.ChartDañadoPorCategoria.Select(x => x.Categoria)));
    const porcentajeCategoria = @Html.Raw(JsonConvert.SerializeObject(Model.ChartDañadoPorCategoria.Select(x => (x.PorcentajeDañado * 100).ToString("F2"))));

    const ctxCategoria = document.getElementById('chartDañadoPorCategoria').getContext('2d');
    const chartCategoria = new Chart(ctxCategoria, {
        type: 'bar',
        data: {
            labels: categorias,
            datasets: [{
                label: '% Dañado por Categoría',
                data: porcentajeCategoria,
                backgroundColor: 'rgba(255, 159, 64, 0.7)',
                borderColor: 'rgba(255, 159, 64, 1)',
                borderWidth: 2
            }]
        },
        options: {

            responsive: true,
            scales: {
                y: {
                    beginAtZero: true,
                    max: 3,
                    title: {
                        display: true,
                        text: '% Dañado'
                    },
                    ticks: {
                        callback: function(value) {
                            return value + '%';
                        }
                    }
                }
            },
            plugins: {
                tooltip: {
                    callbacks: {
                        label: function(context) {
                            return context.dataset.label + ': ' + context.parsed.y + '%';
                        }
                    }
                }
            }
        }
    });
    </script>

    <!--Script para grafica % Dañado por ruta -->
    <script>
        const rutas = @Html.Raw(JsonConvert.SerializeObject(Model.ChartDañadoPorRuta.Select(x => x.NoRutaOV)));
        const porcentajeDañadoRuta = @Html.Raw(JsonConvert.SerializeObject(Model.ChartDañadoPorRuta.Select(x => Math.Round(x.PorcentajeDañadoRuta, 2))));


        const ctxRuta = document.getElementById('chartDañadoPorRuta').getContext('2d');
        new Chart(ctxRuta, {
            type: 'bar',
            data: {
                labels: rutas,
                datasets: [{
                    label: '% Dañado por Ruta',
                    data: porcentajeDañadoRuta,
                    backgroundColor: 'rgba(255, 87, 51, 0.7)',
                    borderColor: 'rgba(255, 159, 64, 1)',
                    borderWidth: 2
                }]
            },
            options: {
                responsive: true,
                scales: {
                    y: {
                        beginAtZero: true,
                        max: 2.5,
                        ticks: {
                            callback: function(value) {
                                return value + '%';
                            }
                        },
                        title: {
                            display: true,
                            text: '% Dañado'
                        }
                    }
                },
                plugins: {
                    tooltip: {
                        callbacks: {
                            label: function(context) {
                                return context.dataset.label + ': ' + context.parsed.y + '%';
                            }
                        }
                    }
                }
            }
        });
    </script>

    <!--Script para grafica % Dañado por Transportista-->
    <script>
            const transportistas = @Html.Raw(JsonConvert.SerializeObject(Model.ChartDañadoPorTransportista.Select(x => x.Transportista)));
            const porcentajePorTransportista = @Html.Raw(JsonConvert.SerializeObject(Model.ChartDañadoPorTransportista.Select(x => x.PorcentajeDañadoTransportista.ToString("F2"))));

            const ctxTransportista = document.getElementById('chartDañadoPorTransportista').getContext('2d');
            const chartTransportista = new Chart(ctxTransportista, {
                type: 'bar',
                data: {
                    labels: transportistas,
                    datasets: [{
                        label: '% Dañado',
                        data: porcentajePorTransportista,
                        backgroundColor: 'rgba(75, 192, 192, 0.6)',
                        borderColor: 'rgba(75, 192, 192, 1)',
                        borderWidth: 1
                    }]
                },
                options: {
                    responsive: true,
                    scales: {
                        y: {
                            beginAtZero: true,
                            max: 5,
                            title: {
                                display: true,
                                text: '% Dañado'
                            },
                            ticks: {
                                callback: function(value) {
                                    return value + '%';
                                }
                            }
                        }
                    },
                    plugins: {
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    return '% Dañado: ' + context.parsed.y + '%';
                                }
                            }
                        }
                    }
                }
            });
    </script>




    <!--Script para grafica Monto Nota Credito por mes-->
    <script>
        const meses = @Html.Raw(JsonConvert.SerializeObject(Model.ChartMontoNCPorMes.Select(x => x.Mes)));
        const montosNcMes = @Html.Raw(JsonConvert.SerializeObject(Model.ChartMontoNCPorMes.Select(x => x.MontoNC.ToString("F2"))));

        const ctxMes = document.getElementById('chartMontoNCMeses').getContext('2d');
        const chartMes = new Chart(ctxMes, {
            type: 'bar',
            data:
            {
                labels: meses,
                datasets: [{
                    label: 'Monto NC',
                    data: montosNcMes,
                    backgroundColor: 'rgba(255, 206, 86, 0.6)',
                    borderColor: 'rgba(255, 206, 86, 1)',
                    borderWidth: 1
                }]
            },
            options: {

                responsive: true,
                scales: {
                    y: {
                        beginAtZero: true,
                        title: {
                            display: true,
                            text: 'Monto NC (Q)'
                        }
                    }
                },
                plugins: {
                    tooltip: {
                        callbacks: {
                            label: function(context) {
                                const valor = parseFloat(context.parsed.y).toFixed(2);
                                return context.dataset.label + ': Q ' + valor;
                            }
                        }
                    }
                }
            }
        });
    </script>


    <!--Script para grafica Dañado en Ruta-->
    <script>


            const dataRutaMes = {
                labels: @Html.Raw(Json.Encode(Model.ChartPorcentajeDañadoRutaMes.Select(x => x.Mes))),
                datasets: [{
                    label: '% Dañado en Ruta por Mes',
                    data: @Html.Raw(Json.Encode(Model.ChartPorcentajeDañadoRutaMes.Select(x => Math.Round(x.PorcentajeDañdoRutaMensual, 2)))),
                    backgroundColor: 'rgba(54, 162, 235, 0.6)',
                    borderColor: 'rgba(54, 162, 235, 1)',
                    borderWidth: 1
                }]
            };
            const ctxRutaMes = document.getElementById('chartPorcentajeDañadoRutaMes').getContext('2d');

            const configRutaMes = {
                type: 'bar',
                data: dataRutaMes,
                options: {
                    responsive: true,
                    scales: {
                        y: {
                            beginAtZero: true,
                            ticks: {
                                callback: function(value) {
                                    return value + '%';
                                }
                            },
                            title: {
                                display: true,
                                text: '% Dañado'
                            }
                        },
                        x: {
                            title: {
                                display: true,
                                text: 'Mes'
                            }
                        }
                    },
                    plugins: {
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    return context.dataset.label + ': ' + context.parsed.y.toFixed(2) + '%';
                                }
                            }
                        }
                    }
                }
            };

            new Chart(ctxRutaMes, configRutaMes);
    </script>

