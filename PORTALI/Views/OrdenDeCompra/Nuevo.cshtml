    <script>
        function armarObjetoOC() {
            var ocEncabezado = {
                CardCode: document.getElementById("codigoProveedor").value.trim(),
                IdSucursal: parseInt(document.getElementById("sucursalSelect").value),
                FechaDocumento: document.getElementById("fecha").value,
                FechaComprometido: document.getElementById("fechaComprometido").value,
                Moneda: document.getElementById("tipoCambioSelect").value,
                Notas: document.getElementById("observaciones").value.trim(),
                Detalle: []
            };

            const filas = document.querySelectorAll("#tablaProductos tbody tr");
            filas.forEach(fila => {
                const ItemCode = fila.querySelector(".input-codigo").value.trim();
                const ItemName = fila.querySelector(".input-descripcion").value.trim();
                const Quantity = parseFloat(fila.querySelector(".input-cantidad").value) || 0;
                const PriceU = parseFloat(fila.querySelector(".input-precioU").value) || 0;
                const CentroCosto = fila.querySelector(".centro-costo").value;
                const TipoArticulo = fila.querySelector(".select-tipoarticulo").value;
                const TipoImpuesto = fila.querySelector(".select-impuesto").value;
                
                if (ItemCode !== "" && Quantity > 0) {
                    ocEncabezado.Detalle.push({
                        ItemCode,
                        ItemName,
                        Quantity,
                        PriceU,
                        CentroCosto,
                        TipoArticulo,
                        TipoImpuesto
                    });
                }
            });

            return ocEncabezado;
        }

        function guardarDatos() {
            if (validarFormulario() === false) {
                return;
            } else if (validarTablaProductos() === false) {
                return;
            }

            Swal.fire({
                title: '¿Desea guardar?',
                text: "Se guardarán los datos ingresados.",
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#28a745',
                cancelButtonColor: '#d33',
                confirmButtonText: 'Sí, guardar',
                cancelButtonText: 'Cancelar'
            }).then((result) => {
                if (result.isConfirmed) {
                    $("#globalLoading").show();
                    var ocEncabezado = armarObjetoOC();                    
                    $.ajax({
                        url: '/OrdenDeCompra/GuardarOC',
                        type: 'POST',
                        contentType: 'application/json; charset=utf-8',
                        data: JSON.stringify(ocEncabezado),
                        success: function (data) {
                            if (data.data.DocNum > 0) {
                                $("#globalLoading").hide();
                                Swal.fire({
                                    icon: 'success',
                                    title: data.message,
                                    html: `
                                            <div>
                                                <strong>No. Documento</strong><br />
                                                <span style="
                                                    display: inline-block;
                                                    background-color: #fff3cd;
                                                    color: #856404;
                                                    padding: 5px 12px;
                                                    border-radius: 8px;
                                                    margin-top: 5px;
                                                    font-weight: bold;
                                                    font-size: 16px;">
                                                    ${data.data.DocNum}
                                                </span>
                                            </div>`,
                                    showCancelButton: true,
                                    confirmButtonText: '📄 PDF Orden compra',
                                    cancelButtonText: '❌ Cerrar',
                                    allowOutsideClick: false,
                                    allowEscapeKey: false
                                }).then((result) => {
                                    if (result.isConfirmed) {
                                        // Abrir el PDF en nueva pestaña
                                        window.open('/OrdenDeCompra/GenerarPDF?DocNum=' + data.data.DocNum, '_blank');

                                        // Esperar 3 segundos antes de recargar
                                        setTimeout(function () {
                                            location.reload();
                                        }, 10000); // 3000 ms = 3 segundos
                                    } else {
                                        location.reload();
                                    }

                                });
                            } else {
                                $("#globalLoading").hide();
                                Swal.fire({
                                    icon: 'error',
                                    title: 'Error al guardar',
                                    text: data.message,
                                    confirmButtonText: 'Aceptar',
                                    allowOutsideClick: false,
                                    allowEscapeKey: false
                                });
                            }
                        },
                        error: function () {
                            $("#globalLoading").hide();
                            Swal.fire({
                                icon: 'error',
                                title: 'Error de comunicación',
                                text: 'No se pudo conectar con el servidor.',
                                confirmButtonText: 'Aceptar',
                                allowOutsideClick: false,
                                allowEscapeKey: false
                            });
                        }
                    });
                }
            });
        }

        function validarFormulario() {
            const codigoProveedor = document.getElementById('codigoProveedor').value.trim();
            const nombreProveedor = document.getElementById('proveedor').value.trim();
            const sucursal = document.getElementById('sucursalSelect').value;
            const fecha = document.getElementById('fecha').value;
            const fechaComprometido = document.getElementById('fechaComprometido').value;

            let errores = [];

            if (!codigoProveedor) {
                errores.push("El campo 'Código Proveedor' es obligatorio.");
            }

            if (!nombreProveedor) {
                errores.push("El campo 'Nombre Proveedor' es obligatorio.");
            }

            if (sucursal === "-1" || sucursal === "") {
                errores.push("Debe seleccionar una sucursal.");
            }

            if (!fecha) {
                errores.push("La fecha es obligatoria.");
            }

            if (!fechaComprometido) {
                errores.push("La fecha comprometido es obligatoria.");
            }

            if (errores.length > 0) {
                Swal.fire({
                    icon: 'error',
                    title: 'Campos obligatorios',
                    html: errores.join('<br>'),
                    confirmButtonText: 'Aceptar'
                });
                return false;
            }

            // Si pasa todas las validaciones
            Swal.fire({
                icon: 'success',
                title: 'Validación exitosa',
                text: 'Todos los campos obligatorios están completos.'
            });

            return true;
        }

        function validarTablaProductos() {
            const tabla = document.getElementById("tablaProductos").getElementsByTagName("tbody")[0];
            const filas = tabla.getElementsByTagName("tr");

            if (filas.length === 0) {
                Swal.fire({
                    icon: 'error',
                    title: 'Productos requeridos',
                    text: 'Debe ingresar al menos un producto.'
                });
                return false;
            }

            let errores = [];

            for (let i = 0; i < filas.length; i++) {
                const fila = filas[i];

                const codigo = fila.querySelector(".input-codigo")?.value.trim();
                const descripcion = fila.querySelector(".input-descripcion")?.value.trim();
                const cantidad = parseFloat(fila.querySelector(".input-cantidad")?.value);
                const precio = parseFloat(fila.querySelector(".input-precioU")?.value);
                const centroCosto = fila.querySelector(".centro-costo")?.value.trim();

                if (!codigo) {
                    errores.push(`Fila ${i + 1}: El código del producto es obligatorio.`);
                }
                if (!descripcion) {
                    errores.push(`Fila ${i + 1}: La descripción del producto es obligatoria.`);
                }
                if (isNaN(cantidad) || cantidad <= 0) {
                    errores.push(`Fila ${i + 1}: La cantidad debe ser mayor a 0.`);
                }
                if (isNaN(precio) || precio <= 0) {
                    errores.push(`Fila ${i + 1}: El precio unitario debe ser mayor a 0.00.`);
                }
                if (!centroCosto) {
                    errores.push(`Fila ${i + 1}: Debe seleccionar un centro de costo.`);
                }
            }

            if (errores.length > 0) {
                Swal.fire({
                    icon: 'error',
                    title: 'Errores en productos',
                    html: errores.join('<br>'),
                    confirmButtonText: 'Revisar'
                });
                return false;
            }

            return true;
        }

        document.addEventListener('change', function (event) {
            if (event.target.classList.contains('select-impuesto')) {
                calcularTotales();
            }
        });

        function calcularTotales() {
            let subtotal = 0;
            let impuesto = 0;
            let totalGeneral = 0;
            document.querySelectorAll('#tablaProductos tbody tr').forEach(fila => {
                const totalInput = fila.querySelector('.input-total');
                const impuestoSelect = fila.querySelector('.select-impuesto');

                let total = 0;

                if (totalInput) {
                    // Quitar símbolo y comas
                    total = parseFloat(totalInput.value.replace(/[Q,]/g, '').replace(/[$,]/g, '')) || 0;
                }

                if (impuestoSelect && impuestoSelect.value === 'IVA') {
                    // Si tiene IVA, dividir entre 1.12 para obtener subtotal
                    const subSinIva = total / 1.12;
                    const iva = total - subSinIva;
                    subtotal += subSinIva;
                    impuesto += iva;
                } else {
                    // Si es EXENTO
                    subtotal += total;
                }

                totalGeneral += total;
            });

            // Mostrar en inputs formateado
            const tipoMoneda = document.getElementById('tipoCambioSelect').value;
            const moneda = tipoMoneda === 'USD' ? 'USD' : 'GTQ';

            document.getElementById('subtotal').value = subtotal.toLocaleString('es-GT', {
                style: 'currency',
                currency: moneda,
                minimumFractionDigits: 2
            });


            document.getElementById('impuesto').value = impuesto.toLocaleString('es-GT', {
                style: 'currency',
                currency: moneda,
                minimumFractionDigits: 2
            });

            document.getElementById('total').value = totalGeneral.toLocaleString('es-GT', {
                style: 'currency',
                currency: moneda,
                minimumFractionDigits: 2
            });
        }

        let filaActual = null; // variable global para guardar la fila activa

        function eliminarFila(boton) {
            const fila = boton.closest('tr');
            fila.remove();
            calcularTotales();
