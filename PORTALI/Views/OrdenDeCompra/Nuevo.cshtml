                                                <div style="display: table-cell; width: 60%; text-align: left; color: #333; font-weight: 500;">
                                                    ${item.CardName}
                                                </div>
                                            </div>
                                        `);
                                    });
                                }
                            });
                        } else {
                            $("#sugerencias").hide();
                        }
                    }

                    // Asignamos evento input normalmente
                    $("#socioInput").on("input", function () {
                        buscarSugerencias($(this).val());
                    });

                    // Cuando se hace clic en una sugerencia
                    $(document).on("click", ".item-sugerencia", function () {
                        const cardCode = $(this).find("div").eq(0).text().trim();
