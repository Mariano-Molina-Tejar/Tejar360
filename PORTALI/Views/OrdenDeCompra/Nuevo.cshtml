                                                </td>
                                            </tr>`;
                            tbody.append(row);
                        });
                    } else {
                        tbody.append('<tr><td colspan="3" class="text-center">No hay datos disponibles.</td></tr>');
                    }
                },
                error: function () {
                    $('#tablaProveedores').html('<tr><td colspan="3" class="text-center text-danger">Error al obtener datos.</td></tr>');
                }
            });
        }

        function buscarProducto() {
