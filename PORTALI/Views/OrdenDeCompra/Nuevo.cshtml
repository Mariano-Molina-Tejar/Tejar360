                        // Detenemos temporalmente el input
                        $("#socioInput").off("input");

                        $("#socioInput").val(cardName);
                        $("#codigoSocio").val(cardCode);
                        $("#sugerencias").hide();

                        // Reactivamos el input luego de un pequeño delay
                        setTimeout(() => {
                            $("#socioInput").on("input", function () {
                                buscarSugerencias($(this).val());
                            });
                        }, 100);
