<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Orden de Compra - SAP</title>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>

    <style>
        body {
            font-family: 'Segoe UI', sans-serif;
            background-color: #f4f6f9;
            margin: 0;
        }

        .container {
            max-width: 1100px;
            margin: auto;
            background: white;
            padding: 25px;
            border-radius: 10px;
            box-shadow: 0 0 20px rgba(0,0,0,0.1);
        }

        h2 {
            text-align: center;
            margin-bottom: 30px;
            color: #2c3e50;
        }

        .form-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }

        .input-full {
            grid-column: 1 / -1;
        }

        label {
            font-weight: bold;
            color: #34495e;
            display: block;
            margin-bottom: 5px;
        }

        input, select, textarea {
            width: 100%;
            padding: 10px;
            border: 1px solid #ccc;
            border-radius: 6px;
            font-size: 14px;
            box-sizing: border-box;
        }

        .input-icon {
            position: relative;
            width: 100%;
        }

            .input-icon input {
                width: 100%;
                padding-right: 40px;
                box-sizing: border-box;
            }

        .btn-icono {
            position: absolute;
            top: 50%;
            right: 8px;
            transform: translateY(-50%);
            background-color: #3498db;
            color: white;
            border: none;
            padding: 6px 10px;
            border-radius: 4px;
            cursor: pointer;
            font-size: 14px;
            line-height: 1;
            transition: background-color 0.2s ease-in-out;
        }

            .btn-icono:hover {
                background-color: #2c80b4;
            }


        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 20px;
        }

            table thead {
                background-color: #2c3e50;
                color: white;
            }

            table th, table td {
                padding: 12px;
                text-align: left;
                border: 1px solid #ccc;
            }

        .btn-agregar {
            background-color: #2980b9;
            color: white;
            padding: 10px 15px;
            border: none;
            border-radius: 6px;
            cursor: pointer;
            margin-top: 15px;
        }

            .btn-agregar:hover {
                background-color: #1c5980;
            }

        .totales {
            margin-top: 30px;
            display: flex;
            flex-direction: column;
            align-items: flex-end;
            gap: 10px;
            padding-right: 10px;
        }

        .total-linea {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 14px;
        }

            .total-linea label {
                min-width: 80px;
                text-align: right;
                color: #2c3e50;
                font-weight: 500;
            }

            .total-linea input {
                width: 120px;
                padding: 6px 10px;
                font-size: 14px;
                background-color: #f1f1f1;
                border: 1px solid #ccc;
                border-radius: 5px;
                text-align: right;
            }

        .grupo-proveedor {
            display: flex;
            gap: 10px;
            align-items: flex-start;
        }

        .campo-con-label {
            flex: 1;
            display: flex;
            flex-direction: column;
        }

        .boton-align {
            display: flex;
            flex-direction: column;
            justify-content: flex-end;
        }

        .btn-buscar {
            background-color: #3498db;
            color: white;
            border: none;
            padding: 8px 14px;
            border-radius: 6px;
            font-size: 14px;
            cursor: pointer;
            transition: background-color 0.2s ease-in-out;
            height: 38px;
        }

            .btn-buscar:hover {
                background-color: #2c80b4;
            }
    </style>

    @*MODAL BUSCAR OSEA FILTRAR*@
    <style>
        .modal-custom {
            position: fixed;
            z-index: 1000;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            overflow: auto;
            background-color: rgba(0,0,0,0.4);
        }

        .modal-content {
            background-color: #fff;
            margin: 40px auto;
            padding: 20px;
            border-radius: 8px;
            width: 90%;
            max-width: 1000px;
            max-height: 90%;
            overflow-y: auto;
            box-shadow: 0 5px 15px rgba(0,0,0,0.3);
        }

        .close {
            color: #aaa;
            float: right;
            font-size: 24px;
            font-weight: bold;
            cursor: pointer;
        }

            .close:hover {
                color: #000;
            }
    </style>
</head>
<body>
    <div class="container" style="margin-bottom:25px;">
        <h2>Orden de Compra - SAP</h2>

