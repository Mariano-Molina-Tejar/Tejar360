        <div class="formulario-container">
            <!-- Documento -->
            <div class="fila">
                <div class="campo campo-corto">
                    <label for="DocNum">Documento</label>
                    <input type="text" id="DocNum" placeholder="00000" readonly />
                </div>
            </div>

            <!-- Proveedor -->
            <div class="fila">
                <div class="campo campo-corto">
                    <label for="codigoProveedor">Código <span style="color: red;">*</span></label>
                    <input type="text" id="codigoProveedor" placeholder="PRV001" readonly />
                </div>

                <div class="boton-align">
                    <label style="visibility: hidden;">Buscar</label>
                    <button class="btn-buscar" type="button" onclick="abrirModalProveedor()">🔍</button>
                </div>

                <div class="campo">
                    <label for="proveedor">Nombre Proveedor <span style="color: red;">*</span></label>
                    <input type="text" id="proveedor" placeholder="Nombre del proveedor" readonly />
                </div>
            </div>

            <!-- Sucursal, Tipo de cambio, Fecha, Fecha comprometido -->
            <div class="fila">
                <div class="campo">
                    <label for="sucursal">Sucursal <span style="color: red;">*</span></label>
                    <select id="sucursalSelect">
                        <option value="-1">Seleccione una sucursal</option>
                    </select>
                </div>

                <div class="campo">
                    <label for="tipoCambio">Tipo de cambio <span style="color: red;">*</span></label>
                    <select id="tipoCambioSelect">
                        <option value="-1">Selecciona Tipo de cambio</option>
                    </select>
                </div>

                <div class="campo">
                    <label for="fecha">Fecha <span style="color: red;">*</span></label>
                    <input type="date" id="fecha" />
                </div>

                <div class="campo">
                    <label for="fechaComprometido">Fecha Comprometido <span style="color: red;">*</span></label>
                    <input type="date" id="fechaComprometido" />
                </div>
            </div>

            <!-- Observaciones -->
            <div class="campo input-full">
                <label for="observaciones">Observaciones</label>
                <textarea id="observaciones" rows="3" placeholder="Observaciones adicionales..."></textarea>
            </div>
        </div>

        <!-- Scripts -->
        <script>
            // Setear fecha actual
            $(document).ready(function () {
                const hoy = new Date();
                const yyyy = hoy.getFullYear();
                const mm = String(hoy.getMonth() + 1).padStart(2, '0');
                const dd = String(hoy.getDate()).padStart(2, '0');
                const fechaActual = `${yyyy}-${mm}-${dd}`;
                $('#fecha').val(fechaActual);
            });

            // Cambiar símbolo de moneda
            document.getElementById('tipoCambioSelect').addEventListener('change', function () {
                const tipoMoneda = this.value;
                const simbolo = tipoMoneda === 'USD' ? '$' : 'Q';

                document.querySelectorAll('#tablaProductos tbody tr').forEach(fila => {
                    const inputTotal = fila.querySelector('.input-total');
                    if (inputTotal) {
                        let valorNumerico = parseFloat(inputTotal.value.replace(/[^\d.-]/g, '')) || 0;
                        inputTotal.value = simbolo + ' ' + valorNumerico.toFixed(2);
                    }
                });
            });
        </script>

        <br />
        <h3 style="color: #2c3e50;">Detalle de Productos</h3>

