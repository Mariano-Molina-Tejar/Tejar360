        <script>

            // Escucha los eventos de cambio en cantidad y precio unitario
            document.addEventListener('input', function (event) {
                if (event.target.classList.contains('input-cantidad') || event.target.classList.contains('input-precioU')) {
                    const fila = event.target.closest('tr');
                    const cantidadInput = fila.querySelector('.input-cantidad');
                    const precioUInput = fila.querySelector('.input-precioU');
                    const totalInput = fila.querySelector('.input-total');

                    const cantidad = parseFloat(cantidadInput.value) || 0;
                    const precioU = parseFloat(precioUInput.value) || 0;
                    const total = cantidad * precioU;

                    totalInput.value = total.toLocaleString('es-GT', {
                        style: 'currency',
                        currency: 'GTQ',
                        minimumFractionDigits: 2,
                        maximumFractionDigits: 2
                    });
                }
                calcularTotales();
            });

            function cargarCentrosCostoSelect(selectElement, elemento) {
                $.ajax({
                    url: '/OrdenDeCompra/ListadoCentroDeCosto',
                    type: 'POST',
                    success: function (data) {
                        if (data && data.length > 0) {
                            // Limpiar opciones anteriores
                            selectElement.innerHTML = '';

                            // Opción vacía como predeterminada
                            const opcionPredeterminada = document.createElement('option');
                            opcionPredeterminada.value = '';
                            opcionPredeterminada.textContent = '-- Seleccione --';
                            opcionPredeterminada.disabled = true;
                            opcionPredeterminada.selected = true;
                            selectElement.appendChild(opcionPredeterminada);

                            // Agregar nuevas opciones
                            data.forEach(item => {
                                const option = document.createElement('option');
                                option.value = item.sCodigo;
                                option.textContent = item.Descripcion;
                                selectElement.appendChild(option);
                            });

                            if (elemento != null && elemento !== '') {
                                selectElement.value = elemento;
                            }
                        } else {
                            selectElement.innerHTML = '<option>No hay centros de costo</option>';
                        }
                    },
                    error: function () {
                        selectElement.innerHTML = '<option>Error al cargar</option>';
                    }
                });
            }

            function TipoDeArticulo(selectElement, elemento) {
                $.ajax({
                    url: '/OrdenDeCompra/TipoArticulo',
                    type: 'POST',
                    success: function (data) {
                        if (data && data.length > 0) {
                            // Limpiar opciones anteriores
                            selectElement.innerHTML = '';

                            // Agregar nuevas opciones
                            data.forEach(item => {
                                const option = document.createElement('option');
                                option.value = item.sCodigo;
                                option.textContent = item.Descripcion;

                                // Si coincide con el valor pasado o con "BB", lo selecciona
                                if ((elemento && item.sCodigo === elemento) || (!elemento && item.sCodigo === 'BB')) {
                                    option.selected = true;
                                }

                                selectElement.appendChild(option);
                            });
                        } else {
                            selectElement.innerHTML = '<option>No hay centros de costo</option>';
                        }
                    },
                    error: function () {
                        selectElement.innerHTML = '<option>Error al cargar</option>';
                    }
                });
            }

            function cargarProyectos(selectElement, elemento) {
                $.ajax({
                    url: '/OrdenDeCompra/ListasLineasProducto',
                    type: 'POST',
                    success: function (data) {
                        if (data && data.length > 0) {
                            // Limpiar opciones anteriores
                            selectElement.innerHTML = '';

                            // Opción vacía como predeterminada
                            const opcionPredeterminada = document.createElement('option');
                            opcionPredeterminada.value = '';
                            opcionPredeterminada.textContent = '-- Seleccione --';
                            opcionPredeterminada.disabled = true;
                            opcionPredeterminada.selected = true;
                            selectElement.appendChild(opcionPredeterminada);

                            // Agregar nuevas opciones
                            data.forEach(item => {
                                const option = document.createElement('option');
                                option.value = item.sCodigo;
                                option.textContent = item.Descripcion;
                                selectElement.appendChild(option);
                            });

                            if (elemento != null && elemento !== '') {
                                selectElement.value = elemento;
                            }
                        } else {
                            selectElement.innerHTML = '<option>No hay data</option>';
                        }
                    },
                    error: function () {
                        selectElement.innerHTML = '<option>Error al cargar</option>';
                    }
                });
            }

            function cargarEtapas(selectElement, elemento) {
                $.ajax({
                    url: '/OrdenDeCompra/ListadoEtapas',
                    type: 'POST',
                    success: function (data) {
                        if (data && data.length > 0) {
                            // Limpiar opciones anteriores
                            selectElement.innerHTML = '';

                            // Opción vacía como predeterminada
                            const opcionPredeterminada = document.createElement('option');
                            opcionPredeterminada.value = '';
                            opcionPredeterminada.textContent = '-- Seleccione --';
                            opcionPredeterminada.disabled = true;
                            opcionPredeterminada.selected = true;
                            selectElement.appendChild(opcionPredeterminada);

                            // Agregar nuevas opciones
                            data.forEach(item => {
                                const option = document.createElement('option');
                                option.value = item.sCodigo;
                                option.textContent = item.Descripcion;
                                selectElement.appendChild(option);
                            });

                            if (elemento != null && elemento !== '') {
                                selectElement.value = elemento;
                            }
                        } else {
                            selectElement.innerHTML = '<option>No hay data</option>';
                        }
                    },
                    error: function () {
                        selectElement.innerHTML = '<option>Error al cargar</option>';
                    }
                });
            }

            $(document).ready(function () {
                document.querySelectorAll('.centro-costo').forEach(select => {
                    cargarCentrosCostoSelect(select, null);
                });

                document.querySelectorAll('.select-tipoarticulo').forEach(select => {
                    TipoDeArticulo(select, null);
                });
            });
        </script>

        <button class="btn-agregar" onclick="agregarFila()">+ Agregar Producto</button>

        <div class="totales">
            <div class="total-linea">
                <label for="subtotal">Subtotal:</label>
                <input type="text" id="subtotal" value="0.00" disabled />
            </div>
            <div class="total-linea">
                <label for="impuesto">Impuesto:</label>
                <input type="text" id="impuesto" value="0.00" disabled />
            </div>
            <div class="total-linea">
                <label for="total"><strong>Total:</strong></label>
                <input type="text" id="total" value="0.00" disabled />
            </div>
        </div>

        <div style="text-align: center; margin-top: 20px;">
            <button type="button"
                    onclick="guardarDatos()"
                    style="background-color: #28a745; color: white; border: none; padding: 10px 25px; font-size: 16px; border-radius: 8px; cursor: pointer; box-shadow: 0 2px 5px rgba(0,0,0,0.1); transition: background-color 0.3s ease;">
                💾 Guardar
            </button>

            <button type="button"
                    onclick="document.getElementById('inputExcel').click();"
                    style="margin-left: 10px; background-color: #fd7e14; color: white; border: none; padding: 10px 25px; font-size: 16px; border-radius: 8px; cursor: pointer;">
                📊 Cargar Excel
            </button>
            <input type="file" id="inputExcel" accept=".xls,.xlsx" style="display: none;" onchange="cargarExcel(this)">

            <script>
                function cargarExcel(input) {
                    const archivo = input.files[0];
                    if (archivo) {
                        console.log("Archivo seleccionado:", archivo.name);
                    }
                }

                async function cargarExcel(input) {
                    const archivo = input.files[0];
                    if (!archivo) return;

                    $("#globalLoading").show();

                    const lector = new FileReader();

                    lector.onload = async function (e) {
                        const data = new Uint8Array(e.target.result);
                        const workbook = XLSX.read(data, { type: 'array' });
                        const hoja = workbook.Sheets[workbook.SheetNames[0]];
                        const json = XLSX.utils.sheet_to_json(hoja, { defval: '' });

                        const tabla = document.getElementById("tablaProductos").getElementsByTagName("tbody")[0];
                        tabla.innerHTML = '';

                        // Creamos una lista de promesas para cada fila que necesita nombre
                        const promesas = json.map((item) => {
                            return new Promise((resolve) => {
                                getNombreArticulo(item.Codigo, function (nombre) {
                                    const fila = document.createElement("tr");

                                    fila.innerHTML = `
                                                                                                                                                                                        <td>
                                                                                                                                                                                            <div style="position: relative; width: 100%; display: inline-block;">
                                                                                                                                                                                                <input type="text" class="input-codigo" value="${item.Codigo}" readonly style="width: 100%; padding-right: 36px; font-size: 14px; border: 1px solid #ccc; border-radius: 4px 0 0 4px;" />
                                                                                                                                                                                                <button type="button" onclick="abrirModalProducto(this)" style="position: absolute; top: 0; right: 0; height: 100%; width: 36px; background-color: #ffb84d; border: 1px solid #ccc; border-left: none; border-radius: 0 4px 4px 0; cursor: pointer;">🔍</button>
                                                                                                                                                                                            </div>
                                                                                                                                                                                        </td>
                                                                                                                                                                                        <td><input type="text" class="input-descripcion" value="${nombre}" style="width: 100%; text-transform: uppercase; font-size: 14px; border: 1px solid #ccc; border-radius: 4px;" /></td>
                                                                                                                                                                                        <td><input type="number" class="input-cantidad" value="${item.Cantidad}" style="width: 100%;" /></td>
                                                                                                                                                                                        <td><input type="text" class="input-precioU" value="${item.PrecioUnitario}" style="width: 100%; text-align: right" /></td>
                                                                                                                                                                                        <td><select class="centro-costo" style="width: 100%;"></select></td>
                                                                                                                                                                                        <td>
                                                                                                                                                                                            <select class="select-impuesto" style="width: 100%;">
                                                                                                                                                                                                <option value="IVA" ${item.Impuesto === 'IVA' ? 'selected' : ''}>IVA</option>
                                                                                                                                                                                                <option value="EXE" ${item.Impuesto === 'EXE' ? 'selected' : ''}>EXE</option>
                                                                                                                                                                                            </select>
                                                                                                                                                                                        </td>
                                                                                                                                                                                        <td><select class="select-proyecto" style="width: 100%;"></select></td>
                                                                                                                                                                                        <td><select class="select-etapas" style="width: 100%;"></select></td>
                                                                                                                                                                                        <td><select class="select-tipoarticulo" style="width: 100%;"></select></td>
                                                                                                                                                                                        <td>
                                                                                                                                                                                          <input class="input-total" type="text"
                                                                                                                                                                                                 value="${formatearQuetzal((item.Cantidad * item.PrecioUnitario).toFixed(2))}"
                                                                                                                                                                                                 disabled style="width: 100%; text-align:right" />
                                                                                                                                                                                        </td>
                                                                                                                                                                                        <td style="text-align: center;">
                                                                                                                                                                                            <button type="button" onclick="eliminarFila(this)" style="background-color: #dc3545; color: white; border: none; border-radius: 20%; width: 32px; height: 32px; font-size: 16px;">🗑</button>
                                                                                                                                                                                        </td>
                                                                                                                                                                                    `;

                                    tabla.appendChild(fila);
                                    // Cargar select
                                    const selectCentroCosto = fila.querySelector('.centro-costo');
                                    cargarCentrosCostoSelect(selectCentroCosto, item.Centro_De_Costo);

                                    const nuevoSelect2 = fila.querySelector('.select-tipoarticulo');
                                    TipoDeArticulo(nuevoSelect2, item.Tipo_Articulo);

                                    resolve(); // Termina esta promesa
                                });
                            });
                        });

                        // Esperamos a que todas las filas se agreguen
                        await Promise.all(promesas);
                        calcularTotales();

                        // Ahora sí: ocultamos el loading
                        $("#globalLoading").hide();
                    };

                    lector.readAsArrayBuffer(archivo);
                }

                function formatearQuetzal(valor) {
                    const num = parseFloat(valor);
                    const monto = isNaN(num) ? 0 : num;

                    return document.getElementById("tipoCambioSelect").value === 'USD'
                        ? '$ ' + monto.toFixed(2)
                        : 'Q ' + monto.toFixed(2);
                }


                function getNombreArticulo(ItemCode, callback) {
                    $.ajax({
                        url: '/OrdenDeCompra/getItemName',
                        type: 'POST',
                        data: { ItemCode: ItemCode },
                        success: function (data) {
                            if (data && data.Descripcion) {
                                callback(data.Descripcion);
                            } else {
                                callback("");
                            }
                        },
                        error: function () {
                            callback("");
                        }
                    });
                }

