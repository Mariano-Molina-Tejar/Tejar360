@using Entity;
@model EmpleadosViewModel
@{
    ViewBag.Title = "Index";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <link href="~/Css/Empleados/style.css" rel="stylesheet">
    <style>
    </style>
</head>
<!-- Bootstrap 5.3.3 -->

<body>
    <div class="container mt-4">
        <div class="card shadow-sm border-0">
            <div class="card card-filtros mb-3">
                <div class="card-body">

                    <div class="row g-3 align-items-end">

                        <!-- Filtro por Nombre -->
                        <div class="col-md-6">
                            <label class="form-label filtro-label">Nombre</label>
                            <div class="input-group">
                                <span class="input-group-text">
                                    <i class="bi bi-search"></i>
                                </span>
                                <input type="text"
                                       id="filtroNombre"
                                       class="form-control"
                                       placeholder="Buscar por nombre...">
                            </div>
                        </div>

                        <!-- Filtro por Estado -->
                        <div class="col-md-3">
                            <label class="form-label filtro-label">Estado</label>
                            <select id="filtroEstado" class="form-select">
                                <option value="">Todos</option>
                                <option value="Y">Activo</option>
                                <option value="N">Inactivo</option>
                            </select>
                        </div>

                    </div>
                </div>

                <div class="card-footer filtros-footer d-flex justify-content-between align-items-center">

                    <!-- IZQUIERDA -->
                    <div class="d-flex gap-2">
                        <span class="badge badge-resultados" id="lblResultados">
                            <span id="resultadosEncontrados">@Model.Empleados.Count()</span>
                            Resultados encontrados
                        </span>
                    </div>

                    <!-- DERECHA -->
                    <div>

                        <span class="badge badge-nuevo">
                            <span>@Model.Empleados.Where(x => x.Nuevo).Count()</span>
                            Nuevos
                        </span>

                        <span class="badge badge-activos">
                            <span>@Model.Empleados.Where(x => x.Activo == "Y").Count()</span>
                            Activos
                        </span>

                        <span class="badge badge-inactivos">
                            <span>@Model.Empleados.Where(x => x.Activo == "N").Count()</span>
                            Inactivos
                        </span>
                    </div>

                </div>

            </div>


            <div class="card-header header-empleados d-flex justify-content-between align-items-center">

                <h5 class="mb-0 d-flex align-items-center">
                    <i class="bi bi-file-earmark-person-fill me-2"></i>
                    Datos maestros de empleados
                </h5>

                <div class="d-flex gap-2">

                    <button class="btn btn-outline-light btn-sm rounded-pill px-3"
                            id="btnEquipos">
                        <i class="bi bi-laptop me-1"></i> Equipos
                    </button>

                    <button class="btn btn-outline-light btn-sm rounded-pill px-3"
                            id="btnPuestos">
                        <i class="bi bi-briefcase me-1"></i> Posiciones
                    </button>

                    <button class="btn btn-outline-light btn-sm rounded-pill px-3"
                            id="btnDepartamentos">
                        <i class="bi bi-building me-1"></i> Departamentos
                    </button>

                </div>
            </div>

            <div class="card-body bg-light">
                <table class="table align-middle text-center tabla-dashboard tabla-empleados">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th class="text-start">Nombre</th>
                            <th>Posición</th>
                            <th>Departamento</th>
                            <th>Estado</th>
                            <th>Jefe Inmediato</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>

                    <tbody id="bodyEmpleados">
                        @if (Model != null && Model.Empleados.Any())
                        {
                            foreach (var empleado in Model.Empleados
                                     .OrderByDescending(x => x.Nuevo)
                                     .ThenBy(x => x.EmpId))
                            {
                                <tr class="@(empleado.Nuevo ? "fila-nuevo" : "")">

                                    <td class="fw-semibold text-primary">
                                        @empleado.EmpId
                                    </td>

                                    <!-- Nombre + badge -->
                                    <td class="text-start">
                                        <div class="d-flex justify-content-between align-items-center">
                                            <span class="fw-semibold">@empleado.Nombre</span>

                                            @if (empleado.Nuevo)
                                            {
                                                <span class="badge bg-primary rounded-pill px-3">
                                                    Nuevo
                                                </span>
                                            }
                                        </div>
                                    </td>

                                    <td>@empleado.Puesto</td>

                                    <td>@empleado.Departamento</td>

                                    <td>
                                        <span class="badge rounded-pill @(empleado.Activo == "Y" ? "bg-success" : "bg-danger")">
                                            @(empleado.Activo == "Y" ? "Activo" : "Inactivo")
                                        </span>
                                    </td>

                                    <td>@empleado.JefeInmediato</td>

                                    <td>
                                        <button class="btn btn-sm btn-outline-primary rounded-pill px-3"
                                                title="Ver perfil"
                                                onclick="abrirModalEmpleado(@empleado.EmpId)">
                                            <i class="bi bi-person-vcard me-1"></i> Perfil
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-center text-muted py-4">
                                    <i class="bi bi-info-circle"></i> No se encontraron empleados
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>


            </div>
        </div>
    </div>

    <div class="modal fade" id="modalPosiciones" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-xl modal-dialog-centered">
            <div class="modal-content modal-posiciones">

                <!-- HEADER -->
                <div class="modal-header modal-posiciones-header">
                    <h5 class="modal-title">
                        <i class="bi bi-briefcase-fill me-2"></i> Definición de posiciones
                    </h5>
                    <button class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>

                <!-- BODY -->
                <div class="modal-body">

                    <!-- FORM CARD -->
                    <div class="card shadow-sm border-0 mb-4">
                        <div class="card-header bg-light fw-semibold">
                            <i class="bi bi-plus-circle me-1 text-success"></i> Nueva posición
                        </div>

                        <div class="card-body">
                            <form id="formPosicion">

                                <div class="row g-3 align-items-end">

                                    <!-- Nombre -->
                                    <div class="col-md-4">
                                        <label class="form-label fw-semibold">Nombre de la posición</label>
                                        <input type="text"
                                               id="posNombre"
                                               class="form-control"
                                               placeholder="Ej: Supervisor"
                                               maxlength="20"
                                               required
                                               oninput="actualizarContador()">
                                        <small id="contadorPosNombre" class="text-muted">
                                            20 caracteres restantes
                                        </small>
                                    </div>

                                    <!-- Descripción -->
                                    <div class="col-md-6">
                                        <label class="form-label fw-semibold">Descripción</label>
                                        <input type="text"
                                               id="posDescripcion"
                                               class="form-control"
                                               placeholder="Descripción breve..."
                                               required>
                                    </div>

                                    <!-- Botón -->
                                    <div class="col-md-2 text-end">
                                        <button class="btn btn-success w-100" id="btnAgregarPosicion">
                                            <i class="bi bi-plus-circle"></i> Agregar
                                        </button>
                                    </div>

                                </div>
                            </form>
                        </div>
                    </div>

                    <!-- TABLA CARD -->
                    <div class="card shadow-sm border-0">

                        <div class="card-header bg-light fw-semibold d-flex justify-content-between">
                            <span>
                                <i class="bi bi-list-task me-1 text-primary"></i> Posiciones registradas
                            </span>
                            <span class="badge bg-primary">
                                @Model.Posicion.Count()
                            </span>
                        </div>

                        <div class="card-body p-0">

                            <div class="table-responsive">
                                <table class="table table-hover align-middle mb-0" id="tablaPosiciones">

                                    <thead class="table-primary text-center">
                                        <tr>
                                            <th style="width:80px;">#</th>
                                            <th>Nombre</th>
                                            <th>Descripción</th>
                                            <th style="width:160px;">Acciones</th>
                                        </tr>
                                    </thead>

                                    <tbody id="posicionesBody">
                                        @foreach (var posicion in Model.Posicion)
                                        {
                                            <tr>
                                                <td class="text-center fw-semibold">
                                                    @posicion.NoPosicion
                                                </td>

                                                <td>@posicion.Nombre</td>
                                                <td class="text-muted">@posicion.Descripcion</td>

                                                <td class="text-center">
                                                    <div class="btn-group">

                                                        <button id="btnPerfil-@(posicion.NoPosicion)"
                                                                class="btn btn-sm @(posicion.Perfil ? "btn-outline-success" : "btn-outline-danger")"
                                                                data-bs-toggle="tooltip"
                                                                title="@(posicion.Perfil ? "Ver perfil" : "Agregar perfil")"
                                                                onclick="abrirModalPerfilPuesto('@posicion.Nombre',
                                                                @posicion.NoPosicion,
                                                                @posicion.Perfil.ToString().ToLower(),
                                                                'btnPerfil-@(posicion.NoPosicion)')">
                                                            <i id="ibtnPerfil-@(posicion.NoPosicion)"
                                                               class="bi bi-file-earmark-text"></i>
                                                        </button>

                                                        <button class="btn btn-sm btn-outline-primary"
                                                                data-bs-toggle="tooltip"
                                                                title="Equipo asignado"
                                                                onclick="verEquiposAsignados('@(posicion.NoPosicion)')">
                                                            <i class="bi bi-laptop"></i>
                                                        </button>

                                                    </div>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>

                                </table>
                            </div>

                        </div>
                    </div>
                </div>

                <!-- FOOTER -->
                <div class="modal-footer bg-light">
                    <button class="btn btn-secondary" data-bs-dismiss="modal">
                        <i class="bi bi-x-circle me-1"></i> Cerrar
                    </button>
                </div>

            </div>
        </div>
    </div>


    <div class="modal fade" id="modalEmpleado" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-xl modal-dialog-centered">
            <div class="modal-content modal-empleado-modern">

                <!-- HEADER -->
                <div class="modal-header modal-empleado-header">
                    <h5 class="modal-title">
                        <i class="bi bi-person-fill me-2"></i> Datos Maestros de Empleado
                    </h5>
                    <button class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>

                <!-- BODY -->
                <div class="modal-body">
                    <form id="formEmpleado">

                        <div class="row g-4">

                            <!-- COLUMNA FOTO -->
                            <div class="col-md-3">

                                <div class="empleado-foto-card text-center">
                                    <img id="imgEmpleado"
                                         src="/Img/PerfilMale.png"
                                         class="img-fluid rounded-circle mb-3"
                                         alt="Foto empleado">

                                    @*<h6 class="fw-semibold mb-1">Foto del empleado</h6>
                                        <small class="text-muted">
                                            Se usará en perfiles y credenciales
                                        </small>*@
                                </div>

                            </div>

                            <!-- COLUMNA FORMULARIO -->
                            <div class="col-md-9">

                                <div class="row g-3">

                                    <!-- Columna izquierda -->
                                    <div class="col-md-6">

                                        <div class="form-group-modern">
                                            <label>Nombre</label>
                                            <input type="text" class="form-control" id="firstName" disabled>
                                        </div>

                                        <div class="form-group-modern d-none">
                                            <input class="form-check-input" type="checkbox" id="Active" checked>
                                        </div>

                                        <div class="form-group-modern">
                                            <label>Segundo nombre</label>
                                            <input type="text" class="form-control" id="middleName" disabled>
                                        </div>

                                        <div class="form-group-modern">
                                            <label>Apellido</label>
                                            <input type="text" class="form-control" id="lastName" disabled>
                                        </div>

                                        <div class="form-group-modern">
                                            <label>Denominación de función</label>
                                            <input type="text" class="form-control" id="jobTitle" disabled>
                                        </div>

                                        <div class="form-group-modern">
                                            <label>Posición</label>
                                            <select id="position" class="form-select" disabled>
                                                @foreach (var posiciones in Model.Posicion)
                                                {
                                                    <option value="@(posiciones.NoPosicion)">
                                                        @posiciones.Descripcion
                                                    </option>
                                                }
                                            </select>
                                        </div>

                                        <div class="form-group-modern">
                                            <label>Departamento</label>
                                            <select id="dept" class="form-select" disabled>
                                                @foreach (var departamentos in Model.Departamentos)
                                                {
                                                    <option value="@(departamentos.Code)">
                                                        @departamentos.Remarks
                                                    </option>
                                                }
                                            </select>
                                        </div>

                                    </div>

                                    <!-- Columna derecha -->
                                    <div class="col-md-6">

                                        <div class="form-group-modern">
                                            <label>Código de empleado</label>
                                            <input type="text" class="form-control" id="empID" disabled>
                                        </div>

                                        <div class="form-check mb-3">
                                            <input class="form-check-input" type="checkbox" id="Active" checked disabled>
                                            <label class="form-check-label fw-semibold">
                                                Empleado activo
                                            </label>
                                        </div>

                                        <div class="row g-3">
                                            <div class="col-md-6">
                                                <label class="form-label fw-semibold">Teléfono móvil</label>
                                                <input type="text" class="form-control" id="mobile">
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label fw-semibold">Teléfono de casa</label>
                                                <input type="text" class="form-control" id="hometel">
                                            </div>
                                        </div>

                                        <div class="form-group-modern">
                                            <label>Correo electrónico</label>
                                            <input type="email" class="form-control" id="email">
                                        </div>

                                        <div class="form-group-modern">
                                            <label>Jefe Inmediato</label>
                                            <select id="U_JefeInmediato" class="form-select" disabled>
                                                @foreach (var empleados in Model.Empleados)
                                                {
                                                    <option value="@(empleados.EmpId)">
                                                        @empleados.Nombre
                                                    </option>
                                                }
                                            </select>
                                        </div>

                                        <div class="form-group-modern">
                                            <label>Tienda Asignada</label>
                                            <select id="U_tienda" class="form-select" disabled>
                                                @foreach (var tiendas in Model.Tiendas)
                                                {
                                                    <option value="@(tiendas.WhsCode)">
                                                        @tiendas.WhsName
                                                    </option>
                                                }
                                            </select>
                                        </div>

                                        <div class="form-group-modern">
                                            <label>Área</label>
                                            <select id="U_tienda" class="form-select" disabled>
                                                @foreach (var areas in Model.Areas)
                                                {
                                                    <option value="@(areas.FldValue)">
                                                        @areas.Descr
                                                    </option>
                                                }
                                            </select>
                                        </div>

                                    </div>
                                </div>

                            </div>
                        </div>
                    </form>
                </div>

                <!-- FOOTER -->
                <div class="modal-footer modal-empleado-footer">
                    <button class="btn btn-light" data-bs-dismiss="modal">
                        <i class="bi bi-x-circle me-1"></i> Cerrar
                    </button>
                    <button class="btn btn-primary rounded-pill px-4" id="btnGuardarEmpleado">
                        <i class="bi bi-save me-1"></i> Guardar
                    </button>
                </div>

            </div>
        </div>
    </div>

    <div class="modal fade" id="modalPerfilPuesto" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content border-0 shadow">

                <!-- Header -->
                <div class="modal-header text-white" style="background-color: steelblue;">
                    <h5 class="modal-title">
                        <i class="bi bi-person-badge"></i>
                        Perfil del Puesto: <span id="tituloPuesto"></span>
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>

                <!-- Body -->
                <div class="modal-body">
                    <form id="formPerfilPuesto">

                        <div class="row g-3">
                            <!-- Experiencia -->
                            <div class="col-md-4">
                                <label class="form-label fw-bold">Experiencia mínima (años)</label>
                                <input type="number" class="form-control" id="U_ExperienciaMinima" required>
                                <input type="number" id="U_IdPuesto" class="d-none" />
                                <input type="text" id="U_IdButton" class="d-none" />
                                <input type="number" id="Code" class="d-none" />
                            </div>

                            <!-- Rango edad -->
                            <div class="col-md-4">
                                <label class="form-label fw-bold">Edad mínima</label>
                                <input type="number" class="form-control" id="U_RangoEdadMin" required>
                            </div>

                            <div class="col-md-4">
                                <label class="form-label fw-bold">Edad máxima</label>
                                <input type="number" class="form-control" id="U_RangoEdadMax" required>
                            </div>

                            <!-- Sexo -->
                            <div class="col-md-4">
                                <label class="form-label fw-bold">Sexo</label>
                                <select class="form-select" id="U_Sexo" required>
                                    <option value="I">Indistinto</option>
                                    <option value="M">Masculino</option>
                                    <option value="F">Femenino</option>
                                </select>
                            </div>

                            <!-- Nivel Estudio -->
                            <div class="col-md-8">
                                <label class="form-label fw-bold">Nivel de estudio</label>
                                <select class="form-select" id="U_NivelEstudio" required>
                                    <option value="Basico">Básico</option>
                                    <option value="Diversificado">Diversificado</option>
                                    <option value="Universitario">Universitario</option>
                                    <option value="Otro">Otro (Especificar en observaciones)</option>
                                </select>
                            </div>

                            <!-- Salario -->
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Salario mínimo (Q) <span class="text-muted">(Opcional)</span></label>
                                <input type="number" class="form-control" id="U_SalarioMin" step="0.01">
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-bold">Salario máximo (Q) <span class="text-muted">(Opcional)</span></label>
                                <input type="number" class="form-control" id="U_SalarioMax" step="0.01">
                            </div>

                            <!-- Observaciones -->
                            <div class="col-12">
                                <label class="form-label fw-bold">Observaciones</label>
                                <textarea class="form-control" rows="3" id="U_Observaciones" required></textarea>
                            </div>
                        </div>
                    </form>
                </div>

                <!-- Footer -->
                <div class="modal-footer" style="display:flex; justify-content:space-between">
                    <div>
                        @*<button id="btnVerEquipo" type="button" class="btn btn-success">
                                <i class="bi bi-laptop"></i> Equipo
                            </button>*@
                    </div>
                    <div>
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                            <i class="bi bi-x-circle"></i> Cancelar
                        </button>
                        <button type="button" class="btn btn-primary" id="btnAbilitarEditar">
                            <i class="bi bi-save"></i> Editar
                        </button>
                        <button type="button" class="btn btn-primary" id="btnGuardarPerfil">
                            <i class="bi bi-save"></i> Guardar Perfil
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="modal fade" id="modalDepartamentos" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content modal-departamentos">

                <!-- HEADER -->
                <div class="modal-header modal-departamentos-header">
                    <h5 class="modal-title">
                        <i class="bi bi-building me-2"></i> Departamentos
                    </h5>
                    <button type="button"
                            class="btn-close btn-close-white"
                            data-bs-dismiss="modal">
                    </button>
                </div>

                <!-- BODY -->
                <div class="modal-body">

                    <div class="card shadow-sm border-0">
                        <div class="card-header bg-light fw-semibold d-flex justify-content-between align-items-center">
                            <span>
                                <i class="bi bi-diagram-3-fill text-primary me-1"></i>
                                Listado de departamentos
                            </span>
                            <span class="badge bg-primary">
                                @Model.Departamentos.Count()
                            </span>
                        </div>

                        <div class="card-body p-0">

                            <div class="table-responsive">
                                <table class="table table-hover align-middle mb-0">

                                    <thead class="table-primary text-center">
                                        <tr>
                                            <th style="width:70px;">#</th>
                                            <th>Departamento</th>
                                            <th>Descripción</th>
                                            <th style="width:220px;">Gerente / Jefe</th>
                                        </tr>
                                    </thead>

                                    <tbody>
                                        @foreach (var departamentos in Model.Departamentos)
                                        {
                                            <tr>
                                                <td class="text-center fw-semibold">
                                                    @departamentos.Code
                                                </td>

                                                <td>
                                                    <i class="bi bi-building text-secondary me-1"></i>
                                                    @departamentos.Name
                                                </td>

                                                <td class="text-muted">
                                                    @departamentos.Remarks
                                                </td>

                                                <td>
                                                    <select id="selectGerenteDepartamento@(departamentos.Code)"
                                                            class="form-select form-select-sm select-gerente"
                                                            value="@departamentos.empID"
                                                            onchange="cambio(this,@departamentos.Code)">
                                                        <option value="">Seleccione...</option>
                                                        @foreach (var empleados in Model.Empleados)
                                                        {
                                                            <option value="@empleados.EmpId"
                                                                    @(empleados.EmpId == departamentos.empID ? "selected" : "")>
                                                                @empleados.Nombre
                                                            </option>
                                                        }
                                                    </select>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>

                                </table>
                            </div>

                        </div>
                    </div>
                </div>

                <!-- FOOTER -->
                <div class="modal-footer bg-light">
                    <button class="btn btn-secondary" data-bs-dismiss="modal">
                        <i class="bi bi-x-circle me-1"></i> Cerrar
                    </button>
                </div>

            </div>
        </div>
    </div>

    <!-- Modal: Gestión de equipo -->
    <div class="modal fade" id="modalEquipos" tabindex="-1">
        <div class="modal-dialog modal-xl">
            <div class="modal-content">

                <div class="modal-header" style="background-color: steelblue;">
                    <h5 class="modal-title text-white">
                        <i class="bi bi-laptop text-white"></i> Asignar Equipo al Perfil
                        <input class="d-none" id="PerfilId" value="" />
                    </h5>
                    <button class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">

                    <div class="row">

                        <!-- LISTA DE EQUIPOS DISPONIBLES -->
                        <div class="col-md-6">
                            <h6 class="fw-bold">
