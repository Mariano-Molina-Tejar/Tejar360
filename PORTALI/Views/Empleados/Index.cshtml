                    {
                        method: "POST",
                        headers: {
                            'Content-Type': 'application/json',
                            'Accept': 'application/json'
                        },
                        body: JSON.stringify({ perfil: idPerfil, equipos: equiposAsignados })
                    });

                const result = await response.json();

                if (result.success)
                {
                    Toast.fire({ icon: 'warning', title: "Equipo agregado con éxito" });
                    $("#globalLoading").hide();
                    modalEquipos.hide();
                    
                } else {
                    Toast.fire({ icon: 'warning', title: "Ocurrio un error al agregar el equipo" });
                }
            }
            catch (error)
            {
                console.log("Error : ",error);
            }
        }

