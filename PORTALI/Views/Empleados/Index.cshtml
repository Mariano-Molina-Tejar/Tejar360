                const result = await response.json();
                if (result.success) {
                    modalEmpleado.hide();
                    $("#globalLoading").hide();

                    Toast.fire({ icon: 'success', title: "El usuario ha sido actulizado en la base de datos de SAP" });
                    setTimeout(() => {
                        location.reload();
