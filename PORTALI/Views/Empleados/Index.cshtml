       //AGREGAR EQUIPOS INICIO

        function renderListas() {
            const disponibles = document.getElementById("listaDisponibles");
            const asignados = document.getElementById("listaAsignados");
            console.log(disponibles);

            disponibles.innerHTML = "";
            asignados.innerHTML = "";

            equiposDisponibles.forEach(eq => {
                disponibles.appendChild(crearEquipoItem(eq));
            });

            equiposAsignados.forEach(eq => {
                asignados.appendChild(crearEquipoItem(eq));
            });

            equiposAsignadosGuardados.forEach(eq => {
                asignados.appendChild(crearEquipoItem(eq));
            });
        }

        function crearEquipoItem(equipo) {
            const div = document.createElement("div");
            div.classList.add("equipo-item");
            div.draggable = true;
            div.dataset.id = equipo.Code;

            div.innerHTML = `
                        <i class="bi ${equipo.U_Icono}"></i>
                        <span>${equipo.U_NombreEquipo}</span>
                      `;

            div.addEventListener("dragstart", () => {
                div.classList.add("dragging");
            });

            div.addEventListener("dragend", () => {
                div.classList.remove("dragging");
            });

            return div;
        }

        document.querySelectorAll(".lista-equipos").forEach(lista => {
            lista.addEventListener("dragover", e => {
                e.preventDefault();
                const dragging = document.querySelector(".dragging");
                lista.appendChild(dragging);
            });

            lista.addEventListener("drop", e => {
                const id = parseInt(document.querySelector(".dragging").dataset.id);

                if (lista.id === "listaAsignados")
                {
                    moverEquipo(id, equiposDisponibles, equiposAsignados);
                } else {
                    moverEquipo(id, equiposAsignados, equiposDisponibles);
                }
            });
        });

        function moverEquipo(id, origen, destino) {
            const index = origen.findIndex(e => e.Code === id);
            if (index >= 0) {
                destino.push(origen[index]);
                origen.splice(index, 1);
            }
        }

        async function guardarEquipoDePerfil() {
            const idPerfil = document.getElementById('PerfilId').value;
            $("#globalLoading").show();
            try {

                const equiposSinRepetidos = [
                    ...new Map(equiposAsignados.map(e => [e.Code, e])).values()
                ];

                if (equiposAsignados.length === 0) {
                    Toast.fire({ icon: 'warning', title: "Debe tener al menos un quipo asignado" });
                    $("#globalLoading").hide();
                    return;
                }
                //$("#globalLoading").hide();
                //return;
                const response = await fetch('/Empleados/GuardarEquipoPorPerfil',
                    {
                        method: "POST",
                        headers: {
                            'Content-Type': 'application/json',
                            'Accept': 'application/json'
                        },
                        body: JSON.stringify({ perfil: idPerfil, equipos: equiposSinRepetidos })
                    });

                const result = await response.json();

                if (result.success) {
                    Toast.fire({ icon: 'success', title: "Equipo agregado con éxito" });
                    modalEquipos.hide();

                } else {
                    Toast.fire({ icon: 'warning', title: "Ocurrio un error al agregar el equipo" });
                }
            }
            catch (error) {
                console.log("Error : ", error);
            }
            finally {
                $("#globalLoading").hide();
            }
        }

        async function verEquiposAsignados(idPosicion) {

            let response = await fetch('/Empleados/ObtenerEquiposGuardados');
            document.getElementById('PerfilId').value = idPosicion;

            let result = await response.json();

            if (result.success) {
                let div = "";
                equiposDisponibles = [];
                equiposDisponibles = result.data;
            }
            else {
                equiposAsignadosGuardados = [];
            }

            response = await fetch(`/Empleados/ObtenerEquiposPorPerfil?perfil=${idPosicion}`);
            result = await response.json();

            if (result.success) {
                //equiposAsignadosGuardados = [];
                equiposAsignados = [];
                equiposAsignados = result.data;

                //equiposAsignadosGuardados = result.data;
                renderListas();
                modalEquipos.show()
            }
            else {
                //equiposAsignadosGuardados = [];
                equiposAsignados = [];
                Toast.fire({ icon: 'warning', title: "No se encontraron equipos agregados al puesto" });
                renderListas();
                modalEquipos.show()
            }
        }

        async function abrirModalAgregarEquipos() {
            modalAgregarEquipo.show();

            let selectedIcon = "bi-laptop";
            iconoEquipo = "bi-laptop";

            document.querySelectorAll(".icon-option").forEach(option => {
                option.addEventListener("click", function () {

                    // Quitar selección previa
                    document.querySelectorAll(".icon-option").forEach(o => o.classList.remove("selected"));

                    // Seleccionar actual
                    this.classList.add("selected");

                    // Obtener icono seleccionado
                    selectedIcon = this.dataset.icon;
                    iconoEquipo = this.dataset.icon;
                    // Actualizar vista previa
                    document.getElementById("previewIcon").innerHTML = `<i class="bi ${selectedIcon}"></i>`;
                });
            });

            const response = await fetch('/Empleados/ObtenerEquiposGuardados');

            const result = await response.json();

            if (result.success) {
                let div = "";

                result.data.forEach((item) => {

                    div += `<div class="equipo-item-added">
                                <i class="bi ${item.U_Icono}"></i>
                                <span>${item.U_NombreEquipo}</span>
                            </div>`;
                })

                document.getElementById("listaEquiposAgregados").innerHTML = div;
            }
        }

        async function guardarTipoEquipo() {

            $("#globalLoading").show();
            const nombre = document.getElementById("equipoNombre").value;
            let icono = iconoEquipo;
            const data = new FormData();

            data.append("nombre", nombre);
            data.append("icono", icono);

            if (nombre.trim() === "") {
                Toast.fire({ icon: 'warning', title: "Debe ingresar el nombre" });
                return;
            }

            const response = await fetch('/Empleados/GuardarTipoEquipo',
                {
                    method: "POST",
                    body: data
                }
            );

            const result = await response.json();

            if (result.success) {
                Toast.fire({ icon: 'success', title: "Se guardo el equipo con éxito" });
                $("#globalLoading").hide();
                modalEquipos.hide();

            } else {
                Toast.fire({ icon: 'error', title: "Ocurrio un error al guardar el equipo" });
                $("#globalLoading").hide();
            }
            document.getElementById("equipoNombre").value = "";
            modalAgregarEquipo.hide();
        };

        document.getElementById("posNombre").addEventListener("input", function () {
            this.value = this.value.trimStart();
        });
        document.getElementById('filtroNombre').addEventListener('input', () => filtrarPorNombre());
        document.getElementById('filtroEstado').addEventListener('change', () => filtrarPorNombre());
        document.getElementById('btnGuardarEmpleado').addEventListener('click', () => guardarDatosEmpleado());
        document.getElementById('btnPuestos').addEventListener('click', () => abrirModalPosiciones());
        document.getElementById('btnAgregarPosicion').addEventListener('click', (e) => {
            e.preventDefault();
            guardarPosicion();
        });
        document.getElementById('btnGuardarPerfil').addEventListener('click', () => guardarPerfilDeUsuario());
        document.getElementById('btnAbilitarEditar').addEventListener('click', () => abilitarEditar());
        document.getElementById('btnDepartamentos').addEventListener('click', () => abrirModalDepartamentos());

        document.getElementById('btnEquipos').addEventListener('click', () => abrirModalAgregarEquipos());
        document.getElementById('btnGuardarEquipos').addEventListener('click', () => guardarEquipoDePerfil());
        document.getElementById("btnGuardarEquipo").addEventListener("click", () => guardarTipoEquipo());
    </script>
</body>
