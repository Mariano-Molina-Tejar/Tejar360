@using Entity;
@model EmpleadosViewModel
@{
    ViewBag.Title = "Index";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <style>
        .lista-equipos {
            border: 2px dashed #ccc;
            min-height: 300px;
            padding: 10px;
            border-radius: 8px;
            background: #fafafa;
        }

        .equipo-item {
            padding: 8px 12px;
            background: white;
            border: 1px solid #ddd;
            border-radius: 6px;
            margin-bottom: 8px;
            cursor: grab;
            display: flex;
            align-items: center;
            gap: 8px;
        }

            .equipo-item i {
                font-size: 18px;
                color: #0d6efd;
            }

            .equipo-item.dragging {
                opacity: 0.4;
            }

        .icon-option {
            border: 2px solid #ccc;
            padding: 10px;
            border-radius: 8px;
            cursor: pointer;
            transition: 0.2s;
        }

            .icon-option:hover {
                border-color: #0d6efd;
                background: #eaf2ff;
            }

            .icon-option.selected {
                border-color: #0d6efd;
                background: #e0ecff;
            }

        .equipo-item-added {
            background: white;
            border: 1px solid #ddd;
            border-radius: 6px;
            padding: 8px 10px;
            margin-bottom: 6px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

            .equipo-item-added i {
                font-size: 22px;
                color: #0d6efd;
            }

        .equipo-delete {
            margin-left: auto;
            cursor: pointer;
            color: #dc3545;
        }

            .equipo-delete:hover {
                color: #a71d2a;
            }

        .btn-equipos {
            width: 42px; /* ajusta según tu gusto */
            height: 32px; /* igual al btn-sm */
            padding: 0;
        }
    </style>
</head>
<!-- Bootstrap 5.3.3 -->

<body>
    <div class="container mt-4">
        <div class="card shadow-sm border-0">
            <div class="card mb-3">

                <div class="card-body">

                    <div class="row g-3 align-items-end">

                        <!-- Filtro por Nombre -->
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Nombre</label>
                            <input type="text" id="filtroNombre" class="form-control" placeholder="Buscar por nombre...">
                        </div>

                        <!-- Filtro por Estado -->
                        <div class="col-md-3">
                            <label class="form-label fw-bold">Estado</label>
                            <select id="filtroEstado" class="form-select">
                                <option value="">Todos</option>
                                <option value="Y">Activo</option>
                                <option value="N">Inactivo</option>
                            </select>
                        </div>
                    </div>
                </div>
                <div class="text-end px-3 pb-2">
                    <span class="badge bg-primary fs-6" id="lblResultados">
                        <span id="resultadosEncontrados">@Model.Empleados.Count()</span> resultados encontrados
                    </span>
                </div>
            </div>

            <div class="card-header text-white d-flex justify-content-between align-items-center"
                 style="background-color: steelblue;">

                <h5 class="mb-0">
                    <i class="bi bi-file-earmark-person-fill me-2"></i> Datos maestros de empleados
                </h5>

                <div style="text-align:end">
                    <button class="btn btn-light btn-sm" id="btnEquipos">
                        <i class="bi bi-laptop"></i> Equipos
                    </button>
                    <button class="btn btn-light btn-sm" id="btnPuestos">
                        <i class="bi bi-briefcase"></i> Posiciones
                    </button>

                    <button class="btn btn-light btn-sm" id="btnDepartamentos">
                        <i class="bi bi-building"></i> Departamentos
                    </button>
                </div>
            </div>
            <div class="card-body bg-light">
                <table class="table table-hover align-middle text-center">
                    <thead class="table-success">
                        <tr>
                            <th>Id</th>
                            <th>Nombress</th>
                            <th>Posicion</th>
                            <th>Departamento</th>
                            <th>Estado</th>
                            <th>Jefe Inmediato</th>
                            <th>Accion</th>
                        </tr>
                    </thead>
                    <tbody id="bodyEmpleados">
                        @if (Model != null)
                        {
                            foreach (var empleado in Model.Empleados.OrderBy(x => x.EmpId))
                            {
                                <tr>
                                    <td>@empleado.EmpId</td>
                                    <td>@empleado.Nombre</td>
                                    <td>@empleado.Puesto</td>
                                    <td>@empleado.Departamento</td>
                                    <td>
                                        @if (empleado.Activo == "Y")
                                        {
                                            <span class="badge bg-success">Activo</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">Inactivo</span>
                                        }
                                    </td>

                                    <td>@empleado.JefeInmediato</td>
                                    <td>
                                        <button class="btn btn-sm btn-primary" title="Ver perfil" onclick="abrirModalEmpleado(@(empleado.EmpId))">
                                            <i class="bi bi-person-vcard"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted py-3" style="font-style: italic;">
                                    <i class="bi bi-info-circle"></i> No se encontraron solicitudes
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="modal fade" id="modalPosiciones" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-xl modal-dialog-centered">
            <div class="modal-content">

                <!-- HEADER -->
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title">
                        <i class="bi bi-list-task"></i> Posicion de empleado - definicion
                    </h5>
                    <button class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>

                <!-- BODY -->
                <div class="modal-body">

                    <!-- FORMULARIO -->
                    <form id="formPosicion">
                        <div class="row g-3 mb-3">
                            <div class="col-md-4">
                                <label class="form-label fw-bold">Nombre posición</label>
                                <input type="text" id="posNombre" class="form-control"
                                       placeholder="Ej: Supervisor" maxlength="20"
                                       required
                                       oninput="actualizarContador()">
                                <small id="contadorPosNombre" class="text-muted">20 caracteres restantes</small>
                            </div>

                            <div class="col-md-8">
                                <label class="form-label fw-bold">Descripción</label>
                                <input type="text" id="posDescripcion" class="form-control" placeholder="Descripción breve..." required>
                            </div>
                        </div>

                        <!-- BOTÓN AGREGAR -->
                        <div class="text-end mb-3">
                            <button class="btn btn-success btn-sm" id="btnAgregarPosicion">
                                <i class="bi bi-plus-circle"></i> Agregar
                            </button>
                        </div>
                    </form>
                    <!-- TABLA -->
                    <div class="table-responsive">
                        <table class="table table-bordered table-striped" id="tablaPosiciones">
                            <thead class="table-light">
                                <tr>
                                    <th>#</th>
                                    <th>Nombre Posición</th>
                                    <th>Descripción</th>
                                    <th>Acciones</th>
                                </tr>
                            </thead>
                            <tbody id="posicionesBody">
                                @foreach (var posicion in Model.Posicion)
                                {
                                    <tr>
                                        <th>@posicion.NoPosicion</th>
                                        <th>@posicion.Nombre</th>
                                        <th>@posicion.Descripcion</th>
                                        <th style="text-align:center">
                                            <button id="btnPerfil-@(posicion.NoPosicion)"
                                                    class="btn btn-sm @(posicion.Perfil ? "btn-outline-success" : "btn-outline-danger")"
                                                    data-bs-toggle="tooltip"
                                                    title="@(posicion.Perfil ? "Ver perfil" : "Agregar perfil")"
                                                    onclick="abrirModalPerfilPuesto('@posicion.Nombre',@posicion.NoPosicion, @posicion.Perfil.ToString().ToLower(), 'btnPerfil-@(posicion.NoPosicion)')">

                                                <i id="ibtnPerfil-@(posicion.NoPosicion)" class="bi bi-file-earmark-text @(posicion.Perfil ? "text-success" : "text-danger")"></i>
                                            </button>
                                            <button class="btn btn-sm btn-outline-primary btn-cuadrado"
                                                    data-bs-toggle="tooltip"
                                                    title="Equipo asignado"
                                                    onclick="verEquiposAsignados('@(posicion.NoPosicion)')">
                                                <i class="bi bi-laptop text-primary"></i>
                                            </button>
                                        </th>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- FOOTER -->
                <div class="modal-footer">
                    <button class="btn btn-secondary" data-bs-dismiss="modal">
                        <i class="bi bi-x-circle"></i> Cerrar
                    </button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal fade" id="modalEmpleado" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-xl modal-dialog-centered">
            <div class="modal-content">

                <!-- Header -->
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title">
                        <i class="bi bi-person-fill"></i> Datos Maestros de Empleado
                    </h5>
                    <button class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>

                <!-- Body -->
                <div class="modal-body">

                    <form id="formEmpleado">
                        <div class="row g-3">

                            <!-- Columna izquierda -->
                            <div class="col-md-6">

                                <div class="mb-3">
                                    <label class="form-label fw-bold">Nombre</label>
                                    <input type="text" class="form-control" id="firstName">
                                </div>
                                <div class="form-check mb-3 d-" style="visibility: hidden">
                                    <input class="form-check-input" type="checkbox" id="Active" checked>
                                    <label class="form-check-label fw-bold" for="Active">
                                        Empleado activo
                                    </label>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label fw-bold">Segundo nombre</label>
                                    <input type="text" class="form-control" id="middleName">
                                </div>

                                <div class="mb-3">
                                    <label class="form-label fw-bold">Apellido</label>
                                    <input type="text" class="form-control" id="lastName">
                                </div>

                                <div class="mb-3">
                                    <label class="form-label fw-bold">Denominación de función</label>
                                    <input type="text" class="form-control" id="jobTitle">
                                </div>

                                <div class="mb-3">
                                    <label class="form-label fw-bold">Posición</label>
                                    <select id="position" class="form-select">
                                        @foreach (var posiciones in Model.Posicion)
                                        {
                                            <option value="@(posiciones.NoPosicion)">@posiciones.Descripcion</option>
                                        }
                                    </select>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label fw-bold">Departamento</label>
                                    <select id="dept" class="form-select">
                                        @foreach (var departamentos in Model.Departamentos)
                                        {
                                            <option value="@(departamentos.Code)">@departamentos.Remarks</option>
                                        }
                                    </select>
                                </div>
                            </div>

                            <!-- Columna derecha -->
                            <div class="col-md-6">

                                <div class="mb-3">
                                    <label class="form-label fw-bold">Código de empleado</label>
                                    <input type="text" class="form-control" id="empID" disabled>
                                </div>

                                <div class="form-check mb-3">
                                    <input class="form-check-input" type="checkbox" id="Active" checked>
                                    <label class="form-check-label fw-bold" for="Active">
                                        Empleado activo
                                    </label>
                                </div>
                                <div class="row g-3">

                                    <div class="col-md-6">
                                        <label class="form-label fw-bold">Teléfono móvil</label>
                                        <input type="text" class="form-control" id="mobile">
                                    </div>

                                    <div class="col-md-6">
                                        <label class="form-label fw-bold">Teléfono de casa</label>
                                        <input type="text" class="form-control" id="hometel">
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label fw-bold">Correo electrónico</label>
                                    <input type="email" class="form-control" id="email">
                                </div>
                                <div class="mb-3">
                                    <label class="form-label fw-bold">Jefe Inmediato</label>
                                    <select id="U_JefeInmediato" class="form-select">
                                        @foreach (var empleados in Model.Empleados)
                                        {
                                            <option value="@(empleados.EmpId)">@empleados.Nombre</option>
                                        }
                                    </select>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label fw-bold">Tienda Asignada</label>
                                    <select id="U_tienda" class="form-select">
                                        @foreach (var tiendas in Model.Tiendas)
                                        {
                                            <option value="@(tiendas.WhsCode)">@tiendas.WhsName</option>
                                        }
                                    </select>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label fw-bold">Area</label>
                                    <select id="U_tienda" class="form-select">
                                        @foreach (var areas in Model.Areas)
                                        {
                                            <option value="@(areas.FldValue)">@areas.Descr</option>
                                        }
                                    </select>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>

                <!-- Footer -->
                <div class="modal-footer">
                    <button class="btn btn-secondary" data-bs-dismiss="modal">
                        <i class="bi bi-x-circle"></i> Cerrar
                    </button>
                    <button class="btn btn-primary" id="btnGuardarEmpleado">
                        <i class="bi bi-save"></i> Guardar
                    </button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal fade" id="modalPerfilPuesto" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content border-0 shadow">

                <!-- Header -->
                <div class="modal-header text-white" style="background-color: steelblue;">
                    <h5 class="modal-title">
                        <i class="bi bi-person-badge"></i>
                        Perfil del Puesto: <span id="tituloPuesto"></span>
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>

                <!-- Body -->
                <div class="modal-body">
                    <form id="formPerfilPuesto">

                        <div class="row g-3">
                            <!-- Experiencia -->
                            <div class="col-md-4">
                                <label class="form-label fw-bold">Experiencia mínima (años)</label>
                                <input type="number" class="form-control" id="U_ExperienciaMinima" required>
                                <input type="number" id="U_IdPuesto" class="d-none" />
                                <input type="text" id="U_IdButton" class="d-none" />
                                <input type="number" id="Code" class="d-none" />
                            </div>

                            <!-- Rango edad -->
                            <div class="col-md-4">
                                <label class="form-label fw-bold">Edad mínima</label>
                                <input type="number" class="form-control" id="U_RangoEdadMin" required>
                            </div>

                            <div class="col-md-4">
                                <label class="form-label fw-bold">Edad máxima</label>
                                <input type="number" class="form-control" id="U_RangoEdadMax" required>
                            </div>

                            <!-- Sexo -->
                            <div class="col-md-4">
                                <label class="form-label fw-bold">Sexo</label>
                                <select class="form-select" id="U_Sexo" required>
                                    <option value="I">Indistinto</option>
                                    <option value="M">Masculino</option>
                                    <option value="F">Femenino</option>
                                </select>
                            </div>

                            <!-- Nivel Estudio -->
                            <div class="col-md-8">
                                <label class="form-label fw-bold">Nivel de estudio</label>
                                <select class="form-select" id="U_NivelEstudio" required>
                                    <option value="Basico">Básico</option>
                                    <option value="Diversificado">Diversificado</option>
                                    <option value="Universitario">Universitario</option>
                                    <option value="Otro">Otro (Especificar en observaciones)</option>
                                </select>
                            </div>

                            <!-- Salario -->
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Salario mínimo (Q) <span class="text-muted">(Opcional)</span></label>
                                <input type="number" class="form-control" id="U_SalarioMin" step="0.01">
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-bold">Salario máximo (Q) <span class="text-muted">(Opcional)</span></label>
                                <input type="number" class="form-control" id="U_SalarioMax" step="0.01">
                            </div>

                            <!-- Observaciones -->
                            <div class="col-12">
                                <label class="form-label fw-bold">Observaciones</label>
                                <textarea class="form-control" rows="3" id="U_Observaciones" required></textarea>
                            </div>
                        </div>
                    </form>
                </div>

                <!-- Footer -->
                <div class="modal-footer" style="display:flex; justify-content:space-between">
                    <div>
                        @*<button id="btnVerEquipo" type="button" class="btn btn-success">
                                <i class="bi bi-laptop"></i> Equipo
                            </button>*@
                    </div>
                    <div>
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                            <i class="bi bi-x-circle"></i> Cancelar
                        </button>
                        <button type="button" class="btn btn-primary" id="btnAbilitarEditar">
                            <i class="bi bi-save"></i> Editar
                        </button>
                        <button type="button" class="btn btn-primary" id="btnGuardarPerfil">
                            <i class="bi bi-save"></i> Guardar Perfil
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- Modal Departamentos -->
    <div class="modal fade" id="modalDepartamentos" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content">

                <!-- Header -->
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title">
                        <i class="bi bi-building"></i> Departamentos
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>

                <!-- Body -->
                <div class="modal-body">

                    <div class="table-responsive">
                        <table class="table table-bordered table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th style="width: 60px;">#</th>
                                    <th>Nombre del Departamento</th>
                                    <th>Descripción</th>
                                    <th style="width: 200px;">Gerente / Jefe</th>
                                </tr>
                            </thead>

                            <tbody>
                                @foreach (var departamentos in Model.Departamentos)
                                {
                                    <tr>
                                        <td>@departamentos.Code</td>
                                        <td>@departamentos.Name</td>
                                        <td>@departamentos.Remarks</td>
                                        <td>
                                            <select id="selectGerenteDepartamento@(departamentos.Code)" class="form-select form-select-sm" value="@departamentos.empID" onchange="cambio(this,@departamentos.Code)">
                                                <option value="">Seleccione...</option>
                                                @foreach (var empleados in Model.Empleados)
                                                {
                                                    <option value="@empleados.EmpId" @(empleados.EmpId == departamentos.empID ? "selected" : "")>@empleados.Nombre</option>
                                                }
                                            </select>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Footer -->
                <div class="modal-footer">
                    <button class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
                </div>
            </div>
        </div>
    </div>
    <!-- Modal: Gestión de equipo -->
    <div class="modal fade" id="modalEquipos" tabindex="-1">
        <div class="modal-dialog modal-xl">
            <div class="modal-content">

                <div class="modal-header" style="background-color: steelblue;">
                    <h5 class="modal-title text-white">
                        <i class="bi bi-laptop text-white"></i> Asignar Equipo al Perfil
                        <input class="d-none" id="PerfilId" value="" />
                    </h5>
                    <button class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">

                    <div class="row">

                        <!-- LISTA DE EQUIPOS DISPONIBLES -->
                        <div class="col-md-6">
                            <h6 class="fw-bold">
                                <i class="bi bi-box-seam"></i> Equipos Disponibles
                            </h6>
                            <div id="listaDisponibles" class="lista-equipos">
                            </div>
                        </div>

                        <!-- LISTA DE EQUIPOS ASIGNADOS -->
                        <div class="col-md-6">
                            <h6 class="fw-bold">
                                <i class="bi bi-check-circle"></i> Equipos Asignados
                            </h6>
                            <div id="listaAsignados" class="lista-equipos">
                                <!-- JS inserta aquí -->
                            </div>
                        </div>
                    </div>
                </div>

                <div class="modal-footer">
                    <button class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button class="btn btn-primary" id="btnGuardarEquipos">Guardar</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal Agregar Equipo -->
    <div class="modal fade" id="modalAgregarEquipo" tabindex="-1">
        <div class="modal-dialog modal-xl">
            <div class="modal-content">

                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="bi bi-pc-display"></i> Agregar Equipo
                    </h5>
                    <button class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">

                    <div class="row">

                        <!-- ===== COLUMNA IZQUIERDA ===== -->
                        <div class="col-md-8">

                            <div class="row">
                                <!-- Nombre del equipo -->
                                <div class="col-md-6 mb-3">
                                    <label class="form-label fw-semibold">Nombre del Equipo</label>
                                    <input type="text" class="form-control" id="equipoNombre" placeholder="Ej: Laptop">
                                </div>

                                <!-- Vista previa del icono -->
                                <div class="col-md-6 mb-3 text-center">
                                    <label class="form-label fw-semibold">Vista Previa del Ícono</label>
                                    <div id="previewIcon"
                                         class="border rounded p-3 fs-1 text-primary"
                                         style="min-height: 80px;">
                                        <i class="bi bi-laptop"></i>
                                    </div>
                                </div>
                            </div>

                            <!-- Selección de íconos -->
                            <div class="mb-2">
                                <label class="form-label fw-semibold">Seleccionar Ícono</label>
                            </div>

                            <div class="d-flex flex-wrap gap-3" id="iconSelector">

                                <!-- 1 -->
                                <div class="icon-option" data-icon="bi-laptop">
                                    <i class="bi bi-laptop fs-2"></i>
                                </div>

                                <!-- 2 -->
                                <div class="icon-option" data-icon="bi-pc-display">
                                    <i class="bi bi-pc-display fs-2"></i>
