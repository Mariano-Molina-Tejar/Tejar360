                }
                else {
                    Toast.fire({ icon: 'error', title: "Ocurrio un error al actualizar al usuario" });
                }
            }
            catch (error) {
                console.log(error);
                Toast.fire({ icon: 'error', title: "Ocurrio un error al actualizar al usuario" });
            }
            finally {
                $("#globalLoading").hide();
            }
        }

