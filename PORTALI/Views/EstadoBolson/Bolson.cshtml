<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reporte de Ventas y Utilidades por Sucursal</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" rel="stylesheet">
    <style>
        body {
            background-color: #f8f9fa;
        }

        h1 {
            text-align: center;
            margin-bottom: 2rem;
        }

        .table thead {
            background-color: #000;
            color: #fff;
        }

        .btn-update {
            margin-bottom: 1rem;
        }

        .location-title {
            background-color: #343a40;
            color: white;
            font-weight: bold;
        }

        .total-row {
            background-color: #d1ecf1;
            font-weight: bold;
        }
    </style>
</head>
<body>
    <div class="container-fluid">
        <h1 class="text-center my-4" style="font-weight: bold; font-size: 2rem; color: #343a40; border-bottom: 3px solid #007bff; display: inline-block; padding-bottom: 10px;">
            📊 Estado bolson
        </h1>

        <div class="row g-2 mb-3">
            <div class="col-auto">
                <div class="d-flex align-items-center" style="height: 100%;">
                    <button class="btn btn-sm btn-dark shadow-sm btn-update" id="btnBuscar" onclick="CargarData()">
                        <i class="fas fa-sync-alt me-1"></i> Actualizar Datos
                    </button>
                </div>
            </div>
        </div>

        <!-- Tabla agrupada por Location -->
        <div class="table-responsive" style="margin-bottom:30px">
            <table class="table table-bordered table-hover" id="tablaVentas">
                <thead class="text-center" style="background-color: black; color: white;">
                    <tr>
                        <th rowspan="2" class="align-middle">Tienda</th>
                        <th rowspan="2" class="align-middle">Bolson activo</th>
                        <th colspan="3">Nuevas cotizaciones</th>
                        <th colspan="3">Facturación</th>
                        <th colspan="3">Perdidas</th>
                    </tr>
                    <tr>
                        <th>Total Lineas</th>
                        <th>Nuevos Q.</th>
                        <th>Tasa generación</th>

                        <th>Total Lineas</th>
                        <th>Facturado Q.</th>
                        <th>Tasa de cierre</th>

                        <th>Total Lineas</th>
                        <th>Perdidas Q.</th>
                        <th>Tasa de perdida</th>
                    </tr>
                </thead>

                <tbody class="text-center" id="tbodyVentas">

                </tbody>
            </table>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

<script>
    $(document).ready(function () {
        CargarData();
    });

    function CargarData() {        
        $("#globalLoading").show();

        $.ajax({
            url: '@Url.Action("CargarData", "EstadoBolson")',
            type: 'POST',            
            success: function (response) {
                console.log(response.data);
                $("#globalLoading").hide();
                if (response.success)
                {
                    let data = response.data;
                    let html = '';
                    let Nivel = 0;

                    let grupos = {};
                    let totalGeneral = {
                        BolsonActivo: 0, LineasCot: 0, DocTotalCot: 0,
                        TasaGeneracion: 0, LineasFac: 0,
                        DocTotalFac: 0, TasaCierre: 0,
                        LineasPerd: 0, DocTotalPerd: 0,
                        TasaPerd: 0
                    };

                    // Agrupar por región
                    $.each(data, function (i, item) {
                        Nivel = item.NivelEntrada;
                        let region = item.Location || "SIN REGION";
                        if (!grupos[region]) grupos[region] = [];
                        grupos[region].push(item);

                        totalGeneral.BolsonActivo += item.BolsonActivo || 0;
                        totalGeneral.LineasCot += item.LineasCot || 0;
                        totalGeneral.DocTotalCot += item.DocTotalCot || 0;
                        totalGeneral.TasaGeneracion += item.TasaGeneracion || 0;
                        totalGeneral.LineasFac += item.LineasFac || 0;
                        totalGeneral.DocTotalFac += item.DocTotalFac || 0;
                        totalGeneral.TasaCierre += item.TasaCierre || 0;
                        totalGeneral.LineasPerd += item.LineasPerd || 0;
                        totalGeneral.DocTotalPerd += item.DocTotalPerd || 0;
                        totalGeneral.TasaPerd += item.TasaPerd || 0;
                    });

                    // Recorrer los grupos
                    $.each(grupos, function (region, items) {
                        if (Nivel != 2) {
                            html += `<tr class="location-title">
                                <td colspan="14" style="text-align: left; padding-left: 20px;">
                                    <i class="fas fa-map-marked-alt"></i> <strong>${region}</strong>
                                </td>
                            </tr>`;
                        }

                        // Filas por tienda
                        $.each(items, function (i, item) {
                            html += `<tr>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <button class="btn btn-sm btn-link p-0 me-2 btn-expandir" data-tienda="${item.WhsCode}" title="Ver detalle" style="margin-right:7px;">
                                                <i class="fas fa-plus-circle text-primary"></i>
                                            </button>
                                            <span>${item.WhsName}</span>
                                        </div>
                                    </td>
                                    <td>${formatoQuetzal(item.BolsonActivo)}</td>
                                    <td>${item.LineasCot}</td>
                                    <td>${formatoQuetzal(item.DocTotalCot)}</td>
                                    <td>${item.TasaGeneracion}%</td>
                                    <td>${item.LineasFac}</td>
                                    <td>${formatoQuetzal(item.DocTotalFac)}</td>
                                    <td>${item.TasaCierre}%</td>
                                    <td>${item.LineasPerd}</td>
                                    <td>${formatoQuetzal(item.DocTotalPerd)}</td>
                                    <td>${item.TasaPerd}%</td>
                                </tr>`;

                            html += `<tr class="detalle-tienda" id="detalle-${item.WhsCode}" style="display: none;">
                                        <td colspan="14">
                                            <div class="contenido-detalle">
                                                Cargando detalle...
                                            </div>
                                        </td>
                                    </tr>`;
                        });

                        let total = {
                            BolsonActivo: 0, LineasCot: 0, DocTotalCot: 0,
                            TasaGeneracion: 0, LineasFac: 0,
                            DocTotalFac: 0, TasaCierre: 0,
                            LineasPerd: 0, DocTotalPerd: 0,
                            TasaPerd: 0
                        };

                        items.forEach(item => {
                            total.BolsonActivo += item.BolsonActivo || 0;
                            total.LineasCot += item.LineasCot || 0;
                            total.DocTotalCot += item.DocTotalCot || 0;
                            total.TasaGeneracion += item.TasaGeneracion || 0;
                            total.LineasFac += item.LineasFac || 0;
                            total.DocTotalFac += item.DocTotalFac || 0;
                            total.TasaCierre += item.TasaCierre || 0;
                            total.LineasPerd += item.LineasPerd || 0;
                            total.DocTotalPerd += item.DocTotalPerd || 0;
                            total.TasaPerd += item.TasaPerd || 0;
                        });

                        html += `<tr class="total-row">
                                <td>TOTAL ${region}</td>
                                <td>${formatoQuetzal(total.BolsonActivo)}</td>
                                <td>${total.LineasCot}</td>
                                <td>${formatoQuetzal(total.DocTotalCot)}</td>
                                <td>${((total.DocTotalCot / total.BolsonActivo) * 100).toFixed(2)}%</td>
                                <td>${total.LineasFac}</td>
                                <td>${formatoQuetzal(total.DocTotalFac)}</td>
                                <td>${((total.DocTotalFac / total.BolsonActivo) * 100).toFixed(2)}%</td>
                                <td>${total.LineasPerd}</td>
                                <td>${formatoQuetzal(total.DocTotalPerd)}</td>
                                <td>${((total.DocTotalPerd / total.BolsonActivo) * 100).toFixed(2)}%</td>
                            </tr>`;
                    });

                    html += `<tr class="total-row bg-dark text-white">
                                    <td><strong>TOTAL GENERAL</strong></td>
                                    <td>${formatoQuetzal(totalGeneral.BolsonActivo)}</td>
                                    <td>${totalGeneral.LineasCot}</td>
                                    <td>${formatoQuetzal(totalGeneral.DocTotalCot)}</td>
                                    <td>${((totalGeneral.DocTotalCot / totalGeneral.BolsonActivo) * 100).toFixed(2)}%</td>
                                    <td>${totalGeneral.LineasFac}</td>
                                    <td>${formatoQuetzal(totalGeneral.DocTotalFac)}</td>
                                    <td>${((totalGeneral.DocTotalFac / totalGeneral.BolsonActivo) * 100).toFixed(2)}%</td>
                                    <td>${totalGeneral.LineasPerd}</td>
                                    <td>${formatoQuetzal(totalGeneral.DocTotalPerd)}</td>
                                    <td>${((totalGeneral.DocTotalPerd / totalGeneral.BolsonActivo) * 100).toFixed(2)}%</td>
                                </tr>`;

                    $('#tbodyVentas').html(html);
                    $('.btn-expandir').off('click').on('click', function () {
                        var tienda = $(this).data('tienda');
                        var detalleRow = $('#detalle-' + tienda);
                        var estaVisible = detalleRow.is(':visible');
                        // Oculta todos los detalles y reinicia íconos
                        $('.detalle-tienda').hide();
                        $('.btn-expandir i').removeClass('fa-minus-circle').addClass('fa-plus-circle');

                        if (!estaVisible) {
                            // Contenido HTML de la tabla
                            let Detalle = `
                            <div class="table-responsive" style="margin-bottom:10px; margin-top:15px">
                                <table class="table table-bordered table-hover" id="tablaVentas-${tienda}">
                                    <thead class="text-center" style="background-color: #004080; color: white;">
                                        <tr>
                                            <th rowspan="2" class="align-middle">Nombre del asesor</th>
                                            <th rowspan="2" class="align-middle">Bolson activo</th>
                                            <th colspan="3">Nuevas cotizaciones	</th>
                                            <th colspan="3">Facturación</th>
                                            <th colspan="3">Perdidas</th>
                                        </tr>
                                        <tr>
                                            <th>Total Lineas</th>
                                            <th>Nuevos Q.</th>
                                            <th>Tasa generación</th>
                                            <th>Total Lineas</th>
                                            <th>Facturado Q.</th>
                                            <th>Tasa de cierre</th>
                                            <th>Total Lineas</th>
                                            <th>Perdidas Q.</th>
                                            <th>Tasa de perdida</th>
                                        </tr>
                                    </thead>
                                    <tbody class="text-center" id="tbodyVentas-${tienda}" style="background-color:white">
                                        <tr>
                                            <td colspan="13">
                                                <img src="/img/loading_circulo.gif" alt="Cargando" style="width:25px; height:25px;"><br/>
                                                Cargando datos...
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>`;

                            detalleRow.find('.contenido-detalle').html(Detalle);
                            detalleRow.show();
                            $(this).find('i').removeClass('fa-plus-circle').addClass('fa-minus-circle');

                            // Llamada AJAX para llenar la tabla
                            $.ajax({
                                url: '/EstadoBolson/DetalleUsuarios',
                                method: 'POST',
                                data: { WhsCode: tienda },
                                success: function (data) {
                                    let tbody = '';
                                    $.each(data.data, function (i, item) {
                                        tbody += `<tr>
                                            <td>${item.SlpName}</td>
                                            <td>${formatoQuetzal(item.BolsonActivo)}</td>
                                            <td>${item.LineasCot}</td>
                                            <td>${formatoQuetzal(item.DocTotalCot)}</td>
                                            <td>${item.TasaGeneracion}%</td>
                                            <td>${item.LineasFac}</td>
                                            <td>${formatoQuetzal(item.DocTotalFac)}</td>
                                            <td>${item.TasaCierre}%</td>
                                            <td>${item.LineasPerd}</td>
                                            <td>${formatoQuetzal(item.DocTotalPerd)}</td>
                                            <td>${item.TasaPerd}%</td>
                                        </tr>`;
                                    });
                                    $('#tbodyVentas-' + tienda).html(tbody);
                                },
                                error: function () {
                                    $('#tbodyVentas-' + tienda).html('<tr><td colspan="13">Error al cargar los datos</td></tr>');
                                }
                            });
                        }
                    });

                } else {
                    alert(response.message);
                }

                $("#globalLoading").hide();
            },
            error: function () {
                $("#globalLoading").hide();
                alert("Error al obtener los datos");
            }
        });
    }

    function formatoQuetzal(valor) {
        return new Intl.NumberFormat('es-GT', {
            style: 'currency',
            currency: 'GTQ',
            minimumFractionDigits: 2
        }).format(valor);
    }
</script>