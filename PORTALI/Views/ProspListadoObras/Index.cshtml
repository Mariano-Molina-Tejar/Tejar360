                        </td>
                        <td><span class="badge bg-success">${formatearFecha(item.ProximaVisita)}</span></td>
                        <td class="text-center">
                            <button class="btn btn-outline-primary btn-sm rounded-pill me-2" onclick="irAlPunto('${item.Ubicacion}')">
                                <i class="fas fa-map-marker-alt"></i> <span class="d-none d-md-inline ms-1">Punto</span>
                            </button>
                            <button class="btn btn-outline-success btn-sm rounded-pill" onclick="comoLlegar('${item.Ubicacion}')">
                                <i class="fas fa-route"></i> <span class="d-none d-md-inline ms-1">Llegar</span>
                            </button>
                        </td>
                    </tr>

                    <!-- Fila de detalle con collapse dentro de un div para no romper la tabla -->
                    <tr>
                        <td colspan="13" class="p-0">
                            <div class="collapse" id="${collapseId}">
                                <div class="p-3 border">
                                    <ul class="nav nav-tabs" id="tab-${index}" role="tablist">
                                        <li class="nav-item" role="presentation">
                                            <button class="nav-link active tab-contactos" id="detalles-tab-${index}"
                                                    data-bs-toggle="tab" data-bs-target="#detalles-${index}"
                                                    type="button" role="tab">
                                                Contactos y fotografías
                                            </button>
                                        </li>
                                        <li class="nav-item" role="presentation">
                                            <button class="nav-link tab-cotizaciones" id="cotizaciones-tab-${index}"
                                                    data-bs-toggle="tab" data-bs-target="#cotizaciones-${index}"
                                                    type="button" role="tab">
