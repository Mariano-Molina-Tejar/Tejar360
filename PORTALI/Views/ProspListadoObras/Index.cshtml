    // Función genérica de confirmación
    function confirmarAccion(mensaje, callback) {
        if (mensaje === "Agendar Revisita") {
            const seleccionados = document.querySelectorAll("#tablaVisitas .fila-check:checked");
            if (seleccionados.length === 0) {
                Swal.fire({
                    title: 'Atención',
                    text: 'Debes seleccionar al menos un dato en el listado.',
                    icon: 'warning',
                    confirmButtonText: 'OK',
                    customClass: {
                        confirmButton: 'btn btn-primary px-4 py-2 shadow-sm rounded-pill'
                    },
                    buttonsStyling: false
                });
                return;
            }
        }

        Swal.fire({
            title: 'Confirmación requerida',
            html: `<strong>¿Programar ${mensaje}?</strong>`,
            icon: 'info',
            showCancelButton: true,
            focusConfirm: false,
            confirmButtonText: '<i class="fas fa-check me-2"></i>Sí, continuar',
            cancelButtonText: '<i class="fas fa-times me-2"></i>No, cancelar',
            customClass: {
                confirmButton: 'btn btn-success px-4 py-2 shadow-sm rounded-pill swal-btn-spacing',
                cancelButton: 'btn btn-danger px-4 py-2 shadow-sm rounded-pill swal-btn-spacing'
            },
            buttonsStyling: false,
            reverseButtons: true
        }).then((result) => {
            if (result.isConfirmed) {
                if (mensaje === "Agendar Revisita") {
                    openModal();
                    const seleccionados = document.querySelectorAll("#tablaVisitas .fila-check:checked");
                    const divFlags = document.getElementById("listaObras");
                    divFlags.innerHTML = ""; // limpiar

                    seleccionados.forEach(cb => {
                        const tr = cb.closest("tr");
                        const numeroObra = tr.children[2].textContent.trim(); // número o nombre
                        const estado = "Pendiente"; // puedes cambiar según tu lógica
                        let clase = "flag-pendiente";
                        if (estado === "Revisita") clase = "flag-revisita";
                        if (estado === "Realizada") clase = "flag-realizada";

                        const span = document.createElement("span");
                        span.className = clase;
                        span.textContent = numeroObra;
                        divFlags.appendChild(span);
                    });
                }

                callback();
            }
        });

    }



    function mostrarCheckboxes() {
        // ✅ Afecta SOLO el encabezado de la tabla principal
        document.getElementById("columnaCheckbox").innerHTML =
            `<input type="checkbox" id="checkAll" class="checkbox-modern ms-2" onclick="seleccionarTodos(this)"> #`;

        // ✅ Selecciona SOLO las filas de la tabla principal
        const filas = document.querySelectorAll("#tablaVisitas > tr");
        filas.forEach((tr) => {
            const firstTd = tr.querySelector("td");
            if (firstTd && firstTd.hasAttribute("colspan")) return; // Evita la fila "Cargando datos..."

            const td = tr.children[1]; // Segunda columna de la tabla principal
            if (!td.querySelector(".fila-check")) {
                const numero = td.textContent.trim();
                td.innerHTML = `
                <input type="checkbox" class="fila-check checkbox-modern me-2">
                ${numero}
            `;
            }
        });
    }


    function ocultarCheckboxes() {
        // Restaurar encabezado solo con #
        document.getElementById("columnaCheckbox").innerHTML = "#";

        // Quitar checkboxes de cada fila pero dejar el número intacto
        document.querySelectorAll("#tablaVisitas tr").forEach((tr) => {
            const firstTd = tr.querySelector("td");
            if (firstTd && firstTd.hasAttribute("colspan")) return; // ignorar filas de detalle

            const td = tr.children[1]; // columna del número
            const cb = td.querySelector(".fila-check");
            if (cb) cb.remove(); // quitamos el checkbox pero dejamos el texto (número)
        });
    }

    function seleccionarTodos(check) {
        document.querySelectorAll("#tablaVisitas .fila-check").forEach((cb) => {
            cb.checked = check.checked;
        });
    }

