                                            </button>
                                        </li>
                                        <li class="nav-item" role="presentation">
                                            <button class="nav-link tab-revisitas" id="revisitas-tab-${index}"
                                                    data-bs-toggle="tab" data-bs-target="#revisitas-${index}"
                                                    type="button" role="tab">
                                                Revisitas y Seguimientos
                                            </button>
                                        </li>
                                    </ul>
                                    <div class="tab-content p-3 border border-top-0">
                                        <div class="tab-pane fade show active" id="detalles-${index}" role="tabpanel">






