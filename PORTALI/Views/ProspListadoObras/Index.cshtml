    function cargarContactos(idVisita) {
        $.ajax({
            url: '/ProspListadoObras/ObtenerContactos', // tu endpoint que devuelve contactos por visita
            type: 'GET',
            data: { NoVisita: idVisita },
            dataType: 'json',
            success: function (contactos) {
                let html = '';
                if (contactos && contactos.length > 0) {
                    contactos.forEach((c, i) => {
                        html += `
                        <tr>
                            <td>${i + 1}</td>
                            <td>${c.NombreContacto}</td>
                            <td>${c.Telefono ?? '-'}</td>
                            <td>${c.TipoCliente ?? '-'}</td>
                            <td class="text-center">
                                <input type="checkbox" ${c.CompradorPrincipal == "Y" ? 'checked' : ''} disabled>
                            </td>
                        </tr>
                    `;
                    });
                } else {
                    html = `<tr><td colspan="5" class="text-center text-muted">No hay contactos registrados.</td></tr>`;
                }

                $(`tbody.contactos-body[data-id="${idVisita}"]`).html(html);
            },
            error: function (err) {
                console.error('Error al cargar contactos:', err);
                $(`tbody.contactos-body[data-id="${idVisita}"]`).html(
                    `<tr><td colspan="5" class="text-center text-danger">Error al cargar contactos</td></tr>`
                );
            }
        });
    }

    function mostrarComentario(comentario) {
