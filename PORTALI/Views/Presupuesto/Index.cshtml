    <script>

        async function postJson(url, data) {
            const res = await fetch(url, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json;charset=utf-8'
                },
                body: JSON.stringify(data)
            });
            if (!res.ok) throw new Error(await res.text());
            return res.json().catch(() => ({}));
        }

        async function VerDocumento(DocNum, CodigoCuenta,Id) {
            console.log(DocNum + " " + CodigoCuenta);

            try {
                const response = await postJson('/Presupuesto/VerDetalleFactura', { DocNum: DocNum, CodigoCuenta: CodigoCuenta, IdDocumento: Id });

                console.log(response);
                document.getElementById('FacturaProveedor').value = response.data[0].Proveedor;
                document.getElementById('FacturaNombre').value = response.data[0].Nombre;
                document.getElementById('FacturaSucursal').value = response.data[0].Sucursal;
                document.getElementById('FacturaDocNum').value = response.data[0].DocNum;
                document.getElementById('FacturaFechaContabilizacion').value = parseJsonDate(response.data[0].FechaContabilizacion);
                document.getElementById('FacturaFechaDocumento').value = parseJsonDate(response.data[0].FechaDocumento);
                document.getElementById('FacturaComentarios').value = response.data[0].Comentarios;
                document.getElementById('FacturaTotal').value = 'Q' + response.data[0].TotalDocumento.toLocaleString('es-GT', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
                document.getElementById('FacturaTotalCuenta').value = 'Q' + response.data[0].TotalCuenta.toLocaleString('es-GT', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
                let tbody = '';
                let contador = 1;
                let titulo = "";
                response.data.forEach(tabla => {

                    tbody += ` <tr style="background-color:${tabla.Color};">
                                            <td style="background-color:${tabla.Color};">${contador}</td>
                                            <td style="background-color:${tabla.Color};">${tabla.ItemCode}</td>
                                            <td style="background-color:${tabla.Color};">${tabla.Dscription}</td>
                                            <td style="background-color:${tabla.Color};">${tabla.Quantity}</td>
                                            <td style="background-color:${tabla.Color};">Q${tabla.LineTotal.toLocaleString('es-GT', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}</td>
                                            <td style="background-color:${tabla.Color};">Q${tabla.Total.toLocaleString('es-GT', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}</td>

                                        </tr>`;
                    contador = contador + 1;
                });

                if (Id === 1) {
                    document.getElementById("Titulo").innerHTML = "Factura proveedores";
                }
                else if (Id === 2) {
                    document.getElementById("Titulo").innerHTML = "Nota de crédito";

                } else {
                    document.getElementById("Titulo").innerHTML = "Orden de compra";
                }

                document.getElementById("BodyHtml").innerHTML = tbody;
                $('#modalFactura').modal('show');
            }
            catch (e) {
                console.log(e);
            }
        };


    function cerrarModalFactura() {
        $('#modalFactura').modal('hide');
    }

        function GuardarNotaPto(Codigo, CodeNote) {
        const anio = document.getElementById("costos-select").value;
        const mes = @mes;
        const id = "#" + Codigo;
        const nota = document.querySelector(id).value;

        const _nota = {
            U_Anio : anio,
            U_Mes : mes,
            U_Nota: nota,
            U_Cuenta: Codigo,
            Code : CodeNote
        }

        console.log(_nota);

        if (_nota.U_Nota == '') {
            return null;
        }

       $("#globalLoading").show?.();
        document.body.style.cursor = 'wait';
        $.ajax({
            url: '@Url.Action("GuardarNotas", "Presupuesto")',
            method: 'POST',
            data: {
                nota: _nota
            },
            success: function (response) {

                console.log(response);
                if (response.success) {
                    Toast.fire({ icon: 'success', title: 'Nota guardada correctamente.' });
                    location.reload();
                } else {
                    Toast.fire({ icon: 'error', title: 'Ocurrio un error al guardar la nota.' + response.message });
                }
            },
            complete: function () {
                $("#globalLoading").hide?.();
                document.body.style.cursor = 'default'; // Vuelve a normal

            }
        });
    }


    function BorrarNotaPto(Nomrbre, _Code, Id) {

        Swal.fire({
            title: '¿Eliminar Nota?',
            text: `Se eliminará la nota de la cuenta "${Nomrbre}"`,
            icon: 'warning',
            showCancelButton: true,
            confirmButtonText: 'Sí, eliminar',
            cancelButtonText: 'Cancelar',
            confirmButtonColor: '#d33',
            cancelButtonColor: '#3085d6',
            reverseButtons: true
        }).then(async (result) => {
            if (result.isConfirmed) {
                document.body.style.cursor = 'wait';
                console.log(result);
                try {
                    //$("#globalLoading").show?.();
                    document.body.style.cursor = 'wait';

                    await postJson('/Presupuesto/BorrarNotas', { code: _Code });
                    const id = "#" + Id;
                    const nota = document.querySelector(id).value;
                    document.querySelector(id).value = '';

                    Toast.fire({ icon: 'success', title: 'Nota Eliminada' });
                    location.reload();
                } catch (e) {
                    console.log(e);
                    Toast.fire({ icon: 'error', title: 'No se pudo eliminar la nota'} );

                } finally {
                    $("#globalLoading").hide?.();
                    document.body.style.cursor = 'default'; // Vuelve a normal
                }
            }
        });
    }
    </script>
</html>