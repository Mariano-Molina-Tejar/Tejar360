    </div>

    <script src="https://cdn.jsdelivr.net/npm/jquery@3.5.1/dist/jquery.slim.min.js" integrity="sha384-DfXdz2htPH0lsSSs5nCTpuj/zy4C+OGpamoFVy38MVbnQ6E/gI1I3G5zXo3Cg7Z0tZq3w==" crossorigin="anonymous"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" rel="stylesheet">
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.5.1.slim.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/popper.js@1.16.1/dist/umd/popper.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.5.1.slim.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/popper.js@1.16.1/dist/umd/popper.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.min.js"></script>

    <script>
        function parseJsonDate(jsonDate) {
            const timestamp = parseInt(String(jsonDate).replace(/\/Date\((\d+)\)\//, '$1'));
            const date = new Date(timestamp);
            const day = String(date.getDate()).padStart(2, '0');
            const month = String(date.getMonth() + 1).padStart(2, '0');
            const year = date.getFullYear();
            return `${day}/${month}/${year}`;
        }
    </script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/sweetalert2/11.22.3/sweetalert2.min.js"></script>
    <script>

    const Toast = Swal.mixin({
        toast: true,
        position: 'top-end',
        showConfirmButton: false,
        timer: 2000,
        timerProgressBar: true
    });
        let detalleActual = null;
        let detalleActualEmpleado = null;

        function VerDetallePresupuesN2(_code,_button) {
            const _mes = document.querySelector("#mes-select").value;
            const tr = _button.closest("tr");

            //const tr = button.closest("tr");
            const idBoton = _button.getAttribute("data-AcctCode");

        //// Toggle si es el mismo
        if (detalleActual && detalleActual.id === idBoton) {
            document.querySelector(".fila-detalle")?.remove();
            detalleActual = null;
            return;
        }

        // Cierra detalle anterior
        document.querySelector(".fila-detalle")?.remove();
        detalleActual = { id: idBoton };

        $("#globalLoading").show?.();
        $.ajax({
            url: '@Url.Action("ObtenerDetalleCuentasN2", "Presupuesto")',
            method: 'POST',
            data: {
                Cuenta: _code,
                Mes: _mes
            },
            success: function (response) {
                if (response.success) {




                    let tbody = '';
                    response.data.forEach(tabla => {
                      tbody += `
                        <tr>
                            <td>
                                <button class="btn btn-sm btn-link toggle-sub-table"
                                  onclick="VerDetallePresupuesN3('${tabla.AcctCode}',this)"
                                   data-AcctCode2="${tabla.AcctCode}"
                                        >
                                    <i class="fas fa-plus"></i>
                                </button>
                            </td>
                            <td>${tabla.Cuenta}</td>
                            <td>Q${tabla.TotalEjecutadoCt.toLocaleString('es-GT', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}</td>
                            <td>Q${tabla.TotalPresupuestoCt.toLocaleString('es-GT', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}</td>
                            <td>Q${tabla.DifenciaCt.toLocaleString('es-GT', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}</td>
                            <td>${(tabla.EjecutadoCt * 100).toFixed(2)}%</td>
                            <td>
                                <textarea rows="1" cols="40" id= "${tabla.AcctCode}"
                                    style="
                                        border: 1px solid #ccc;
                                        border-radius: 8px;
                                        padding: 8px;
                                        font-family: Arial, sans-serif;
                                        font-size: 14px;
                                        box-shadow: 0 2px 5px rgba(0,0,0,0.1);
                                        outline: none;
                                        text-align: left;   /* texto empieza desde la izquierda */
                                        vertical-align: top; /* asegura que el texto arranque arriba */
                                    ">${tabla.Nota || ''}</textarea>
                                <!-- Botón Guardar -->
                                        <button style="
                                            background-color: #f8f9fa;
                                            border: 1px solid #ced4da;
                                            color: #495057;
                                            padding: 6px 10px;
                                            border-radius: 6px;
                                            cursor: pointer;
                                            transition: background-color 0.2s ease, color 0.2s ease;
                                        "
                                        onclick="GuardarNotaPto('${tabla.AcctCode}',${tabla.Code})">
                                            <i class="fas fa-save"></i>
                                        </button>

                                        <!-- Botón Eliminar -->
                                        <button style="
                                            background-color: #f8f9fa; 
                                            border: 1px solid #ced4da;
                                            color: #dc3545;
                                            padding: 6px 10px;
                                            border-radius: 6px;
                                            cursor: pointer;
                                            transition: background-color 0.2s ease, color 0.2s ease;
                                        "
                                        onclick="BorrarNotaPto('${tabla.Cuenta}',${tabla.Code},'${tabla.AcctCode}')">
                                            <i class="fas fa-trash"></i>
                                        </button>

                            </td>

                        </tr>`;
                    });

                    const html = `
                      <tr class="fila-detalle">
                        <td colspan="6">
                          <div class="soft-card detail-wrapper">
