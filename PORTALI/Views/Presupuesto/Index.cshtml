                        </div>
                        <!-- Comentarios y Totales -->
                        <div class="form-row mt-3">
                            <div class="form-group col-md-3">
                                <label>Comentarios</label>
                                <textarea class="form-control form-control-sm" id="FacturaComentarios" rows="5" style="background:#fff9d6;" disabled></textarea>
                            </div>
                            <div class="form-group col-md-6">

                            </div>
                            <div class="form-group col-md-3">
                                <table class="table table-sm mb-0" style="font-size:13px;">
                                    <tbody>
                                        <tr><td>Total cuenta seleccionada </td><td><input style="font-weight:bold" type="text" id="FacturaTotalCuenta" class="form-control form-control-sm" value="" disabled></td></tr>
                                        <tr><td>Total del documento</td><td><input type="text" id="FacturaTotal" class="form-control form-control-sm" value="" disabled></td></tr>
