                    <th class="oculto" style="padding: 8px; text-align: center">Región</th>
                    <th class="oculto" style="padding: 8px; text-align: center">WhsCode</th>
                    <th class="oculto" style="padding: 8px; text-align: center">Tienda</th>
                    <th class="oculto" style="padding: 8px; text-align: center">SlpCode</th>
                    <th style="padding: 8px; text-align: center">Asesor</th>
                    <th style="padding: 8px; text-align: center">NIT</th>
                    <th style="padding: 8px; text-align: center">Nombre</th>
                    <th onclick="sortTable(this.cellIndex)" style="cursor:pointer; padding:8px; text-align:center">Teléfono</th>
                    <th onclick="sortTable(this.cellIndex)" style="cursor:pointer; padding:8px; text-align:center">Fecha</th>
                    <th onclick="sortTable(this.cellIndex)" style="cursor:pointer; padding:8px; text-align:center">Total</th>
                    <th style="cursor:pointer; padding:8px; text-align:center;">
                        Fecha Posible Compra
                        <button onclick="toggleFiltroFechas(event)" style="border:none; background:none; cursor:pointer;">
                            <i class="fa fa-filter" style="margin-left:5px; color:gray;"></i>
                        </button>

                        <!-- Filtro de fechas emergente -->
                        <div id="filtroFechas" style="display:none; position:absolute; top:100%; right:0; background:white; border:1px solid #ccc; padding:10px; z-index:1000; box-shadow: 0 0 10px rgba(0,0,0,0.2); border-radius:5px;">
                            <label style="font-size: 12px;">Desde:</label>
                            <input type="date" id="fechaInicio" style="width:100%; margin-bottom:5px;"><br>
                            <label style="font-size: 12px;">Hasta:</label>
                            <input type="date" id="fechaFin" style="width:100%; margin-bottom:5px;"><br>

                            <div style="display: flex; justify-content: space-between; gap: 5px;">
                                <button onclick="filtrarPorFechas()" title="Filtrar" style="flex: 1; background:#007bff; color:white; border:none; padding:5px; border-radius:3px; font-size: 12px;">
                                    Filtrar
                                </button>
                                <button onclick="quitarFiltroFechas()" title="Quitar filtro" style="background:#dc3545; color:white; border:none; padding:5px; border-radius:3px; font-size: 12px;">
                                    <i class="fa fa-times"></i>
                                </button>
                            </div>
