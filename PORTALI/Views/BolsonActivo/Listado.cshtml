                    </th>
                    <th onclick="sortTable(this.cellIndex)" style="cursor:pointer; padding:8px; text-align:center">Estado</th>
                    <th onclick="sortTable(this.cellIndex)" style="cursor:pointer; padding:8px; text-align:center">Fecha Seguimiento</th>
                    <th class="oculto" style="padding: 8px; text-align: center">Tipo</th>
                    <th style="padding: 8px; text-align:center">Opciones</th>
                </tr>
            </thead>
            <tbody id="BolsonActivo" class="BolsonActivo">
            </tbody>
        </table>       
        <script>
            // Mostrar/ocultar el filtro de fechas
            function toggleFiltroFechas(event) {
                event.stopPropagation(); // evita que el clic cierre el panel
                const filtro = document.getElementById("filtroFechas");
                filtro.style.display = (filtro.style.display === "none" || filtro.style.display === "") ? "block" : "none";
            }

            // Escucha clics en el documento para cerrar si hacen clic afuera
            document.addEventListener("click", function (event) {
                const filtro = document.getElementById("filtroFechas");
                const boton = event.target.closest("button");
                const dentroDelFiltro = filtro.contains(event.target);

                // Si no se hizo clic dentro del filtro ni en el botón del filtro, ocultar
                if (!dentroDelFiltro && !(boton && boton.innerHTML.includes('fa-filter'))) {
                    filtro.style.display = "none";
                }
            });

            // Esta función se llama cuando haces clic en el botón "Filtrar"
            function filtrarPorFechas() {
                let idRegion = $('#filtroRegion').val();
                let whsCode = $('#filtroTienda').val();
                let slpCode = $('#filtroAsesor').val();
                let fechaInicio = $('#fechaInicio').val();
                let fechaFin = $('#fechaFin').val();

                // Ejecutar la carga de datos
                cargarTabla(idRegion, whsCode, slpCode, fechaInicio, fechaFin);


                //const inicio = document.getElementById("fechaInicio").value;
                //const fin = document.getElementById("fechaFin").value; 

                //// Luego de filtrar, cerrar el filtro
                document.getElementById("filtroFechas").style.display = "none";
            }

            function quitarFiltroFechas() {

            }
        </script>
    </div>
</div>

<div class="modal fade" id="modalSeguimiento" tabindex="-1" aria-labelledby="miModalLabel" aria-hidden="true" data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-confirm" style="max-width: 700px; margin: auto;">
        <div class="modal-content" style="border-radius: 8px; padding: 15px; box-shadow: 0 4px 8px rgba(0, 0, 0, 0.2);">

            <!-- Header -->
            <div class="modal-header" style="display: flex; align-items: center; justify-content: center; border-bottom: 1px solid #ddd; padding: 15px;">
                <h5 class="modal-title" id="miModalLabel" style="margin: 0; font-weight: bold; display: flex; align-items: center;">
                    <i class="fas fa-tasks" style="color: #007bff; margin-right: 10px;"></i> Seguimiento
                </h5>
            </div>

            <div class="modal-body" style="background-color: #fdfdfd; padding: 20px; border-radius: 8px;">
                <form id="formSeguimiento">

                    <div style="margin-bottom: 15px; display:none">
                        <label for="txtDocEntry" style="font-weight: bold; display: block; margin-bottom: 4px;">DocEntry <a style="color:red">*</a></label>
                        <input type="text" id="txtDocEntry"
                               style="width: 100%; padding: 10px; font-size: 15px; border: 1px solid #ccc; border-radius: 6px;" disabled>
                    </div>

                    <div style="margin-bottom: 15px;">
                        <label for="txtDocNum" style="font-weight: bold; display: block; margin-bottom: 4px;">No. Documento <a style="color:red">*</a></label>
                        <input type="text" id="txtDocNum"
                               style="width: 100%; padding: 10px; font-size: 15px; border: 1px solid #ccc; border-radius: 6px;" disabled>
                    </div>

                    <div style="margin-bottom: 15px;">
                        <label for="txtMedioContacto" style="font-weight: bold; display: block; margin-bottom: 4px;">Medio de Contacto <a style="color:red">*</a></label>
                        <select id="txtMedioContacto"
                                style="width: 100%; padding: 10px; font-size: 15px; border: 1px solid #ccc; border-radius: 6px;">
                        </select>
                    </div>

                    <div style="margin-bottom: 15px;">
                        <label for="txtNotas" style="font-weight: bold; display: block; margin-bottom: 4px;">Observaciones<a style="color:red">*</a></label>
                        <textarea id="txtNotas" rows="2"
                                  style="width: 100%; padding: 10px; font-size: 15px; border: 1px solid #ccc; border-radius: 6px;"></textarea>
                    </div>

                    <style>
                        .list-container {
                            display: flex;
                            gap: 20px;
                            margin: 5px 0;
                            font-size: 12px;
                        }

                        .list {
                            flex: 1;
                            min-height: 150px;
                            border: 2px dashed #aaa;
                            border-radius: 8px;
                            padding: 5px;
                            background: #f9f9f9;
                        }

                            .list h4 {
                                text-align: center;
                                margin-bottom: 10px;
                                font-size: 12px;
                                font-family: sans-serif;
                            }

                        .flag {
                            display: inline-block;
                            padding: 4px 6px;
                            margin: 5px;
                            border-radius: 6px;
                            background: #eaeaea;
                            cursor: grab;
                            font-size: 12px;
                            font-weight: bold;
                            transition: 0.2s;
                        }

                            .flag:active {
                                cursor: grabbing;
                                opacity: 0.6;
                            }

                        .acciones {
                            width: 200px; /* Ancho del contenedor */
                            height: 150px; /* Alto fijo */
                            border: 1px solid #ccc;
                            border-radius: 8px;
                            padding: 10px;
                            overflow-y: auto; /* Scroll vertical */
                            background: #f9f9f9;
                        }

                        .accion {
                            padding: 8px;
                            margin: 5px 0;
                            background: #fff;
                            border: 1px solid #ddd;
                            border-radius: 5px;
                            cursor: grab; /* Para que se vea arrastrable */
                        }
                    </style>

                    <div class="list-container">
                        <div class="list" id="list1">
                            <h4>Disponibles</h4>
                        </div>

                        <div class="list" id="list2">
                            <h4>Acciones implementadas</h4>
                        </div>

                        <script>
                            $(document).ready(function () {
                                $.ajax({
                                    url: "/BolsonActivo/GetAcciones", // <-- tu endpoint
                                    type: "GET",
                                    dataType: "json",
                                    success: function (data) {
                                        const tbody = $('#list1');

                                        data.forEach(item => {
                                            // Si item.Icono no existe o está vacío, asignar un icono por defecto
                                            const icono = item.Icono && item.Icono.trim() !== "" ? item.Icono : "fas fa-question-circle";

                                            const fila = $(`
                                                            <div class="flag accion" draggable="true" style="margin:5px;" data-codigo="${item.Codigo}">
                                                                <i class="${icono}"></i> ${item.Nombre}
                                                            </div>
                                                        `);
                                            tbody.append(fila);
                                        });

                                    },
                                    error: function (xhr, status, error) {
                                        console.error("Error cargando acciones:", error);
                                    }
                                });
                            });
                        </script>
                    </div>

                    <script>
                        // Drag start y drag end para elementos .flag, incluso los dinámicos
                        document.addEventListener("dragstart", function (e) {
                            if (e.target.classList.contains("flag")) {
                                e.dataTransfer.setData("text/plain", e.target.outerHTML);
                                e.dataTransfer.effectAllowed = "move";
                                e.target.classList.add("dragging");
                            }
                        });

                        document.addEventListener("dragend", function (e) {
                            if (e.target.classList.contains("flag")) {
                                e.target.classList.remove("dragging");
                            }
                        });

                        // Dragover y drop para listas
                        document.querySelectorAll('.list').forEach(list => {
                            list.addEventListener('dragover', e => {
                                e.preventDefault();
                                e.dataTransfer.dropEffect = "move";
                            });

                            list.addEventListener('drop', e => {
                                e.preventDefault();
                                const draggedEl = document.querySelector(".dragging");

                                if (draggedEl && draggedEl.parentNode !== list) {
                                    list.appendChild(draggedEl);
                                }
                            });
                        });

                    </script>

                    <div style="margin-bottom: 15px; margin-top:6px;">
                        <label for="txtFechaCompra" style="font-weight: bold; display: block; margin-bottom: 6px;">Posible Fecha de Compra <a style="color:red">*</a></label>
                        <input type="date" id="txtFechaCompra"
                               style="width: 100%; padding: 10px; font-size: 15px; border: 1px solid #ccc; border-radius: 6px;">
                    </div>

                    <div style="margin-bottom: 15px;">
                        <label for="txtProximoSeg" style="font-weight: bold; display: block; margin-bottom: 6px;">Fecha Próximo Seguimiento <a style="color:red">*</a></label>
                        <input type="date" id="txtProximoSeg"
                               style="width: 100%; padding: 10px; font-size: 15px; border: 1px solid #ccc; border-radius: 6px;">
                    </div>

                    <div style="margin-bottom: 15px;">
                        <label for="chkPerdida" style="font-weight: bold; display: flex; align-items: center; font-size: 1.05rem;">
                            <input type="checkbox" id="chkPerdida"
                                   style="margin-right: 10px; transform: scale(1.3); width: 16px; height: 16px;">
                            Cotización perdida
                        </label>
                    </div>

                    <div style="margin-bottom: 10px;">
                        <label for="txtMotivoPerdida" style="font-weight: bold; display: block; margin-bottom: 6px;">Motivo de la cotización perdida <a style="color:red">*</a></label>
                        <select id="txtMotivoPerdida"
                                disabled
                                style="width: 100%; padding: 10px; font-size: 15px; border: 1px solid #ccc; border-radius: 6px;">
                        </select>
                    </div>
                    <script>
                        document.getElementById("chkPerdida").addEventListener("change", function () {
                            const isChecked = this.checked;

