        document.getElementById('btnSaveSeguimiento').addEventListener('click', function () {
        const chkPerdida = document.getElementById('chkPerdida');
        const medioContacto = document.getElementById('txtMedioContacto');
        const notas = document.getElementById('txtNotas');
        const fechaCompra = document.getElementById('txtFechaCompra');
        const proximoSeg = document.getElementById('txtProximoSeg');
        const motivoPerdida = document.getElementById('txtMotivoPerdida');

        if (!notas.value.trim()) {
            alert("Escribe alguna observación o acción realizada.");
            notas.focus();
            return;
        }

        if (chkPerdida.checked) {
            // Validaciones solo para cotización perdida
            if (!motivoPerdida.value || motivoPerdida.value === "0" || motivoPerdida.value === "-1") {
                alert("Si marcaste que se perdió, dime por qué… ¡Vamos! selecciona el motivo de la cotización perdida");
                motivoPerdida.focus();
                return;
            }
        } else {
            // Validaciones normales
            if (!medioContacto.value || medioContacto.value === "0" || medioContacto.value == "-1") {
                alert("Selecciona un medio de contacto.");
                medioContacto.focus();
                return;
            }
            if (!fechaCompra.value) {
                alert("No olvides seleccionar la posible fecha de compra.");
                fechaCompra.focus();
                return;
            }
            if (!proximoSeg.value) {
                alert("¿Y cuándo le vas a dar seguimiento? Selecciona la fecha.");
                proximoSeg.focus();
                return;
            }
        }

        if (chkPerdida.checked) {
            Swal.fire({
                title: '¡Atención!',
                text: '¿Estás seguro de marcar esta cotización como perdida? Esta acción indica que no continuarás con el proceso.',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Sí, estoy seguro',
                cancelButtonText: 'No, cancelar',
                confirmButtonColor: '#dc3545',
                cancelButtonColor: '#6c757d',
                reverseButtons: true,
                backdrop: `rgba(255,0,0,0.1)`
            }).then((result) => {
                if (result.isConfirmed) {
                    guardarSeguimiento();
                } else {
                    Swal.fire({
                        title: 'Cotización NO marcada como perdida',
                        icon: 'info',
                        timer: 1800,
                        showConfirmButton: false
                    });
                }
            });
        } else {
            Swal.fire({
                title: '¿Está seguro?',
                text: '¿Desea guardar el seguimiento?',
                icon: 'question',
                showCancelButton: true,
                confirmButtonText: 'Sí, guardar',
                cancelButtonText: 'Cancelar',
                confirmButtonColor: '#28a745',
                cancelButtonColor: '#d33'
            }).then((result) => {
                if (result.isConfirmed) {
                    guardarSeguimiento();
                }
            });
        }
        });

    function resetearListas() {

        const list1 = document.getElementById('list1');
        const list2 = document.getElementById('list2');

        // Mover solo los elementos después del h4
        while (list2.children.length > 1) {
            list1.appendChild(list2.children[1]); // siempre el siguiente al h4
        }
    }


    function guardarSeguimiento() {
        $("#globalLoading").show();

        const codigos = Array.from(document.querySelectorAll('#list2 .flag'))
            .map(el => el.dataset.codigo)
            .join(',');

        console.log(codigos);
            // Capturar los valores de los inputs
            var data = {
                DocEntry: document.getElementById("txtDocEntry").value,
                DocNum: document.getElementById("txtDocNum").value,
                MedioContacto: document.getElementById("txtMedioContacto").value,
                Notas: document.getElementById("txtNotas").value,
                PosFechaCompra: document.getElementById("txtFechaCompra").value,
                FechaSeguimiento: document.getElementById("txtProximoSeg").value,
                EstadoPerdida: document.getElementById("chkPerdida").checked ? "Y" : "N",
                MotivoPerdida: document.getElementById("txtMotivoPerdida").value,
                Acciones: codigos
            };

            // Enviar datos con AJAX
            $.ajax({
                url: "/Ventas/SaveSeguimiento", // Ruta a tu backend en ASP.NET
                type: "POST",
                contentType: "application/json",
                data: JSON.stringify(data),
                success: function (response) {
                    if (response.result === 1) {
                        $("#globalLoading").hide();

                        Swal.fire({
                            title: 'Se guardó correctamente',
                            icon: 'success',
                            confirmButtonText: 'OK',
                            allowOutsideClick: false,
                            allowEscapeKey: false,
                            allowEnterKey: false
                        }).then(() => {
                            let idRegion = $('#filtroRegion').val();
                            let whsCode = $('#filtroTienda').val();
                            let slpCode = $('#filtroAsesor').val();
                            let fechaInicio = $('#fechaInicio').val();
                            let fechaFin = $('#fechaFin').val();

                            // Ejecutar la carga de datos
                            cargarTabla(idRegion, whsCode, slpCode, fechaInicio, fechaFin);
                            limpiarCampos();                            

                            $("#modalSeguimiento").modal('hide');
                            $("#globalLoading").hide();
                        });

                    } else {
                        alert("Error: " + response.message);
                        $("#globalLoading").hide();
                    }
                },
                error: function () {
                    alert("Error al enviar la solicitud.");
                    $("#globalLoading").hide();
                }
            });
    }

    function limpiarCampos() {
        document.getElementById("txtDocEntry").value = "";
        document.getElementById("txtDocNum").value = "";
        document.getElementById("txtMedioContacto").value = "-1";
        document.getElementById("txtMedioContacto").disabled = false;
        document.getElementById("txtNotas").value = "";
        document.getElementById("txtFechaCompra").value = "";
        document.getElementById("txtFechaCompra").disabled = false;
        document.getElementById("txtProximoSeg").value = "";
        document.getElementById("txtProximoSeg").disabled = false;
        document.getElementById("chkPerdida").checked = false;
        document.getElementById("txtMotivoPerdida").disabled = true;
        document.getElementById("txtMotivoPerdida").value = "-1";

        resetearListas();

    }


    function formatearTotal(valor) {
        if (valor == null || isNaN(valor)) return 'Q0.00';
        return new Intl.NumberFormat('es-GT', {
            style: 'currency',
            currency: 'GTQ',
            minimumFractionDigits: 2
        }).format(valor);
    }

    function formatearFecha(fechaJson) {
        if (!fechaJson) return '--'; // Si viene null, undefined o vacío
        try {
            const timestamp = parseInt(fechaJson.match(/\d+/)[0]);
            const fecha = new Date(timestamp);
            const dia = fecha.getDate().toString().padStart(2, '0');
            const mes = (fecha.getMonth() + 1).toString().padStart(2, '0');
            const anio = fecha.getFullYear();
            return `${dia}/${mes}/${anio}`;
        } catch (e) {
            return '--'; // Si falla el parseo, también muestra --
        }
    }

// Función para ocultar columnas por índice
    function ocultarColumnas(indices) {
        $('table thead tr th').each(function (index) {
            if (indices.includes(index)) {
                $(this).hide();
            }
        });

        $('table tbody tr').each(function () {
            $(this).find('td').each(function (index) {
                if (indices.includes(index)) {
                    $(this).hide();
                }
            });
        });
    }
</script>
