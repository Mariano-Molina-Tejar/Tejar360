@model Entity.BolsonActivoEntity
@{
    ViewBag.Title = "Seguimiento de Cotizaciones";

    var sessions = (Entity.SessionLoginEntity)Session["PropertiesEntity"];
}

<style>
    body {
        background-color: #f4f6f8;
        font-family: 'Segoe UI', sans-serif;
        margin: 0;        
    }

    .filtros-container {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 1rem;
        margin-bottom: 2rem;
    }

        .filtros-container label {
            font-weight: 600;
            margin-bottom: 0.3rem;
            display: block;
            color: black;
        }

        .filtros-container select {
            padding: 0.5rem;
            border: 1px solid #ccc;
            border-radius: 8px;
            width: 100%;
            font-size: 0.95rem;
        }

        .filtros-container .derecha {
            display: flex;
            align-items: end;
            gap: 0.5rem;
        }

        .filtros-container button {
            padding: 0.55rem 1.2rem;
            background-color: black;
            color: white;
            border: none;
            border-radius: 8px;
            font-weight: bold;
            font-size: 0.95rem;
            transition: background 0.3s ease;
        }

            .filtros-container button:hover {
                background-color: black;
            }

    .paneles-container {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
        margin-bottom: 2rem;
    }

    .panel {
        flex: 1 1 150px;
        background-color: white;
        padding: 1rem;
        border-radius: 12px;
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.05);
        text-align: center;
    }

        .panel h3 {
            margin: 0;
            font-size: 1rem;
            color: #555;
        }

        .panel span {
            display: block;
            margin-top: 0.5rem;
            font-size: 1.4rem;
            font-weight: bold;
            color: black;
        }

    .oculto {
        display: none;
    }

    .tab-content {
        display: none;
    }

        .tab-content.active {
            display: block;
        }

    .tab-buttons {
        display: flex;
        margin-bottom: 10px;
    }

    .tab-button {
        padding: 8px 16px;
        cursor: pointer;
        border: 1px solid #ccc;
        margin-right: 5px;
        background-color: #f0f0f0;
    }

        .tab-button.active {
            background-color: #d0d0d0;
            font-weight: bold;
        }

</style>
<div style="padding:20px;padding-bottom:40px">
    <div class="filtros-container">
        <div>
            <label>Región</label>
            <select id="filtroRegion">
                <option value="-101">-- Seleccionar --</option>
            </select>
            <script>
                $(document).ready(function () {
                    CargarRegiones();
                });

                $('#filtroRegion').on('change', function () {
                    let idRegion = $(this).val();
                    CargarTiendas(idRegion);
                });

                function CargarRegiones(){
                    $.ajax({
                        url: '@Url.Action("ListadoRegiones", "BolsonActivo")',
                        type: "POST",
                        success: function (data) {
                            if (data && data.length > 0) {
                                $.each(data, function (index, item) {
                                    $('#filtroRegion').append(
                                        $('<option>', {
                                            value: item.IdRegion,
                                            text: item.Region
                                        })
                                    );
                                });

                                if (data.length === 1) {
                                    // Solo una opción, seleccionarla y bloquear el select
                                    $('#filtroRegion').val(data[0].IdRegion).trigger('change');
                                    CargarTiendas(data[0].IdRegion);
                                    $('#filtroRegion').prop('disabled', true); // bloquear select
                                } else {
                                    // Más de una opción, seleccionar '-1' y desbloquear el select
                                    $('#filtroRegion').val('-1').trigger('change');
                                    CargarTiendas(-1);
                                    $('#filtroRegion').prop('disabled', false); // desbloquear select
                                }

                            } else {
                                // No hay datos, mantener seleccionado el -1
                                $('#filtroRegion').val('-1');
                            }
                        },
                        error: function (xhr, status, error) {
                            console.error("Error al cargar las regiones:", error);
                            $('#filtroRegion').val('-1');
                        },
                        complete: function () {
                            $("#globalLoading").hide(); // Oculta el loading si lo estás usando
                        }
                    });
                }
            </script>
        </div>
        <div>
            <label>Tienda</label>
            <select id="filtroTienda">
                <option value="-1">-- Seleccionar --</option>
            </select>

            <script>
                $('#filtroTienda').on('change', function () {
                    let idRegion = $('#filtroRegion').val();
                    let WhsCode = $(this).val();
                    CargarUsuarios(idRegion, WhsCode);
                });

                function CargarTiendas(idRegion) {
                    $('#filtroTienda')
                        .html('') // limpiar todo
                        .append($('<option>', { value: '-1', text: '-- Seleccionar --' }))
                        .val('-1')
                        .trigger('change');

                    $.ajax({
                        url: '@Url.Action("ListadoTiendas", "BolsonActivo")',
                        type: "POST",
                        data: { IdRegion: idRegion },
                        success: function (data) {
                            if (data && data.length > 0) {
                                $.each(data, function (index, item) {
                                    $('#filtroTienda').append(
                                        $('<option>', {
                                            value: item.WhsCode,
                                            text: item.WhsName
                                        })
                                    );
                                });

                                    if (data.length === 1) {
                                        $('#filtroTienda').val(data[0].WhsCode).trigger('change');
                                        $('#filtroTienda').prop('disabled', true);
                                        CargarUsuarios(idRegion, data[0].WhsCode);
                                    } else {
                                        $('#filtroTienda').val('-1').trigger('change');
                                        $('#filtroTienda').prop('disabled', false);
                                        CargarUsuarios(idRegion, -1);
                                    }
                                } else {
                                    $('#filtroTienda').val('-1');
                                }
                            },
                            error: function (xhr, status, error) {
                                console.error("Error al cargar las tiendas:", error);
                                $('#filtroTienda').val('-1');
                            },
                            complete: function () {
                                $("#globalLoading").hide();
                            }
                    });
                }
            </script>
        </div>

        <div class="derecha">
            <div style="flex: 1;">
                <label>Asesor</label>
                <select id="filtroAsesor">
                    <option value="">-- Seleccionar --</option>
                </select>
                <script>
                    function CargarUsuarios(idRegion, whsCode) {
                        $('#filtroAsesor').html(''); // limpiar todo

                        $.ajax({
                            url: '@Url.Action("ListaDeAsesores", "BolsonActivo")',
                            type: "POST",
                            data: { IdRegion: idRegion, WhsCode: whsCode },
                            success: function (data) {
                                if (data && data.length > 0) {

                                    // Si NO son 2, agregar "-- Seleccionar --"
                                    if (data.length > 1) {
                                        $('#filtroAsesor')
                                            .append($('<option>', { value: '-101', text: '-- Seleccionar --' }));
                                    }

                                    $.each(data, function (index, item) {
                                        $('#filtroAsesor').append(
                                            $('<option>', {
                                                value: item.SlpCode,
                                                text: item.SlpName
                                            })
                                        );
                                    });

                                    if (data.length === 1) {
                                        // Seleccionar automáticamente el único valor útil
                                        $('#filtroAsesor').val(data[1].SlpCode).trigger('change');
                                        $('#filtroAsesor').prop('disabled', true); // si quieres bloquearlo
                                    } else {
                                        $('#filtroAsesor').val('-101').trigger('change');
                                        $('#filtroAsesor').prop('disabled', false);
                                    }
                                } else {
                                    $('#filtroAsesor')
                                        .html('')
                                        .append($('<option>', { value: '-101', text: '-- Seleccionar --' }))
                                        .val('-101')
                                        .prop('disabled', false);
                                }
                            },
                            error: function (xhr, status, error) {
                                console.error("Error al cargar los asesores:", error);
                                $('#filtroAsesor').val('-101').prop('disabled', false);
                            },
                            complete: function () {
                                $("#globalLoading").hide();
                            }
                        });
                    }
                </script>

            </div>

            <div style="display: flex; flex-direction: column; align-items: center; justify-content: center;">
                <label style="margin-bottom: 6px; font-weight: bold; text-align: center;">Referidos de SAC</label>

                <label style="display: inline-flex; align-items: center; cursor: pointer;">
                    <input type="checkbox" id="chkReferidos" style="display: none;">
                    <span id="switchReferidos" style="
                width: 40px;
                height: 20px;
                background-color: #ccc;
                border-radius: 20px;
                position: relative;
                transition: background-color 0.2s;
                display: inline-block;
            ">
                        <span style="
                content: '';
                position: absolute;
                top: 2px;
                left: 2px;
                width: 16px;
                height: 16px;
                background-color: white;
                border-radius: 50%;
                transition: left 0.2s;
            "></span>
                    </span>
                </label>
            </div>

            <script>
                const chk = document.getElementById("chkReferidos");
                const knob = document.getElementById("switchReferidos").firstElementChild;
                const bg = document.getElementById("switchReferidos");

                chk.addEventListener("change", function () {
                    if (this.checked) {
                        bg.style.backgroundColor = "#4CAF50";
                        knob.style.left = "22px";
                    } else {
                        bg.style.backgroundColor = "#ccc";
                        knob.style.left = "2px";
                    }
                });
            </script>
            <button id="btnFiltrar">Filtrar</button>
        </div>
    </div>

    <div class="paneles-container">
        <div class="panel">
            <h3>Activos</h3>
            <span id="txtActivos">Q0.00</span>
        </div>
        <div class="panel">
            <h3>Nuevos</h3>
            <span id="txtNuevos">Q0.00</span>
        </div>
        <div class="panel">
            <h3>Facturado</h3>
            <span id="txtFacturados">Q0.00</span>
        </div>
        <div class="panel">
            <h3>Perdidos</h3>
            <span id="txtPerdidos">Q0.00</span>
        </div>
    </div>
    <style>
        .contenedor-tabla {
            max-height: 70vh;
            overflow-y: auto;
