            }
    </style>

    <div style="max-height: 70vh; overflow-y: auto; background-color:white">
        <table class="tablaBolson" style="width: 100%; border-collapse: collapse; font-size:12px" border="1">
            <thead style="background-color: #f8f9fa; color: #212529; font-weight: bold; text-align: center; border-bottom: 2px solid #dee2e6;">
                <tr>
                    <th style="padding: 8px; text-align: center">-</th>
                    <th class="oculto" style="padding: 8px; text-align: center">DocEntry</th>
