<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sistema de Tickets - Freshdesk Style</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <link href="~/Css/styleTicket.css" rel="stylesheet" />
</head>
<body>
    <div class="container">
        <!-- Header -->
        <header>
            <div class="logo">
                <div class="logo-icon">
                    <i class="fas fa-headset"></i>
                </div>
                <div class="logo-text">Ticket<span> Tejar</span></div>
            </div>

            <div class="user-info">
                <div class="notification">
                    <i class="fas fa-bell"></i>
                    <span class="notification-badge">3</span>
                </div>
                <div class="user-avatar">BL</div>
            </div>
        </header>

        <!-- Dashboard -->
        <div class="dashboard">
            <div class="stats-card open">
                <div class="title">Tickets Abiertos</div>
                <div class="value">24</div>
                <div class="trend">
                    <i class="fas fa-arrow-up"></i> 12% desde ayer
                </div>
            </div>

            <div class="stats-card pending">
                <div class="title">Pendientes</div>
                <div class="value">8</div>
                <div class="trend down">
                    <i class="fas fa-arrow-down"></i> 5% desde ayer
                </div>
            </div>

            <div class="stats-card resolved">
                <div class="title">Resueltos</div>
                <div class="value">42</div>
                <div class="trend">
                    <i class="fas fa-arrow-up"></i> 18% desde ayer
                </div>
            </div>
        </div>

        <!-- Filters and Actions -->
        <div class="filters-actions">
            <div class="filters">
                <select>
                    <option>Todos los estados</option>
                    <option>Abierto</option>
                    <option>Pendiente</option>
                    <option>Resuelto</option>
                </select>

                <select>
                    <option>Todas las prioridades</option>
                    <option>Alta</option>
                    <option>Media</option>
                    <option>Baja</option>
                </select>

                <select>
                    <option>Todos los agentes</option>
                    <option>María Rodríguez</option>
                    <option>Carlos Vargas</option>
                    <option>Ana López</option>
                </select>
            </div>

            <div class="actions">
                <div class="search-box">
                    <i class="fas fa-search"></i>
                    <input type="text" placeholder="Buscar tickets...">
                </div>
            </div>

            <button id="newTicketBtn" class="btn btn-primary">
                <i class="fas fa-plus"></i> Nuevo Ticket
            </button>
        </div>

        <!-- Ticket List -->
        <div class="ticket-list">
            <div class="ticket-header">
                <div>ID</div>
                <div>Asunto</div>
                <div>Estado</div>
                <div>Fecha</div>
                <div>Prioridad</div>
                <div>Agente</div>
            </div>

            <!-- Ticket 1 -->
            <div class="ticket-item">
                <div class="ticket-id"><i class="fas fa-tag"></i> #34521</div>
                <div class="ticket-subject">
                    <span>Problema con facturación electrónica</span>
                    <span class="category">Facturación</span>
                </div>
                <div><span class="status status-open">Abierto</span></div>
                <div class="ticket-date"><i class="far fa-clock"></i> Hoy, 10:25 AM</div>
                <div class="priority priority-high">
                    <span class="priority-indicator"></span>
                    <span>Alta</span>
                </div>
                <div class="agent">
                    <div class="agent-avatar">MR</div>
                    <span class="agent-name">María Rodríguez</span>
                </div>
            </div>

            <!-- Ticket 2 -->
            <div class="ticket-item">
                <div class="ticket-id"><i class="fas fa-tag"></i> #34218</div>
                <div class="ticket-subject">
                    <span>Error al sincronizar inventario</span>
                    <span class="category">Inventario</span>
                </div>
                <div><span class="status status-pending">Pendiente</span></div>
                <div class="ticket-date"><i class="far fa-clock"></i> Ayer, 3:45 PM</div>
                <div class="priority priority-high">
                    <span class="priority-indicator"></span>
                    <span>Alta</span>
                </div>
                <div class="agent">
                    <div class="agent-avatar">CV</div>
                    <span class="agent-name">Carlos Vargas</span>
                </div>
            </div>

            <!-- Ticket 3 -->
            <div class="ticket-item">
                <div class="ticket-id"><i class="fas fa-tag"></i> #33987</div>
                <div class="ticket-subject">
                    <span>Consulta sobre integración API</span>
                    <span class="category">Desarrollo</span>
                </div>
                <div><span class="status status-open">Abierto</span></div>
                <div class="ticket-date"><i class="far fa-clock"></i> 13 Jul, 9:30 AM</div>
                <div class="priority priority-medium">
                    <span class="priority-indicator"></span>
                    <span>Media</span>
                </div>
                <div class="agent">
                    <div class="agent-avatar">AL</div>
                    <span class="agent-name">Ana López</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal para crear nuevo ticket -->
    <div class="modal-overlay" id="ticketModal">
        <div class="modal">
            <div class="modal-header">
                <h2>Crear Nuevo Ticket</h2>
                <div class="modal-close" id="closeModal">
                    <i class="fas fa-times"></i>
                </div>
            </div>

            <div class="modal-body">
                <form id="ticketForm">
                    <div class="form-group">
                        <label for="subject">Asunto</label>
                        <input type="text" id="subject" class="form-control" placeholder="Resumen del problema" required>
                    </div>

                    <div class="form-group">
                        <label for="description">Descripción</label>
                        <textarea id="description" class="form-control" placeholder="Describe el problema en detalle..." required></textarea>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label for="priority">Prioridad</label>
                            <select id="priority" class="form-control" required>
                                <option value="">Seleccionar prioridad</option>
                                <option value="high">Alta</option>
                                <option value="medium">Media</option>
                                <option value="low">Baja</option>
                            </select>
                        </div>

                        <div class="form-group">
                            <label for="category">Categoría</label>
                            <select id="category" class="form-control" required>
                                <option value="">Seleccionar categoría</option>
                                <option value="billing">Facturación</option>
                                <option value="access">Acceso</option>
                                <option value="technical">Problema Técnico</option>
                                <option value="feature">Solicitud de Funcionalidad</option>
                                <option value="other">Otro</option>
                            </select>
                        </div>
                    </div>

                    <div class="form-group">
                        <label for="attachment">Adjuntar archivo</label>
                        <input type="file" id="attachment" class="form-control">
                    </div>
                </form>
            </div>

            <div class="modal-footer">
                <button class="btn btn-secondary" id="cancelBtn">Cancelar</button>
                <button class="btn btn-primary" id="submitTicket">Crear Ticket</button>
            </div>
        </div>
    </div>

    <script>
        // Control del modal
        const modal = document.getElementById('ticketModal');
        const newTicketBtn = document.getElementById('newTicketBtn');
        const closeModal = document.getElementById('closeModal');
        const cancelBtn = document.getElementById('cancelBtn');
        const submitTicket = document.getElementById('submitTicket');
        const ticketForm = document.getElementById('ticketForm');
        
        // Abrir modal
        newTicketBtn.addEventListener('click', () => {
            modal.classList.add('active');
            document.body.style.overflow = 'hidden'; // Prevenir scroll
        });

        // Cerrar modal
        function closeTicketModal() {
            modal.classList.remove('active');
            document.body.style.overflow = 'auto'; // Restaurar scroll
            ticketForm.reset();
        }

        closeModal.addEventListener('click', closeTicketModal);
        cancelBtn.addEventListener('click', closeTicketModal);

        // Cerrar modal al hacer clic fuera
        modal.addEventListener('click', (e) => {
            if (e.target === modal) {
                closeTicketModal();
            }
        });

        // Cerrar con Esc
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape' && modal.classList.contains('active')) {
                closeTicketModal();
            }
        });

        // Enviar formulario
        submitTicket.addEventListener('click', (e) => {
            e.preventDefault();

            // Validar formulario
            if (ticketForm.checkValidity()) {
                // Aquí iría la lógica para enviar a un servidor
                // Por ahora solo mostramos un mensaje
                alert('Ticket creado exitosamente!');
                closeTicketModal();

                // Agregar el nuevo ticket a la lista
                const newId = Math.floor(Math.random() * 90000) + 10000;
                const newSubject = document.getElementById('subject').value;
                const newCategory = document.getElementById('category').options[document.getElementById('category').selectedIndex].text;
                const newPriority = document.getElementById('priority').options[document.getElementById('priority').selectedIndex].text;

                const now = new Date();
                const options = { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' };
                const formattedDate = now.toLocaleTimeString('es-ES', options);

                const ticketList = document.querySelector('.ticket-list');
                const newTicket = document.createElement('div');
                newTicket.className = 'ticket-item';
                newTicket.innerHTML = `
                        <div class="ticket-id"><i class="fas fa-tag"></i> #${newId}</div>
                        <div class="ticket-subject">
                            <span>${newSubject}</span>
                            <span class="category">${newCategory}</span>
                        </div>
                        <div><span class="status status-open">Abierto</span></div>
                        <div class="ticket-date"><i class="far fa-clock"></i> ${formattedDate}</div>
                        <div class="priority priority-${document.getElementById('priority').value}">
                            <span class="priority-indicator"></span>
                            <span>${newPriority}</span>
                        </div>
                        <div class="agent">
                            <div class="agent-avatar">TU</div>
                            <span class="agent-name">Tú</span>
                        </div>
                    `;

                // Insertar como primer ticket
                ticketList.insertBefore(newTicket, ticketList.children[1]);
            } else {
                alert('Por favor complete todos los campos requeridos');
            }
        });

        // Simular notificación
        const notification = document.querySelector('.notification');
        notification.addEventListener('click', () => {
            alert('Tienes 3 notificaciones sin leer');
        });
    </script>
</body>
</html>