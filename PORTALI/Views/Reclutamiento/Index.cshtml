            document.getElementById("pPrimerApellido").innerText = datosAspirante.DatosPersonalesVM.PrimerApellido;
            document.getElementById("pSegundoApellido").innerText = datosAspirante.DatosPersonalesVM.SegundoApellido;
            document.getElementById("pFechaNacimiento").innerText = convertirFechaDotNet(datosAspirante.DatosPersonalesVM.FechaNacimiento);
            document.getElementById("pSexo").innerText = datosAspirante.DatosPersonalesVM.Sexo == 'M' ? 'Masculino' : 'Femenino';
            document.getElementById("pDpi").innerText = datosAspirante.DatosPersonalesVM.NoDPI;
            document.getElementById("pCorreo").innerText = datosAspirante.DatosPersonalesVM.CorreoPersonal;
            document.getElementById("pCode").value = datosAspirante.DatosPersonalesVM.Code;

            let tbodyAcademico = '';
            let containerLaboral = '';
            let contador = 1;

            if (datosAspirante.DatosAcademicosVM.length != 0) {
