        document.getElementById("chkAsesorDeVEntas").addEventListener("change", (e) => {
            const usuarioVentas = document.getElementById("chkUsuarioVentas");
            const tejar360 = document.getElementById("chkTejar360");
            const meta = document.getElementById("chkMeta");
            const tienda = document.getElementById("selectTiendaEmpDeVentas");

            if (e.target.checked) {
                usuarioVentas.checked = true;
                tejar360.checked = true;
                meta.checked = true;
                tienda.disabled = false;
            } else {
                usuarioVentas.checked = false;
                tejar360.checked = false;
