                                                    <th>${item.Establecimiento}</th>
                                                    <th>${item.Anio}</th>
                                               </tr> `;

                    contador++;
                });
            }
            else {
                tbodyAcademico += `<tr>
                                      <th colspan ="5"><div class="text-center text-muted py-3">
                                         <i class="bi bi-info-circle"></i> No se encontraron datos
                                      </div></th>
                                   </tr> `;
            }

            if (datosAspirante.DatosLaboralesVM.length != 0) {
                datosAspirante.DatosLaboralesVM.forEach(item => {
                    containerLaboral += `
                                        <li class="list-group-item">
