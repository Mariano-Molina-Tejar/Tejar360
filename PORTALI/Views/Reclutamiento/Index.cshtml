@model Entity.ReclutamientoViewModel
@{
    ViewBag.Title = "Reclutamiento";
}

<!DOCTYPE html>
<html lang="es">

<head>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
</head>

<body>
    <div class="container mt-4">
        <div class="card shadow-sm border-0">
            <div class="card-header text-white d-flex justify-content-between align-items-center"
                 style="background-color: steelblue;">

                <h5 class="mb-0">
                    <i class="bi bi-file-earmark-person-fill me-2"></i> Solicitudes de Alta de personal
                </h5>

                <button class="btn btn-light btn-sm" id="btnAgregarSolicitud" onclick="agregarSolicitud()">
                    <i class="bi bi-plus-circle"></i> Agregar solicitud
                </button>
            </div>
            <div class="card-body bg-light">
                <table class="table table-hover align-middle text-center">
                    <thead class="table-success">
                        <tr>
                            <th>#</th>
                            <th>Fecha Solicitud</th>
                            <th>Puesto</th>
                            <th>Departamento</th>
                            <th>Solicita</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Reclutamiento.Count() != 0)
                        {
                            foreach (var puesto in Model.Reclutamiento)
                            {
                                <tr>
                                    <td>
                                        @puesto.SolicitudDeAlta
                                    </td>
                                    <td>@puesto.FechaSolicitud.ToString("dd/MM/yyyy")</td>
                                    <td>
                                        <div class="d-flex justify-content-between align-items-center">
                                            <span>@puesto.Puesto</span>

                                            <button id="btnPerfil-@(puesto.SolicitudDeAlta)"
                                                    class="btn btn-sm @(puesto.Perfil ? "btn-outline-success" : "btn-outline-danger")"
                                                    data-bs-toggle="tooltip"
                                                    title="@(puesto.Perfil ? "Ver perfil" : "Agregar perfil")"
                                                    onclick="abrirModalPerfilPuesto('@puesto.Puesto',@puesto.PuestoId,'btnPerfil-@(puesto.SolicitudDeAlta)')">

                                                <i id="ibtnPerfil-@(puesto.SolicitudDeAlta)" class="bi bi-file-earmark-text @(puesto.Perfil ? "text-success" : "text-danger")"></i>
                                            </button>
                                        </div>
                                    </td>
                                    <td>@puesto.Departamento</td>
                                    <td>@puesto.Solicita</td>
                                    <td>
                                        <button class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#modalDetalle"
                                                data-Puesto="@puesto.Puesto"
                                                data-PuestoId="@puesto.PuestoId"
                                                data-Departamento="@puesto.Departamento"
                                                data-DepartamentoId="@puesto.DepartamentoId"
                                                data-FechaSolicitud="@puesto.FechaSolicitud.ToString("dd/MM/yyyy")"
                                                data-Solicita="@puesto.Solicita"
                                                data-SolicitaId="@puesto.SolicitaId"
                                                data-Solicitud="@puesto.SolicitudDeAlta"
                                                onclick="verDetalleSolicitud(this)">
                                            <i class="bi bi-eye-fill"></i> Detalle
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted py-3" style="font-style: italic;">
                                    <i class="bi bi-info-circle"></i> No se encontraron solicitudes
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Modal Detalle -->
    <div class="modal fade" id="modalDetalle" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-xl modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header text-white" style="background-color:steelblue;">
                    <h5 class="modal-title"><i class="bi bi-info-circle-fill"></i> Detalle de Solicitud</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body bg-light">
                    <div id="solicitud-InformacionGeneral" class="mb-3">
                    </div>

                    <hr>

                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h6 class="fw-bold text-secondary mb-0">Aspirantes al puesto</h6>
                        <button id="btnCrearUsuarioClave" class="btn btn-warning btn-sm text-dark fw-semibold">
                            <i class="bi bi-person-plus-fill"></i> Generar Usuario y Contraseña
                        </button>
                    </div>

                    <table class="table table-striped table-bordered table-sm text-center">
                        <thead class="table-warning">
                            <tr>
                                <th>#</th>
                                <th>Usuario</th>
                                <th>Nombre Aspirante</th>
                                <th>Correo</th>
                                <th>Creado</th>
                                <th>Estado</th>
                                <th>Acción</th>
                            </tr>
                        </thead>
                        <tbody id="tbodyAspirantes">
                            <tr id="filaCarga">
                                <td colspan="5" class="text-center py-4">
                                    <div class="spinner-border text-warning" role="status"></div>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <div class="modal-footer">
                    <button class="btn btn-secondary" data-bs-dismiss="modal">
                        <i class="bi bi-x-circle"></i> Cerrar
                    </button>
                </div>
            </div>
        </div>
    </div>
    <!-- Modal Ver Usuario -->
    <div class="modal fade" id="modalUsuario" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content shadow-lg border-0">
                <div class="modal-header text-white" style="background-color:steelblue;">
                    <h5 class="modal-title"><i class="bi bi-person-circle me-2"></i> Información de Usuario</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body bg-light">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Usuario:</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-person-badge-fill"></i></span>
                            <input type="text" id="usuarioModal" class="form-control" readonly value="USUARIO123">
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Contraseña:</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-lock-fill"></i></span>
                            <input type="password" id="passwordModal" class="form-control" readonly value="MiClave123">
                            <button class="btn btn-outline-secondary" type="button" id="btnVerPassword">
                                <i id="iconoBtnVerUsuario" class="bi bi-eye-fill"></i>
                            </button>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Correo:</label>
                        <div class="input-group">
                            <span class="input-group-text">
                                <i class="bi bi-envelope-fill"></i>
                            </span>
                            <input type="text" id="emailModal" class="form-control">
                            <button class="btn btn-outline-secondary" type="button" id="btnEditarCorreo">
                                <i id="btnEditar" class="bi bi-pencil-fill"></i>
                                <span id="loadingGuardar" class="spinner-border spinner-border-sm d-none"></span>
                            </button>
                        </div>
                    </div>
                </div>

                <div class="modal-footer d-flex justify-content-between">

                    <!-- Botón izquierda -->
                    <button id="btnReenviarCorreo" class="btn btn-warning">
                        <i class="bi bi-envelope-arrow-up"></i> Reenviar correo
                    </button>

                    <!-- Botón derecha -->
                    <button class="btn btn-secondary" data-bs-dismiss="modal">
                        <i class="bi bi-x-circle"></i> Cerrar
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal Detalle Aspirante -->
    <div class="modal fade" id="modalDetalleAspirante" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-fullscreen modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg">

                <!-- Encabezado -->
                <div class="modal-header text-white" style="background-color:steelblue;">
                    <h5 class="modal-title">
                        <i class="bi bi-person-lines-fill"></i> Detalle del Aspirante
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>

                <!-- Cuerpo -->
                <div class="modal-body bg-light">

                    <div class="d-flex justify-content-between align-items-center">

                        <!-- Nav Tabs -->
                        <ul class="nav nav-tabs mb-3" id="detalleTabs" role="tablist">
                            <li class="nav-item" role="presentation">
                                <button class="nav-link active" id="tab-personal" data-bs-toggle="tab" data-bs-target="#info-personal" type="button" role="tab">
                                    <i class="bi bi-person-fill"></i> Personal
                                </button>
                            </li>
                            <li class="nav-item" role="presentation">
                                <button class="nav-link" id="tab-academico" data-bs-toggle="tab" data-bs-target="#info-academica" type="button" role="tab">
                                    <i class="bi bi-mortarboard-fill"></i> Académico
                                </button>
                            </li>
                            <li class="nav-item" role="presentation">
                                <button class="nav-link" id="tab-laboral" data-bs-toggle="tab" data-bs-target="#info-laboral" type="button" role="tab">
                                    <i class="bi bi-briefcase-fill"></i> Laboral
                                </button>
                            </li>
                            <li class="nav-item" role="presentation">
                                <button class="nav-link" id="tab-cv" data-bs-toggle="tab" data-bs-target="#info-cv" type="button" role="tab">
                                    <i class="bi bi-file-earmark-person-fill"></i> CV Digitalizado
                                </button>
                            </li>
                            <li class="nav-item" role="presentation">
                                <button class="nav-link" id="tab-comentarios" data-bs-toggle="tab" data-bs-target="#info-comentarios" type="button" role="tab">
                                    <i class="bi bi-chat-dots-fill"></i> Comentarios
                                </button>
                            </li>
                            <li class="nav-item" role="presentation">
                                <button class="nav-link" id="tab-config-alta" data-bs-toggle="tab"
                                        data-bs-target="#info-config-alta" type="button" role="tab">
                                    <i class="bi bi-person-check"></i> Confirmacion de alta
                                </button>
                            </li>
                        </ul>
                    </div>

                    <!-- Contenido de Tabs -->
                    <div class="tab-content" id="detalleTabsContent">

                        <!-- PERSONAL -->
                        <div class="tab-pane fade show active" id="info-personal" role="tabpanel">
                            <div class="card border-0 shadow-sm">
                                <div class="card-header bg-primary text-white fw-semibold">
                                    <i class="bi bi-info-circle-fill"></i> Información Personal
                                </div>
                                <div class="card-body">
                                    <div class="row g-3">
                                        <div class="col-md-3">
                                            <label class="form-label fw-bold">Primer Nombre</label>
                                            <p id="pPrimerNombre" class="mb-0"></p>
                                        </div>
                                        <div class="col-md-3">
                                            <label class="form-label fw-bold">Segundo Nombre</label>
                                            <p id="pSegundoNombre" class="mb-0"></p>
                                        </div>
                                        <div class="col-md-3">
                                            <label class="form-label fw-bold">Primer Apellido</label>
                                            <p id="pPrimerApellido" class="mb-0"></p>
                                        </div>
                                        <div class="col-md-3">
                                            <label class="form-label fw-bold">Segundo Apellido</label>
                                            <p id="pSegundoApellido" class="mb-0"></p>
                                        </div>

                                        <div class="col-md-3">
                                            <label class="form-label fw-bold">Fecha de Nacimiento</label>
                                            <p id="pFechaNacimiento" class="mb-0"></p>
                                        </div>
                                        <div class="col-md-3">
                                            <label class="form-label fw-bold">Sexo</label>
                                            <p id="pSexo" class="mb-0"></p>
                                        </div>
                                        <div class="col-md-3">
                                            <label class="form-label fw-bold">DPI</label>
                                            <p id="pDpi" class="mb-0"></p>
                                        </div>
                                        <div class="col-md-3">
                                            <label class="form-label fw-bold">Correo</label>
                                            <p id="pCorreo" class="mb-0"></p>
                                            <input id="pCode" class="mb-0" style="display:none;">
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- ACADÉMICA -->
                        <div class="tab-pane fade" id="info-academica" role="tabpanel">
                            <div class="card border-0 shadow-sm">
                                <div class="card-header bg-primary text-white fw-semibold">
                                    <i class="bi bi-mortarboard"></i> Formación Académica
                                </div>
                                <div class="card-body">
                                    <table class="table table-striped table-bordered table-sm text-center">
                                        <thead class="table-success">
                                            <tr>
                                                <th>#</th>
                                                <th>Nivel</th>
                                                <th>Grado</th>
                                                <th>Establecimiento</th>
                                                <th>Año</th>
                                            </tr>
                                        </thead>
                                        <tbody id="tbodyAcademico">
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>

                        <!-- LABORAL -->
                        <div class="tab-pane fade" id="info-laboral" role="tabpanel">
                            <div class="card border-0 shadow-sm">
                                <div class="card-header bg-primary text-white fw-semibold">
                                    <i class="bi bi-briefcase"></i> Experiencia Laboral
                                </div>
                                <div class="card-body">
                                    <ul id="containerLaboral" class="list-group list-group-flush">
                                    </ul>
                                </div>
                            </div>
                        </div>

                        <!-- CV DIGITALIZADO -->
                        <div class="tab-pane fade" id="info-cv" role="tabpanel">
                            <div class="row">
                                <!-- Panel izquierdo: listado de documentos -->
                                <div class="col-md-3">
                                    <div class="card shadow-sm border-0">
                                        <div class="card-header bg-light fw-bold">
                                            <i class="bi bi-folder2-open me-2 text-primary"></i> Documentos
                                        </div>

                                        <div class="card-body p-3">
                                            @if (!string.IsNullOrEmpty(Model.Documentos[0].ErrorMessage))
                                            {
                                                <div class="alert alert-danger d-flex align-items-center" role="alert">
                                                    <i class="bi bi-exclamation-octagon-fill me-2 fs-5"></i>
                                                    <div>
                                                        <strong>Error:</strong> @Model.Documentos[0].ErrorMessage.
                                                    </div>
                                                </div>
                                            }
                                            @*<div class="mb-3">
                                                        <input type="text" id="buscarDocumentos" class="form-control" placeholder="Buscar Documentos" />
                                                </div>*@
                                            <div id="listaDocumentos" class="list-group overflow-auto" style="max-height: 2000px;">
                                                <!-- Ejemplo de items -->
                                                @foreach (var Documentos in Model.Documentos)
                                                {
                                                    <a href="#" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center" onclick="seleccionarDocumento(this,@(Documentos.DocEntry),'@(Documentos.Extension)','@(Documentos.Descripcion)')">
                                                        <div>
                                                            <div class="fw-bold">@Documentos.Nombre</div>
                                                            @*<small class="text-primary"><i class="bi bi-clock me-1"></i> Vigente</small>*@
                                                        </div>
                                                        <i id="Icono-@(Documentos.DocEntry)" class="bi bi-x-lg text-danger fs-5"></i>
                                                    </a>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-md-9">
                                    <div class="card shadow-sm border-0 h-100">
                                        <div class="card-body d-flex align-items-center justify-content-center bg-light">
                                            <h5 class="text-muted d-flex align-items-center" id="mensajePrincipal">
                                                <i class="bi bi-info-circle me-2"></i>
                                                Seleccione un registro del listado para cargar o visualizar sus documentos.
                                            </h5>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <!-- COMENTARIOS DEL RECLUTADOR -->
                        <div class="tab-pane fade" id="info-comentarios" role="tabpanel">
                            <div class="card border-0 shadow-sm">
                                <div class="card-header bg-secondary text-white fw-semibold">
                                    <i class="bi bi-chat-dots-fill"></i> Comentarios del Reclutador
                                </div>

                                <div class="card-body">

                                    <!-- Campo para agregar comentario -->
                                    <div class="mb-3">
                                        <label class="form-label fw-bold">Agregar comentario</label>
                                        <textarea id="txtNuevoComentario" class="form-control" rows="3"
                                                  placeholder="Escribe un comentario sobre el proceso..."></textarea>
                                    </div>

                                    <button class="btn btn-primary mb-4" id="btnAgregarComentario">
                                        <i class="bi bi-plus-circle"></i> Agregar Comentario
                                    </button>

                                    <hr>

                                    <!-- Listado de comentarios -->
                                    <h6 class="fw-bold mb-3"><i class="bi bi-list-ul"></i> Historial de comentarios</h6>

                                    <ul class="list-group" id="listaComentarios">
                                        <!-- Aquí se insertarán dinámicamente -->
                                        <li class="list-group-item">
                                            <div class="d-flex justify-content-between">

                                                <!-- Información del comentario -->
                                                @*<div>
                                                        <i class="bi bi-chat-left-text"></i> Comentario 1
                                                        <br>
                                                        <small class="text-muted">
                                                            05-05-2025 — <strong>por Juan Pérez</strong>
                                                        </small>
                                                    </div>*@

                                                <!-- Botón eliminar -->
                                                @*<button class="btn btn-sm btn-danger btnEliminarComentario">
                                                        <i class="bi bi-trash"></i>
                                                    </button>*@
                                            </div>
                                        </li>
                                    </ul>
                                </div>
                            </div>
                        </div>

                        <!-- CONFIGURACIÓN DE ALTA -->
                        <div class="tab-pane fade" id="info-config-alta" role="tabpanel">
                            <div class="card border-0 shadow-sm">
                                <<div class="card-header bg-secondary text-white fw-semibold d-flex align-items-center">

                                    <!-- Título -->
                                    <div class="fs-6">
                                        <i class="bi bi-gear-fill me-1"></i> Configuración de Alta
                                    </div>

                                    <!-- Botón a la derecha -->
                                    <button id="btnDarDeAlta" class="btn btn-success ms-auto px-4 shadow-sm rounded-pill">
                                        <i class="bi bi-person-check fs-5 me-2"></i> Dar de alta
                                    </button>

                                </div>


                                <div class="card-body">

                                    <!-- TÍTULO -->
                                    <h6 class="fw-bold mb-3 text-primary">Configuraciones obligatorias</h6>

                                    <div class="row g-3">

                                        <!-- Obligatorio 1 -->
                                        <div class="col-md-4">
                                            <div class="form-check">
                                                <input class="form-check-input" type="checkbox" id="chkEmpleado" checked disabled>
                                                <label class="form-check-label fw-semibold">
                                                    Creación de datos maestro de empleado <span class="text-danger">*</span>
                                                </label>
                                            </div>
                                        </div>

                                        <!-- Obligatorio 2 -->
                                        <div class="col-md-4">
                                            <div class="form-check">
                                                <input class="form-check-input" type="checkbox" id="chkCliente" checked disabled>
                                                <label class="form-check-label fw-semibold">
                                                    Creación de cliente <span class="text-danger">*</span>
                                                </label>
                                            </div>
                                        </div>

                                        <!-- Obligatorio 3 -->
                                        <div class="col-md-4">
                                            <div class="form-check">
                                                <input class="form-check-input" type="checkbox" id="chkProveedor" checked disabled>
                                                <label class="form-check-label fw-semibold">
                                                    Creación de proveedor <span class="text-danger">*</span>
                                                </label>
                                            </div>
                                        </div>
                                    </div>

                                    <hr class="my-4">

                                    <!-- OPCIONAL GENERAL -->
                                    <h6 class="fw-bold mb-3 text-primary">Opcionales generales</h6>

                                    <div class="row g-3">

                                        <!-- Usuario SAP -->
                                        <div class="col-md-4">
                                            <div class="form-check">
                                                <input class="form-check-input" type="checkbox" id="chkUsuarioSAP">
                                                <label class="form-check-label fw-semibold">
                                                    Crear Usuario SAP (Opcional)
                                                </label>
                                            </div>

                                            <!-- Mensaje informativo -->
                                            <small class="text-muted d-block ms-4">
                                                <i class="bi bi-info-circle"></i>
                                                Se necesitará una licencia para usar SAP.
                                            </small>
                                        </div>

                                    </div>

                                    <hr class="my-4">

                                    <!-- SECCIÓN SOLO PARA ASESORES DE VENTAS -->
                                    <h6 class="fw-bold mb-3 text-success">
                                        Solo para asesores de ventas
                                    </h6>

                                    <div class="row g-3">

                                        <!-- Usuario de ventas -->
                                        <div class="col-md-4">
                                            <div class="form-check">
                                                <input class="form-check-input" type="checkbox" id="chkUsuarioVentas">
                                                <label class="form-check-label fw-semibold">
                                                    Crear usuario de empleado de ventas (Opcional)
                                                </label>
                                            </div>
                                        </div>

                                        <!-- Usuario Tejar360 -->
                                        <div class="col-md-4">
                                            <div class="form-check">
                                                <input class="form-check-input" type="checkbox" id="chkTejar360">
                                                <label class="form-check-label fw-semibold">
                                                    Crear usuario Tejar360 (Opcional)
                                                </label>
                                            </div>
                                        </div>

                                        <!-- Tienda Asignada -->
                                        <div class="col-md-4">
                                            <label class="form-label fw-semibold">Tienda Asignada</label>
                                            <select id="selectTienda" class="form-control">
                                                <option value="">Seleccione...</option>
                                                <option value="1">Tienda Central</option>
                                                <option value="2">Tienda Norte</option>
                                                <option value="3">Tienda Sur</option>
                                                <option value="4">Tienda Oriente</option>
                                            </select>
                                        </div>

                                        <!-- Meta -->
                                        <div class="col-md-4">
                                            <div class="form-check mt-4">
                                                <input class="form-check-input" type="checkbox" id="chkMeta">
                                                <label class="form-check-label fw-semibold">
                                                    Asignación de meta (Opcional)
                                                </label>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- Footer -->
                <div class="modal-footer">
                    <button class="btn btn-secondary" data-bs-dismiss="modal">
                        <i class="bi bi-x-circle"></i> Cerrar
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal -->
    <div class="modal fade" id="modalCrearUsuario" tabindex="-1" aria-labelledby="modalCrearUsuarioLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content shadow">

                <!-- Header -->
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title" id="modalCrearUsuarioLabel">
                        <i class="bi bi-person-plus-fill"></i> Crear usuario y clave
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
