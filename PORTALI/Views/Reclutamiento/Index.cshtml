@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://code.jquery.com/ui/1.13.2/jquery-ui.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        const modelo = JSON.parse(
            document.getElementById('dataModel').dataset.model
        );

        const modalAspitantes = new bootstrap.Modal(document.getElementById("modalDetalle"));
        const modalUsuario = new bootstrap.Modal(document.getElementById("modalUsuario"));
        const modalDetalleUsuario = new bootstrap.Modal(document.getElementById("modalDetalleAspirante"));
        const modalEnviarUsuarioCorreo = new bootstrap.Modal(document.getElementById("modalCrearUsuario"));
        const modalPerfilPuesto = new bootstrap.Modal(document.getElementById('modalPerfilPuesto'));
        const modalAgregarSolicitud = new bootstrap.Modal(document.getElementById('modalAgregarSolicitud'));
        const modalProcesos = new bootstrap.Modal(document.getElementById('modalProcesos'));
        const modalIA = new bootstrap.Modal(document.getElementById('modalIA'));
        let dataAspiranteFinal = {};
        let idModal = "";

        const Toast = Swal.mixin({
            toast: true,
            position: 'top-end',
            showConfirmButton: false,
            timer: 5000,
            timerProgressBar: true
        })

        function verDetalleSolicitud(button) {

            let datosSolicitud = {
                puesto: button.getAttribute("data-Puesto"),
                puestoId: button.getAttribute("data-PuestoId"),
                departamento: button.getAttribute("data-Departamento"),
                departamentoId: button.getAttribute("data-DepartamentoId"),
                fechaSolicitud: button.getAttribute("data-FechaSolicitud"),
                solicita: button.getAttribute("data-Solicita"),
                solicitaId: button.getAttribute("data-SolicitaId"),
                solicitud: button.getAttribute("data-Solicitud"),
                finalizada: button.getAttribute("data-finalizada"),
                Observaciones: button.getAttribute("data-Observaciones")
            }

            /*let informacionGeneral = `*/


            // Datos visibles
            document.getElementById("detallePuesto").innerText = datosSolicitud.puesto;
            document.getElementById("departamento").innerText = datosSolicitud.departamento;
            document.getElementById("fechaSolicitud").innerText = datosSolicitud.fechaSolicitud;
            document.getElementById("solicitadoPor").innerText = datosSolicitud.solicita;

            // Datos ocultos (IDs)
            document.getElementById("idSolicitud").innerText = datosSolicitud.solicitud;
            document.getElementById("idPuesto").innerText = datosSolicitud.puestoId;
            document.getElementById("idDepartamento").innerText = datosSolicitud.departamentoId;
            document.getElementById("idSolicita").innerText = datosSolicitud.solicitaId;

            // Observaciones (textarea)
            document.getElementById("txtObservaciones").value =
                datosSolicitud.Observaciones ?? '';

            ObtenerDatosAspirantes(datosSolicitud.finalizada);

            if (datosSolicitud.finalizada === "1") {
                document.getElementById("btnCrearUsuarioClave").classList.add("d-none");
                document.getElementById("cajaAgregarComentario").classList.add("d-none");
                document.getElementById("contenedorConfiguracionAlta").classList.add("d-none");
            }
            else {
                document.getElementById("btnCrearUsuarioClave").classList.remove("d-none");
                document.getElementById("cajaAgregarComentario").classList.remove("d-none");
                document.getElementById("contenedorConfiguracionAlta").classList.remove("d-none");
            }
        }

        function abrirModalCrarUsuario() {
            modalEnviarUsuarioCorreo.show();
        }

        async function crearUsuarioClave() {
            let puesto = document.getElementById("detallePuesto").textContent;
            let solicitud = document.getElementById("idSolicitud").textContent;
            let user = generarUsuario(puesto);
            let correlativo = await verCodigoSiguiente(user);
            numero = correlativo.toString().padStart(2, '0');

            let userEnd = user + correlativo;

            CrearUsuario(userEnd, solicitud);
        }

        function generarUsuario(puesto) {
            puesto = puesto.toUpperCase();

            let partes = puesto.split(' ');
            let codigo = partes.map(p => p[0]).join('');
            let ultimaPalabra = partes[partes.length - 1];
            codigo += ultimaPalabra.substring(0, 2);
            return codigo;
        }

        async function verCodigoSiguiente(idUsuario) {

            const response = await fetch(`/Reclutamiento/ObtenerCodigoSiguiente?userId=${idUsuario}`,
                {
                    method: "GET"
                });

            const reply = await response.json();

            return reply;
        }

        async function CrearUsuario(usuario, IdSolicitud) {
            try {
                const nombreAspirante = document.getElementById('nombreAspirante').value;
                const correoAspirante = document.getElementById('correoAspirante').value;
                const form = document.getElementById('formCrearUsuario');

                if (form.checkValidity()) {
                    $("#globalLoading").show();

                    const formData = new FormData();
                    formData.append("usuario", usuario);
                    formData.append("idSolicitudAlta", IdSolicitud);
                    formData.append("nombreAspirante", nombreAspirante);
                    formData.append("correoAspirante", correoAspirante);

                    const response = await fetch('/Reclutamiento/CrearUsuarioLanding', {
                        method: "POST",
                        body: formData
                    })

                    const reply = await response.json();

                    if (reply.success) {
                        modalAspitantes.hide();
                        modalEnviarUsuarioCorreo.hide();
                        $("#globalLoading").hide();
                        Toast.fire({ icon: 'success', title: reply.message });
                    } else {
                        Toast.fire({ icon: 'warning', title: reply.message });
                    }
                }
                else {
                    $("#globalLoading").hide();
                    Toast.fire({ icon: 'warning', title: "Todos los campos son obligatorios" });
                }
            } catch {
                $("#globalLoading").hide();
                Toast.fire({ icon: 'error', title: "Ocurrio un error inesperado, comunicarse al area de Desarrollo El Tejar" });
            }
            finally {
                $("#globalLoading").hide();
            }
        }

        async function ObtenerDatosAspirantes(finalizada = 0) {

            const idSolicitud = document.getElementById("idSolicitud").textContent
            console.log("Solicitud : ", idSolicitud)

            const response = await fetch(`/Reclutamiento/ObtenerDetalleAspirantes?userName=${idSolicitud}`, {
                method: "GET"
            })

            const reply = await response.json();
            console.log(reply);
            let tbody = '';

            if (reply.success) {

                reply.data.forEach(item => {
                    tbody += `
<tr ${item.EmpIdSAP != 0 ? `class="fila-verde"` : ``}>
        <th>${item.Rw}</th>
        <th>${item.UserName}</th>
        <th>${item.NombreAspirante}</th>
        <th id="e${item.Rw}">${item.Correo}</th>
        <th>${convertirFechaDotNet(item.Created)}</th>
        <th>${item.Estado}</th>

        <!-- NOTA IA -->
        <th>
            <span class="badge
                ${item.NotaIA >= 80 ? 'bg-success' : item.NotaIA >= 60 ? 'bg-warning text-dark' : 'bg-danger'}">
                ${item.NotaIA}
            </span>
        </th>

        <!-- CUMPLE -->
        <th>
            <span class="fw-semibold
                ${item.Cumple ? 'text-success' : 'text-danger'}">
                <i class="bi ${item.Cumple ? 'bi-check-circle-fill' : 'bi-x-circle-fill'} me-1"></i>

            </span>
        </th>

        <!-- ACCIONES -->
        <th>
            ${finalizada == 0
                            ? `
                <button class="btn btn-outline-primary btn-sm"
                        data-bs-toggle="tooltip"
                        title="Usuario"
                        onclick="verPerfilUsuario('${item.UserName}','${item.Correo}','e${item.Rw}')">
                    <i class="bi bi-person-fill"></i>
                </button>
                `
                            : ``
                        }

            <button class="btn btn-outline-primary btn-sm"
                    data-bs-toggle="tooltip"
                    title="CV"
                    onclick="verDetalleAspirante('${item.UserName}','${item.EmpIdSAP}')">
                <i class="bi bi-file-earmark-text"></i>
            </button>

            <!-- BOTÓN IA -->
            <button class="btn btn-outline-dark btn-sm"
                    data-bs-toggle="tooltip"
                    title="Análisis IA"
                    onclick="verAnalisisIA('${item.UserId}', ${item.SolicitudBaja})">
                <i class="bi bi-robot"></i>
            </button>
        </th>
</tr>
`;

                });

            }
            else {
                tbody += `<tr>
                                                                                                            <th colspan = "7">No se encontraron datos</th>
                                                                                                         </tr>
                                                                                                                    `;
            }
            document.getElementById("tbodyAspirantes").innerHTML = tbody;
        }

        async function verPerfilUsuario(userName, correo, id) {
            const input = document.getElementById("passwordModal");
            const icon = document.getElementById("btnEditar");
            idModal = id;

            document.getElementById("loadingGuardar").classList.add("d-none");
            icon.classList.remove("bi-floppy-fill");
            icon.classList.add("bi-pencil-fill");
            icon.classList.remove("d-none");

            const correoInput = document.getElementById("emailModal");

            correoInput.disabled = true;
            input.type = "password";

            const response = await fetch(`/Reclutamiento/VerClaveUsuario?userName=${userName}`)
            const reply = await response.json();

            if (reply.success) {
                document.getElementById("usuarioModal").value = userName;
                correoInput.value = document.getElementById(idModal).innerText;
                correoInput.disabled = true;
                passwordModal.value = reply.clave;
                modalUsuario.show();
            }
            else {
                Toast.fire({ icon: 'warning', title: "No se pudieron cargar los datos del usuario" });
            }
        }

        async function verDetalleAspirante(userName, empId = 0) {
            limpiarDatos();
            const response = await fetch(`/Reclutamiento/ObtenerDatosPersonales?userName=${userName}`);
            const result = await response.json();
            $("#globalLoading").show();
            if (result.success) {
                await cargarDatosAspirante(result.data, userName, empId);
                dataAspiranteFinal = result.data.DatosPersonalesVM;
                modalDetalleUsuario.show();
            }
            else {
                Toast.fire({ icon: 'warning', title: "No se encontraron datos" });
                mostrarComentarios();
            }
        }

        document.getElementById("btnVerPassword").addEventListener("click", () => {
            const input = document.getElementById("passwordModal");
            const icon = document.getElementById("iconoBtnVerUsuario");

            if (input.type === "password") {
                input.type = "text";
                icon.classList.remove("bi-eye-fill");
                icon.classList.add("bi-eye-slash-fill");
            } else {
                input.type = "password";
                icon.classList.remove("bi-eye-slash-fill");
                icon.classList.add("bi-eye-fill");
            }
        });

        document.getElementById("btnEditarCorreo").addEventListener("click", async () => {
            const input = document.getElementById("emailModal");
            const inputUsuario = document.getElementById("usuarioModal");
            const icon = document.getElementById("btnEditar");
