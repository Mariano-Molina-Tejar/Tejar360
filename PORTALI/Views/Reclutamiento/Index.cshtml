        async function creacionDeAspirante(dataAspiranteFinal, idPuesto, idDepartamento, idSolicita) {
            let response = await fetch('/Reclutamiento/DarDeAltaAAspirante',
                {
                    method: "POST",
                    body: JSON.stringify(
                        {
                            datosPersonales: dataAspiranteFinal,
                            puestoId: idPuesto,
                            departamentoId: idDepartamento,
                            solicitaId: idSolicita
                        }),
                    headers: { "Content-Type": "application/json" }
                }
            )

            let result = await response.json();

            if (result.success) {
                document.getElementById("step1-icon").innerHTML = `<i class="bi bi-check-circle-fill text-success fs-5"></i>`;
                return result.empId;

            }
            else {
                document.getElementById("step1-icon").innerHTML = `<i class="bi bi-x-circle-fill text-danger fs-5"></i> `;
                return "";
            }
        }

        async function creacionDeProveedor(proveedor, dataAspiranteFinal, empleadoId) {
            response = await fetch('/Reclutamiento/CrearProveedor',
                {
                    method: "POST",
                    body: JSON.stringify(
                        {
                            proveedor: proveedor,
                            datosPersonales: dataAspiranteFinal,
                            empId: empleadoId
                        }
                    ),
                    headers: { "Content-Type": "application/json" }
                }
            );

            result = await response.json();

            if (result.success) {
                document.getElementById("step2-icon").innerHTML = `<i class="bi bi-check-circle-fill text-success fs-5"></i>`;
                return result.proveedor;
            }
            else {
                document.getElementById("step2-icon").innerHTML = `<i class="bi bi-x-circle-fill text-danger fs-5"></i> `;
                return "";
            }
        }

