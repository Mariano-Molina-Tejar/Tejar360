@model IEnumerable<Entity.ReclutemientoEntity>
@{
    ViewBag.Title = "Reclutamiento";
}

<!-- Bootstrap 5.3.3 -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<!-- Bootstrap Icons -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">

<div class="container mt-4">
    <div class="card shadow-sm border-0">
        <div class="card-header text-white" style="background-color:black;">
            <h5 class="mb-0"><i class="bi bi-file-earmark-person-fill"></i> Solicitudes de Alta de personal</h5>
        </div>

        <div class="card-body bg-light">
            <table class="table table-hover align-middle text-center">
                <thead class="table-warning">
                    <tr>
                        <th>#</th>
                        <th>Fecha Solicitud</th>
                        <th>Puesto</th>
                        <th>Departamento</th>
                        <th>Solicita</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var puesto in Model)
                    {
                        <tr>
                            <td>@puesto.SolicitudDeBaja</td>
                            <td>@puesto.FechaSolicitud.ToString("dd/MM/yyyy")</td>
                            <td>@puesto.Puesto</td>
                            <td>@puesto.Departamento</td>
                            <td>@puesto.Solicita</td>
                            <td>
                                <button class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#modalDetalle"
                                        data-Puesto="@puesto.Puesto"
                                        data-Departamento="@puesto.Departamento"
                                        data-FechaSolicitud="@puesto.FechaSolicitud.ToString("dd/MM/yyyy")"
                                        data-Solicita="@puesto.Solicita"
                                        onclick="verDetalleSolicitud(this)">
                                    <i class="bi bi-eye-fill"></i> Detalle
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Modal Detalle -->
<div class="modal fade" id="modalDetalle" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header text-white" style="background-color:steelblue;">
                <h5 class="modal-title"><i class="bi bi-info-circle-fill"></i> Detalle de Solicitud</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body bg-light">
                <div id="solicitud-InformacionGeneral" class="mb-3">
                    <h6 class="fw-bold text-secondary">Información del Puesto</h6>
                    <p><strong>Puesto:</strong> <span id="detallePuesto">JEFE DE INVENTARIOS</span></p>
                    <p><strong>Departamento:</strong> GENERAL</p>
                    <p><strong>Fecha de Solicitud:</strong> 2025-11-11</p>
                    <p><strong>Solicitado por:</strong> Manuel de Jesús Lemus Peña</p>
                </div>

                <hr>

                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h6 class="fw-bold text-secondary mb-0">Aspirantes al puesto</h6>
                    <button id="btnCrearUsuarioClave" class="btn btn-warning btn-sm text-dark fw-semibold">
                        <i class="bi bi-person-plus-fill"></i> Generar Usuario y Contraseña
                    </button>
                </div>

                <table class="table table-striped table-bordered table-sm text-center">
                    <thead class="table-warning">
                        <tr>
                            <th>#</th>
                            <th>Nombre Aspirante</th>
                            <th>Correo</th>
                            <th>Estado</th>
                            <th>Acción</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>1</td>
                            <td>María López García</td>
                            <td>maria.lopez@eltejar.com</td>
                            <td><span class="badge bg-success">Ficha completa</span></td>
                            <td>
                                <button class="btn btn-outline-primary btn-sm">
                                    <i class="bi bi-person-badge-fill"></i> Ver CV
                                </button>
                            </td>
                        </tr>
                        <tr>
                            <td>2</td>
                            <td>Carlos Méndez Ortiz</td>
                            <td>carlos.mendez@eltejar.com</td>
                            <td><span class="badge bg-warning text-dark">Pendiente</span></td>
                            <td>
                                <button class="btn btn-outline-secondary btn-sm">
                                    <i class="bi bi-hourglass-split"></i> En proceso
                                </button>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="bi bi-x-circle"></i> Cerrar
                </button>
            </div>
        </div>
    </div>
</div>
<script>
    function verDetalleSolicitud(button) {

        const datosSolicitud =  {
            puesto: button.getAttribute("data-Puesto"),
            departamento: button.getAttribute("data-Departamento"),
            fechaSolicitud: button.getAttribute("data-FechaSolicitud"),
            solicita: button.getAttribute("data-Solicita")
        }

        let informacionGeneral = `<h6 class="fw-bold text-secondary">Información del Puesto</h6>
                                <p><strong>Puesto:</strong> <span id="detallePuesto"> ${datosSolicitud.puesto}</span></p>
                                <p><strong>Departamento:</strong> ${datosSolicitud.departamento}</p>
                                <p><strong>Fecha de Solicitud:</strong> ${datosSolicitud.fechaSolicitud}</p>    
                                <p><strong>Solicitado por:</strong> ${datosSolicitud.solicita}</p>`
        ;

        document.getElementById('solicitud-InformacionGeneral').innerHTML = informacionGeneral;
    }

    function crearUsuarioClave() {

        let puesto = document.getElementById("detallePuesto").textContent;
        alert(generarUsuario(puesto, 1));
    }
    function generarUsuario(puesto, correlativo) {
        puesto = puesto.toUpperCase();

        let partes = puesto.split(' ');
        let codigo = partes.map(p => p[0]).join('');
        let ultimaPalabra = partes[partes.length - 1];
        codigo += ultimaPalabra.substring(0, 2);
        let numero = correlativo.toString().padStart(2, '0');
        return codigo + numero;
    }
    document.getElementById('btnCrearUsuarioClave').addEventListener('click', () => crearUsuarioClave());

</script>