        function convertirFechaDotNet(fechaDotNet) {
            if (!fechaDotNet) return "";

            const match = /\/Date\((\d+)\)\//.exec(fechaDotNet);
            if (!match) return "";

            // Convierte los milisegundos a fecha
            const fecha = new Date(parseInt(match[1]));

            // Formatea en dd/MM/yyyy
            const dia = fecha.getDate().toString().padStart(2, '0');
            const mes = (fecha.getMonth() + 1).toString().padStart(2, '0');
            const anio = fecha.getFullYear();

            return `${dia}/${mes}/${anio}`;
        }

        document.addEventListener("click", function (e) {
            if (e.target.closest(".toggle-detalle")) {
                const btn = e.target.closest(".toggle-detalle");
                const detalle = btn.closest("li").querySelector(".detalle-laboral");
                const icon = btn.querySelector("i");

                // Alternar visibilidad
                const visible = detalle.style.display === "block";
                detalle.style.display = visible ? "none" : "block";

                // Cambiar ícono
                icon.classList.toggle("bi-plus-lg", visible);
                icon.classList.toggle("bi-dash-lg", !visible);
            }
        });

        function seleccionarDocumento(element, tipo, extencion, descripcion) {
            $("#globalLoading").show();
            document.querySelectorAll("#listaDocumentos a").forEach(a => a.classList.remove("active"));
            // Marcar seleccionado
            element.classList.add("active");

            // Mostrar contenido del documento seleccionado
            const nombre = element.querySelector(".fw-bold").innerText;

            $("#mensajePrincipal").load(`/Reclutamiento/CargarVistaParcial?nombreDocumento=${encodeURIComponent(nombre)}&tipo=${encodeURIComponent(tipo)}&extencion=${encodeURIComponent(extencion)}&descripcion=${encodeURI(descripcion)}`);
            $("#globalLoading").hide();
        }

        function CambiarIconoDocumentos() {

            let userCode = document.getElementById("pCode").value;

            let Direccion = `/Reclutamiento/ExistenciaDocumentos`;
            $.ajax({
                url: Direccion,
                type: "POST",
                data: { Documentos: modelo , idUser : userCode },
                success: (data) => {
                    if (data.Response === 1) {
                        $.each(data.Objet, (index, item) => {
                            if (item.Existe === 1) {
                                $(`#Icono-${item.DocEntry}`).removeClass();
                                $(`#Icono-${item.DocEntry}`).addClass("bi bi-check-lg text-success fs-5");
                            } else {
                                $(`#Icono-${item.DocEntry}`).removeClass();
                                $(`#Icono-${item.DocEntry}`).addClass("bi bi-x-lg text-danger fs-5");
                            }
                        });
                    } else {

                    }

                },
                error: (error) => { },
                complete: () => {  }
            });
        }

        async function reenviaCorreo() {
            const _usuario = document.getElementById('usuarioModal').value;
            const formData = new FormData();
            formData.append("usuario", _usuario);

            $("#globalLoading").show();
            try {
                const response = await fetch('/Reclutamiento/ReenviarCorreoAspirante', {
                    method: "POST",
                    body: formData
                })

                const result = await response.json();

                if (result.success) {
                    Toast.fire({ icon: 'success', title: result.message });
                }
                else {
                    Toast.fire({ icon: 'warning', title: result.message });
                }
            }
            catch (error) {
                console.log(error)
                Toast.fire({ icon: 'error', title: "Ocurrio un error inesperado al re-enviar el correo" });
            }
            finally {
                $("#globalLoading").hide();
            }
        }

        async function agregarComentario() {

            try {

                $('#globalLoading').show();
                const code = document.getElementById('pCode').value;
                const comentario = document.getElementById('txtNuevoComentario').value;

                if (comentario === "") {
                    Toast.fire({ icon: 'warning', title: "No has escrito ningun comentario" });
                    return
                }

                const data = new FormData();
                data.append("code", code);
                data.append("comentario", comentario);

                const response = await fetch('/Reclutamiento/AgregarComentario', {
                    method: "POST",
                    body: data
                });

                const result = await response.json();

                if (result.success) {
                    Toast.fire({ icon: 'success', title: "El comentario se agrego con exito" });
                    document.getElementById('txtNuevoComentario').value = "";
                    mostrarComentarios();
                }
                else {
                    Toast.fire({ icon: 'error', title: "Ocurrio un error al guardar el comentario" });
                }
            }
            finally {
                $('#globalLoading').hide();
            }

        }

        async function mostrarComentarios() {
            const code = document.getElementById('pCode').value;
            const contenedorComentarios = document.getElementById("listaComentarios");
            const response = await fetch(`/Reclutamiento/ObtenerComentariosAspirantes?usuario=${code}`)
            const result = await response.json();
            let li = "";
            contenedorComentarios.innerHTML = "";

            if (result.success) {
                result.data.forEach(item => {
                    li += ` <li class="list-group-item">
                                <div class="d-flex align-items-start justify-content-between">

                                    <div>
                                        <p class="mb-1">
                                            <i class="bi bi-chat-left-quote text-primary"></i>
                                            <strong>${item.ComentarioPor}</strong> comentó:
                                        </p>

                                        <div class="ps-4 text-secondary">
                                            ${item.Comentario}
                                        </div>

                                        <small class="text-muted ps-4">
                                            <i class="bi bi-calendar"></i> ${convertirFechaDotNet(item.Fecha)}
                                        </small>
                                    </div>

                                    <!-- Botón eliminar -->
                                    @*<button class="btn btn-sm btn-outline-danger btnEliminarComentario">
                                        <i class="bi bi-trash"></i>
                                    </button>*@
                                </div>
                            </li>
                        `;

                });

            } else {
                li += `<li class="list-group-item text-center text-muted">
                            <i class="bi bi-inbox"></i> No hay comentarios registrados
                        </li>
                       `;
            }
            contenedorComentarios.innerHTML = li;
            $("#globalLoading").hide();
        }

