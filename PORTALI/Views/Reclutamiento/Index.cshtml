        async function GenerarAnalisisConIA() {

            try {

                Swal.fire({
                    title: 'Análisis inteligente en progreso',
                    text: 'La inteligencia artificial está evaluando la información...',
                    allowOutsideClick: false,
                    allowEscapeKey: false,
                    didOpen: () => {
                        Swal.showLoading();
                    }
                });

                const data = new FormData();
                data.append("idSolicitud", document.getElementById("idSolicitud").textContent)
                data.append("idPuesto", document.getElementById("idPuesto").textContent)

                const response = await fetch('/Reclutamiento/ObtenerAnalisisMixtral',
                    {
                        method: "POST",
                        body: data
                    });

                const result = await response.json();

                if (result.success) {
                    Toast.fire({ icon: 'success', title: "Data generada con éxito" });

                }
                else {
                    Toast.fire({ icon: 'error', title: "Ocurrio un error al crear la solicitud" });
                }

            }
            catch {
                Toast.fire({ icon: "error", title: "Ha ocurrio un error al consultar la IA" })
            }
            finally {
                Swal.close();
            }
        }
        async function verAnalisisIA(userId, SolicitudId) {

            console.log(userId, SolicitudId);

            const response = await fetch(`/Reclutamiento/obtenerAnalisisIA?userId=${userId}`);
            const result = await response.json();

            console.log(result);

            if (!result.success || !Array.isArray(result.data)) {
                console.error("Respuesta IA inválida");
                return;
            }

            const fortalezasSet = new Set();
            const debilidadesSet = new Set();
            let observacionGeneral = "";

            console.log(result);
            result.data.forEach((item, index) => {

                
                if (item.Tipo === 1 && item.Observaciones) {
                    fortalezasSet.add(item.Observaciones);
                }

                // Debilidades
                if (item.Tipo === 0 && item.Observaciones) {
                    debilidadesSet.add(item.Observaciones);
                }

                // Observación general (solo una vez)
                if (index === 0 && item.ObservacionesGenerales) {
                    observacionGeneral = item.ObservacionesGenerales;
                }
            });

            // Fallback si no viene observación general
            if (!observacionGeneral) {
                observacionGeneral = "El análisis fue generado por IA en base al perfil del aspirante y el puesto evaluado.";
            }

            // Referencias DOM
            const f = document.getElementById("iaFortalezas");
            const d = document.getElementById("iaDebilidades");
            const o = document.getElementById("iaObservacion");

            f.innerHTML = "";
            d.innerHTML = "";

            // Pintar fortalezas
            if (fortalezasSet.size === 0) {
                f.innerHTML = `<li>No se identificaron fortalezas relevantes.</li>`;
            } else {
                fortalezasSet.forEach(x => f.innerHTML += `<li>${x}</li>`);
            }

            // Pintar debilidades
            if (debilidadesSet.size === 0) {
                d.innerHTML = `<li>No se identificaron debilidades relevantes.</li>`;
            } else {
                debilidadesSet.forEach(x => d.innerHTML += `<li>${x}</li>`);
            }

            // Observación
            o.innerText = observacionGeneral;

            // Mostrar modal (Bootstrap)
            const modal = new bootstrap.Modal(document.getElementById("modalIA"));
            modal.show();
        }


