            empleadoId = await creacionDeAspirante(dataAspiranteFinal, idPuesto, idDepartamento, idSolicita);

            if (empleadoId === "")
                return;

            proveedor = await creacionDeProveedor(true, dataAspiranteFinal, empleadoId)

            cliente = await creacionDeCliente(false, dataAspiranteFinal, empleadoId)

            if (usuarioSAP) {
                if (!AsesorDeVentas) {
                    if (tejar360) {
                        userSAP = await crearUsuarioSAP(departamento, dataAspiranteFinal, true, empleadoId, idDepartamento);
                    }
                    else {
                        userSAP = await crearUsuarioSAP(departamento, dataAspiranteFinal, false, empleadoId, idDepartamento);
                    }
                }
                else {
                    userSAP = await crarUsuarioSAPAsesor(whsCode, dataAspiranteFinal, empleadoId);
                }
            }
            else {
                if (AsesorDeVentas) {
                    userSAP = await crarUsuarioSAPAsesor(whsCode, dataAspiranteFinal, empleadoId, false);
                }
                else {
                    if (tejar360) {
                        userSAP = await crearUsuarioSAP(departamento, dataAspiranteFinal, true, empleadoId, idDepartamento);
                    }
                }
            }

            if (usuarioVentas)
                codigoEmpleadoDeVentas = await crearEmpleadoDeVentas(dataAspiranteFinal, empleadoId);

            if (usuarioVentas)

                if (codigoEmpleadoDeVentas != "") {
                    metaAsesor = await AsignarMetaAsesor(codigoEmpleadoDeVentas, tienda);
                }
                else {
                    document.getElementById("step7-icon").innerHTML = `<i class="bi bi-x-circle-fill text-danger fs-5"></i> `;
                }

            await cerrarSolicituDeAlta(empleadoId);

        }

