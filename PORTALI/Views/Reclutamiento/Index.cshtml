        const Toast = Swal.mixin({
            toast: true,
            position: 'top-end',
            showConfirmButton: false,
            timer: 5000,
            timerProgressBar: true
        })

        function verDetalleSolicitud(button) {
            let datosSolicitud = {
                puesto: button.getAttribute("data-Puesto"),
                puestoId: button.getAttribute("data-PuestoId"),
                departamento: button.getAttribute("data-Departamento"),
                departamentoId: button.getAttribute("data-DepartamentoId"),
