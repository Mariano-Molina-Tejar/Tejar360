<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    const Toast = Swal.mixin({
        toast: true,
        position: 'top-end',
        showConfirmButton: false,
        timer: 2000,
        timerProgressBar: true
    });

    function EnviarCorreo() {
        let reporte = document.getElementById("ReporteGeneral").outerHTML;
        $("#globalLoading").show();
    $.ajax({
        url: '@Url.Action("SendMail", "VentasEmpresa")', // genera la URL correcta
        type: "POST",
        data: { Body: reporte }, // debe coincidir con el parámetro de tu acción
        success: function (resp) {
            if (resp.success) {
                $("#globalLoading").hide();
                Toast.fire({ icon: 'success', title: "Correo enviado con exito" });
            } else {
                $("#globalLoading").hide();
                Toast.fire({ icon: 'warning', title: resp.mensaje });
            }
        },
        error: function (xhr, status, error) {
            $("#globalLoading").hide();
            Toast.fire({ icon: 'error', title: xhr.responseText });
        }

    });
}


</script>
