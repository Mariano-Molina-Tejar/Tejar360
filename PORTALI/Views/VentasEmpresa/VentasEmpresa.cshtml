<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reporte de Ventas y Utilidades por Sucursal</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" rel="stylesheet">
    <style>
        body {
            background-color: #f8f9fa;
        }

        h1 {
            text-align: center;
            margin-bottom: 2rem;
        }

        .table thead {
            background-color: #000;
            color: #fff;
        }

        .btn-update {
            margin-bottom: 1rem;
        }

        .location-title {
            background-color: #343a40;
            color: white;
            font-weight: bold;
        }

        .total-row {
            background-color: #d1ecf1;
            font-weight: bold;
        }
    </style>
</head>
<body>
    <div class="container-fluid">
        <h1 class="text-center my-4" style="font-weight: bold; font-size: 2rem; color: #343a40; border-bottom: 3px solid #007bff; display: inline-block; padding-bottom: 10px;">
            📊 Reporte de Ventas y Utilidad por Sucursal
        </h1>

        <div class="row g-2 mb-3">
            <div class="col-auto">
                <div class="d-flex align-items-center">
                    <input type="date" id="FechaI" class="form-control form-control-sm shadow-sm border-secondary" />
                </div>
            </div>
            <div class="col-auto">
                <div class="d-flex align-items-center">
                    <input type="date" id="FechaF" class="form-control form-control-sm shadow-sm border-secondary" />
                </div>
            </div>
            <div class="col-auto">
                <div class="d-flex align-items-center" style="height: 100%;">
                    <button class="btn btn-sm btn-dark shadow-sm btn-update" id="btnBuscar">
                        <i class="fas fa-sync-alt me-1"></i> Actualizar Datos
                    </button>
                </div>
            </div>
        </div>

        <!-- Tabla agrupada por Location -->
        <div class="table-responsive" style="margin-bottom:30px">
            <table class="table table-bordered table-hover" id="tablaVentas">
                <thead class="text-center" style="background-color: black; color: white;">
                    <tr>
                        <th rowspan="2" class="align-middle">Tienda</th>
                        <th colspan="5">Venta</th>
                        <th colspan="4">Utilidad</th>
                        <th colspan="3">Diario</th>
                    </tr>
                    <tr>
                        <th>Meta</th>
                        <th>Venta</th>
                        <th>Promedio diario</th>
                        <th>Proyeccion</th>
                        <th>Meta Venta %</th>
                        <th>Utilidad</th>
                        <th>Promedio diario</th>
                        <th>Proyeccion</th>
                        <th>Margen</th>
                        <th>Venta</th>
                        <th>Utilidad</th>
                        <th>Margen</th>
                    </tr>
                </thead>

                <tbody class="text-center" id="tbodyVentas"></tbody>
            </table>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

<script>
    $(document).ready(function () {
        const today = new Date();

        // Fecha inicial: primer día del mes actual
        const firstDay = new Date(today.getFullYear(), today.getMonth(), 1);

        // Fecha final: último día del mes actual
        const lastDay = new Date(today.getFullYear(), today.getMonth() + 1, 0);

        // Función para formatear la fecha en formato yyyy-mm-dd
        function formatDate(date) {
            const year = date.getFullYear();
            const month = String(date.getMonth() + 1).padStart(2, '0');
            const day = String(date.getDate()).padStart(2, '0');
            return `${year}-${month}-${day}`;
        }

        // Asignar a los inputs
        $('#FechaI').val(formatDate(firstDay));
        $('#FechaF').val(formatDate(lastDay));

        CargarData();
        $('.btn-expandir').first().click();
        setTimeout(function () {
            $('.btn-expandir').first().click(); // Expande el primer panel después de cargar la data
        }, 600); // Pequeño retraso para asegurar que los datos estén listos
    });

    function formatoQuetzal(valor) {
        return new Intl.NumberFormat('es-GT', {
            style: 'currency',
            currency: 'GTQ',
            minimumFractionDigits: 2
        }).format(valor);
    }

    $('#btnBuscar').click(function () {
        CargarData();
        $('.btn-expandir').first().click();
        setTimeout(function () {
            $('.btn-expandir').first().click(); // Expande el primer panel después de cargar la data
        }, 600); // Pequeño retraso para asegurar que los datos estén listos
    });

    function CargarData() {
        var fechaI = $('#FechaI').val();
        var fechaF = $('#FechaF').val();
        $("#globalLoading").show();

        $.ajax({
            url: '@Url.Action("CargarData", "VentasEmpresa")',
            type: 'POST',
            data: { FechaI: fechaI, FechaF: fechaF },
            success: function (response) {
                console.log(response.data);
                $("#globalLoading").hide();
                if (response.success)
                {
                    let data = response.data;
                    let html = '';
                    let Nivel = 0;

                    let grupos = {};
                    let totalGeneral = {
                        V_Meta: 0, V_Venta: 0, V_Proyeccion: 0,
                        U_Utilidad: 0, U_Proyeccion: 0,
                        D_Venta: 0, D_Utilidad: 0,
                        V_PromDiario: 0, U_PromDiario: 0
                    };

                    // Agrupar por región
                    $.each(data, function (i, item) {
                        Nivel = item.NivelEntrada;
                        let region = item.Region || "SIN REGION";
                        if (!grupos[region]) grupos[region] = [];
                        grupos[region].push(item);

                        // Acumulamos en el total general
                        totalGeneral.V_Meta += item.V_Meta || 0;
                        totalGeneral.V_Venta += item.V_Venta || 0;
                        totalGeneral.V_Proyeccion += item.V_Proyeccion || 0;
                        totalGeneral.U_Utilidad += item.U_Utilidad || 0;
                        totalGeneral.U_Proyeccion += item.U_Proyeccion || 0;
                        totalGeneral.D_Venta += item.D_Venta || 0;
                        totalGeneral.D_Utilidad += item.D_Utilidad || 0;
                        totalGeneral.V_PromDiario += item.V_PromDiario || 0;
                        totalGeneral.U_PromDiario += item.U_PromDiario || 0;
                    });

                    // Recorrer los grupos
                    $.each(grupos, function (region, items) {
                        if (Nivel != 2) {
                            html += `<tr class="location-title">
                                <td colspan="14" style="text-align: left; padding-left: 20px;">
                                    <i class="fas fa-map-marked-alt"></i> <strong>${region}</strong>
                                </td>
                            </tr>`;
                        }

                        // Filas por tienda
                        $.each(items, function (i, item) {
                            html += `<tr>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <button class="btn btn-sm btn-link p-0 me-2 btn-expandir" data-tienda="${item.WhsCode}" title="Ver detalle" style="margin-right:7px;">
                                                <i class="fas fa-plus-circle text-primary"></i>
                                            </button>
                                            <span>${item.WhsName}</span>
                                        </div>
                                    </td>
                                    <td>${formatoQuetzal(item.V_Meta)}</td>
                                    <td>${formatoQuetzal(item.V_Venta)}</td>
                                    <td>${formatoQuetzal(item.V_PromDiario)}</td>
                                    <td>${formatoQuetzal(item.V_Proyeccion)}</td>
                                    <td>${(item.V_Proyeccion / item.V_Meta * 100).toFixed(2)}%</td> <!-- Proyección / Meta -->
                                    <td>${formatoQuetzal(item.U_Utilidad)}</td>
                                    <td>${formatoQuetzal(item.U_PromDiario)}</td>
                                    <td>${formatoQuetzal(item.U_Proyeccion)}</td>
                                    <td>${(item.U_Proyeccion / item.V_Proyeccion * 100).toFixed(2)}%</td> <!-- Proyección de Utilidad / Proyección de Venta -->
                                    <td>${formatoQuetzal(item.D_Venta)}</td>
                                    <td>${formatoQuetzal(item.D_Utilidad)}</td>
                                    <td>${(item.U_PromDiario / item.V_PromDiario * 100).toFixed(2)}%</td> <!-- Utilidad / Venta en Diario -->
                                </tr>`;

                            html += `<tr class="detalle-tienda" id="detalle-${item.WhsCode}" style="display: none;">
                                        <td colspan="14">
                                            <div class="contenido-detalle">
                                                Cargando detalle...
                                            </div>
                                        </td>
                                    </tr>`;
                        });


                        // Totales por región
                        let total = {
                            V_Meta: 0, V_Venta: 0, V_Proyeccion: 0,
                            U_Utilidad: 0, U_Proyeccion: 0,
                            D_Venta: 0, D_Utilidad: 0,
                            V_PromDiario: 0, U_PromDiario: 0
                        };

                        items.forEach(item => {
                            total.V_Meta += item.V_Meta || 0;
                            total.V_Venta += item.V_Venta || 0;
                            total.V_Proyeccion += item.V_Proyeccion || 0;
                            total.U_Utilidad += item.U_Utilidad || 0;
                            total.U_Proyeccion += item.U_Proyeccion || 0;
                            total.D_Venta += item.D_Venta || 0;
                            total.D_Utilidad += item.D_Utilidad || 0;
                            total.V_PromDiario += item.V_PromDiario || 0;
                            total.U_PromDiario += item.U_PromDiario || 0;
                        });



                        if (Nivel != 2)
                        {
                            html += `<tr class="total-row">
                                <td>TOTAL ${region}</td>
                                <td>${formatoQuetzal(total.V_Meta)}</td>
                                <td>${formatoQuetzal(total.V_Venta)}</td>
                                <td>${formatoQuetzal(total.V_PromDiario)}</td>
                                <td>${formatoQuetzal(total.V_Proyeccion)}</td>
                                <td>${(total.V_Proyeccion / total.V_Meta * 100).toFixed(2)}%</td> <!-- Proyección / Meta -->
                                <td>${formatoQuetzal(total.U_Utilidad)}</td>
                                <td>${formatoQuetzal(total.U_PromDiario)}</td>
                                <td>${formatoQuetzal(total.U_Proyeccion)}</td>
                                <td>${(total.U_Proyeccion / total.V_Proyeccion * 100).toFixed(2)}%</td> <!-- Proyección de Utilidad / Proyección de Venta -->
                                <td>${formatoQuetzal(total.D_Venta)}</td>
                                <td>${formatoQuetzal(total.D_Utilidad)}</td>
                                <td>${(total.U_PromDiario / total.V_PromDiario * 100).toFixed(2)}%</td> <!-- Utilidad / Venta en Diario -->
                            </tr>`;
                        }
                    });

                    // Agregar total general
                    if (Nivel != 2) {
                        // Agregar total general
                        html += `<tr class="total-row bg-dark text-white">
                                    <td><strong>TOTAL GENERAL</strong></td>
                                    <td>${formatoQuetzal(totalGeneral.V_Meta)}</td>
                                    <td>${formatoQuetzal(totalGeneral.V_Venta)}</td>
                                    <td>${formatoQuetzal(totalGeneral.V_PromDiario)}</td>
                                    <td>${formatoQuetzal(totalGeneral.V_Proyeccion)}</td>
                                    <td>${(totalGeneral.V_Proyeccion / totalGeneral.V_Meta * 100).toFixed(2)}%</td> <!-- Proyección / Meta -->
                                    <td>${formatoQuetzal(totalGeneral.U_Utilidad)}</td>
                                    <td>${formatoQuetzal(totalGeneral.U_PromDiario)}</td>
                                    <td>${formatoQuetzal(totalGeneral.U_Proyeccion)}</td>
                                    <td>${(totalGeneral.U_Proyeccion / totalGeneral.V_Proyeccion * 100).toFixed(2)}%</td> <!-- Proyección de Utilidad / Proyección de Venta -->
                                    <td>${formatoQuetzal(totalGeneral.D_Venta)}</td>
                                    <td>${formatoQuetzal(totalGeneral.D_Utilidad)}</td>
                                    <td>${(totalGeneral.U_PromDiario / totalGeneral.V_PromDiario * 100).toFixed(2)}%</td> <!-- Utilidad / Venta en Diario -->
                                </tr>`;
                    }

                    $('#tbodyVentas').html(html);


                    //BOTON DE EXPANDIR DETALLE
                    $('.btn-expandir').off('click').on('click', function () {
                        var tienda = $(this).data('tienda');
                        var detalleRow = $('#detalle-' + tienda);
                        var estaVisible = detalleRow.is(':visible');
                        // Oculta todos los detalles y reinicia íconos
                        $('.detalle-tienda').hide();
                        $('.btn-expandir i').removeClass('fa-minus-circle').addClass('fa-plus-circle');

                        if (!estaVisible) {
                            // Contenido HTML de la tabla
                            let Detalle = `
                            <div class="table-responsive" style="margin-bottom:10px; margin-top:15px">
                                <table class="table table-bordered table-hover" id="tablaVentas-${tienda}">
                                    <thead class="text-center" style="background-color: #004080; color: white;">
                                        <tr>
                                            <th rowspan="2" class="align-middle">Nombre del asesor</th>
                                            <th colspan="5">Venta</th>
                                            <th colspan="4">Utilidad</th>
                                            <th colspan="3">Diario</th>
                                        </tr>
                                        <tr>
                                            <th>Meta</th>
                                            <th>Venta</th>
                                            <th>Promedio diario</th>
                                            <th>Proyección</th>
                                            <th>Meta Venta %</th>
                                            <th>Utilidad</th>
                                            <th>Promedio diario</th>
                                            <th>Proyección</th>
                                            <th>Margen</th>
                                            <th>Venta</th>
                                            <th>Utilidad</th>
                                            <th>Margen</th>
                                        </tr>
                                    </thead>
                                    <tbody class="text-center" id="tbodyVentas-${tienda}" style="background-color:white">
                                        <tr>
                                            <td colspan="13">
                                                <img src="/img/loading_circulo.gif" alt="Cargando" style="width:25px; height:25px;"><br/>
                                                Cargando datos...
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>`;

                            detalleRow.find('.contenido-detalle').html(Detalle);
                            detalleRow.show();
                            $(this).find('i').removeClass('fa-plus-circle').addClass('fa-minus-circle');

                            // Llamada AJAX para llenar la tabla
                            $.ajax({
                                url: '/VentasEmpresa/DetalleUsuarios',
                                method: 'POST',
                                data: { FechaI: fechaI, FechaF: fechaF, WhsCode: tienda },
                                success: function (data) {
                                    let tbody = '';
                                    $.each(data.data, function (i, venta) {
                                        tbody += `<tr>
                                            <td>${venta.SlpName}</td>
                                            <td>${formatoQuetzal(venta.V_Meta)}</td>
                                            <td>${formatoQuetzal(venta.V_Venta)}</td>
                                            <td>${formatoQuetzal(venta.V_PromDiario)}</td>
                                            <td>${formatoQuetzal(venta.V_Proyeccion)}</td>
                                            <td>${(venta.V_Proyeccion / venta.V_Meta * 100).toFixed(2)}%</td>
                                            <td>${formatoQuetzal(venta.U_Utilidad)}</td>
                                            <td>${formatoQuetzal(venta.U_PromDiario)}</td>
                                            <td>${formatoQuetzal(venta.U_Proyeccion)}</td>
                                            <td>${(venta.U_Proyeccion / venta.V_Proyeccion * 100).toFixed(2)}%</td>
                                            <td>${formatoQuetzal(venta.D_Venta)}</td>
                                            <td>${formatoQuetzal(venta.D_Utilidad)}</td>
                                            <td>${(venta.U_PromDiario / venta.V_PromDiario * 100).toFixed(2)}%</td>
                                        </tr>`;
                                    });
                                    $('#tbodyVentas-' + tienda).html(tbody);
                                },
                                error: function () {
                                    $('#tbodyVentas-' + tienda).html('<tr><td colspan="13">Error al cargar los datos</td></tr>');
                                }
                            });
                        }
                    });

                } else {
                    alert(response.message);
                }

                $("#globalLoading").hide();
            },
            error: function () {
                $("#globalLoading").hide();
                alert("Error al obtener los datos");
            }
        });

    }

    $(document).ready(function () {
        // Dispara el click automáticamente sobre el botón con data-tienda="TI001"
        $('.btn-expandir[data-tienda="FTT-TSAL"]').trigger('click');
    });

</script>