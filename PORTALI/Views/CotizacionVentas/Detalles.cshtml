<script>
    function AbrirVentana(valor) {
        // Cierra todos los modales abiertos
        $('.modal').modal('hide'); // Cierra los modales de Bootstrap
        $('.modal-backdrop').remove(); // Elimina el fondo oscuro de los modales

        // Muestra el loading
        $("#globalLoading").show();

        // Redirige según el valor
        if (valor === 1) {
            window.location.href = '/MiCarrito/ListadoCarrito';
            $("#globalLoading").hide();
        } else if (valor === 2) {
            window.location.href = '/CotizacionVentas/Cotizacion';
            $("#globalLoading").hide();
        }
    }

    $(document).ready(function () {
        CalcularTotales();
    });

    function buscarProductoEnCotizacion() {
        const existingCotizacion = getCookie('Cotizacion_A1'); // Obtenemos la cookie

        if (existingCotizacion) {
            const cotizacion = JSON.parse(existingCotizacion); // Convertimos el JSON a un objeto
            console.log(cotizacion);

            // Verificamos si hay productos en la cotización
            if (cotizacion.productos && cotizacion.productos.length > 0) {
                const primerListPrice = cotizacion.productos[0]["ListPrice"]; // Obtenemos el primer ListPrice
                return primerListPrice;
            } else {
                return 0; // Si no hay productos, retornamos 0
            }
        } else {
            return 0; // Si no existe la cookie, retornamos 0
        }
    }

    // Imágenes de la galería
    const images = [
        "https://www.mndelgolfo.com/blog/wp-content/uploads/2021/09/Sabes-como-crear-ambientes-unicos-con-pisos-porcelanicos-de-gran-formato-Daltile2-1024x576.jpg",
        "https://pewenpisosvinilicos.com.ar/wp-content/uploads/pewen-pisos-vinilicos-click-1.jpg",
        "https://cdn1.infocasas.com.uy/web/66154e6e434a5_pisos.jpg#hasTH",
        "https://st.hzcdn.com/simgs/pictures/living-rooms/sloane-avenue-studio-laroya-and-co-img~57d15c5806c60a93_14-0217-1-a5bbb15.jpg"
    ];
    let currentIndex = 0;

    // Función para abrir el modal
    function OpenData() {
        document.getElementById('modalTejar').classList.add('active');
        updateImage();
    }

    // Función para cerrar el modal
    function cerrarModal() {
        document.getElementById('modalTejar').classList.remove('active');
    }

    // Función para cambiar de imagen
    function changeSlide(direction) {
        currentIndex = (currentIndex + direction + images.length) % images.length;
        updateImage();
    }

    // Actualizar la imagen mostrada
    function updateImage() {
        document.getElementById('modalImage').src = images[currentIndex];
    }
    function LevantarPop() {
        $("#myCustomModal").modal('show');
    }

    document.getElementById("CantNecesita").addEventListener("keydown", function (event) {
        if (event.key === "Enter") {
            event.preventDefault();
            document.getElementById("btnAplicar").click();
        }
    });

    function CalcularDescuentos(tipo) {
        const precioBase = parseFloat(document.getElementById("selected-price").value) || 0;
        let dsctoPorcentaje = parseFloat(document.getElementById("txtPdecuento").value) || 0;
        let dsctoCantidad = parseFloat(document.getElementById("txtQdescuento").value) || 0;
        let granTotal = 0;

        if (precioBase <= 0) {
            alert("El precio base no es válido.");
            return;
        }

        if (tipo === "P") {
            dsctoCantidad = (precioBase * dsctoPorcentaje) / 100;
            granTotal = precioBase - dsctoCantidad;
            document.getElementById("txtQdescuento").value = dsctoCantidad.toFixed(2);
        } else if (tipo === "Q") {
            if (dsctoCantidad > precioBase) {
                alert("El descuento no puede ser mayor al precio base.");
                return;
            }
            dsctoPorcentaje = (dsctoCantidad / precioBase) * 100;
            granTotal = precioBase - dsctoCantidad;
            document.getElementById("txtPdecuento").value = dsctoPorcentaje.toFixed(2);
        }

        document.getElementById("txtTotalDescuento").value = granTotal.toFixed(2);

        const tabla = document.querySelector(".tblPrecios tbody");
        if (!tabla) {
            console.error("No se encontró la tabla.");
            return;
        }

        tabla.querySelectorAll("tr").forEach((fila, index) => {
            const celdas = fila.cells;
            if (celdas.length < 4) {
                console.warn(`Fila ${index} no tiene suficientes celdas.`);
                return;
            }
            const precioInicial = parseFloat(celdas[2].innerText.replace("Q", "").replace(",", "").trim()) || 0;
            const precioFinal = parseFloat(celdas[3].innerText.replace("Q", "").replace(",", "").trim()) || 0;

            if (granTotal >= precioInicial && granTotal <= precioFinal) {
                fila.style.backgroundColor = "orange"; // Verde claro
                fila.style.color = "white"; // Texto verde oscuro
            } else {
                fila.style.backgroundColor = "";
                fila.style.color = "";
            }
        });
    }

    function ApplicarCalculo() {
        let CantNecesita = document.getElementById("CantNecesita").value;
        let Metraje = parseFloat("@Model.Encabezado.Metraje");

        if (Metraje > 0) {
            let resultado = Math.ceil(CantNecesita / Metraje);
            document.getElementById("counterInput").value = resultado;
            document.getElementById('iMetrosTotal').textContent = "Total metros de piso: " + (resultado * Metraje).toFixed(2);

            $("#Calculadora").modal('hide');
        } else {
            alert("No se puede calcular los metros necesarios por la falta de configuración en el metraje, comuníquese con el departamento de categorías.");
        }
    }

    function Calculadora() {
        $("#Calculadora").modal('show');
    }

    function CalculoTotales() {
        let Ahorro = 0.00;
        let Cantidad = parseFloat(document.getElementById('counterInput').value) || 0;
        let Descuento = parseFloat(document.getElementById('txtDescuento').textContent.replace("%", "")) || 0;
        let Precio = parseFloat(document.getElementById('txtPrecio').textContent) || 0;
        let Metraje = "@Model.Encabezado.Metraje";
        let TotalMetros = 0.00;

        let Total = (Precio * Cantidad) - (((Precio * Cantidad) * Descuento) / 100);
        Ahorro = (((Precio * Cantidad) * Descuento) / 100);

        document.getElementById('totalOutput').textContent = Total.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
        document.getElementById('txtAhorro').textContent = Ahorro.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });

        if ("@Model.Encabezado.IdGrupo == 1") {
            TotalMetros = Metraje * Cantidad;
        }
        document.getElementById('iMetrosTotal').textContent = "Total metros de piso: " + TotalMetros.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    }

    function openModal() {
        if ("@Model.Encabezado.TipoPromo" == "PU")
        {
            alert("Un producto con precio de promocion no aplica a descuento");
            return;
        }

        let price = document.getElementById('txtPrecio').textContent.trim();
        if (price === '' || price === "0.00") {
            alert("Seleccione un precio");
            return;
        }

        price = parseFloat(price);
        if (isNaN(price)) {
            alert("El precio no es válido");
            return;
        }

        $("#discountModal").modal('show');
        document.getElementById('selected-price').value = price.toFixed(2);
    }

    function applyDiscount() {
        const discountP = document.getElementById('txtPdecuento').value;
        const discountQ = document.getElementById('txtQdescuento').value;
        const priceBefore = document.getElementById('selected-price').value;
        const priceNew = document.getElementById('txtTotalDescuento').value;
        document.getElementById('txtDescuento').textContent = parseFloat(discountP).toFixed(2) + "%";
        document.getElementById('txtAhorro').textContent = parseFloat(discountQ).toFixed(2);
        document.getElementById('txtAhorro').textContent = parseFloat(discountQ).toFixed(2);
        document.getElementById('totalOutput').textContent = parseFloat(priceNew).toFixed(2);
        $("#discountModal").modal('hide');
    }

    function sendAuthorization() {
        const reason = document.getElementById('authorization-reason').value;
        if (reason.trim() === "") {
            alert('Debe ingresar un motivo para la autorización.');
            return;
        }
        alert('Se ha enviado una solicitud para la autorización de descuento');
        $("#authorizationModal").modal('hide');
        $("#discountModal").modal('hide');
    }

    function closeModal() {
        $("#discountModal").modal('hide');
    }

    function scrollItems(direction) {
        const container = document.querySelector('.items-container');
        const scrollAmount = 200;

        container.scrollBy({
            left: direction * scrollAmount,
            behavior: 'smooth'
        });
    }

    function borrarCotizacion(clienteId) {
        let cookieName = obtenerNombreCookieMasReciente("T-OneCotizacion-");
        borrarCookie(cookieName);

        actualizarCarritoBadge(0);
        alert("Carrito borrado exitosamente.");
    }

    function borrarCookie(cookieName) {
        // Establecer la cookie con una fecha de expiración pasada
        document.cookie = cookieName + "=; expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/;";
        console.log(`Cookie ${cookieName} eliminada.`);
    }

    function generateUUID() {
        return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, function (c) {
            const r = (Math.random() * 16) | 0,
                v = c === 'x' ? r : (r & 0x3) | 0x8;
            return v.toString(16);
        });
    }

    function agregarProductoDesdeVista() {
        $("#globalLoading").show();        
        const precioNo = "@Model.Encabezado.PrecioVenta";
        const precioOf = "@Model.Encabezado.PrecioBeneficio";
        const clienteId = 'A1';
        const itemCode = "@Model.Encabezado.ItemCode";
        const itemName = "@Model.Encabezado.ItemName";
        const quantity = parseFloat(document.getElementById('counterInput').value);
        const price = "@Model.Encabezado.PrecioFinal";
        const dscto = "0.00";
        const savings = "0.00";
        const descuentoU = parseFloat(precioOf - precioNo).toFixed(2);
        const listPrice = "@Model.Encabezado.PLFinal";
        const lineTotal = parseFloat((price * quantity).toFixed(2)) - parseFloat(savings).toFixed(2);
        const elemento = document.getElementById('iMetrosTotal');
        const cantidadMetros = elemento ? elemento.textContent.replace("Total metros de piso:", "").trim() : "0";
        const linkImg = "@Model.Encabezado.Imagen";
        const EsPromo = "@Model.Encabezado.EsPromo";        
        let lineId = regresarId();

        const producto = {
            DocE: 0,
            LineN: -1,
            Identity: generateUUID(),
            LineId: lineId,
            ItemCode: itemCode,
            Dscription: itemName.replace(/&#160;/g, ' '),
            Quantity: quantity,
            ListPrice: parseInt(listPrice),
            Price: (parseFloat(price) - parseFloat(descuentoU)),
            DescuentoU: parseFloat(descuentoU),
            Dscto: parseFloat(dscto.replace("%", "")),
            LineTotal: lineTotal,
            CantidadMetros: parseFloat(cantidadMetros),
            LinkImg: linkImg,
            EsPromo: EsPromo,
            DescuentoLpr: 0,
            DescuentoPor: 0.00,
            DescuentoQtz: 0.00,
            DescuentoNwp: 0.00
        };

        if (CrearCotizacionCookie(clienteId, producto,0) === true) {
            $('#miModal').modal('show').addClass('fade-in');
            $("#globalLoading").hide();
        }
    }

