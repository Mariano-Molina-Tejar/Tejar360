        }
    });

    function selectPriceSection(element) {
        document.querySelectorAll('.price-section').forEach((section) => {
            section.classList.remove('active');
        });

        element.classList.add('active');
        const _precio = element.getAttribute('data-price');
        document.getElementById('txtPrecio').innerHTML = _precio;

        const _listPrice = element.getAttribute('data-priceList');
        document.getElementById('txtListPrice').innerHTML = _listPrice;
        CalculoTotales();
