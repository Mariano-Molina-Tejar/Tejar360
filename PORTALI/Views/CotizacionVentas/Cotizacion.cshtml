<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/material-design-iconic-font/2.2.0/css/material-design-iconic-font.min.css" integrity="sha256-3sPp8BkKUE7QyPSl6VfBByBroQbKxKG7tsusY2mhbVY=" crossorigin="anonymous" />
<link href="~/Css/styleCotizacionVentas.css" rel="stylesheet" />
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
<script src="~/Scripts/bootstrap.min.js"></script>
<link href="~/Css/font-awesome.min.css" rel="stylesheet" />
<style>
    body {
        background-color: white;
    }
    /* Personalización del botón de búsqueda */
    #btnBuscar .input-group-text {
        background-color: #FF8C00; /* Color naranja */
        color: white;
        border: none;
        cursor: pointer;
    }

    /* Input con bordes redondeados a la izquierda */
    #txtBuscar {
        border-top-left-radius: 20px;
        border-bottom-left-radius: 20px;
    }

        /* Quitar borde del input cuando el botón está dentro */
        #txtBuscar:focus {
            box-shadow: none;
        }
    /* Input más alto */
    .input-group .form-control {
        height: 45px;
    }
</style>
<div>
    <div class="row">
        <div class="col-lg-12" style="margin-top:10px">
            <div class="row justify-content-center">
                <div class="col-xl-8">
                    <div class="input-group">
                        <input id="txtBuscar" autocomplete="off" type="text" class="form-control text-uppercase" placeholder="Buscar producto..." />
                        <div id="btnBuscar" class="input-group-append">
                            <span class="input-group-text">
                                <i class="fa fa-search"></i>
                            </span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<div id="resultadosBusqueda"></div>
<script src="~/Scripts/jquery-3.4.1.min.js"></script>
<script>
    $(document).ready(function () {
        $('#txtBuscar').on('keydown', function (event) {
            if (event.key === "Enter") {
                event.preventDefault();
                BuscarProducto();
            }
        });
    });

    $(document).ready(function () {
        $("#btnBuscar").click(function () {
            BuscarProducto();
        });
    });

    function BuscarProducto() {
        var textBuscar = $("#txtBuscar").val();
        $("#globalLoading").show();
        $.ajax({
            url: '@Url.Action("BuscarProductos", "CotizacionVentas")',
            data: { NombreProducto: textBuscar },
            success: function (data) {
                $("#resultadosBusqueda").html(data);
                $("#txtBuscar").focus();
                $("#globalLoading").hide();
            }
        });
        $("#globalLoading").hide();
    }
</script>