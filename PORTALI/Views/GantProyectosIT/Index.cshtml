<style>
    body {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        background-color: #f4f6f8;
        color: #333;
        margin: 0;
    }

    h1 {
        text-align: center;
        margin-bottom: 30px;
        color: #1f3c88;
    }

    form#filtroFechas {
        display: flex;
        justify-content: center;
        gap: 15px;
        margin-bottom: 30px;
        flex-wrap: wrap;
        background-color: #fff;
        padding: 15px 20px;
        border-radius: 10px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }

        form#filtroFechas input[type="date"] {
            padding: 5px 10px;
            border-radius: 5px;
            border: 1px solid #ccc;
        }

        form#filtroFechas button {
            padding: 6px 15px;
            border: none;
            background-color: #1f3c88;
            color: #fff;
            font-weight: bold;
            border-radius: 5px;
            cursor: pointer;
            transition: background-color 0.3s;
        }

            form#filtroFechas button:hover {
                background-color: #3954b3;
            }

    .totales-cards, .kpi-cards {
        display: flex;
        justify-content: center;
        gap: 20px;
        margin-bottom: 30px;
        flex-wrap: wrap;
    }

    .total-card, .kpi-card {
        background-color: #fff;
        padding: 20px;
        border-radius: 10px;
        flex: 1;
        min-width: 220px;
        text-align: center;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }

        .total-card h2, .kpi-card h2 {
            margin: 0;
            color: #1f3c88;
        }

    .lists-container {
        display: flex;
        gap: 20px;
        margin-bottom: 30px;
        flex-wrap: wrap;
        justify-content: center;
    }

    .list-card {
        background-color: #fff;
        flex: 1;
        min-width: 300px;
        padding: 15px;
        border-radius: 10px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        overflow-y: auto;
    }

        .list-card h3 {
            margin-top: 0;
            color: #1f3c88;
            text-align: center;
        }

        .list-card table {
            width: 100%;
            border-collapse: collapse;
        }

        .list-card th, .list-card td {
            padding: 8px;
            text-align: left;
            border-bottom: 1px solid #ddd;
        }

    .charts-container {
        display: flex;
        flex-wrap: wrap;
        gap: 30px;
        justify-content: center;
        margin-bottom: 30px;
    }

    canvas {
        background-color: #fff;
        padding: 15px;
        border-radius: 10px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        max-width: 600px;
    }

    #tablaCategoriaUsuario {
        width: 100%;
        border-collapse: collapse;
    }

        #tablaCategoriaUsuario thead {
            background-color: #1f3c88;
            color: white;
            display: table;
            width: 100%;
            table-layout: fixed; /* mantiene alineación */
        }

        #tablaCategoriaUsuario tbody {
            display: block;
            max-height: 400px; /* ajusta según lo que quieras */
            overflow-y: auto;
            width: 100%;
        }

            #tablaCategoriaUsuario tbody tr {
                display: table;
                width: 100%;
                table-layout: fixed; /* para que coincidan las columnas con thead */
            }
</style>

<style>
    .list-card {
        margin-bottom: 20px;
        padding: 10px;
        border: 1px solid #ccc;
        border-radius: 5px;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        margin-bottom: 10px;
    }

    th, td {
        border: 1px solid #ccc;
        padding: 5px;
        text-align: left;
    }

    .hitos-table {
        margin-top: 5px;
        display: none;
    }

    .expand-btn {
        cursor: pointer;
        color: blue;
        text-decoration: underline;
    }

    .green {
        color: green;
        font-weight: bold;
    }

    .red {
        color: red;
        font-weight: bold;
    }

    .total-card {
        position: relative;
        padding: 20px;
        border-radius: 12px;
        color: #111;
        font-weight: bold;
        overflow: hidden;
        text-align: center;
        min-width: 120px;
        margin: 10px;
    }

        /* Iconos de fondo */
        .total-card::before {
            content: "";
            position: absolute;
            font-family: "Font Awesome 6 Free";
            font-weight: 900;
            font-size: 60px;
            color: rgba(0,0,0,0.05); /* muy transparente */
            top: 10px;
            right: 10px;
            z-index: 0;
        }

    /* Iconos específicos por tarjeta */
    .total-proyectos::before {
        content: "\f0c0";
    }
    /* fa-users */
    .total-en-curso::before {
        content: "\f121"; /* fa-tasks → desarrollo/proyectos en curso */
        font-family: "Font Awesome 6 Free";
        font-weight: 900;
        font-size: 60px;
        position: absolute;
        top: 10px;
        right: 10px;
        z-index: 0;
    }

    /* fa-spinner */
    .total-en-pausa::before {
        content: "\f28b";
    }
    /* fa-pause-circle */
    .total-finalizados::before {
        content: "\f00c";
    }
    /* fa-check-circle */
    .total-indice::before {
        content: "\f201";
    }
    /* fa-chart-line */

    /* Asegurarse que el texto esté encima del icono */
    .total-card h2, .total-card p {
        position: relative;
        z-index: 1;
    }
</style>

