    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const tbody = document.querySelector("#tblProyectos tbody");

            Sortable.create(tbody, {
                animation: 150, // animación al mover
                handle: ".expand-btn", // solo arrastrar por la columna del nombre
                filter: ".hitos-table", // las filas de hitos no se arrastran solas
                draggable: "tr.expandable", // solo las filas principales se pueden arrastrar
                onMove: function (evt) {
                    // evita que se mueva otra fila que no sea expandable
                    return evt.related.classList.contains("expandable") || evt.related.classList.contains("hitos-table") || evt.related === tbody;
                },
                onEnd: function (evt) {
                    const movedRow = tbody.children[evt.newIndex];
                    const nextRow = movedRow.nextElementSibling;

                    // si el siguiente es la fila de hitos, la movemos junto con la principal
                    if (nextRow && nextRow.classList.contains("hitos-table")) {
                        tbody.insertBefore(nextRow, tbody.children[evt.newIndex + 1]);
                    }
                }

            });
        });

        document.querySelectorAll(".progress-bar").forEach(bar => {
            let value = parseInt(bar.dataset.value) || 0;

            // Colores suaves translúcidos
            if (value >= 100) {
                bar.style.backgroundColor = "rgba(74, 222, 128, 0.4)"; // verde translúcido
            } else if (value > 50) {
                bar.style.backgroundColor = "rgba(245, 158, 11, 0.4)"; // naranja translúcido
            } else {
                bar.style.backgroundColor = "rgba(239, 68, 68, 0.4)"; // rojo translúcido
            }

            // Animación de llenado
            setTimeout(() => {
                bar.style.width = value + "%";
            }, 100);
        });

        document.querySelectorAll('.expand-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                const hitosRow = btn.parentElement.nextElementSibling;
                hitosRow.style.display = hitosRow.style.display === 'table-row' ? 'none' : 'table-row';
            });
        });

        function contarProyectosPrincipales() {
            const filasPrincipales = document.querySelectorAll("#tblProyectos tbody tr.expandable");
            document.getElementById("totalTickets").textContent = filasPrincipales.length;
        }
        document.addEventListener("DOMContentLoaded", contarProyectosPrincipales);

        function contarProyectosEnCurso() {
            // Selecciona solo las filas principales (clase expandable)
            const filasPrincipales = document.querySelectorAll("#tblProyectos tbody tr.expandable");

            // Filtra solo las que tengan "En curso" en la columna de Estatus (6ª columna)
            const enCurso = Array.from(filasPrincipales).filter(tr => {
                const estatus = tr.cells[6].innerText.trim(); // columna 6 → índice 5
                return estatus === "En curso";
            });

            // Actualiza el h2
            document.getElementById("ticketsEnCurso").textContent = enCurso.length;
        }

        // Ejecutar al cargar la página
        document.addEventListener("DOMContentLoaded", contarProyectosEnCurso);

        function contarProyectosEnPausa() {
            // Selecciona solo las filas principales (clase expandable)
            const filasPrincipales = document.querySelectorAll("#tblProyectos tbody tr.expandable");

            // Filtra solo las que tengan "En curso" en la columna de Estatus (6ª columna)
            const enCurso = Array.from(filasPrincipales).filter(tr => {
                const estatus = tr.cells[6].innerText.trim(); // columna 6 → índice 5
                return estatus === "En pausa";
            });

            // Actualiza el h2
            document.getElementById("ticketsEnPausa").textContent = enCurso.length;
        }

        // Ejecutar al cargar la página
        document.addEventListener("DOMContentLoaded", contarProyectosEnPausa);

        function contarProyectosFinalizados() {
            // Selecciona solo las filas principales (clase expandable)
            const filasPrincipales = document.querySelectorAll("#tblProyectos tbody tr.expandable");

            // Filtra solo las que tengan "En curso" en la columna de Estatus (6ª columna)
            const enCurso = Array.from(filasPrincipales).filter(tr => {
                const estatus = tr.cells[6].innerText.trim(); // columna 6 → índice 5
                return estatus === "Finalizado";
            });

            // Actualiza el h2
            document.getElementById("Finalizados").textContent = enCurso.length;
        }

        // Ejecutar al cargar la página
        document.addEventListener("DOMContentLoaded", contarProyectosFinalizados);

        function actualizarTotales() {
            // Selecciona solo filas principales (clase expandable)
            const filasPrincipales = document.querySelectorAll("#tblProyectos tbody tr.expandable");

            // Filtra los que están en curso
            const enCurso = Array.from(filasPrincipales).filter(tr => {
                return tr.cells[6].innerText.trim().toLowerCase() === "en curso";
            });

            // Filtra los que están finalizados
            const finalizados = Array.from(filasPrincipales).filter(tr => {
                return tr.cells[6].innerText.trim().toLowerCase() === "finalizado";
            });

            // Total de filas principales
            const total = filasPrincipales.length;

            // Actualiza los contadores
            document.getElementById("ticketsEnCurso").textContent = enCurso.length;
            document.getElementById("Finalizados").textContent = finalizados.length;

            // Calcula índice: finalizados / total en decimal con dos decimales
            let indice = total > 0 ? (finalizados.length / total * 100).toFixed(2) : "0.00";
            document.getElementById("Indice").textContent = indice + "%";
        }

        // Ejecutar al cargar la página
        document.addEventListener("DOMContentLoaded", actualizarTotales);

    </script>
