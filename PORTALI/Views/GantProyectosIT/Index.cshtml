    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const table = document.getElementById("tblProyectos");
            const rows = table.querySelectorAll("tbody tr.expandable"); // solo filas principales

            rows.forEach((row, index) => {
                // Crea una celda al inicio
                const cell = document.createElement("td");
                cell.textContent = index + 1; // Numeración empieza en 1
                cell.style.fontWeight = "bold";
                cell.style.textAlign = "center";
                row.insertBefore(cell, row.firstChild);
            });
        });

        document.addEventListener("DOMContentLoaded", function () {

            const table = document.getElementById("tblProyectos");
            const rows = table.querySelectorAll("tbody tr.expandable"); // solo filas principales

            const usuarios = {};
            const areas = {};

            rows.forEach(row => {
                const usuario = row.cells[1].textContent.trim();
                const area = row.cells[3].textContent.trim();

                if (usuario !== "" && usuario.toLowerCase() !== "sin asignar") {
                    usuarios[usuario] = (usuarios[usuario] || 0) + 1;
                }

                if (area !== "") {
                    areas[area] = (areas[area] || 0) + 1;
                }
            });

            // --- Usuarios Chart ---
            const ctxUsuarios = document.getElementById("usuariosChart").getContext("2d");
            new Chart(ctxUsuarios, {
                type: 'doughnut',
                data: {
                    labels: Object.keys(usuarios),
                    datasets: [{
                        data: Object.values(usuarios),
                        backgroundColor: [
                            'rgba(54, 162, 235, 0.7)',
                            'rgba(255, 206, 86, 0.7)',
                            'rgba(255, 99, 132, 0.7)',
                            'rgba(75, 192, 192, 0.7)',
                            'rgba(153, 102, 255, 0.7)',
                            'rgba(255, 159, 64, 0.7)'
                        ],
                        borderWidth: 1
                    }]
                },
                options: {
                    plugins: {
                        title: {
                            display: true,
                            text: 'Proyectos por Usuario',
                            font: {
                                size: 18,
                                weight: 'bold'
                            }
                        },
                        legend: {
                            display: true,
                            position: 'left', // leyenda a la izquierda
                            labels: {
                                boxWidth: 20,
                                padding: 10
                            }
                        }
                    },
                    responsive: true,
                    maintainAspectRatio: false
                }
            });

            // --- Areas Chart ---
            const ctxAreas = document.getElementById("areasChart").getContext("2d");
            new Chart(ctxAreas, {
                type: 'doughnut',
                data: {
                    labels: Object.keys(areas),
                    datasets: [{
                        data: Object.values(areas),
                        backgroundColor: [
                            'rgba(255, 99, 132, 0.7)',
                            'rgba(54, 162, 235, 0.7)',
                            'rgba(255, 206, 86, 0.7)',
                            'rgba(75, 192, 192, 0.7)',
                            'rgba(153, 102, 255, 0.7)',
                            'rgba(255, 159, 64, 0.7)'
                        ],
                        borderWidth: 1
                    }]
                },
                options: {
                    plugins: {
                        title: {
                            display: true,
                            text: 'Proyectos por Área',
                            font: {
                                size: 18,
                                weight: 'bold'
                            }
                        },
                        legend: {
                            display: true,
                            position: 'left',
                            labels: {
                                boxWidth: 20,
                                padding: 10
                            }
                        }
                    },
                    responsive: true,
                    maintainAspectRatio: false
                }
            });

        });
