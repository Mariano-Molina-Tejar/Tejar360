    <script>
        $(document).ready(function ()
        {
            $('.ver-detalle-btn').on('click', function ()
            {
                var boton = $(this);
                var ruta = boton.data('ruta');
                var filaPrincipal = boton.closest('tr');
                var filaDetalle = filaPrincipal.next('.fila-detalle');
                var contenedorDetalle = filaDetalle.find('.detalle-contenedor');

                //alternar visibilidad
                if (filaDetalle.is(':visible')) {
                    filaDetalle.hide();
                    return;
                }

                // Ocultar otros detalles
                $('.fila-detalle').hide();

                // Mostrar fila detalle actual
                filaDetalle.show();
                contenedorDetalle.html('<div class="spinner-border text-primary" role="status"><span class="visually-hidden">Cargando...</span></div>');

                 // Llamada AJAX
                $.ajax({
                    url: '@Url.Action("ObtenerDetallePorRuta", "ReporteInterTiendas")',
                    type: 'POST',
                    data: { ruta: ruta },
                    success: function (result)
                    {
                        contenedorDetalle.html(result);
                    },
                    error: function ()
                    {
                        contenedorDetalle.html('<div class="alert alert-danger">Error al cargar el detalle.</div>');
                    }
                });
            });
        });

    </script>


}






