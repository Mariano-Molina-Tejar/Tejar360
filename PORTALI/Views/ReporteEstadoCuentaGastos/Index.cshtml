
@model Entity.Filtros.FiltroEstadoCuentaGastos
@{
    ViewBag.Title = "Reporte Estado de Cuenta Gastos";
    var resultados = ViewBag.Resultado as List<Entity.ReporteEstadoCuentaGastosEntity>;
}

<div class="container mt-4">
    <h2 class="mb-4">Reporte Estado de Cuenta Gastos</h2>



    <div class="card shadow-sm mb-4">
        <div class="card-header bg-light">
            <h5 class="mb-0">Filtros de búsqueda</h5>
        </div>

        <div class="card-body">
            @using (Html.BeginForm("Index", "ReporteEstadoCuentaGastos", FormMethod.Post, new { @class = "row g-3" }))
            {
                <div class="col-12 col-md-4">
                    <label for="FechaInicio" class="form-label">Fecha de Inicio</label>
                    <input type="date"
                           id="FechaInicio"
                           name="FechaInicio"
                           class="form-control"
                           value="@ViewBag.FechaInicio"
                           aria-describedby="fechaInicioHelp"
                           required />
                    <small id="fechaInicioHelp" class="form-text text-muted">
                        Seleccione la fecha desde la cual desea consultar.
                    </small>
                </div>

                <div class="col-12 col-md-4">
                    <label for="FechaFin" class="form-label">Fecha de Fin</label>
                    <input type="date"
                           id="FechaFin"
                           name="FechaFin"
                           class="form-control"
                           value="@ViewBag.FechaFin"
                           aria-describedby="fechaFinHelp"
                           required />
                    <small id="fechaFinHelp" class="form-text text-muted">
                        Seleccione la fecha hasta la cual desea consultar.
                    </small>
                </div>

                <div class="col-12 col-md-4">
                    <label for="CodArticulo" class="form-label">Código del Artículo</label>
                    <input type="text"
                           id="CodArticulo"
                           name="CodArticulo"
                           class="form-control form-control-lg"
                           value="@Model.CodArticulo"
                           placeholder="Ej. C0003"
                           aria-describedby="codArticuloHelp"
                           maxlength="20" />
                    <small id="codArticuloHelp" class="form-text text-muted">
                        Ingrese el código exacto del artículo (máx. 20 caracteres).
                    </small>
                </div>

                <div class="col-12 col-md-4">
                    <label for="Proveedor" class="form-label">Proveedor</label>
                    @Html.DropDownListFor(m => m.Proveedor,
                        ViewBag.Proveedores as SelectList,
                        "-- Seleccione un Proveedor --",
                        new
                        {
                            @class = "form-select dropdown-toggle form-control",
                            aria_label = "Seleccione Proveedor",
                            style = "border-radius: 3px; box-shadow: 0 4px 6px rgba(0, 45, 145, 0.1);"
                        })
                    <small id="proveedorHelp" class="form-text text-muted">
                        Seleccione el proveedor con el que desea realizar la transacción.
                    </small>
                </div>



                <div class="col-12 text-end mt-3">
                    <button type="submit" class="btn btn-primary btn-lg px-4 py-2 me-2 shadow-sm">
                        <i class="bi bi-funnel-fill me-1"></i> Filtrar
                    </button>

                    <a href="@Url.Action("Index", "ReporteEstadoCuentaGastos")" class="btn btn-outline-secondary btn-lg px-4 py-2 shadow-sm">
                        <i class="bi bi-arrow-repeat me-1"></i> Restablecer
                    </a>
                </div>
            }
        </div>
    </div>



    <div class="card shadow-sm mb-4">
        <div class="card-body text-end">
            <div class="row g-3 mb-4">
                <div class="col-md-2 d-flex align-items-end">
                    @using (Html.BeginForm("ExportarExcel", "ReporteEstadoCuentaGastos", FormMethod.Post))
                    {
                        @Html.HiddenFor(m => m.FechaInicio)
                        @Html.HiddenFor(m => m.FechaFin)
                        @Html.HiddenFor(m => m.Proveedor)
                        @Html.HiddenFor(m => m.CodArticulo)

                        <button type="submit" class="btn btn-success btn-lg w-100 shadow-sm">
                            <i class="bi bi-file-earmark-excel-fill me-1"></i> Exportar Excel
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>




    <!-- Tabla de Resultados -->
    @if (resultados != null && resultados.Any())
    {

        <table class="table table-bordered table-hover table-striped table-sm align-middle">
            <thead class="table-dark">
                <tr>
                    <th class="text-nowrap">Fecha</th>
                    <th class="text-nowrap">Código Artículo</th>
                    <th>Artículo</th>
                    <th class="text-nowrap">Código Proveedor</th>
                    <th>Proveedor</th>
                    <th class="text-end">Gasto Total</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in resultados)
                {
                    <tr>
                        <td>@item.Fecha.ToString("dd/MM/yyyy")</td>
                        <td>@item.CodigoArticulo</td>
                        <td>@item.Articulo</td>
                        <td>@item.Codigo</td>
                        <td>@item.Nombre</td>
                        <td class="text-end">@item.GastoTotal.ToString("C")</td>
                    </tr>
                }
            </tbody>
        </table>


    }
    else if (Request.HttpMethod == "POST")
    {
        <div class="alert alert-warning d-flex align-items-center" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            No se encontraron resultados para los filtros aplicados.
        </div>
    }
</div>
