@using Entity;
@model List<AsistenciaSemanalViewModel>

@{
    ViewBag.Title = "Reporte Semanal de Asistencia";
}

<div class="card shadow border-0">
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
        <h5 class="mb-0">
            <i class="glyphicon glyphicon-calendar"></i> Reporte semanal de asistencia
        </h5>
    </div>

    <div class="card-body">
        <!-- 🔹 FILTROS -->
        <form class="form-row mb-4" action="Index">
            <div class="form-group col-md-2">
                <label for="FechaInicio" class="font-weight-bold">Fecha inicial</label>
                <input type="date" name="fechaI" class="form-control" value="@(ViewBag.FechaI)">
            </div>

            <div class="form-group col-md-2">
                <label for="FechaFinal" class="font-weight-bold">Fecha final</label>
                <input type="date" name="fechaF" class="form-control" value="@(ViewBag.FechaF)">
            </div>
            <div class="form-group col-md-4">
                <label for="Empleado" class="font-weight-bold">Empleado</label>
                <input type="text" name="nombre" class="form-control" placeholder="Buscar empleado..." value="@(ViewBag.Nombre)">
            </div>

            <div class="form-group col-md-2 d-flex align-items-end">
                <button type="submit" class="btn btn-primary w-100">
                    <span class="glyphicon glyphicon-search"></span> Buscar
                </button>
            </div>

            <div class="form-group col-md-2 d-flex align-items-end">
                <button class="btn btn-outline-secondary w-100" id="btnLimpiar">
                    <span class="glyphicon glyphicon-refresh"></span> Limpiar
                </button>
            </div>
        </form>

        <!-- 🔹 TABLA -->
        <div class="table-responsive">
            <table class="table table-bordered table-hover text-center align-middle">
                <thead class="thead-light">                    
                    <tr>
                        <th rowspan="2" style="vertical-align: middle;">No.</th>
                        <th rowspan="2" style="vertical-align: middle;">Nombre</th>
                        <th colspan="3">Lunes</th>
                        <th colspan="3">Martes</th>
                        <th colspan="3">Miércoles</th>
                        <th colspan="3">Jueves</th>
                        <th colspan="3">Viernes</th>
                        <th colspan="3">Sábado</th>
                    </tr>

                    <tr>
                        <th>Tienda</th>
                        <th>Entrada</th>
                        <th>Salida</th>
                        <th>Tienda</th>
                        <th>Entrada</th>
                        <th>Salida</th>
                        <th>Tienda</th>
                        <th>Entrada</th>
                        <th>Salida</th>
                        <th>Tienda</th>
                        <th>Entrada</th>
                        <th>Salida</th>
                        <th>Tienda</th>
                        <th>Entrada</th>
                        <th>Salida</th>
                        <th>Tienda</th>
                        <th>Entrada</th>
                        <th>Salida</th>
                    </tr>
                </thead>

                <tbody>
                    @{
                        int i = 1;
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>@i</td>
                                <td class="text-left pl-3">@item.Empleado</td>

                                <td>@item.LunesSucursal</td>
                                <td>@item.LunesEntrada</td>
                                <td>@item.LunesSalida</td>
                                <td>@item.MartesSucursal</td>
                                <td>@item.MartesEntrada</td>
                                <td>@item.MartesSalida</td>
                                <td>@item.MiercolesSucursal</td>
                                <td>@item.MiercolesEntrada</td>
                                <td>@item.MiercolesSalida</td>
                                <td>@item.JuevesSucursal</td>
                                <td>@item.JuevesEntrada</td>
                                <td>@item.JuevesSalida</td>
                                <td>@item.ViernesSucursal</td>
                                <td>@item.ViernesEntrada</td>
                                <td>@item.ViernesSalida</td>
                                <td>@item.SabadoSucursal</td>
                                <td>@item.SabadoEntrada</td>
                                <td>@item.SabadoSalida</td>
                            </tr>
                            i++;
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // 🔍 Buscar registros
        //$("#btnBuscar").click(function () {
        //    var fe = $("#NoSemana").val();
        //    var empleado = $("#Empleado").val();

        //    console.log("Buscando semana:", semana, "empleado:", empleado);
        //    // Llamada AJAX opcional
        //    // $.get('/Asistencia/Buscar', { semana: semana, empleado: empleado }, function (data) { ... });
        //});

        // 🔄 Limpiar filtros
        $("#btnLimpiar").click(function () {
            $("#NoSemana").val("");
            $("#Empleado").val("");
        });
    </script>
}
